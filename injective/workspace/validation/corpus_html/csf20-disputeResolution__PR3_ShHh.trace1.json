{"html":"<br/>\n<h2>Fact Symbols with Injective Instances</h2><br/>\n<p class=\"monospace rules\">None</p><br/>\n<h2>Multiset Rewriting Rules</h2><br/>\n<p class=\"monospace rules\"><span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) isend:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> K( x ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> In( x ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) irecv:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out( x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--&gt;</span> <span class=\"hl_operator\">[</span> !KD( x ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) ChanOut_A:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out_A( $A, x ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> ChanOut_A( $A, x ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !Auth( $A, x ), Out( &lt;$A, x&gt; ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) ChanIn_A:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !Auth( $A, x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> ChanIn_A( $A, x ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> In_A( $A, x ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) ChanOut_IR_HP:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out_IR_HP( $A, $B, m ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> ChanOut_IR_HP( $A, $B, m ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out( &lt;$A, $B, m&gt; ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) ChanIn_IR_HP:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> In( &lt;$A, $B, m&gt; ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> ChanIn_IR_HP( $A, $B, m ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> In_IR_HP( $A, $B, m ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) ChanOut_IR_PS:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out_IR_PS( $A, $B, m ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> ChanOut_IR_PS( $A, $B, m ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out( &lt;$A, $B, m&gt; ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) ChanIn_IR_PS:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> In( &lt;$A, $B, m&gt; ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> ChanIn_IR_PS( $A, $B, m ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> In_IR_PS( $A, $B, m ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) fakeEvidence:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> In( &lt;ballot, evidence&gt; ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> Evidence( ballot, evidence ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) publickeyinfrastructure:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Fr( ~skX ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> LongtermKey( $X, ~skX ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !Ltk( $X, ~skX ), !Pk( $X, pk(~skX) ), Out( pk(~skX) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) Setup:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !Ltk( &#39;P&#39;, ~skP ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span><br/>\n&nbsp;&nbsp;Setup( ), Voter( &#39;H&#39; ), Server( &#39;S&#39; ),<br/>\n&nbsp;&nbsp;Honest( &#39;S&#39; ),<br/>\n&nbsp;&nbsp;BB_pkP( &#39;BB&#39;, &lt;&#39;pkPs&#39;, pk(~skP)&gt; )<br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;AgSt_H0( &#39;H&#39;, &lt;&#39;BB&#39;, &#39;P&#39;, $v&gt; ),<br/>\n&nbsp;&nbsp;&nbsp;AgSt_BB0( &#39;BB&#39;, &#39;S&#39; ),<br/>\n&nbsp;&nbsp;&nbsp;AgSt_P0( &#39;P&#39;, &lt;&#39;S&#39;, ~skP&gt; ),<br/>\n&nbsp;&nbsp;&nbsp;AgSt_S0( &#39;S&#39;, &#39;empty&#39; ),<br/>\n&nbsp;&nbsp;&nbsp;Out_A( &#39;BB&#39;, &lt;&#39;pkPs&#39;, pk(~skP)&gt; )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) H_1:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> AgSt_H0( $H, &lt;$BB, $P, $v&gt; ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span><br/>\n&nbsp;&nbsp;Vote( $H, $v ), Ballot( $H, &lt;$v, $H&gt; ),<br/>\n&nbsp;&nbsp;Send_R_HP( $H, $P, &lt;$v, $H&gt; )<br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;AgSt_H1( $H, &lt;$BB, $P, $v&gt; ),<br/>\n&nbsp;&nbsp;&nbsp;Out_IR_HP( $H, $P, &lt;$v, $H&gt; )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) P:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;AgSt_P0( $P, &lt;$S, ~skP&gt; ), In_IR_HP( $H, $P, &lt;$v, $H&gt; )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span><br/>\n&nbsp;&nbsp;Receive_R_HP( $H, $P, &lt;$v, $H&gt; ),<br/>\n&nbsp;&nbsp;Evidence( &lt;$v, $H&gt;, sg(&lt;$v, $H&gt;, ~skP) ),<br/>\n&nbsp;&nbsp;Send_R_PS( $P, $S, &lt;$v, $H&gt; )<br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out_IR_PS( $P, $S, &lt;$v, $H&gt; ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) S_1:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;AgSt_S0( $S, &#39;empty&#39; ), In_IR_PS( $P, $S, &lt;$v, $H&gt; )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> Receive_R_PS( $P, $S, &lt;$v, $H&gt; ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;Out_A( $S, &lt;&#39;bs&#39;, $v, $H&gt; ),<br/>\n&nbsp;&nbsp;&nbsp;Out_A( $S, &lt;&#39;vs&#39;, $v&gt; )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) BB:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;AgSt_BB0( $BB, $S ), In_A( $S, &lt;&#39;bs&#39;, bs&gt; ),<br/>\n&nbsp;&nbsp;&nbsp;In_A( $S, &lt;&#39;vs&#39;, vs&gt; )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span><br/>\n&nbsp;&nbsp;BB_recorded( $BB, &lt;&#39;bs&#39;, bs&gt; ),<br/>\n&nbsp;&nbsp;BB_tallied( $BB, &lt;&#39;vs&#39;, vs&gt; ), End( )<br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;Out_A( $BB, &lt;&#39;bs&#39;, bs&gt; ),<br/>\n&nbsp;&nbsp;&nbsp;Out_A( $BB, &lt;&#39;vs&#39;, vs&gt; )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">// loop breakers: [1,2]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) H_5:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;AgSt_H1( $H, &lt;$BB, $P, $v&gt; ),<br/>\n&nbsp;&nbsp;&nbsp;In_A( $BB, &lt;&#39;bs&#39;, bRecorded&gt; )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> Verify( $H, &lt;$v, $H&gt;, bRecorded ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span></p><br/>\n<h2>Restrictions of the Set of Traces</h2><br/>\n<p class=\"monospace rules\"><span class=\"hl_keyword\">restriction</span> Chan_R_HP:<br/>\n&nbsp;&nbsp;&quot;<span class=\"hl_operator\">∀ </span>A B m #i<span class=\"hl_operator\">.</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span>Send_R_HP( A, B, m ) <span class=\"hl_operator\">@</span> #i<span class=\"hl_operator\">)</span> <span class=\"hl_operator\">⇒</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span><span class=\"hl_operator\">∃ </span>#j<span class=\"hl_operator\">.</span> Receive_R_HP( A, B, m ) <span class=\"hl_operator\">@</span> #j<span class=\"hl_operator\">)</span>&quot;<br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/*<br/>\n&nbsp;&nbsp;expanded formula:<br/>\n&nbsp;&nbsp;&quot;<span class=\"hl_operator\">∀ </span>A B m #i<span class=\"hl_operator\">.</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span>Send_R_HP( A, B, m ) <span class=\"hl_operator\">@</span> #i<span class=\"hl_operator\">)</span> <span class=\"hl_operator\">⇒</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span><span class=\"hl_operator\">∃ </span>#j<span class=\"hl_operator\">.</span> Receive_R_HP( A, B, m ) <span class=\"hl_operator\">@</span> #j<span class=\"hl_operator\">)</span>&quot;<br/>\n&nbsp;&nbsp;*/</span><br/>\n<br/>\n<span class=\"hl_keyword\">restriction</span> Chan_R_PS:<br/>\n&nbsp;&nbsp;&quot;<span class=\"hl_operator\">∀ </span>A B m #i<span class=\"hl_operator\">.</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span>Send_R_PS( A, B, m ) <span class=\"hl_operator\">@</span> #i<span class=\"hl_operator\">)</span> <span class=\"hl_operator\">⇒</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span><span class=\"hl_operator\">∃ </span>#j<span class=\"hl_operator\">.</span> Receive_R_PS( A, B, m ) <span class=\"hl_operator\">@</span> #j<span class=\"hl_operator\">)</span>&quot;<br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/*<br/>\n&nbsp;&nbsp;expanded formula:<br/>\n&nbsp;&nbsp;&quot;<span class=\"hl_operator\">∀ </span>A B m #i<span class=\"hl_operator\">.</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span>Send_R_PS( A, B, m ) <span class=\"hl_operator\">@</span> #i<span class=\"hl_operator\">)</span> <span class=\"hl_operator\">⇒</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span><span class=\"hl_operator\">∃ </span>#j<span class=\"hl_operator\">.</span> Receive_R_PS( A, B, m ) <span class=\"hl_operator\">@</span> #j<span class=\"hl_operator\">)</span>&quot;<br/>\n&nbsp;&nbsp;*/</span><br/>\n<br/>\n<span class=\"hl_keyword\">restriction</span> OneSetup:<br/>\n&nbsp;&nbsp;&quot;<span class=\"hl_operator\">∀ </span>#i #j<span class=\"hl_operator\">.</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span><span class=\"hl_operator\">(</span>Setup( ) <span class=\"hl_operator\">@</span> #i<span class=\"hl_operator\">)</span> <span class=\"hl_operator\">∧</span> <span class=\"hl_operator\">(</span>Setup( ) <span class=\"hl_operator\">@</span> #j<span class=\"hl_operator\">)</span><span class=\"hl_operator\">)</span> <span class=\"hl_operator\">⇒</span> <span class=\"hl_operator\">(</span>#i <span class=\"hl_operator\">=</span> #j<span class=\"hl_operator\">)</span>&quot;<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">// safety formula</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/*<br/>\n&nbsp;&nbsp;expanded formula:<br/>\n&nbsp;&nbsp;&quot;<span class=\"hl_operator\">∀ </span>#i #j<span class=\"hl_operator\">.</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span><span class=\"hl_operator\">(</span>Setup( ) <span class=\"hl_operator\">@</span> #i<span class=\"hl_operator\">)</span> <span class=\"hl_operator\">∧</span> <span class=\"hl_operator\">(</span>Setup( ) <span class=\"hl_operator\">@</span> #j<span class=\"hl_operator\">)</span><span class=\"hl_operator\">)</span> <span class=\"hl_operator\">⇒</span> <span class=\"hl_operator\">(</span>#i <span class=\"hl_operator\">=</span> #j<span class=\"hl_operator\">)</span>&quot;<br/>\n&nbsp;&nbsp;*/</span></p><br/>\n","title":"Multiset rewriting rules and restrictions"}