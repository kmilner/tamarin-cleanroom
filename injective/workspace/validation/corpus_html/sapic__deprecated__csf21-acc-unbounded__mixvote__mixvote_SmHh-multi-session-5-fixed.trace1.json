{"html":"<br/>\n<h2>Fact Symbols with Injective Instances</h2><br/>\n<p class=\"monospace rules\">None</p><br/>\n<h2>Multiset Rewriting Rules</h2><br/>\n<p class=\"monospace rules\"><span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) isend:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> K( x ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> In( x ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) irecv:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out( x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--&gt;</span> <span class=\"hl_operator\">[</span> !KD( x ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) ChanOut_S:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out_S( A, B, x ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> ChanOut_S( A, B, x ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !Sec( A, B, x ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) ChanIn_S:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !Sec( A, B, x ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> ChanIn_S( A, B, x ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> In_S( A, B, x ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) ChanOut_A:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out_A( A, x ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> ChanOut_A( A, x ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !Auth( A, x ), Out( &lt;A, x&gt; ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) ChanIn_A:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !Auth( A, x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> ChanIn_A( A, x ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> In_A( A, x ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) ChanOut_IR_HP:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out_IR_HP( A, B, m ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> ChanOut_IR_HP( A, B, m ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out( &lt;A, B, m&gt; ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) ChanIn_IR_HP:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> In( &lt;A, B, m&gt; ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> ChanIn_IR_HP( A, B, m ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> In_IR_HP( A, B, m ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) ChanOut_IR_PS:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out_IR_PS( A, B, m ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> ChanOut_IR_PS( A, B, m ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out( &lt;A, B, m&gt; ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) ChanIn_IR_PS:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> In( &lt;A, B, m&gt; ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> ChanIn_IR_PS( A, B, m ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> In_IR_PS( A, B, m ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) ChanOut_IR_SP:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out_IR_SP( A, B, m ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> ChanOut_IR_SP( A, B, m ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out( &lt;A, B, m&gt; ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) ChanIn_IR_SP:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> In( &lt;A, B, m&gt; ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> ChanIn_IR_SP( A, B, m ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> In_IR_SP( A, B, m ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) ChanOut_IR_PH:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out_IR_PH( A, B, m ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> ChanOut_IR_PH( A, B, m ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out( &lt;A, B, m&gt; ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) ChanIn_IR_PH:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> In( &lt;A, B, m&gt; ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> ChanIn_IR_PH( A, B, m ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> In_IR_PH( A, B, m ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) fakeEvidence:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> In( &lt;sid, ballot, evidence&gt; ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> Evidence( sid, ballot, evidence ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) Init:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Fr( ~sid ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> Init( ~sid ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !Session( ~sid ), Out( ~sid ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) publickeyinfrastructure:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Fr( ~skX ), !Session( ~sid ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> LongtermKey( &lt;~sid, $X&gt;, ~skX ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;!Ltk( &lt;~sid, $X&gt;, &lt;~sid, ~skX&gt; ),<br/>\n&nbsp;&nbsp;&nbsp;!Pk( &lt;~sid, $X&gt;, pk(&lt;~sid, ~skX&gt;) ),<br/>\n&nbsp;&nbsp;&nbsp;Out( pk(&lt;~sid, ~skX&gt;) )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) Setup:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;!Session( ~sid ), !Ltk( &lt;~sid, $S&gt;, skS ),<br/>\n&nbsp;&nbsp;&nbsp;!Ltk( &lt;~sid, &#39;D1&#39;&gt;, sskD1 )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span><br/>\n&nbsp;&nbsp;Setup( ~sid ),<br/>\n&nbsp;&nbsp;BB_pskDs( &lt;~sid, &#39;BB&#39;&gt;,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;&#39;spkD&#39;, pk(sskD1)&gt;<br/>\n&nbsp;&nbsp;),<br/>\n&nbsp;&nbsp;BB_pkS( &lt;~sid, &#39;BB&#39;&gt;, &lt;&#39;spkS&#39;, pk(skS)&gt;<br/>\n&nbsp;&nbsp;),<br/>\n&nbsp;&nbsp;BB_H( &lt;~sid, &#39;BB&#39;&gt;,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;&lt;~sid, &#39;H&#39;&gt;, ~sid, &#39;H1&#39;&gt;<br/>\n&nbsp;&nbsp;),<br/>\n&nbsp;&nbsp;CastByCorresp( &lt;~sid, &#39;H1&#39;&gt;, pk(sskD1) ),<br/>\n&nbsp;&nbsp;Voter( &lt;~sid, &#39;H1&#39;&gt; ), SecretKeyD( ~sid, sskD1 ),<br/>\n&nbsp;&nbsp;Server( &lt;~sid, $S&gt; ), Corrupted( $S ),<br/>\n&nbsp;&nbsp;Restr_Setup_1( $S, $S, $S, $S, $S, $S )<br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;AgSt_H0( &lt;~sid, &#39;H1&#39;&gt;,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;&lt;~sid, &#39;D1&#39;&gt;, &lt;~sid, &#39;P&#39;&gt;, <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;~sid, &#39;BB&#39;&gt;, $v1&gt;<br/>\n&nbsp;&nbsp;&nbsp;),<br/>\n&nbsp;&nbsp;&nbsp;AgSt_D0( &lt;~sid, &#39;D1&#39;&gt;,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;&lt;~sid, &#39;H1&#39;&gt;, &lt;~sid, $S&gt;, pk(skS), sskD1<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&gt;<br/>\n&nbsp;&nbsp;&nbsp;),<br/>\n&nbsp;&nbsp;&nbsp;AgSt_A0( &lt;~sid, &#39;A&#39;&gt;,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;&lt;~sid, $S&gt;, &lt;~sid, &#39;BB&#39;&gt;, pk(skS)&gt;<br/>\n&nbsp;&nbsp;&nbsp;),<br/>\n&nbsp;&nbsp;&nbsp;AgSt_P0( &lt;~sid, &#39;P&#39;&gt;, &lt;~sid, $S&gt; ),<br/>\n&nbsp;&nbsp;&nbsp;AgSt_P1( &lt;~sid, &#39;P&#39;&gt;, &lt;~sid, &#39;H1&#39;&gt; ),<br/>\n&nbsp;&nbsp;&nbsp;AgSt_BB0( &lt;~sid, &#39;BB&#39;&gt;,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;&lt;~sid, $S&gt;, pk(sskD1), pk(skS), ~sid, &#39;H1&#39;&gt;<br/>\n&nbsp;&nbsp;&nbsp;),<br/>\n&nbsp;&nbsp;&nbsp;Out_A( &lt;~sid, &#39;BB&#39;&gt;,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;&#39;spkD&#39;, pk(sskD1)&gt;<br/>\n&nbsp;&nbsp;&nbsp;),<br/>\n&nbsp;&nbsp;&nbsp;Out_A( &lt;~sid, &#39;BB&#39;&gt;, &lt;&#39;spkS&#39;, pk(skS)&gt;<br/>\n&nbsp;&nbsp;&nbsp;),<br/>\n&nbsp;&nbsp;&nbsp;Out_A( &lt;~sid, &#39;BB&#39;&gt;,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;&lt;~sid, &#39;H&#39;&gt;, ~sid, &#39;H1&#39;&gt;<br/>\n&nbsp;&nbsp;&nbsp;),<br/>\n&nbsp;&nbsp;&nbsp;AgSt_S0( &lt;~sid, $S&gt;, &lt;skS, pk(sskD1)&gt; ),<br/>\n&nbsp;&nbsp;&nbsp;Out( &lt;&lt;~sid, $S&gt;, skS, pk(sskD1)&gt; )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) H_1:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;AgSt_H0( &lt;~sid, &#39;H1&#39;&gt;,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;&lt;~sid, &#39;D1&#39;&gt;, &lt;~sid, &#39;P&#39;&gt;, <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;~sid, &#39;BB&#39;&gt;, $v&gt;<br/>\n&nbsp;&nbsp;&nbsp;)<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span><br/>\n&nbsp;&nbsp;Vote( &lt;~sid, &#39;H1&#39;&gt;, $v ),<br/>\n&nbsp;&nbsp;Send( &lt;~sid, &#39;H1&#39;&gt;, &lt;~sid, &#39;D1&#39;&gt;, $v ),<br/>\n&nbsp;&nbsp;H1( ~sid )<br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">]-&gt;</spa