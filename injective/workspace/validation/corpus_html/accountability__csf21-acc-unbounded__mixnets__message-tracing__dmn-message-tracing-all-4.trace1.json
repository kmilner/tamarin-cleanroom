{"html":"<br/>\n<h2>Fact Symbols with Injective Instances</h2><br/>\n<p class=\"monospace rules\">None</p><br/>\n<h2>Multiset Rewriting Rules</h2><br/>\n<p class=\"monospace rules\"><span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) isend:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> K( x ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> In( x ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) irecv:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out( x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--&gt;</span> <span class=\"hl_operator\">[</span> !KD( x ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) DistinctParty:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> Once( $p ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> Party( $p ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) AInit:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;Fr( ~sid ), Party( $s1 ), Party( $s2 ), Party( $m1 ), Party( $m2 ),<br/>\n&nbsp;&nbsp;&nbsp;Party( $m3 ), Party( $m4 )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span><br/>\n&nbsp;&nbsp;Init( ~sid ), IsMixer( &lt;~sid, $m4&gt;, &#39;0&#39; ),<br/>\n&nbsp;&nbsp;IsMixer( &lt;~sid, $m3&gt;, S(&#39;0&#39;) ),<br/>\n&nbsp;&nbsp;IsMixer( &lt;~sid, $m2&gt;, S(S(&#39;0&#39;)) ),<br/>\n&nbsp;&nbsp;IsMixer( &lt;~sid, $m1&gt;, S(S(S(&#39;0&#39;))) )<br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;Sender( &lt;~sid, $s1&gt; ), Sender( &lt;~sid, $s2&gt; ),<br/>\n&nbsp;&nbsp;&nbsp;PostCount( &lt;~sid, $m1&gt;, S(S(&#39;0&#39;)) ),<br/>\n&nbsp;&nbsp;&nbsp;PostCount( &lt;~sid, $m2&gt;, S(S(&#39;0&#39;)) ),<br/>\n&nbsp;&nbsp;&nbsp;PostCount( &lt;~sid, $m3&gt;, S(S(&#39;0&#39;)) ),<br/>\n&nbsp;&nbsp;&nbsp;PostCount( &lt;~sid, $m4&gt;, S(S(&#39;0&#39;)) ),<br/>\n&nbsp;&nbsp;&nbsp;!IMixer( &lt;~sid, $m4&gt;, &#39;0&#39; ),<br/>\n&nbsp;&nbsp;&nbsp;!IMixer( &lt;~sid, $m3&gt;, S(&#39;0&#39;) ),<br/>\n&nbsp;&nbsp;&nbsp;!IMixer( &lt;~sid, $m2&gt;, S(S(&#39;0&#39;)) ),<br/>\n&nbsp;&nbsp;&nbsp;!IMixer( &lt;~sid, $m1&gt;, S(S(S(&#39;0&#39;))) ), Out( ~sid )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) BSender:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;Sender( &lt;~sid, $s&gt; ),<br/>\n&nbsp;&nbsp;&nbsp;!IMixer( &lt;~sid, $m4&gt;, &#39;0&#39; ),<br/>\n&nbsp;&nbsp;&nbsp;!IMixer( &lt;~sid, $m3&gt;, S(&#39;0&#39;) ),<br/>\n&nbsp;&nbsp;&nbsp;!IMixer( &lt;~sid, $m2&gt;, S(S(&#39;0&#39;)) ),<br/>\n&nbsp;&nbsp;&nbsp;!IMixer( &lt;~sid, $m1&gt;, S(S(S(&#39;0&#39;))) ), Fr( ~r1 ),<br/>\n&nbsp;&nbsp;&nbsp;Fr( ~r2 ), Fr( ~r3 ), Fr( ~r4 ), Fr( ~r5 ), Fr( ~m )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span><br/>\n&nbsp;&nbsp;Sender( &lt;~sid, $s&gt; ), Send( &lt;~sid, $s&gt;, ~m ),<br/>\n&nbsp;&nbsp;Post( &lt;~sid, $s&gt;, S(S(S(S(&#39;0&#39;)))),<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;aenc(pk(&lt;~sid, $m1&gt;), ~r1,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;aenc(pk(&lt;~sid, $m2&gt;), ~r2,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;aenc(pk(&lt;~sid, $m3&gt;), ~r3,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;aenc(pk(&lt;~sid, $m4&gt;), ~r4, ~m))))<br/>\n&nbsp;&nbsp;)<br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;IntCipher( &lt;~sid, $s&gt;, &#39;0&#39;, ~r5, ~m, $m4 ),<br/>\n&nbsp;&nbsp;&nbsp;IntCipher( &lt;~sid, $s&gt;, S(&#39;0&#39;), ~r4,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;aenc(pk(&lt;~sid, $m4&gt;), ~r4, ~m), $m3<br/>\n&nbsp;&nbsp;&nbsp;),<br/>\n&nbsp;&nbsp;&nbsp;IntCipher( &lt;~sid, $s&gt;, S(S(&#39;0&#39;)), ~r3,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;aenc(pk(&lt;~sid, $m3&gt;), ~r3,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;aenc(pk(&lt;~sid, $m4&gt;), ~r4, ~m)),<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;$m2<br/>\n&nbsp;&nbsp;&nbsp;),<br/>\n&nbsp;&nbsp;&nbsp;IntCipher( &lt;~sid, $s&gt;, S(S(S(&#39;0&#39;))), ~r2,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;aenc(pk(&lt;~sid, $m2&gt;), ~r2,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;aenc(pk(&lt;~sid, $m3&gt;), ~r3,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;aenc(pk(&lt;~sid, $m4&gt;), ~r4, ~m))),<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;$m1<br/>\n&nbsp;&nbsp;&nbsp;),<br/>\n&nbsp;&nbsp;&nbsp;Mixer( &lt;~sid, $m4&gt;, &#39;0&#39; ),<br/>\n&nbsp;&nbsp;&nbsp;Mixer( &lt;~sid, $m3&gt;, S(&#39;0&#39;) ),<br/>\n&nbsp;&nbsp;&nbsp;Mixer( &lt;~sid, $m2&gt;, S(S(&#39;0&#39;)) ),<br/>\n&nbsp;&nbsp;&nbsp;Mixer( &lt;~sid, $m1&gt;, S(S(S(&#39;0&#39;))) ),<br/>\n&nbsp;&nbsp;&nbsp;Verify( &lt;~sid, $s&gt;, S(S(S(S(&#39;0&#39;)))) ),<br/>\n&nbsp;&nbsp;&nbsp;BBPost( ~sid, S(S(S(S(&#39;0&#39;)))),<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;aenc(pk(&lt;~sid, $m1&gt;), ~r1,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;aenc(pk(&lt;~sid, $m2&gt;), ~r2,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;aenc(pk(&lt;~sid, $m3&gt;), ~r3,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;aenc(pk(&lt;~sid, $m4&gt;), ~r4, ~m))))<br/>\n&nbsp;&nbsp;&nbsp;)<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) AMixStep:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;BBPost( ~sid, S(n), aenc(pk(&lt;~sid, $m&gt;), r, e) ),<br/>\n&nbsp;&nbsp;&nbsp;Mixer( &lt;~sid, $m&gt;, n ), PostCount( &lt;~sid, $m&gt;, S(pc) )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span><br/>\n&nbsp;&nbsp;Post( &lt;~sid, $m&gt;, n, e ), PostCount( &lt;~sid, $m&gt;, pc )<br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> BBPost( ~sid, n, e ), PostCount( &lt;~sid, $m&gt;, pc ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">// loop breakers: [2,0]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) BMixStepCorrupted:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;BBPost( ~sid, S(n), c ), Mixer( &lt;~sid, $m&gt;, n ),<br/>\n&nbsp;&nbsp;&nbsp;PostCount( &lt;~sid, $m&gt;, S(pc) ), In( a )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span><br/>\n&nbsp;&nbsp;Post( &lt;~sid, $m&gt;, n, a ), Corrupted( &lt;~sid, $m&gt; ),<br/>\n&nbsp;&nbsp;PostCount( &lt;~sid, $m&gt;, pc ),<br/>\n&nbsp;&nbsp;Restr_BMixStepCorrupted_1( ~sid, n, a, ~sid )<br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> BBPost( ~sid, n, a ), PostCount( &lt;~sid, $m&gt;, pc ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">// loop breakers: [2,0]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) BAVerify:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;IntCipher( &lt;~sid, $s&gt;, n, r, c, $m ),<br/>\n&nbsp;&nbsp;&nbsp;Verify( &lt;~sid, $s&gt;, S(n) )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span><br/>\n&nbsp;&nbsp;Valid( &lt;~sid, $s&gt;, n, c ), Verified( &lt;~sid, $s&gt;, n ),<br/>\n&nbsp;&nbsp;Restr_BAVerify_1( &lt;~sid, $m&gt;, n, c )<br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Verify( &lt;~sid, $s&gt;, n ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">// loop breaker: [1]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) AAVerifyBlame:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;IntCipher( &lt;~sid, $s&gt;, n, r, c, $m ),<br/>\n&nbsp;&nbsp;&nbsp;Verify( &lt;~sid, $s&gt;, S(n) )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span><br/>\n&nbsp;&nbsp;Blame( &lt;~sid, $m&gt; ), Verified( &lt;~sid, $s&gt;, n ),<br/>\n&nbsp;&nbsp;Restr_AAVerifyBlame_1( &lt;~sid, $m&gt;, n, c )<br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Verify( &lt;~sid, $s&gt;, n ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">// loop breaker: [1]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span></p><br/>\n<h2>Restrictions of the Set of Traces</h2><br/>\n<p class=\"monospace rules\"><span class=\"hl_keyword\">restriction</span> Restr_BMixStepCorrupted_1:<br/>\n&nbsp;&nbsp;&quot;<span class=\"hl_operator\">∀ </span>x #NOW x.1 x.2 x.3<span class=\"hl_operator\">.</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span>Restr_BMixStepCorrupted_1( x, x.1, x.2, x.3 ) <span class=\"hl_operator\">@</span> #NOW<span class=\"hl_operator\">)</span> <span class=\"hl_operator\">⇒</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span><span class=\"hl_operator\">∀ </span>mp np #i<span class=\"hl_operator\">.</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span><span class=\"hl_operator\">(</span>IsMixer( &lt;x, mp&gt;, np ) <span class=\"hl_operator\">@</span> #i<span class=\"hl_operator\">)</span> <span class=\"hl_operator\">∧</span> <span class=\"hl_operator\">(</span>x.1 <span class=\"hl_operator\">=</span> S(np)<span class=\"hl_operator\">)</span><span class=\"hl_operator\">)</span> <span class=\"hl_operator\">⇒</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span><span class=\"hl_operator\">∃ </span>r e<span class=\"hl_operator\">.</span> x.2 <span class=\"hl_operator\">=</span> aenc(pk(&lt;x.3, mp&gt;), r, e)<span class=\"hl_operator\">)</span><span class=\"hl_operator\">)</span>&quot;<br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/*<br/>\n&nbsp;&nbsp;expanded formula:<br/>\n&nbsp;&nbsp;&quot;<span class=\"hl_operator\">∀ </span>x #NOW x.1 x.2 x.3<span class=\"hl_operator\">.</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span>Restr_BMixStepCorrupted_1( x, x.1, x.2, x.3 ) <span class=\"hl_operator\">@</span> #NOW<span class=\"hl_operator\">)</span> <span class=\"hl_operator\">⇒</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span><span class=\"hl_operator\">∀ </span>mp np #i<span class=\"hl_operator\">.</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span><span class=\"hl_operator\">(</span>IsMixer( &lt;x, mp&gt;, np ) <span class=\"hl_operator\">@</span> #i<span class=\"hl_operator\">)</span> <span class=\"hl_operator\">∧</span> <span class=\"hl_operator\">(</span>x.1 <span class=\"hl_operator\">=</span> S(np)<span class=\"hl_operator\">)</span><span class=\"hl_operator\">)</span> <span class=\"hl_operator\">⇒</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span><span class=\"hl_operator\">∃ </span>r e<span class=\"hl_operator\">.</span> x.2 <span class=\"hl_operator\">=</span> aenc(pk(&lt;x.3, mp&gt;), r, e)<span class=\"hl_operator\">)</span><span class=\"hl_operator\">)</span>&quot;<br/>\n&nbsp;&nbsp;*/</span><br/>\n<br/>\n<span class=\"hl_keyword\">restriction</span> Restr_BAVerify_1:<br/>\n&nbsp;&nbsp;&quot;<span class=\"hl_operator\">∀ </span>x #NOW x.1 x.2<span class=\"hl_operator\">.</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span>Restr_BAVerify_1( x, x.1, x.2 ) <span class=\"hl_operator\">@</span> #NOW<span class=\"hl_operator\">)</span> <span class=\"hl_operator\">⇒</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span><span class=\"hl_operator\">∃ </span>#i<span class=\"hl_operator\">.</span> Post( x, x.1, x.2 ) <span class=\"hl_operator\">@</span> #i<span class=\"hl_operator\">)</span>&quot;<br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/*<br/>\n&nbsp;&nbsp;expanded formula:<br/>\n&nbsp;&nbsp;&quot;<span class=\"hl_operator\">∀ </span>x #NOW x.1 x.2<span class=\"hl_operator\">.</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span>Restr_BAVerify_1( x, x.1, x.2 ) <span class=\"hl_operator\">@</span> #NOW<span class=\"hl_operator\">)</span> <span class=\"hl_operator\">⇒</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span><span class=\"hl_operator\">∃ </span>#i<span class=\"hl_operator\">.</span> Post( x, x.1, x.2 ) <span class=\"hl_operator\">@</span> #i<span class=\"hl_operator\">)</span>&quot;<br/>\n&nbsp;&nbsp;*/</span><br/>\n<br/>\n<span class=\"hl_keyword\">restriction</span> Restr_AAVerifyBlame_1:<br/>\n&nbsp;&nbsp;&quot;<span class=\"hl_operator\">∀ </span>x #NOW x.1 x.2<span class=\"hl_operator\">.</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span>Restr_AAVerifyBlame_1( x, x.1, x.2 ) <span class=\"hl_operator\">@</span> #NOW<span class=\"hl_operator\">)</span> <span class=\"hl_operator\">⇒</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span><span class=\"hl_operator\">¬</span><span class=\"hl_operator\">(</span><span class=\"hl_operator\">∃ </span>#i<span class=\"hl_operator\">.</span> Post( x, x.1, x.2 ) <span class=\"hl_operator\">@</span> #i<span class=\"hl_operator\">)</span><span class=\"hl_operator\">)</span>&quot;<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">// safety formula</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/*<br/>\n&nbsp;&nbsp;expanded formula:<br/>\n&nbsp;&nbsp;&quot;<span class=\"hl_operator\">∀ </span>x #NOW x.1 x.2<span class=\"hl_operator\">.</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span>Restr_AAVerifyBlame_1( x, x.1, x.2 ) <span class=\"hl_operator\">@</span> #NOW<span class=\"hl_operator\">)</span> <span class=\"hl_operator\">⇒</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span><span class=\"hl_operator\">¬</span><span class=\"hl_operator\">(</span><span class=\"hl_operator\">∃ </span>#i<span class=\"hl_operator\">.</span> Post( x, x.1, x.2 ) <span class=\"hl_operator\">@</span> #i<span class=\"hl_operator\">)</span><span class=\"hl_operator\">)</span>&quot;<br/>\n&nbsp;&nbsp;*/</span><br/>\n<br/>\n<span class=\"hl_keyword\">restriction</span> verify_sender:<br/>\n&nbsp;&nbsp;&quot;<span class=\"hl_operator\">∀ </span>s #i<span class=\"hl_operator\">.</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span>Sender( s ) <span class=\"hl_operator\">@</span> #i<span class=\"hl_operator\">)</span> <span class=\"hl_operator\">⇒</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span><span class=\"hl_operator\">∃ </span>#j<span class=\"hl_operator\">.</sp