{"html":"<br/>\n<h2>Fact Symbols with Injective Instances</h2><br/>\n<p class=\"monospace rules\">None</p><br/>\n<h2>Multiset Rewriting Rules</h2><br/>\n<p class=\"monospace rules\"><span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) isend:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> K( x ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> In( x ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) irecv:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out( x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--&gt;</span> <span class=\"hl_operator\">[</span> !KD( x ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) Setup:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Fr( ~k ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> OnlyOnce( ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !InitLTK( ~k ), !RespLTK( ~k ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) initiator:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Fr( ~na ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> Challenge( ~na ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out( ~na ), Initiated( ~na ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) responder:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> In( na ), Fr( ~nb ), !RespLTK( ~k ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> Response( ~k ), Neq( na, zero ), NeqForExec( na, zero ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out( &lt;h((~k⊕~nb⊕na)), ~nb&gt; ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/*<br/>\n&nbsp;&nbsp;<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) responder:<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> In( na ), Fr( ~nb ), !RespLTK( ~k ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> Response( ~k ), Neq( na, zero ), NeqForExec( na, zero ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out( &lt;h(z), ~nb&gt; ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_keyword\">variants</span> (<span class=\"hl_keyword\">modulo</span> AC)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;1. ~k    = ~k.5<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;~nb   = ~nb.5<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;na    = na.5<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z     = (~k.5⊕~nb.5⊕na.5)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;2. ~k    = ~k.5<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;~nb   = ~nb.5<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;na    = zero<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z     = (~k.5⊕~nb.5)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;3. ~k    = ~x.5<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;~nb   = ~nb.6<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;na    = ~x.5<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z     = ~nb.6<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;4. ~k    = ~x.5<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;~nb   = ~nb.8<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;na    = (~x.5⊕x.7)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z     = (x.7⊕~nb.8)<br/>\n&nbsp;&nbsp;*/</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) initiator2:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Initiated( ~na ), !InitLTK( ~k ), In( &lt;m, nb&gt; ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> Alive( ~na, ~k ), Eq( h((~k⊕~na⊕nb)), m ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/*<br/>\n&nbsp;&nbsp;<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) initiator2:<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Initiated( ~na ), !InitLTK( ~k ), In( &lt;m, nb&gt; ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> Alive( ~na, ~k ), Eq( h(z), m ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_keyword\">variants</span> (<span class=\"hl_keyword\">modulo</span> AC)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;1. ~k    = ~k.6<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;~na   = ~na.6<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;nb    = nb.6<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z     = (~k.6⊕~na.6⊕nb.6)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;2. ~k    = ~k.6<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;~na   = ~na.6<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;nb    = zero<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z     = (~k.6⊕~na.6)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;3. ~k    = ~x.6<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;~na   = ~x.6<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;nb    = nb.7<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z     = nb.7<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;4. ~k    = ~x.6<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;~na   = ~na.7<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;nb    = ~x.6<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z     = ~na.7<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;5. ~k    = ~x.6<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;~na   = ~x.7<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;nb    = (~x.6⊕~x.7)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z     = zero<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;6. ~k    = ~x.6<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;~na   = ~x.7<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;nb    = (~x.6⊕~x.7⊕x.9)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z     = x.9<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;7. ~k    = ~x.6<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;~na   = ~na.10<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;nb    = (~x.6⊕x.9)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z     = (x.9⊕~na.10)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;8. ~k    = ~k.7<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;~na   = ~x.6<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;nb    = ~x.6<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z     = ~k.7<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;9. ~k    = ~k.9<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;~na   = ~x.6<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;nb    = (~x.6⊕x.8)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z     = (x.8⊕~k.9)<br/>\n&nbsp;&nbsp;*/</span></p><br/>\n<h2>Restrictions of the Set of Traces</h2><br/>\n<p class=\"monospace rules\"><span class=\"hl_keyword\">restriction</span> equality:<br/>\n&nbsp;&nbsp;&quot;<span class=\"hl_operator\">∀ </span>x y #i<span class=\"hl_operator\">.</span> <span class=\"hl_operator\">(</span>Eq( x, y ) <span class=\"hl_operator\">@</span> #i<span class=\"hl_operator\">)</span> <span class=\"hl_operator\">⇒</span> <span class=\"hl_operator\">(</span>x <span class=\"hl_operator\">=</span> y<span class=\"hl_operator\">)</span>&quot;<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">// safety formula</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/*<br/>\n&nbsp;&nbsp;expanded formula:<br/>\n&nbsp;&nbsp;&quot;<span class=\"hl_operator\">∀ </span>x y #i<span class=\"hl_operator\">.</span> <span class=\"hl_operator\">(</span>Eq( x, y ) <span class=\"hl_operator\">@</span> #i<span class=\"hl_operator\">)</span> <span class=\"hl_operator\">⇒</span> <span class=\"hl_operator\">(</span>x <span class=\"hl_operator\">=</span> y<span class=\"hl_operator\">)</span>&quot;<br/>\n&nbsp;&nbsp;*/</span><br/>\n<br/>\n<span class=\"hl_keyword\">restriction</span> unique:<br/>\n&nbsp;&nbsp;&quot;<span class=\"hl_operator\">∀ </span>#i #j<span class=\"hl_operator\">.</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span><span class=\"hl_operator\">(</span>OnlyOnce( ) <span class=\"hl_operator\">@</span> #i<span class=\"hl_operator\">)</span> <span class=\"hl_operator\">∧</span> <span class=\"hl_operator\">(</span>OnlyOnce( ) <span class=\"hl_operator\">@</span> #j<span class=\"hl_operator\">)</span><span class=\"hl_operator\">)</span> <span class=\"hl_operator\">⇒</span> <span class=\"hl_operator\">(</span>#i <span class=\"hl_operator\">=</span> #j<span class=\"hl_operator\">)</span>&quot;<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">// safety formula</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/*<br/>\n&nbsp;&nbsp;expanded formula:<br/>\n&nbsp;&nbsp;&quot;<span class=\"hl_operator\">∀ </span>#i #j<span class=\"hl_operator\">.</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span><span class=\"hl_operator\">(</span>OnlyOnce( ) <span class=\"hl_operator\">@</span> #i<span class=\"hl_operator\">)</span> <span class=\"hl_operator\">∧</span> <span class=\"hl_operator\">(</span>OnlyOnce( ) <span class=\"hl_operator\">@</span> #j<span class=\"hl_operator\">)</span><span class=\"hl_operator\">)</span> <span class=\"hl_operator\">⇒</span> <span class=\"hl_operator\">(</span>#i <span class=\"hl_operator\">=</span> #j<span class=\"hl_operator\">)</span>&quot;<br/>\n&nbsp;&nbsp;*/</span><br/>\n<br/>\n<span class=\"hl_keyword\">restriction</span> inequality:<br/>\n&nbsp;&nbsp;&quot;<span class=\"hl_operator\">¬</span><span class=\"hl_operator\">(</span><span class=\"hl_operator\">∃ </span>x #i<span class=\"hl_operator\">.</span> Neq( x, x ) <span class=\"hl_operator\">@</span> #i<span class=\"hl_operator\">)</span>&quot;<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">// safety formula</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/*<br/>\n&nbsp;&nbsp;expanded formula:<br/>\n&nbsp;&nbsp;&quot;<span class=\"hl_operator\">¬</span><span class=\"hl_operator\">(</span><span class=\"hl_operator\">∃ </span>x #i<span class=\"hl_operator\">.</span> Neq( x, x ) <span class=\"hl_operator\">@</span> #i<span class=\"hl_operator\">)</span>&quot;<br/>\n&nbsp;&nbsp;*/</span></p><br/>\n","title":"Multiset rewriting rules and restrictions"}