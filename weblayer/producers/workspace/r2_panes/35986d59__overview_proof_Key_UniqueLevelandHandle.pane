<span class="hl_good"><span class="hl_keyword">lemma</span> Key_UsageImpliesInitialization:<br/>
&nbsp;&nbsp;all-traces<br/>
&nbsp;&nbsp;&quot;<span class="hl_operator">∀ </span>d k l h #keyUse<span class="hl_operator">.</span><br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="hl_operator">(</span>UseKey( d, k, h, l ) <span class="hl_operator">@</span> #keyUse<span class="hl_operator">)</span> <span class="hl_operator">⇒</span><br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="hl_operator">(</span><span class="hl_operator">∃ </span>#keyInit<span class="hl_operator">.</span><br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="hl_operator">(</span>InitKey( d, k, h, l ) <span class="hl_operator">@</span> #keyInit<span class="hl_operator">)</span> <span class="hl_operator">∧</span> <span class="hl_operator">(</span>#keyInit <span class="hl_operator">&lt;</span> #keyUse<span class="hl_operator">)</span><span class="hl_operator">)</span>&quot;<br/>
