<span class="hl_good"><span class="hl_keyword">lemma</span> Counter_Monotonicity [heuristic={Counter_Monotonicity},<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;use_induction, reuse]:<br/>
&nbsp;&nbsp;all-traces<br/>
&nbsp;&nbsp;&quot;<span class="hl_operator">∀ </span>d c C #before #later<span class="hl_operator">.</span><br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="hl_operator">(</span><span class="hl_operator">(</span><span class="hl_operator">(</span>DCtrIs( d, c ) <span class="hl_operator">@</span> #before<span class="hl_operator">)</span> <span class="hl_operator">∧</span> <span class="hl_operator">(</span>DCtrIs( d, C ) <span class="hl_operator">@</span> #later<span class="hl_operator">)</span><span class="hl_operator">)</span> <span class="hl_operator">∧</span><br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="hl_operator">(</span>#before <span class="hl_operator">&lt;</span> #later<span class="hl_operator">)</span><span class="hl_operator">)</span> <span class="hl_operator">⇒</span><br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="hl_operator">(</span><span class="hl_operator">∃ </span>z<span class="hl_operator">.</span> C <span class="hl_operator">=</span> (c++z)<span class="hl_operator">)</span>&quot;<br/>
<a class="internal-link edit" href="/thy/trace/7/main/edit/Counter_Monotonicity">edit lemma</a>  or  <a class="internal-link delete" href="/thy/trace/7/main/delete/Counter_Monotonicity">delete lemma</a></span><br/>
