<span class="hl_keyword">lemma</span> IV_Uniqueness [heuristic={IV_Uniqueness}]:<br/>
&nbsp;&nbsp;all-traces<br/>
&nbsp;&nbsp;&quot;<span class="hl_operator">∀ </span>iv #before #later<span class="hl_operator">.</span><br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="hl_operator">(</span><span class="hl_operator">(</span>IV( iv ) <span class="hl_operator">@</span> #before<span class="hl_operator">)</span> <span class="hl_operator">∧</span> <span class="hl_operator">(</span>IV( iv ) <span class="hl_operator">@</span> #later<span class="hl_operator">)</span><span class="hl_operator">)</span> <span class="hl_operator">⇒</span><br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="hl_operator">(</span>#later <span class="hl_operator">=</span> #before<span class="hl_operator">)</span>&quot;<br/>
<a class="internal-link edit" href="/thy/trace/1/main/edit/IV_Uniqueness">edit lemma</a>  or  <a class="internal-link delete" href="/thy/trace/1/main/delete/IV_Uniqueness">delete lemma</a><br/>
