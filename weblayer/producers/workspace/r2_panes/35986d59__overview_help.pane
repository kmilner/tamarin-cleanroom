<span class="hl_keyword">lemma</span> Key_UniqueLevelandHandle [reuse]:<br/>
&nbsp;&nbsp;all-traces<br/>
&nbsp;&nbsp;&quot;<span class="hl_operator">∀ </span>d D k l L h H #i #j<span class="hl_operator">.</span><br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="hl_operator">(</span><span class="hl_operator">(</span>InitKey( d, k, h, l ) <span class="hl_operator">@</span> #i<span class="hl_operator">)</span> <span class="hl_operator">∧</span> <span class="hl_operator">(</span>InitKey( D, k, H, L ) <span class="hl_operator">@</span> #j<span class="hl_operator">)</span><span class="hl_operator">)</span> <span class="hl_operator">⇒</span><br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="hl_operator">(</span><span class="hl_operator">(</span>l <span class="hl_operator">=</span> L<span class="hl_operator">)</span> <span class="hl_operator">∧</span> <span class="hl_operator">(</span>h <span class="hl_operator">=</span> H<span class="hl_operator">)</span><span class="hl_operator">)</span>&quot;<br/>
