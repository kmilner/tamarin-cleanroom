&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="hl_operator">(</span>PCR_Extend( xPrev, y, h(&lt;&#39;pcr0&#39;, $a&gt;) ) <span class="hl_operator">@</span> #j<span class="hl_operator">)</span>) <span class="hl_keyword">)</span></a><a class="internal-link remove-step" href="/thy/trace/6/main/proof/right_reachable/_/PCR_Init/PCR_Unbind"></a><br/>
