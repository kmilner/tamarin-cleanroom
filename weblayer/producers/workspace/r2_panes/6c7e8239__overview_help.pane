<span class="hl_keyword">lemma</span> Login_reachable:<br/>
&nbsp;&nbsp;exists-trace<br/>
&nbsp;&nbsp;&quot;<span class="hl_operator">∃ </span>#i pid k<span class="hl_operator">.</span><br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Login( pid, k, (&#39;one&#39;++&#39;zero&#39;) ) <span class="hl_operator">@</span> #i&quot;<br/>
