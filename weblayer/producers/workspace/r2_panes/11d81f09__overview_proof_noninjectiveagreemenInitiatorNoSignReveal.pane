&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;(<span class="hl_operator">∃</span> K X #l<span class="hl_operator">.</span> <span class="hl_operator">(</span>Reveal( K, X ) <span class="hl_operator">@</span> #l<span class="hl_operator">)</span> <span class="hl_operator">∧</span> <span class="hl_operator">¬</span><span class="hl_operator">(</span><span class="hl_operator">last</span>(#l)<span class="hl_operator">)</span>) <span class="hl_keyword">)</span></a><a class="internal-link remove-step" href="/thy/trace/16/main/proof/secrecy_session_key/non_empty_trace"></a><br/>
