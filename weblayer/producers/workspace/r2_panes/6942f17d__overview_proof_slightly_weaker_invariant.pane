&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;(<span class="hl_operator">∀</span> z.2<span class="hl_operator">.</span> <span class="hl_operator">(</span>(otc1++z++z.2) <span class="hl_operator">=</span> (otc2++z.1)<span class="hl_operator">)</span> <span class="hl_operator">⇒</span> <span class="hl_operator">⊥</span>) <span class="hl_keyword">)</span></a><a class="internal-link remove-step" href="/thy/trace/7/main/proof/slightly_weaker_invariant/non_empty_trace"></a><br/>
