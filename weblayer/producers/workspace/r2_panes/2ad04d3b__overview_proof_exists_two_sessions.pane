&nbsp;&nbsp;all-traces<br/>
&nbsp;&nbsp;&quot;<span class="hl_operator">(</span><span class="hl_operator">∀ </span>pki pkr peki pekr psk ck #i<span class="hl_operator">.</span><br/>
