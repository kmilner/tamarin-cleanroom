&nbsp;&nbsp;exists-trace &quot;<span class="hl_operator">∀ </span>x #j<span class="hl_operator">.</span> <span class="hl_operator">(</span>Loop( x ) <span class="hl_operator">@</span> #j<span class="hl_operator">)</span> <span class="hl_operator">⇒</span> <span class="hl_operator">(</span><span class="hl_operator">⊥</span><span class="hl_operator">)</span>&quot;<br/>
