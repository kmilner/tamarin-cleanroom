&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="hl_operator">(</span>BB_rec( BB, &lt;&#39;b&#39;, ba&gt; ) <span class="hl_operator">@</span> #k<span class="hl_operator">)</span><span class="hl_operator"> ∧</span><br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="hl_operator">(</span>Evidence( b, sg(b, skS) ) <span class="hl_operator">@</span> #l<span class="hl_operator">)</span><span class="hl_operator"> ∧</span><br/>
