&nbsp;&nbsp;<span class="hl_good"><span class="hl_keyword">by</span> </span><a class="internal-link proof-step hl_good" href="/thy/trace/5/main/proof/counter_increases/empty_trace"><span class="hl_keyword">contradiction</span> <span class="hl_comment">/* from formulas */</span></a><a class="internal-link remove-step" href="/thy/trace/5/main/proof/counter_increases/empty_trace"></a><br/>
<span class="hl_good"><span class="hl_keyword">next</span></span><br/>
&nbsp;&nbsp;<span class="hl_good"><span class="hl_keyword">case</span> non_empty_trace</span><br/>
&nbsp;&nbsp;<a class="internal-link proof-step hl_good" href="/thy/trace/5/main/proof/counter_increases/non_empty_trace"><span class="hl_keyword">solve(</span> (<span class="hl_operator">∃</span> z<span class="hl_operator">.</span> <span class="hl_operator">(</span>(x++z) <span class="hl_operator">=</span> y<span class="hl_operator">)</span>)<span class="hl_operator">  ∥</span> (<span class="hl_operator">∃</span> z<span class="hl_operator">.</span> <span class="hl_operator">(</span>(y++z) <span class="hl_operator">=</span> x<span class="hl_operator">)</span>)<span class="hl_operator">  ∥</span> (y <span class="hl_operator">=</span> x) <span class="hl_keyword">)</span></a><a class="internal-link remove-step" href="/thy/trace/5/main/proof/counter_increases/non_empty_trace"></a><br/>
&nbsp;&nbsp;&nbsp;&nbsp;<span class="hl_good"><span class="hl_keyword">case</span> case_1</span><br/>
