&nbsp;&nbsp;<a class="internal-link proof-step hl_good" href="/thy/trace/13/main/proof/matching_detects_prior_misuse/non_empty_trace"><span class="hl_keyword">solve(</span> Session( &#39;I&#39;, pks, data2 ) <span class="hl_operator">@</span> #t2 <span class="hl_keyword">)</span></a><a class="internal-link remove-step" href="/thy/trace/13/main/proof/matching_detects_prior_misuse/non_empty_trace"></a><br/>
