{"html":"<h2>Macros</h2><br/>\n<p class=\"monospace rules\"><span class=\"hl_keyword\">macros:</span> globalVar( ) =  $R</p><br/>\n<h2>Fact Symbols with Injective Instances</h2><br/>\n<p class=\"monospace rules\">None</p><br/>\n<h2>Multiset Rewriting Rules</h2><br/>\n<p class=\"monospace rules\"><span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) isend:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> K( x ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> In( x ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) irecv:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out( x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--&gt;</span> <span class=\"hl_operator\">[</span> !KD( x ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) Register_pk:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Fr( ~ltkA ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !Ltk( $A, ~ltkA ), !Pk( $A, pk(~ltkA) ), Out( pk(~ltkA) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) Reveal_ltk:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !Ltk( A, ltkA ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> RevLtk( A ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> Out( ltkA ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) I_1:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Fr( ~ni ), !Pk( globalVar, pkR ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> OUT_I_1( aenc(&lt;&#39;1&#39;, ~ni, $I&gt;, pkR) ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;Out( aenc(&lt;&#39;1&#39;, ~ni, $I&gt;, pkR) ),<br/>\n&nbsp;&nbsp;&nbsp;St_I_1( $I, globalVar, ~ni )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/*<br/>\n&nbsp;&nbsp;<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) I_1:<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Fr( ~ni ), !Pk( $R, pkR ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> OUT_I_1( aenc(&lt;&#39;1&#39;, ~ni, $I&gt;, pkR) ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Out( aenc(&lt;&#39;1&#39;, ~ni, $I&gt;, pkR) ),<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;St_I_1( $I, $R, ~ni )<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;*/</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) R_1:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;!Ltk( $R, ltkR ), In( aenc(&lt;&#39;1&#39;, ni, I&gt;, pk(ltkR)) ),<br/>\n&nbsp;&nbsp;&nbsp;!Pk( I, pkI ), Fr( ~nr )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span><br/>\n&nbsp;&nbsp;IN_R_1_ni( ni, aenc(&lt;&#39;1&#39;, ni, I&gt;, pk(ltkR)) ),<br/>\n&nbsp;&nbsp;OUT_R_1( aenc(&lt;&#39;2&#39;, ni, ~nr&gt;, pkI) ),<br/>\n&nbsp;&nbsp;Running( I, globalVar, &lt;&#39;init&#39;, ni, ~nr&gt; )<br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;Out( aenc(&lt;&#39;2&#39;, ni, ~nr&gt;, pkI) ),<br/>\n&nbsp;&nbsp;&nbsp;St_R_1( globalVar, I, ni, ~nr )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/*<br/>\n&nbsp;&nbsp;<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) R_1:<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;!Ltk( $R, ltkR ), In( aenc(&lt;&#39;1&#39;, ni, I&gt;, pk(ltkR)) ),<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;!Pk( I, pkI ), Fr( ~nr )<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">--[</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;IN_R_1_ni( ni, aenc(&lt;&#39;1&#39;, ni, I&gt;, pk(ltkR)) ),<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;OUT_R_1( aenc(&lt;&#39;2&#39;, ni, ~nr&gt;, pkI) ),<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;Running( I, $R, &lt;&#39;init&#39;, ni, ~nr&gt; )<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Out( aenc(&lt;&#39;2&#39;, ni, ~nr&gt;, pkI) ),<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;St_R_1( $R, I, ni, ~nr )<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;*/</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) I_2:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;St_I_1( I, R, ni ), !Ltk( I, ltkI ),<br/>\n&nbsp;&nbsp;&nbsp;In( aenc(&lt;&#39;2&#39;, ni, nr&gt;, pk(ltkI)) ), !Pk( R, pkR )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span><br/>\n&nbsp;&nbsp;IN_I_2_nr( nr, aenc(&lt;&#39;2&#39;, ni, nr&gt;, pk(ltkI)) ),<br/>\n&nbsp;&nbsp;Commit( I, R, &lt;&#39;init&#39;, ni, nr&gt; ),<br/>\n&nbsp;&nbsp;Running( R, I, &lt;&#39;resp&#39;, ni, nr&gt; )<br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;Out( aenc(&lt;&#39;3&#39;, nr&gt;, pkR) ), Secret( I, R, nr ),<br/>\n&nbsp;&nbsp;&nbsp;Secret( I, R, ni )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) R_2:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;St_R_1( R, I, ni, nr ), !Ltk( R, ltkR ),<br/>\n&nbsp;&nbsp;&nbsp;In( aenc(&lt;&#39;3&#39;, nr&gt;, pk(ltkR)) )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> Commit( R, I, &lt;&#39;resp&#39;, ni, nr&gt; ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Secret( R, I, nr ), Secret( R, I, ni ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) Secrecy_claim:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Secret( A, B, m ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> Secret( A, B, m ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span></p><br/>\n","title":"Multiset rewriting rules and restrictions"}