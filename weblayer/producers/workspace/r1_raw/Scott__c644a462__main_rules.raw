{"html":"<br/>\n<h2>Fact Symbols with Injective Instances</h2><br/>\n<p class=\"monospace rules\">None</p><br/>\n<h2>Multiset Rewriting Rules</h2><br/>\n<p class=\"monospace rules\"><span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) isend:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> K( x ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> In( x ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) irecv:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out( x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--&gt;</span> <span class=\"hl_operator\">[</span> !KD( x ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) KGC_Setup:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Fr( ~msk ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> KGCSetup( ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> !MSK( ~msk ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) KGC_request:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !MSK( ~msk ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--&gt;</span> <span class=\"hl_operator\">[</span> !LTK( $ID, pmult(~msk, hp($ID)) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) Reveal_ltk:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !LTK( $ID, skID ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> LtkRev( $ID ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> Out( skID ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) Reveal_master_key:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !MSK( ~msk ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> MskRev( ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> Out( ~msk ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) Reveal_session_key:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !Sessk( ~ey, sek ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> SesskRev( ~ey ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> Out( sek ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) Init_1:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Fr( ~ex ), !LTK( $A, pmult(~s, hp($A)) ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;Init( ~ex, $A, $B, em(hp($B), pmult(~s, hp($A)))^~ex ),<br/>\n&nbsp;&nbsp;&nbsp;Out( em(hp($B), pmult(~s, hp($A)))^~ex )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/*<br/>\n&nbsp;&nbsp;<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) Init_1:<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Fr( ~ex ), !LTK( $A, pmult(~s, hp($A)) ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">--&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Init( ~ex, $A, $B, em(hp($A), hp($B))^(~ex*~s) ),<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Out( em(hp($A), hp($B))^(~ex*~s) )<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;*/</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) Init_2:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Init( ~ex, $A, $B, X ), In( Y ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span><br/>\n&nbsp;&nbsp;Accept( ~ex, $A, $B, kdf(&lt;Y^~ex, $A, $B, X, Y&gt;) ),<br/>\n&nbsp;&nbsp;Sid( ~ex, &lt;&#39;Init&#39;, $A, $B, X, Y&gt; ),<br/>\n&nbsp;&nbsp;Match( ~ex, &lt;&#39;Resp&#39;, $B, $A, X, Y&gt; )<br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !Sessk( ~ex, kdf(&lt;Y^~ex, $A, $B, X, Y&gt;) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/*<br/>\n&nbsp;&nbsp;<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) Init_2:<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Init( ~ex, $A, $B, X ), In( Y ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">--[</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;Accept( ~ex, $A, $B, kdf(&lt;z, $A, $B, X, Y&gt;) ),<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;Sid( ~ex, &lt;&#39;Init&#39;, $A, $B, X, Y&gt; ),<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;Match( ~ex, &lt;&#39;Resp&#39;, $B, $A, X, Y&gt; )<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !Sessk( ~ex, kdf(&lt;z, $A, $B, X, Y&gt;) ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_keyword\">variants</span> (<span class=\"hl_keyword\">modulo</span> AC)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;1. ~ex   = ~ex.10<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Y     = Y.12<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z     = Y.12^~ex.10<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;2. ~ex   = ~ex.11<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Y     = z.14^inv(~ex.11)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z     = z.14<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;3. ~ex   = ~ex.15<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Y     = x.25^x.26<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z     = x.25^(~ex.15*x.26)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;4. ~ex   = ~ex.17<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Y     = x.29^inv((~ex.17*x.30))<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z     = x.29^inv(x.30)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;5. ~ex   = ~ex.17<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Y     = x.29^(x.30*inv(~ex.17))<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z     = x.29^x.30<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;6. ~ex   = ~ex.18<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Y     = x.30^(x.31*inv((~ex.18*x.32)))<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z     = x.30^(x.31*inv(x.32))<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;7. Y     = DH_neutral<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z     = DH_neutral<br/>\n&nbsp;&nbsp;*/</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) Resp_1:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Fr( ~ey ), !LTK( $B, pmult(~s, hp($B)) ), In( X ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span><br/>\n&nbsp;&nbsp;Accept( ~ey, $B, $A,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;kdf(&lt;X^~ey, $A, $B, X, em(hp($A), pmult(~s, hp($B)))^~ey&gt;)<br/>\n&nbsp;&nbsp;),<br/>\n&nbsp;&nbsp;Sid( ~ey,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;&#39;Resp&#39;, $B, $A, X, em(hp($A), pmult(~s, hp($B)))^~ey<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&gt;<br/>\n&nbsp;&nbsp;),<br/>\n&nbsp;&nbsp;Match( ~ey,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;&#39;Init&#39;, $A, $B, X, em(hp($A), pmult(~s, hp($B)))^~ey<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&gt;<br/>\n&nbsp;&nbsp;)<br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;Out( em(hp($A), pmult(~s, hp($B)))^~ey ),<br/>\n&nbsp;&nbsp;&nbsp;!Sessk( ~ey,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;kdf(&lt;X^~ey, $A, $B, X, em(hp($A), pmult(~s, hp($B)))^~ey&gt;)<br/>\n&nbsp;&nbsp;&nbsp;)<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/*<br/>\n&nbsp;&nbsp;<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) Resp_1:<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Fr( ~ey ), !LTK( $B, pmult(~x, hp($B)) ), In( X ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">--[</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;Accept( ~ey, $B, $A,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;kdf(&lt;z, $A, $B, X, em(hp($A), hp($B))^(~ey*~x)&gt;)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;),<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;Sid( ~ey,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;&#39;Resp&#39;, $B, $A, X, em(hp($A), hp($B))^(~ey*~x)&gt;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;),<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;Match( ~ey,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;&#39;Init&#39;, $A, $B, X, em(hp($A), hp($B))^(~ey*~x)&gt;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Out( em(hp($A), hp($B))^(~ey*~x) ),<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;!Sessk( ~ey, kdf(&lt;z, $A, $B, X, em(hp($A), hp($B))^(~ey*~x)&gt;)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_keyword\">variants</span> (<span class=\"hl_keyword\">modulo</span> AC)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;1. ~ey   = ~ey.36<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;X     = X.38<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z     = X.38^~ey.36<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;2. ~ey   = ~ey.372<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;X     = x.739^x.740<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z     = x.739^(~ey.372*x.740)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;3. X     = DH_neutral<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z     = DH_neutral<br/>\n&nbsp;&nbsp;*/</span></p><br/>\n","title":"Multiset rewriting rules and restrictions"}