{"html":"<br/>\n<h2>Fact Symbols with Injective Instances</h2><br/>\n<p class=\"monospace rules\">None</p><br/>\n<h2>Multiset Rewriting Rules</h2><br/>\n<p class=\"monospace rules\"><span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) isend:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> K( x ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> In( x ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) irecv:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out( x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--&gt;</span> <span class=\"hl_operator\">[</span> !KD( x ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) ChanOut_S:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out_S( $A, $B, x ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> ChanOut_S( $A, $B, x ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !Sec( $A, $B, x ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) ChanIn_S:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !Sec( $A, $B, x ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> ChanIn_S( $A, $B, x ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> In_S( $A, $B, x ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) ChanOut_A:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out_A( $A, x ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> ChanOut_A( $A, x ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !Auth( $A, x ), Out( &lt;$A, x&gt; ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) ChanIn_A:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !Auth( $A, x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> ChanIn_A( $A, x ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> In_A( $A, x ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) publickeyinfrastructure:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Fr( ~skX ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> LongtermKey( $X, ~skX ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !Ltk( $X, ~skX ), !Pk( $X, pk(~skX) ), Out( pk(~skX) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) Setup:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;Fr( ~x1 ), Fr( ~x2 ), !Ltk( &#39;D1&#39;, ~skD1 ),<br/>\n&nbsp;&nbsp;&nbsp;!Ltk( &#39;D2&#39;, ~skD2 )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span><br/>\n&nbsp;&nbsp;Setup( ), H_x_no( &#39;H1&#39;, ~x1, &#39;1&#39; ),<br/>\n&nbsp;&nbsp;H_x_no( &#39;H2&#39;, ~x2, &#39;2&#39; )<br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;AgSt_D0( &#39;D1&#39;, &lt;~skD1, &#39;S&#39;, &#39;H1&#39;&gt; ),<br/>\n&nbsp;&nbsp;&nbsp;AgSt_D0( &#39;D2&#39;, &lt;~skD2, &#39;S&#39;, &#39;H2&#39;&gt; ),<br/>\n&nbsp;&nbsp;&nbsp;Out( &lt;&#39;S&#39;, &#39;BB&#39;, &#39;E&#39;, <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;(&lt;&#39;H1&#39;, &#39;D1&#39;, pk(~skD1), ~x1, &#39;1&#39;&gt;++<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;&#39;H2&#39;, &#39;D2&#39;, pk(~skD2), ~x2, &#39;2&#39;&gt;)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&gt;<br/>\n&nbsp;&nbsp;&nbsp;),<br/>\n&nbsp;&nbsp;&nbsp;AgSt_H0( &#39;H1&#39;,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;&#39;D1&#39;, &#39;S&#39;, &#39;BB&#39;&gt;<br/>\n&nbsp;&nbsp;&nbsp;),<br/>\n&nbsp;&nbsp;&nbsp;AgSt_H0( &#39;H2&#39;,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;&#39;D2&#39;, &#39;S&#39;, &#39;BB&#39;&gt;<br/>\n&nbsp;&nbsp;&nbsp;),<br/>\n&nbsp;&nbsp;&nbsp;AgSt_A0( &#39;A&#39;,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;&#39;S&#39;, &#39;BB&#39;, &#39;E&#39;&gt;<br/>\n&nbsp;&nbsp;&nbsp;),<br/>\n&nbsp;&nbsp;&nbsp;Env( &#39;E&#39; ), AgSt_BB0( &#39;BB&#39;, &#39;S&#39; )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) BB_2:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;AgSt_BB0( $BB, $S ),<br/>\n&nbsp;&nbsp;&nbsp;In( &lt;$S, &#39;ys&#39;, (&lt;y1, no1&gt;++&lt;y2, no2&gt;)&gt; )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> BB_Ys( $BB, &#39;ys&#39;, (&lt;y1, no1&gt;++&lt;y2, no2&gt;) )<br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;AgSt_BB2( $BB,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;$S, &#39;ys&#39;, (&lt;y1, no1&gt;++&lt;y2, no2&gt;)&gt;<br/>\n&nbsp;&nbsp;&nbsp;),<br/>\n&nbsp;&nbsp;&nbsp;Out_A( $BB,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;&#39;ys&#39;, (&lt;y1, no1&gt;++&lt;y2, no2&gt;)&gt;<br/>\n&nbsp;&nbsp;&nbsp;),<br/>\n&nbsp;&nbsp;&nbsp;YPublished( )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) A_3:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;AgSt_A0( $A, &lt;$S, $BB, $E&gt; ),<br/>\n&nbsp;&nbsp;&nbsp;In_A( $BB, &lt;&#39;ys&#39;, (&lt;y1, no1&gt;++&lt;y2, no2&gt;)&gt;<br/>\n&nbsp;&nbsp;&nbsp;)<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span><br/>\n&nbsp;&nbsp;Learn_A_Ys( $A, $S,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;&#39;ys&#39;, (&lt;y1, no1&gt;++&lt;y2, no2&gt;)&gt;<br/>\n&nbsp;&nbsp;)<br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;AgSt_A3( $A,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;$S, $BB, $E, &#39;ys&#39;, (&lt;y1, no1&gt;++&lt;y2, no2&gt;)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&gt;<br/>\n&nbsp;&nbsp;&nbsp;)<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) D_4:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;AgSt_D0( $D, &lt;~skD, $S, $H&gt; ),<br/>\n&nbsp;&nbsp;&nbsp;In( &lt;$S, aenc(x, pk(~skD))&gt; )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> Comm_D_Y( $D, h(&lt;$H, x&gt;) ), Commit( $D, $S, $H, x )<br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out_S( $D, $H, h(&lt;$H, x&gt;) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) H_5:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;AgSt_H0( $H, &lt;$D, $S, $BB&gt; ), In_S( $D, $H, yD ),<br/>\n&nbsp;&nbsp;&nbsp;In_A( $BB, &lt;&#39;ys&#39;, (&lt;y1, no1&gt;++&lt;y2, no2&gt;)&gt;<br/>\n&nbsp;&nbsp;&nbsp;)<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span><br/>\n&nbsp;&nbsp;Learn_H_yD( $H, $D, yD ),<br/>\n&nbsp;&nbsp;Learn_H_Ys( $H, $S,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;&#39;ys&#39;, (&lt;y1, no1&gt;++&lt;y2, no2&gt;)&gt;<br/>\n&nbsp;&nbsp;)<br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> AgSt_H5( $H, &lt;$D, $S, $BB, yD, y1, y2&gt; ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) environment_1:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Env( $E ), YPublished( ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> Env_No( $E, &#39;1&#39; ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out_A( $E, &#39;1&#39; ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) environment_2:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Env( $E ), YPublished( ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> Env_No( $E, &#39;2&#39; ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out_A( $E, &#39;2&#39; ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) BB_8:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;AgSt_BB2( $BB,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;$S, &#39;ys&#39;, (&lt;y1, no1&gt;++&lt;y2, no2&gt;)&gt;<br/>\n&nbsp;&nbsp;&nbsp;),<br/>\n&nbsp;&nbsp;&nbsp;In( &lt;$S, &#39;ySG&#39;, ySG&gt; )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> BB_YSG( $BB, &lt;&#39;ySG&#39;, ySG&gt; ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out_A( $BB, &lt;&#39;ySG&#39;, ySG&gt; ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) H_9:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;AgSt_H5( $H, &lt;$D, $S, $BB, yD, y1, y2&gt; ),<br/>\n&nbsp;&nbsp;&nbsp;In_A( $BB, &lt;&#39;ySG&#39;, ySG&gt; )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> Learn_H_ySG( $H, $S, &lt;&#39;ySG&#39;, ySG&gt; ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) A_9:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;AgSt_A3( $A,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;$S, $BB, $E, &#39;ys&#39;, (&lt;y1, no1&gt;++&lt;y2, no2&gt;)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&gt;<br/>\n&nbsp;&nbsp;&nbsp;),<br/>\n&nbsp;&nbsp;&nbsp;In_A( $E, noSel ), In_A( $BB, &lt;&#39;ySG&#39;, ySG&gt; )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> Learn_A_noSel( $A, $E, noSel ), Learn_A_ySG( $A, $S, ySG )<br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span></p><br/>\n<h2>Restrictions of the Set of Traces</h2><br/>\n<p class=\"monospace rules\"><span class=\"hl_keyword\">restriction</span> OneSetup:<br/>\n&nbsp;&nbsp;&quot;<span class=\"hl_operator\">∀ </span>#i #j<span class=\"hl_operator\">.</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span><span class=\"hl_operator\">(</span>Setup( ) <span class=\"hl_operator\">@</span> #i<span class=\"hl_operator\">)</span> <span class=\"hl_operator\">∧</span> <span class=\"hl_operator\">(</span>Setup( ) <span class=\"hl_operator\">@</span> #j<span class=\"hl_operator\">)</span><span class=\"hl_operator\">)</span> <span class=\"hl_operator\">⇒</span> <span class=\"hl_operator\">(</span>#i <span class=\"hl_operator\">=</span> #j<span class=\"hl_operator\">)</span>&quot;<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">// safety formula</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/*<br/>\n&nbsp;&nbsp;expanded formula:<br/>\n&nbsp;&nbsp;&quot;<span class=\"hl_operator\">∀ </span>#i #j<span class=\"hl_operator\">.</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span><span class=\"hl_operator\">(</span>Setup( ) <span class=\"hl_operator\">@</span> #i<span class=\"hl_operator\">)</span> <span class=\"hl_operator\">∧</span> <span class=\"hl_operator\">(</span>Setup( ) <span class=\"hl_operator\">@</span> #j<span class=\"hl_operator\">)</span><span class=\"hl_operator\">)</span> <span class=\"hl_operator\">⇒</span> <span class=\"hl_operator\">(</span>#i <span class=\"hl_operator\">=</span> #j<span class=\"hl_operator\">)</span>&quot;<br/>\n&nbsp;&nbsp;*/</span></p><br/>\n","title":"Multiset rewriting rules and restrictions"}