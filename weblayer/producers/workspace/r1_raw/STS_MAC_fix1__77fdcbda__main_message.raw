{"html":"<h2>Signature</h2><br/>\n<p class=\"monospace rules\"><span class=\"hl_keyword\">builtins:</span> diffie-hellman<br/>\n<span class=\"hl_keyword\">functions:</span> KDF/1, fst/1, mac/2, pair/2, pk/1, sign/2, snd/1,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;true/0, verify/3<br/>\n<span class=\"hl_keyword\">equations:</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;fst(&lt;x.1, x.2&gt;) <span class=\"hl_operator\">=</span> x.1,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;snd(&lt;x.1, x.2&gt;) <span class=\"hl_operator\">=</span> x.2,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;verify(sign(x.1, x.2), x.1, pk(x.2)) <span class=\"hl_operator\">=</span> true</p><br/>\n<h2>Construction Rules</h2><br/>\n<p class=\"monospace rules\"><span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) c_KDF:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> !KU( KDF(x) ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> !KU( KDF(x) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) c_fst:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> !KU( fst(x) ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> !KU( fst(x) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) c_mac:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( x ), !KU( x.1 ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> !KU( mac(x, x.1) ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( mac(x, x.1) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) c_pair:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( x ), !KU( x.1 ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> !KU( &lt;x, x.1&gt; ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( &lt;x, x.1&gt; ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) c_pk:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> !KU( pk(x) ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> !KU( pk(x) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) c_sign:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( x ), !KU( x.1 ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> !KU( sign(x, x.1) ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( sign(x, x.1) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) c_snd:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> !KU( snd(x) ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> !KU( snd(x) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) c_true:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> !KU( true ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> !KU( true ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) c_verify:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( x ), !KU( x.1 ), !KU( x.2 ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> !KU( verify(x, x.1, x.2) ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( verify(x, x.1, x.2) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) coerce:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> !KU( x ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> !KU( x ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) pub:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> !KU( $x ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> !KU( $x ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) fresh:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Fr( ~x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> !KU( ~x ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> !KU( ~x ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) c_exp:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( x ), !KU( x.1 ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> !KU( x^x.1 ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> !KU( x^x.1 ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) c_inv:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> !KU( inv(x) ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> !KU( inv(x) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) c_one:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> !KU( one ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> !KU( one ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) c_DH_neutral:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> !KU( DH_neutral ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> !KU( DH_neutral ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) c_mult:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( x ), !KU( x.1 ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> !KU( (x*x.1) ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( (x*x.1) ) <span class=\"hl_operator\">]</span></p><br/>\n<h2>Deconstruction Rules</h2><br/>\n<p class=\"monospace rules\"><span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) d_0_fst:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( &lt;x.1, x.2&gt; ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--&gt;</span> <span class=\"hl_operator\">[</span> !KD( x.1 ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) d_0_snd:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( &lt;x.1, x.2&gt; ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--&gt;</span> <span class=\"hl_operator\">[</span> !KD( x.2 ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) d_exp:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( x.2^x.3 ), !KU( x.1 ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--&gt;</span> <span class=\"hl_operator\">[</span> !KD( x.2^(x.1*x.3) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) d_exp:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( x.3^x.2 ), !KU( inv(x.2) ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--&gt;</span> <span class=\"hl_operator\">[</span> !KD( x.3 ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) d_exp:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( x.3^inv(x.2) ), !KU( x.2 ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--&gt;</span> <span class=\"hl_operator\">[</span> !KD( x.3 ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) d_exp:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( x.3^inv(x.4) ), !KU( inv(x.2) ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( x.3^inv((x.2*x.4)) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) d_exp:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( x.2^x.3 ), !KU( inv((x.3*x.4)) ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( x.2^inv(x.4) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) d_exp:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( x.2^x.3 ), !KU( (x.4*inv(x.3)) ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--&gt;</span> <span class=\"hl_operator\">[</span> !KD( x.2^x.4 ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) d_exp:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( x.4^inv(x.2) ), !KU( (x.2*x.3) ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--&gt;</span> <span class=\"hl_operator\">[</span> !KD( x.4^x.3 ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) d_exp:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( x.3^inv((x.2*x.4)) ), !KU( x.2 ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( x.3^inv(x.4) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) d_exp:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( x.3^(x.2*x.4) ), !KU( inv(x.2) ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--&gt;</span> <span class=\"hl_operator\">[</span> !KD( x.3^x.4 ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) d_exp:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( x.3^(x.4*inv(x.2)) ), !KU( x.2 ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--&gt;</span> <span class=\"hl_operator\">[</span> !KD( x.3^x.4 ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) d_exp:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( x.2^inv(x.3) ), !KU( (x.4*inv(x.5)) ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( x.2^(x.4*inv((x.3*x.5))) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) d_exp:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( x.3^(x.4*inv(x.5)) ), !KU( inv(x.2) ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( x.3^(x.4*inv((x.2*x.5))) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) d_exp:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( x.2^x.3 ), !KU( (x.4*inv((x.3*x.5))) ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( x.2^(x.4*inv(x.5)) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) d_exp:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( x.4^inv((x.2*x.5)) ), !KU( (x.2*x.3) ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( x.4^(x.3*inv(x.5)) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) d_exp:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( x.4^(x.3*x.5) ), !KU( (x.2*inv(x.3)) ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( x.4^(x.2*x.5) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) d_exp:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( x.4^(x.3*x.5) ), !KU( inv((x.2*x.3)) ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( x.4^(x.5*inv(x.2)) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) d_exp:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( x.4^(x.5*inv(x.2)) ), !KU( (x.2*x.3) ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( x.4^(x.3*x.5) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) d_exp:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( x.3^(x.4*inv((x.2*x.5))) ), !KU( x.2 ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( x.3^(x.4*inv(x.5)) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) d_exp:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( x.4^(x.5*inv(x.6)) ), !KU( 