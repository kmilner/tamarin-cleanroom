{"html":"<br/>\n<h2>Fact Symbols with Injective Instances</h2><br/>\n<p class=\"monospace rules\">St_C(id,=,=,.,≤), St_W(id,=,=,.,.)</p><br/>\n<h2>Multiset Rewriting Rules</h2><br/>\n<p class=\"monospace rules\"><span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) isend:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> K( x ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> In( x ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) irecv:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out( x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--&gt;</span> <span class=\"hl_operator\">[</span> !KD( x ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) RegisterKey:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Fr( ~ltk ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> Key( ~ltk ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !F_AgentKey( ~ltk ), Out( pk(~ltk) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) CompromiseKey:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !F_AgentKey( ~ltk ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> Compromise( pk(~ltk) ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out( ~ltk ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) BindState_C:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !F_AgentKey( ~ltkA ), !F_AgentKey( ~ltkB ), Fr( ~id ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span><br/>\n&nbsp;&nbsp;Paired( ~id, &#39;C&#39;, ~ltkA, ~ltkB ),<br/>\n&nbsp;&nbsp;Counter( ~id, &#39;0&#39; ),<br/>\n&nbsp;&nbsp;Injectivity( ~id, &#39;nonce&#39;, &#39;0&#39; ),<br/>\n&nbsp;&nbsp;F_InvariantSource_C( ~id, ~ltkA, pk(~ltkB) )<br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> St_C( ~id, ~ltkA, pk(~ltkB), &#39;m0&#39;, &#39;0&#39; ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) BindState_W:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !F_AgentKey( ~ltkA ), !F_AgentKey( ~ltkB ), Fr( ~id ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span><br/>\n&nbsp;&nbsp;Paired( ~id, &#39;W&#39;, ~ltkA, ~ltkB ),<br/>\n&nbsp;&nbsp;Counter( ~id, &#39;0&#39; ),<br/>\n&nbsp;&nbsp;Injectivity( ~id, &#39;nonce&#39;, &#39;0&#39; ),<br/>\n&nbsp;&nbsp;F_InvariantSource_W( ~id, ~ltkB, pk(~ltkA) )<br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> St_W( ~id, ~ltkB, pk(~ltkA), &#39;m1&#39;, &#39;0&#39; ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) C_0:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> St_C( ~id, ~ltkA, pkB, &#39;m0&#39;, cc ), Fr( ~nc ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span><br/>\n&nbsp;&nbsp;Gen( ~nc ), Injectivity( ~id, cc, ~nc ),<br/>\n&nbsp;&nbsp;Invariant_C( ~id, ~ltkA, pkB )<br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;St_C( ~id, ~ltkA, pkB, &lt;&#39;m2&#39;, ~nc&gt;, cc ),<br/>\n&nbsp;&nbsp;&nbsp;Out( &lt;&#39;1&#39;, pk(~ltkA), pkB, ~nc&gt; )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) W_0:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;St_W( ~id, ~ltkB, pkA, &#39;m1&#39;, cw ), Fr( ~nw ),<br/>\n&nbsp;&nbsp;&nbsp;In( &lt;&#39;1&#39;, pkA, pk(~ltkB), nc&gt; )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span><br/>\n&nbsp;&nbsp;Nonces( ~id, nc, ~nw ), Counter( &lt;~id, &#39;m1&#39;&gt;, cw ),<br/>\n&nbsp;&nbsp;Gen( ~nw ), Begin( &#39;W&#39;, &lt;pkA, pk(~ltkB)&gt;, S(cw) ),<br/>\n&nbsp;&nbsp;Injectivity( ~id, cw, ~nw ), Invariant_W( ~id, ~ltkB, pkA )<br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;St_W( ~id, ~ltkB, pkA, &lt;&#39;m3&#39;, nc, ~nw&gt;, cw ),<br/>\n&nbsp;&nbsp;&nbsp;Out( &lt;&lt;&#39;2&#39;, pk(~ltkB), pkA, nc, ~nw&gt;, <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;sign(&lt;&#39;2&#39;, pk(~ltkB), pkA, nc, ~nw&gt;, ~ltkB)&gt;<br/>\n&nbsp;&nbsp;&nbsp;)<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) C_1:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;St_C( ~id, ~ltkA, pkB, &lt;&#39;m2&#39;, nc&gt;, cc ),<br/>\n&nbsp;&nbsp;&nbsp;In( &lt;&lt;&#39;2&#39;, pkB, pk(~ltkA), nc, nw&gt;, sig&gt; ),<br/>\n&nbsp;&nbsp;&nbsp;Fr( ~inj )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span><br/>\n&nbsp;&nbsp;Eq( verify(sig, &lt;&#39;2&#39;, pkB, pk(~ltkA), nc, nw&gt;, pkB),<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;true<br/>\n&nbsp;&nbsp;),<br/>\n&nbsp;&nbsp;Nonces( ~id, nc, nw ), Counter( &lt;~id, &#39;m3&#39;&gt;, S(cc) ),<br/>\n&nbsp;&nbsp;Injectivity( ~id, nc, ~inj ),<br/>\n&nbsp;&nbsp;Begin( &#39;C&#39;, &lt;pk(~ltkA), pkB&gt;, S(cc) ),<br/>\n&nbsp;&nbsp;Invariant_C( ~id, ~ltkA, pkB )<br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;St_C( ~id, ~ltkA, pkB, &lt;&#39;m4&#39;, nc, nw, ~inj&gt;, S(cc) ),<br/>\n&nbsp;&nbsp;&nbsp;Out( &lt;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;&#39;3&#39;, pk(~ltkA), pkB, <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;&lt;&#39;1&#39;, pk(~ltkA), pkB, nc&gt;, &#39;2&#39;, pkB, <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;pk(~ltkA), nc, nw&gt;), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;S(cc)&gt;, <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;sign(&lt;&#39;3&#39;, pk(~ltkA), pkB, <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;&lt;&#39;1&#39;, pk(~ltkA), pkB, nc&gt;, &#39;2&#39;, pkB, <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;pk(~ltkA), nc, nw&gt;), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;S(cc)&gt;,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;~ltkA)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&gt;<br/>\n&nbsp;&nbsp;&nbsp;)<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">// loop breaker: [0]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/*<br/>\n&nbsp;&nbsp;<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) C_1:<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;St_C( ~id, ~ltkA, pkB, &lt;&#39;m2&#39;, nc&gt;, cc ),<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;In( &lt;&lt;&#39;2&#39;, pkB, pk(~ltkA), nc, nw&gt;, sig&gt; ),<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Fr( ~inj )<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">--[</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;Eq( z, true ), Nonces( ~id, nc, nw ),<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;Counter( &lt;~id, &#39;m3&#39;&gt;, S(cc) ),<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;Injectivity( ~id, nc, ~inj ),<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;Begin( &#39;C&#39;, &lt;pk(~ltkA), pkB&gt;, S(cc) ),<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;Invariant_C( ~id, ~ltkA, pkB )<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;St_C( ~id, ~ltkA, pkB, &lt;&#39;m4&#39;, nc, nw, ~inj&gt;, S(cc) ),<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Out( &lt;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;&#39;3&#39;, pk(~ltkA), pkB, <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;&lt;&#39;1&#39;, pk(~ltkA), pkB, nc&gt;, &#39;2&#39;, pkB, <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;pk(~ltkA), nc, nw&gt;), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;S(cc)&gt;, <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;sign(&lt;&#39;3&#39;, pk(~ltkA), pkB, <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;&lt;&#39;1&#39;, pk(~ltkA), pkB, nc&gt;, &#39;2&#39;, pkB, <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;pk(~ltkA), nc, nw&gt;), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;S(cc)&gt;,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;~ltkA)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&gt;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_keyword\">variants</span> (<span class=\"hl_keyword\">modulo</span> AC)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;1. ~ltkA = ~ltkA.21<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;nc    = nc.23<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;nw    = nw.24<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;pkB   = pkB.25<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;sig   = sig.26<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z     = verify(sig.26,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;&#39;2&#39;, pkB.25, pk(~ltkA.21), nc.23, nw.24&gt;, pkB.25)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;2. ~ltkA = ~ltkA.104<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;nc    = nc.106<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;nw    = nw.107<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;pkB   = pk(x.204)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;sig   = sign(&lt;&#39;2&#39;, pk(x.204), pk(~ltkA.104), nc.106, <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;nw.107&gt;,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;x.204)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z     = true<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_comment\">// loop breaker: [0]</span><br/>\n&nbsp;&nbsp;*/</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) W_detect:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;St_W( ~id, ~ltkB, pkA, &lt;&#39;m3&#39;, nc, nw&gt;, cw ),<br/>\n&nbsp;&nbsp;&nbsp;In( &lt;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;&#39;3&#39;, pkA, pk(~ltkB), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;&lt;&#39;1&#39;, pkA, pk(~ltkB), nc&gt;, &#39;2&#39;, <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;pk(~ltkB), pkA, nc, nw&gt;), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;scc&gt;, <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;sig&gt;<br/>\n&nbsp;&nbsp;&nbsp;)<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span><br/>\n&nbsp;&nbsp;Eq( verify(sig,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;&#39;3&#39;, pkA, pk(~ltkB), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;&lt;&#39;1&#39;, pkA, pk(~ltkB), nc&gt;, &#39;2&#39;, <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;pk(~ltkB), pkA, nc, nw&gt;), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;scc&gt;,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;pkA),<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;true<br/>\n&nbsp;&nbsp;),<br/>\n&nbsp;&nbsp;InEq( scc, S(cw) ), Detect( &lt;pkA, pk(~ltkB)&gt; ),<br/>\n&nbsp;&nbsp;Session( &#39;W&#39;, &lt;pkA, pk(~ltkB)&gt;, &lt;nc, nw&gt;, scc<br/>\n&nbsp;&nbsp;),<br/>\n&nbsp;&nbsp;Counter( &lt;~id, &#39;m4&#39;&gt;, S(cw) ),<br/>\n&nbsp;&nbsp;Injectivity( ~id, nw, S(cw) ), Invariant_W( ~id, ~ltkB, pkA )<br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;Remediate_W( ~id, ~ltkB, pkA, &#39;m1&#39;, scc ),<br/>\n&nbsp;&nbsp;&nbsp;Discard( &lt;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;&#39;4&#39;, pk(~ltkB), pkA, <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;&lt;&#39;1&#39;, pkA, pk(~ltkB), nc&gt;, <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;&#39;2&#39;, pk(~ltkB), pkA, nc, nw&gt;, &#39;3&#39;, pkA, <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;pk(~ltkB), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;&lt;&#39;1&#39;, pkA, pk(~ltkB), nc&gt;, &#39;2&#39;, <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;pk(~ltkB), pkA, nc, nw&gt;), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;scc&gt;)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&gt;, <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;sign(&lt;&#39;4&#39;, pk(~ltkB), pkA, <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;&lt;&#39;1&#39;, pkA, pk(~ltkB), nc&gt;, <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;&#39;2&#39;, pk(~ltkB), pkA, nc, nw&gt;, &#39;3&#39;, pkA, <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;pk(~ltkB), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;&lt;&#39;1&#39;, pkA, pk(~ltkB), nc&gt;, &#39;2&#39;, <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;pk(~ltkB), pkA, nc, nw&gt;), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;scc&gt;)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&gt;,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;~ltkB)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&gt;<br/>\n&nbsp;&nbsp;&nbsp;)<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/*<br/>\n&nbsp;&nbsp;<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) W_detect:<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;St_W( ~id, ~ltkB, pkA, &lt;&#39;m3&#39;, nc, nw&gt;, cw ),<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;In( &lt;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;&#39;3&#39;, pkA, pk(~ltkB), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;&lt;&#39;1&#39;, pkA, pk(~ltkB), nc&gt;, &#39;2&#39;, <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp