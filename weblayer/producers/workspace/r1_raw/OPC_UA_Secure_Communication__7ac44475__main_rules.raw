<span class=\"hl_operator\">)</span> <span class=\"hl_operator\">∨</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span><span class=\"hl_operator\">∃ </span>#t.1<span class=\"hl_operator\">.</span> ProgressTo_11111211112( prog_1111121111 ) <span class=\"hl_operator\">@</span> #t.1<span class=\"hl_operator\">)</span><span class=\"hl_operator\">)</span>&quot;<br/>\n&nbsp;&nbsp;*/</span><br/>\n<br/>\n<span class=\"hl_keyword\">restriction</span> progressInit:<br/>\n&nbsp;&nbsp;&quot;<span class=\"hl_operator\">∃ </span>#t<span class=\"hl_operator\">.</span> Init( ) <span class=\"hl_operator\">@</span> #t&quot;<br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/*<br/>\n&nbsp;&nbsp;expanded formula:<br/>\n&nbsp;&nbsp;&quot;<span class=\"hl_operator\">∃ </span>#t<span class=\"hl_operator\">.</span> Init( ) <span class=\"hl_operator\">@</span> #t&quot;<br/>\n&nbsp;&nbsp;*/</span><br/>\n<br/>\n<span class=\"hl_keyword\">restriction</span> reliable:<br/>\n&nbsp;&nbsp;&quot;<span class=\"hl_operator\">∀ </span>#i x y<span class=\"hl_operator\">.</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span>Send( x, y ) <span class=\"hl_operator\">@</span> #i<span class=\"hl_operator\">)</span> <span class=\"hl_operator\">⇒</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span><span class=\"hl_operator\">∃ </span>#j<span class=\"hl_operator\">.</span> <span class=\"hl_operator\">(</span>Receive( x, y ) <span class=\"hl_operator\">@</span> #j<span class=\"hl_operator\">)</span> <span class=\"hl_operator\">∧</span> <span class=\"hl_operator\">(</span>#i <span class=\"hl_operator\">&lt;</span> #j<span class=\"hl_operator\">)</span><span class=\"hl_operator\">)</span>&quot;<br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/*<br/>\n&nbsp;&nbsp;expanded formula:<br/>\n&nbsp;&nbsp;&quot;<span class=\"hl_operator\">∀ </span>#i x y<span 