lemma duplicates_sender_duplicate_uniq:
  all-traces
  "∀ sa2 sid s1 s2 c #i #j.
    (((((sa2 = <sid, s2>) ∧ (Post( <sid, s1>, S(S(S('0'))), c ) @ #i)) ∧
       (Post( <sid, s2>, S(S(S('0'))), c ) @ #j)) ∧
      (#i < #j)) ∧
     (¬(s1 = s2))) ⇒
    (∃ #i.1. Corrupted( sa2 ) @ #i.1)"
/*
guarded formula characterizing all counter-examples:
"∃ sa2 sid s1 s2 c #i #j.
  (sa2 = <sid, s2>) ∧
  (Post( <sid, s1>, S(S(S('0'))), c ) @ #i) ∧
  (Post( <sid, s2>, S(S(S('0'))), c ) @ #j)
 ∧
  (#i < #j) ∧ (¬(s1 = s2)) ∧ (∀ #i.1. (Corrupted( sa2 ) @ #i.1) ⇒ ⊥)"
*/
by sorry

lemma duplicates_mixer_duplicate_uniq:
  all-traces
  "∀ ma sid m n c #i #j.
    (((((ma = <sid, m>) ∧ (Post( <sid, m>, n, c ) @ #i)) ∧
       (Post( <sid, m>, n, c ) @ #j)) ∧
      (¬(n = S(S(S('0')))))) ∧
     (¬(#i = #j))) ⇒
    (∃ #i.1. Corrupted( ma ) @ #i.1)"
