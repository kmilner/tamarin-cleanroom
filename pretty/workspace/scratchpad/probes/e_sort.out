theory Esort

begin

// Function signature and definition of the equational theory E

functions: c/2, fst/1, pair/2, snd/1, v/1, w/1
equations:
    fst(<x.1, x.2>) = x.1,
    snd(<x.1, x.2>) = x.2,
    v(c(x, y)) = y,
    w(c(x, y)) = x

rule (modulo E) A:
   [ In( x ) ] --> [ Out( x ) ]

  /* has exactly the trivial AC variant */



end
