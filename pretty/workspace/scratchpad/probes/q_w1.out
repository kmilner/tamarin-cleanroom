theory qw1

begin

// Function signature and definition of the equational theory E

functions: fst/1, pair/2, snd/1
equations: fst(<x.1, x.2>) = x.1, snd(<x.1, x.2>) = x.2

rule (modulo E) R1:
   [ In( x ) ] --[ A( x ), B( x, x ), C( ) ]-> [ Out( x ) ]

  /* has exactly the trivial AC variant */

restriction r_alltr:
  "∀ x #i. (A( x ) @ #i) ⇒ (∃ #j. B( x, x ) @ #j)"

  /*
  expanded formula:
  "∀ x #i. (A( x ) @ #i) ⇒ (∃ #j. B( x, x ) @ #j)"
  */

restriction r_exists:
  "∃ x #i. A( x ) @ #i"

  /*
  expanded formula:
  "∃ x #i. A( x ) @ #i"
  */

restriction r_eq:
  "∀ x y #i. (B( x, y ) @ #i) ⇒ (x = y)"
  // safety formula

  /*
  expanded formula:
  "∀ x y #i. (B( x, y ) @ #i) ⇒ (x = y)"
  */

lemma l_top:
  all-traces "⊤"
/*
guarded formula characterizing all counter-examples:
"⊥"
*/
by sorry

lemma l_bot:
  exists-trace "⊥"
/*
guarded formula characterizing all satisfying traces:
"⊥"
*/
by sorry

lemma l_short:
  all-traces "∀ x #i. (A( x ) @ #i) ⇒ (⊤)"
/*
guarded formula characterizing all counter-examples:
"⊥"
*/
by sorry

lemma l_attrs [use_induction, reuse]:
  all-traces "∀ x #i. (A( x ) @ #i) ⇒ (∃ #j. B( x, x ) @ #j)"
/*
guarded formula characterizing all counter-examples:
"∃ x #i. (A( x ) @ #i) ∧ ∀ #j. (B( x, x ) @ #j) ⇒ ⊥"
*/
by sorry

lemma l_extr:
  exists-trace "∃ x #i. (A( x ) @ #i) ∧ (∃ #j. C( ) @ #j)"
/*
guarded formula characterizing all satisfying traces:
"∃ x #i. (A( x ) @ #i) ∧ ∃ #j. (C( ) @ #j)"
*/
by sorry



end
