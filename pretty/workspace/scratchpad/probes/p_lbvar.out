theory Plbvar

begin

// Function signature and definition of the equational theory E

builtins: xor
functions: fst/1, pair/2, snd/1
equations: fst(<x.1, x.2>) = x.1, snd(<x.1, x.2>) = x.2

rule (modulo E) LV:
   [ A( x ), Fr( ~y ) ] --> [ A( (~y⊕x) ) ]

  // loop breaker: [0]
  /*
  rule (modulo AC) LV:
     [ A( x ), Fr( ~y ) ] --> [ A( z ) ]
    variants (modulo AC)
    1. ~y    = ~y.4
       x     = x.4
       z     = (~y.4⊕x.4)
    
    2. ~y    = ~y.4
       x     = zero
       z     = ~y.4
    // loop breaker: [0]
  */

rule (modulo E) S:
   [ Fr( ~a ) ] --> [ A( ~a ) ]

  /* has exactly the trivial AC variant */



end
