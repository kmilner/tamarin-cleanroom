theory Parr1

begin

// Function signature and definition of the equational theory E

functions: fst/1, pair/2, snd/1
equations: fst(<x.1, x.2>) = x.1, snd(<x.1, x.2>) = x.2

rule (modulo E) AR:
   [ In( x ) ]
  --[ Actfact( actvariablename000001 ), Actfacu( actvariablename000002 )
  ]->
   [ Out( x ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) CO:
   [ In( x ) ]
  -->
   [ Cnclfact( averyverylongvariable01 ), Cnclfacu( averyverylongvariable2 )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) PR:
   [ Prmfact( averyverylongvariable01 ), Prmfacu( averyverylongvariable2 ) ]
  -->
   [ Out( x ) ]

  /* has exactly the trivial AC variant */



end
