theory PeqD

begin

// Function signature and definition of the equational theory E

functions: f/2, fst/1, g/1, pair/2, snd/1
equations:
    f(azz, g(azz)) = azz,
    f(b, g(b)) = b,
    fst(<x.1, x.2>) = x.1,
    snd(<x.1, x.2>) = x.2

rule (modulo E) A:
   [ In( x ) ] --> [ Out( x ) ]

  /* has exactly the trivial AC variant */



end
