theory Texp2

begin

// Function signature and definition of the equational theory E

builtins: diffie-hellman
functions: fst/1, pair/2, snd/1
equations: fst(<x.1, x.2>) = x.1, snd(<x.1, x.2>) = x.2

rule (modulo E) E1:
   [ Fr( ~x ), Fr( ~y ) ] --> [ Out( 'g'^~x^~y ) ]

  /*
  rule (modulo AC) E1:
     [ Fr( ~x ), Fr( ~y ) ] --> [ Out( 'g'^(~x*~y) ) ]
  */

rule (modulo E) E2:
   [ Fr( ~x ), Fr( ~y ) ] --> [ Out( 'g'^~x^~y ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) E3:
   [ Fr( ~x ), Fr( ~y ) ] --> [ Out( 'g'^~x^~y ) ]

  /*
  rule (modulo AC) E3:
     [ Fr( ~x ), Fr( ~y ) ] --> [ Out( 'g'^(~x*~y) ) ]
  */



end
