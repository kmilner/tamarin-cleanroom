theory Econv

begin

// Function signature and definition of the equational theory E

functions: dec/2, enc/2, fst/1, pair/2, snd/1
equations [convergent]:
    dec(enc(x, y), y) = x,
    fst(<x.1, x.2>) = x.1,
    snd(<x.1, x.2>) = x.2

rule (modulo E) A:
   [ In( x ) ] --> [ Out( x ) ]

  /* has exactly the trivial AC variant */



end
