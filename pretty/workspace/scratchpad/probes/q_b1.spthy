theory qb1 begin

rule R1: [ In(x), Fr(~n) ] --[ A(x), M(~n, $p, x) ]-> [ Out(x) ]

restriction b1_sigils: "All ~n $p x #i. M(~n, $p, x)@i ==> Ex #j. A(x)@j"

restriction b2_order: "All #i x ~n $p. M(~n, $p, x)@i ==> Ex #j. A(x)@j"

lemma b3_exists_sigils: exists-trace "Ex ~n $p x #i. M(~n, $p, x)@i"

end
