restriction set_in:
  "∀ x y #t3.
    (IsIn( x, y ) @ #t3) ⇒
    (∃ #t2.
      ((Insert( x, y ) @ #t2) ∧ (#t2 < #t3)) ∧
      (∀ #t1 yp.
        (Insert( x, yp ) @ #t1) ⇒ (((#t1 < #t2) ∨ (#t1 = #t2)) ∨ (#t3 < #t1))))"

  /*
  expanded formula:
  "∀ x y #t3.
    (IsIn( x, y ) @ #t3) ⇒
    (∃ #t2.
      ((Insert( x, y ) @ #t2) ∧ (#t2 < #t3)) ∧
      (∀ #t1 yp.
        (Insert( x, yp ) @ #t1) ⇒ (((#t1 < #t2) ∨ (#t1 = #t2)) ∨ (#t3 < #t1))))"
  */

restriction set_notin:
  "∀ x #t3.
    (IsNotSet( x ) @ #t3) ⇒ (∀ #t1 y. (Insert( x, y ) @ #t1) ⇒ (#t3 < #t1))"
  // safety formula

  /*
  expanded formula:
  "∀ x #t3.
    (IsNotSet( x ) @ #t3) ⇒ (∀ #t1 y. (Insert( x, y ) @ #t1) ⇒ (#t3 < #t1))"
  */

restriction predicate_eq:
  "∀ #i a b. (Pred_Eq( a, b ) @ #i) ⇒ (a = b)"
  // safety formula

  /*
  expanded formula:
  "∀ #i a b. (Pred_Eq( a, b ) @ #i) ⇒ (a = b)"
  */

restriction predicate_not_eq:
  "∀ #i a b. (Pred_Not_Eq( a, b ) @ #i) ⇒ (¬(a = b))"
  // safety formula

  /*
  expanded formula:
  "∀ #i a b. (Pred_Not_Eq( a, b ) @ #i) ⇒ (¬(a = b))"
  */

restriction single_session:
  "∀ #i #j. ((Init( ) @ #i) ∧ (Init( ) @ #j)) ⇒ (#i = #j)"
  // safety formula

  /*
  expanded formula:
  "∀ #i #j. ((Init( ) @ #i) ∧ (Init( ) @ #j)) ⇒ (#i = #j)"
  */

lemma acc_invalidReqD_suff:
  exists-trace
  "∃ x a id #i #j.
    (((((Log( x, a, id ) @ #i) ∧ (Execute( a, id ) @ #j)) ∧
       (¬((a = SpecialReq) ∨ (a = NormalReq)))) ∧
      (¬(∃ a.1 b. x = <a.1, b>))) ∧
     (∀ x.1 a.1 id.1 #i.1 #j.1.
       ((((Log( x.1, a.1, id.1 ) @ #i.1) ∧ (Execute( a.1, id.1 ) @ #j.1)) ∧
         (¬((a.1 = SpecialReq) ∨ (a.1 = NormalReq)))) ∧
        (¬(∃ a.2 b. x.1 = <a.2, b>))) ⇒
       (x.1 = x))) ∧
    ((∀ a.1 #i.1. (Corrupted( a.1 ) @ #i.1) ⇒ (a.1 = x)) ∧
     (¬(∃ x.1 y a.1 id.1 #i.1 #j.1.
         ((((Log( <x.1, y>, a.1, id.1 ) @ #i.1) ∧ (Execute( a.1, id.1 ) @ #j.1)) ∧
           (¬(x.1 = y))) ∧
          (¬((a.1 = SpecialReq) ∨ (a.1 = NormalReq)))) ∧
         (¬(∃ z a.2 id.2 #i.2 #j.2.
             ((((Log( z, a.2, id.2 ) @ #i.2) ∧ (Execute( a.2, id.2 ) @ #j.2)) ∧
               (¬((a.2 = SpecialReq) ∨ (a.2 = NormalReq)))) ∧
              (¬(∃ a.3 b. x.1 = <a.3, b>))) ∧
             ((z = x.1) ∨ (z = y)))))))"
/*
guarded formula characterizing all satisfying traces:
"∃ x a id #i #j.
  (Log( x, a, id ) @ #i) ∧ (Execute( a, id ) @ #j)
 ∧
  (¬(a = SpecialReq)) ∧
  (¬(a = NormalReq)) ∧
  (∀ a.1 b. (x = <a.1, b>) ⇒ ⊥) ∧
  (∀ x.1 a.1 id.1 #i.1 #j.1.
    (Log( x.1, a.1, id.1 ) @ #i.1) ∧ (Execute( a.1, id.1 ) @ #j.1)
   ⇒
    ((a.1 = SpecialReq) ∨
     (a.1 = NormalReq) ∨
     (∃ a.2 b. (x.1 = <a.2, b>)) ∨
     (x.1 = x))) ∧
  (∀ a.1 #i.1. (Corrupted( a.1 ) @ #i.1) ⇒ a.1 = x) ∧
  (∀ x.1 y a.1 id.1 #i.1 #j.1.
    (Log( <x.1, y>, a.1, id.1 ) @ #i.1) ∧ (Execute( a.1, id.1 ) @ #j.1)
   ⇒
    ((x.1 = y) ∨
     (a.1 = SpecialReq) ∨
     (a.1 = NormalReq) ∨
     (∃ z a.2 id.2 #i.2 #j.2.
       (Log( z, a.2, id.2 ) @ #i.2) ∧ (Execute( a.2, id.2 ) @ #j.2)
      ∧
       (¬(a.2 = SpecialReq)) ∧
       (¬(a.2 = NormalReq)) ∧
       (∀ a.3 b. (x.1 = <a.3, b>) ⇒ ⊥) ∧
       (((z = x.1) ∨ (z = y))))))"
*/
by sorry

lemma acc_invalidReqDC_suff:
  exists-trace
  "∃ x y a id #i #j.
    ((((((Log( <x, y>, a, id ) @ #i) ∧ (Execute( a, id ) @ #j)) ∧
        (¬(x = y))) ∧
       (¬((a = SpecialReq) ∨ (a = NormalReq)))) ∧
      (¬(∃ z a.1 id.1 #i.1 #j.1.
          ((((Log( z, a.1, id.1 ) @ #i.1) ∧ (Execute( a.1, id.1 ) @ #j.1)) ∧
            (¬((a.1 = SpecialReq) ∨ (a.1 = NormalReq)))) ∧
           (¬(∃ a.2 b. x = <a.2, b>))) ∧
          ((z = x) ∨ (z = y))))) ∧
     (∀ x.1 y.1 a.1 id.1 #i.1 #j.1.
       (((((Log( <x.1, y.1>, a.1, id.1 ) @ #i.1) ∧
           (Execute( a.1, id.1 ) @ #j.1)) ∧
          (¬(x.1 = y.1))) ∧
         (¬((a.1 = SpecialReq) ∨ (a.1 = NormalReq)))) ∧
        (¬(∃ z a.2 id.2 #i.2 #j.2.
            ((((Log( z, a.2, id.2 ) @ #i.2) ∧ (Execute( a.2, id.2 ) @ #j.2)) ∧
              (¬((a.2 = SpecialReq) ∨ (a.2 = NormalReq)))) ∧
             (¬(∃ a.3 b. x.1 = <a.3, b>))) ∧
            ((z = x.1) ∨ (z = y.1))))) ⇒
       (<x.1, y.1> = <x, y>))) ∧
    ((∀ a.1 #i.1. (Corrupted( a.1 ) @ #i.1) ⇒ ((a.1 = x) ∨ (a.1 = y))) ∧
     (¬(∃ x.1 a.1 id.1 #i.1 #j.1.
         (((Log( x.1, a.1, id.1 ) @ #i.1) ∧ (Execute( a.1, id.1 ) @ #j.1)) ∧
          (¬((a.1 = SpecialReq) ∨ (a.1 = NormalReq)))) ∧
         (¬(∃ a.2 b. x.1 = <a.2, b>)))))"
/*
guarded formula characterizing all satisfying traces:
"∃ x y a id #i #j.
  (Log( <x, y>, a, id ) @ #i) ∧ (Execute( a, id ) @ #j)
 ∧
  (¬(x = y)) ∧
  (¬(a = SpecialReq)) ∧
  (¬(a = NormalReq)) ∧
  (∀ z a.1 id.1 #i.1 #j.1.
    (Log( z, a.1, id.1 ) @ #i.1) ∧ (Execute( a.1, id.1 ) @ #j.1)
   ⇒
    ((a.1 = SpecialReq) ∨
     (a.1 = NormalReq) ∨
     (∃ a.2 b. (x = <a.2, b>)) ∨
     ((¬(z = x)) ∧ (¬(z = y))))) ∧
  (∀ x.1 y.1 a.1 id.1 #i.1 #j.1.
    (Log( <x.1, y.1>, a.1, id.1 ) @ #i.1) ∧ (Execute( a.1, id.1 ) @ #j.1)
   ⇒
    ((x.1 = y.1) ∨
     (a.1 = SpecialReq) ∨
     (a.1 = NormalReq) ∨
     (∃ z a.2 id.2 #i.2 #j.2.
       (Log( z, a.2, id.2 ) @ #i.2) ∧ (Execute( a.2, id.2 ) @ #j.2)
      ∧
       (¬(a.2 = SpecialReq)) ∧
       (¬(a.2 = NormalReq)) ∧
       (∀ a.3 b. (x.1 = <a.3, b>) ⇒ ⊥) ∧
       (((z = x.1) ∨ (z = y.1)))) ∨
     (<x.1, y.1> = <x, y>))) ∧
  (∀ a.1 #i.1. (Corrupted( a.1 ) @ #i.1) ⇒ ((a.1 = x) ∨ (a.1 = y))) ∧
  (∀ x.1 a.1 id.1 #i.1 #j.1.
