theory CentralizedMonitor

begin

// Function signature and definition of the equational theory E

functions: NormalReq/0, SpecialReq/0, extract/1, fst/1, pair/2, pk/1,
           sig/2, sk/1[private,constructor], snd/1, true/0, verify/3
equations:
    extract(sig(m, sk(i))) = m,
    fst(<x.1, x.2>) = x.1,
    snd(<x.1, x.2>) = x.2,
    verify(sig(m, sk(i)), m, pk(sk(i))) = true

heuristic: p

predicate: IsSpecial( a )<=>a = SpecialReq

predicate: IsNormal( a )<=>a = NormalReq

predicate: IsValid( a )<=>(a = SpecialReq) ∨ (a = NormalReq)

predicate: IsInvalid( a )<=>¬((a = SpecialReq) ∨ (a = NormalReq))

predicate: IsPair( m )<=>∃ a b. m = <a, b>

restriction one_role:
  "∀ x r_1 r_2 #i #j.
    ((Insert( <'roles', x, r_1>, true ) @ #i) ∧
     (Insert( <'roles', x, r_2>, true ) @ #j)) ⇒
    ((#i = #j) ∧ (r_1 = r_2))"
  // safety formula

  /*
  expanded formula:
  "∀ x r_1 r_2 #i #j.
    ((Insert( <'roles', x, r_1>, true ) @ #i) ∧
     (Insert( <'roles', x, r_2>, true ) @ #j)) ⇒
    ((#i = #j) ∧ (r_1 = r_2))"
  */

rule (modulo E) Init[color=#ffffff, process="!", issapicrule,
                     role='Process']:
   [ ] --[ Init( ) ]-> [ State_( ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) p_0_[color=#ffffff, process="!", issapicrule,
                     role='Process']:
   [ State_( ) ] --> [ !Semistate_1( ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) p_1_[color=#ffffff, process="!", issapicrule,
                     role='Process']:
   [ !Semistate_1( ) ] --> [ State_1( ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) P_0_1[color=#ffffff, process="P();", issapicrule,
                      role='Process']:
   [ State_1( ) ] --> [ State_11( ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) p_0_11[color=#6c8040, process="|", issapicrule,
                       role='P']:
   [ State_11( ) ] --> [ State_111( ), State_112( ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) p_0_111[color=#6c8040, process="|", issapicrule,
                        role='P']:
   [ State_111( ) ] --> [ State_1111( ), State_1112( ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) p_0_1111[color=#6c8040, process="|", issapicrule,
                         role='P']:
   [ State_1111( ) ] --> [ State_11111( ), State_11112( ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) inx_0_11111[color=#6c8040, process="in($x.1);",
                            issapicrule, role='P']:
   [ State_11111( ), In( $x.1 ) ] --> [ State_111111( $x.1 ) ]

  /*
  rule (modulo AC) inx_0_11111[color=#6c8040, process="in($x.1);",
                               issapicrule, role='P']:
     [ State_11111( ), In( $x ) ] --> [ State_111111( $x ) ]
  */

rule (modulo E) D_0_111111[color=#6c8040, process="D();", issapicrule,
                           role='P']:
   [ State_111111( $x.1 ) ] --> [ State_1111111( $x.1 ) ]

  /*
  rule (modulo AC) D_0_111111[color=#6c8040, process="D();", issapicrule,
                              role='P']:
     [ State_111111( $x ) ] --> [ State_1111111( $x ) ]
  */

rule (modulo E) insertrolesxDtrue_0_1111111[color=#408048,
                                            process="insert <'roles', $x.1, 'D'>,true;", issapicrule,
                                            role='P_D']:
   [ State_1111111( $x.1 ) ]
  --[ Insert( <'roles', $x.1, 'D'>, true ) ]->
   [ State_11111111( $x.1 ) ]

  /*
  rule (modulo AC) insertrolesxDtrue_0_1111111[color=#408048,
                                               process="insert <'roles', $x.1, 'D'>,true;", issapicrule,
                                               role='P_D']:
     [ State_1111111( $x ) ]
    --[ Insert( <'roles', $x, 'D'>, true ) ]->
     [ State_11111111( $x ) ]
  */

rule (modulo E) outpkskx_0_11111111[color=#408048,
                                    process="out(pk(sk($x.1)));", issapicrule, role='P_D']:
   [ State_11111111( $x.1 ) ]
  -->
   [ State_111111111( $x.1 ), Out( pk(sk($x.1)) ) ]

  /*
  rule (modulo AC) outpkskx_0_11111111[color=#408048,
                                       process="out(pk(sk($x.1)));", issapicrule, role='P_D']:
     [ State_11111111( $x ) ] --> [ State_111111111( $x ), Out( pk(sk($x)) ) ]
  */

rule (modulo E) ina_0_111111111[color=#408048, process="in(a.1);",
                                issapicrule, role='P_D']:
   [ State_111111111( $x.1 ), In( a.1 ) ]
  -->
   [ State_1111111111( $x.1, a.1 ) ]

  /*
  rule (modulo AC) ina_0_111111111[color=#408048, process="in(a.1);",
                                   issapicrule, role='P_D']:
     [ State_111111111( $x ), In( a ) ] --> [ State_1111111111( $x, a ) ]
  */

restriction Restr_ifIsNormala_0_1111111111_1:
  "∀ x #NOW.
    (Restr_ifIsNormala_0_1111111111_1( x ) @ #NOW) ⇒ (x = NormalReq)"
  // safety formula

  /*
  expanded formula:
  "∀ x #NOW.
    (Restr_ifIsNormala_0_1111111111_1( x ) @ #NOW) ⇒ (x = NormalReq)"
  */

rule (modulo E) ifIsNormala_0_1111111111[color=#408048,
                                         process="if IsNormal( a.1 )", issapicrule, role='P_D']:
   [ State_1111111111( $x.1, a.1 ) ]
  --[ Restr_ifIsNormala_0_1111111111_1( a.1 ) ]->
   [ State_11111111111( $x.1, a.1 ) ]

  /*
  rule (modulo AC) ifIsNormala_0_1111111111[color=#408048,
                                            process="if IsNormal( a.1 )", issapicrule, role='P_D']:
     [ State_1111111111( $x, a ) ]
    --[ Restr_ifIsNormala_0_1111111111_1( a ) ]->
     [ State_11111111111( $x, a ) ]
  */

