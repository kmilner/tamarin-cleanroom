  */

rule (modulo E) outDoasigDoaskx_0_11111111111[color=#408048,
                                              process="out(<<'Do', a.1>, sig(<'Do', a.1>, sk($x.1))>);",
                                              issapicrule, role='P_D']:
   [ State_11111111111( $x.1, a.1 ) ]
  -->
   [
   State_111111111111( $x.1, a.1 ),
   Out( <<'Do', a.1>, sig(<'Do', a.1>, sk($x.1))> )
   ]

  /*
