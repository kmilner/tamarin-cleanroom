       (((z = x.1) ∨ (z = y.1)))) ∨
     (<x.1, y.1> = <x, y>))) ∧
  (∀ x.1 a.1 id.1 #i.1 #j.1.
    (Log( x.1, a.1, id.1 ) @ #i.1) ∧ (Execute( a.1, id.1 ) @ #j.1)
   ⇒
    ((a.1 = SpecialReq) ∨ (a.1 = NormalReq) ∨ (∃ a.2 b. (x.1 = <a.2, b>))))"
*/
by sorry



end
