{"html":"<br/>\n<h2>Fact Symbols with Injective Instances</h2><br/>\n<p class=\"monospace rules\">None</p><br/>\n<h2>Multiset Rewriting Rules</h2><br/>\n<p class=\"monospace rules\"><span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) isend:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> K( x ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> In( x ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) irecv:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out( x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--&gt;</span> <span class=\"hl_operator\">[</span> !KD( x ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) Init[color=#ffffff, process=&quot;!&quot;,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;issapicrule, role=&#39;Process&#39;]:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> Init( ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> State_( ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) p_0_[color=#ffffff, process=&quot;!&quot;,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;issapicrule, role=&#39;Process&#39;]:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> State_( ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--&gt;</span> <span class=\"hl_operator\">[</span> !Semistate_1( ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) p_1_[color=#ffffff, process=&quot;!&quot;,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;issapicrule, role=&#39;Process&#39;]:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !Semistate_1( ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--&gt;</span> <span class=\"hl_operator\">[</span> State_1( ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) newk_0_1[color=#ffffff,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;process=&quot;new ~k.1;&quot;, issapicrule,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;role=&#39;Process&#39;]:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> State_1( ), Fr( ~k.1 ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--&gt;</span> <span class=\"hl_operator\">[</span> State_11( ~k.1 ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/*<br/>\n&nbsp;&nbsp;<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) newk_0_1[color=#ffffff,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;process=&quot;new ~k.1;&quot;, issapicrule,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;role=&#39;Process&#39;]:<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> State_1( ), Fr( ~k ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--&gt;</span> <span class=\"hl_operator\">[</span> State_11( ~k ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;*/</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) newid_0_11[color=#ffffff,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;process=&quot;new ~id.1;&quot;, issapicrule,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;role=&#39;Process&#39;]:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> State_11( ~k.1 ), Fr( ~id.1 ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> State_111( ~id.1, ~k.1 ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/*<br/>\n&nbsp;&nbsp;<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) newid_0_11[color=#ffffff,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;process=&quot;new ~id.1;&quot;, issapicrule,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;role=&#39;Process&#39;]:<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> State_11( ~k ), Fr( ~id ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--&gt;</span> <span class=\"hl_operator\">[</span> State_111( ~id, ~k ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;*/</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) p_0_111[color=#ffffff, process=&quot;!&quot;,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;issapicrule, role=&#39;Process&#39;]:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> State_111( ~id.1, ~k.1 ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !Semistate_1111( ~id.1, ~k.1 ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/*<br/>\n&nbsp;&nbsp;<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) p_0_111[color=#ffffff, process=&quot;!&quot;,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;issapicrule, role=&#39;Process&#39;]:<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> State_111( ~id, ~k ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--&gt;</span> <span class=\"hl_operator\">[</span> !Semistate_1111( ~id, ~k ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;*/</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) p_1_111[color=#ffffff, process=&quot;!&quot;,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;issapicrule, role=&#39;Process&#39;]:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !Semistate_1111( ~id.1, ~k.1 ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> State_1111( ~id.1, ~k.1 ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/*<br/>\n&nbsp;&nbsp;<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) p_1_111[color=#ffffff, process=&quot;!&quot;,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;issapicrule, role=&#39;Process&#39;]:<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !Semistate_1111( ~id, ~k ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--&gt;</span> <span class=\"hl_operator\">[</span> State_1111( ~id, ~k ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;*/</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) p_0_1111[color=#ffffff, process=&quot;|&quot;,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;issapicrule, role=&#39;Process&#39;]:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> State_1111( ~id.1, ~k.1 ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> State_11111( ~id.1, ~k.1 ), State_11112( ~id.1, ~k.1 ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/*<br/>\n&nbsp;&nbsp;<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) p_0_1111[color=#ffffff, process=&quot;|&quot;,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;issapicrule, role=&#39;Process&#39;]:<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> State_1111( ~id, ~k ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">--&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> State_11111( ~id, ~k ), State_11112( ~id, ~k ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;*/</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) Reader_0_11111[color=#ffffff,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;process=&quot;Reader();&quot;, issapicrule,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;role=&#39;Process&#39;]:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> State_11111( ~id.1, ~k.1 ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> State_111111( ~id.1, ~k.1 ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/*<br/>\n&nbsp;&nbsp;<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) Reader_0_11111[color=#ffffff,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;process=&quot;Reader();&quot;, issapicrule,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;role=&#39;Process&#39;]:<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> State_11111( ~id, ~k ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--&gt;</span> <span class=\"hl_operator\">[</span> State_111111( ~id, ~k ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;*/</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) newr_0_111111[color=#404480,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;process=&quot;new ~r1.1;&quot;, issapicrule,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;role=&#39;Reader&#39;]:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> State_111111( ~id.1, ~k.1 ), Fr( ~r1.1 ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> State_1111111( ~id.1, ~k.1, ~r1.1 ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/*<br/>\n&nbsp;&nbsp;<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) newr_0_111111[color=#404480,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;process=&quot;new ~r1.1;&quot;, issapicrule,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;role=&#39;Reader&#39;]:<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> State_111111( ~id, ~k ), Fr( ~r1 ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">--&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> State_1111111( ~id, ~k, ~r1 ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;*/</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) eventChallengerReader_0_1111111[color=#404480,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;process=&quot;event Challenge( ~r1.1, &#39;Reader&#39; );&quot;,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;issapicrule, role=&#39;Reader&#39;]:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> State_1111111( ~id.1, ~k.1, ~r1.1 ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> Challenge( ~r1.1, &#39;Reader&#39; ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> State_11111111( ~id.1, ~k.1, ~r1.1 ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/*<br/>\n&nbsp;&nbsp;<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) eventChallengerReader_0_1111111[color=#404480,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp