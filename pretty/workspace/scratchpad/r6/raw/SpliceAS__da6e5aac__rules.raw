{"html":"<br/>\n<h2>Fact Symbols with Injective Instances</h2><br/>\n<p class=\"monospace rules\">None</p><br/>\n<h2>Multiset Rewriting Rules</h2><br/>\n<p class=\"monospace rules\"><span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) isend:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> K( x ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> In( x ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) irecv:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out( x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--&gt;</span> <span class=\"hl_operator\">[</span> !KD( x ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) Register_pk:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Fr( ~ltk ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> Register( $U, ~ltk ), OnlyOnce( $U ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !Ltk( $U, ~ltk ), !Pk( $U, pk(~ltk) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) Get_pk:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !Pk( $U, pubkey ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--&gt;</span> <span class=\"hl_operator\">[</span> Out( pubkey ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) Reveal_ltk:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !Ltk( $U, ~ltk ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> Reveal( $U ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> Out( ~ltk ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) C_to_AS:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !Ltk( $C, ~ltkC ), Fr( ~n1 ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;Out( &lt;&#39;Req&#39;, $C, $S, ~n1&gt; ),<br/>\n&nbsp;&nbsp;&nbsp;StateC1( $C, &#39;AS&#39;, $S, ~ltkC, ~n1 )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) AS_send_key:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;In( &lt;&#39;Req&#39;, x, y, n&gt; ), !Ltk( &#39;AS&#39;, ~ltkAS ),<br/>\n&nbsp;&nbsp;&nbsp;!Pk( y, pk(~ltkY) )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;Out( &lt;&#39;AS&#39;, x, n, pk(~ltkY), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;sign(&lt;&#39;Key&#39;, &#39;AS&#39;, x, n, pk(~ltkY)&gt;, ~ltkAS)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&gt;<br/>\n&nbsp;&nbsp;&nbsp;)<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) C_to_S:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;In( &lt;&#39;AS&#39;, $C, ~n1, pkS, <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;sign(&lt;&#39;Key&#39;, &#39;AS&#39;, $C, ~n1, pkS&gt;, ~ltkAS)&gt;<br/>\n&nbsp;&nbsp;&nbsp;),<br/>\n&nbsp;&nbsp;&nbsp;StateC1( $C, &#39;AS&#39;, $S, ~ltkC, ~n1 ),<br/>\n&nbsp;&nbsp;&nbsp;!Pk( &#39;AS&#39;, pk(~ltkAS) ), !Ltk( $C, ~ltkC ), Fr( ~t ),<br/>\n&nbsp;&nbsp;&nbsp;Fr( ~l ), Fr( ~n2 )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span><br/>\n&nbsp;&nbsp;Secret( $C, $S, ~n2 ),<br/>\n&nbsp;&nbsp;Running_A( $C, $S, &lt;&#39;C&#39;, &#39;S&#39;, ~n2&gt; )<br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;Out( &lt;$C, $S, ~t, ~l, aenc(&lt;&#39;4&#39;, ~n2&gt;, pkS), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;sign(&lt;&#39;3&#39;, $C, ~t, ~l, <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;aenc(&lt;&#39;4&#39;, ~n2&gt;, pkS)&gt;,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;~ltkC)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&gt;<br/>\n&nbsp;&nbsp;&nbsp;),<br/>\n&nbsp;&nbsp;&nbsp;StateC2( $C, &#39;AS&#39;, $S, ~ltkC, ~n1, ~n2, ~t, ~l, pkS )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) S_to_AS:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;In( &lt;c, $S, t, l, aenc(&lt;&#39;4&#39;, n2&gt;, pk(~ltkS)), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;sign(&lt;&#39;3&#39;, c, t, l, <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;aenc(&lt;&#39;4&#39;, n2&gt;, pk(~ltkS))&gt;,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;ltkC)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&gt;<br/>\n&nbsp;&nbsp;&nbsp;),<br/>\n&nbsp;&nbsp;&nbsp;!Ltk( $S, ~ltkS ), Fr( ~n3 )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;Out( &lt;&#39;Req&#39;, $S, c, ~n3&gt; ),<br/>\n&nbsp;&nbsp;&nbsp;StateS( c, &#39;AS&#39;, $S, ~ltkS, t, l, n2, ltkC, ~n3 )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) S_to_C:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;In( &lt;AS, $S, ~n3, pk(ltkC), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;sign(&lt;&#39;Key&#39;, AS, $S, ~n3, pk(ltkC)&gt;, ~ltkAS)&gt;<br/>\n&nbsp;&nbsp;&nbsp;),<br/>\n&nbsp;&nbsp;&nbsp;StateS( c, AS, $S, ~ltkS, t, l, n2, ltkC, ~n3 ),<br/>\n&nbsp;&nbsp;&nbsp;!Pk( AS, pk(~ltkAS) ), !Ltk( $S, ~ltkS )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span><br/>\n&nbsp;&nbsp;Secret( c, $S, n2 ),<br/>\n&nbsp;&nbsp;Commit_B( c, $S, &lt;&#39;C&#39;, &#39;S&#39;, n2&gt; ),<br/>\n&nbsp;&nbsp;Running_B( c, $S, &lt;&#39;C&#39;, &#39;S&#39;, n2&gt; )<br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;Out( &lt;$S, c, aenc(&lt;&#39;5&#39;, $S, inc(n2)&gt;, pk(ltkC))<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&gt;<br/>\n&nbsp;&nbsp;&nbsp;)<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) C_from_S:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;In( &lt;$S, $C, aenc(&lt;&#39;5&#39;, $S, inc(~n2)&gt;, pk(~ltkC))<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&gt;<br/>\n&nbsp;&nbsp;&nbsp;),<br/>\n&nbsp;&nbsp;&nbsp;StateC2( $C, AS, $S, ~ltkC, ~n1, ~n2, ~t, ~l, pkS ),<br/>\n&nbsp;&nbsp;&nbsp;!Ltk( $C, ~ltkC )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> Commit_A( $C, $S, &lt;&#39;C&#39;, &#39;S&#39;, ~n2&gt; )<br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span></p><br/>\n<h2>Restrictions of the Set of Traces</h2><br/>\n<p class=\"monospace rules\"><span class=\"hl_keyword\">restriction</span> OnlyOnce:<br/>\n&nbsp;&nbsp;&quot;<span class=\"hl_operator\">∀ </span>A B #i #j<span class=\"hl_operator\">.</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span><span class=\"hl_operator\">(</span><span class=\"hl_operator\">(</span>OnlyOnce( A ) <span class=\"hl_operator\">@</span> #i<span class=\"hl_operator\">)</span> <span class=\"hl_operator\">∧</span> <span class=\"hl_operator\">(</span>OnlyOnce( B ) <span class=\"hl_operator\">@</span> #j<span class=\"hl_operator\">)</span><span class=\"hl_operator\">)</span> <span class=\"hl_operator\">∧</span> <span class=\"hl_operator\">(</span>A <span class=\"hl_operator\">=</span> B<span class=\"hl_operator\">)</span><span class=\"hl_operator\">)</span> <span class=\"hl_operator\">⇒</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span>#i <span class=\"hl_operator\">=</span> #j<span class=\"hl_operator\">)</span>&quot;<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">// safety formula</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/*<br/>\n&nbsp;&nbsp;expanded formula:<br/>\n&nbsp;&nbsp;&quot;<span class=\"hl_operator\">∀ </span>A B #i #j<span class=\"hl_operator\">.</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span><span class=\"hl_operator\">(</span><span class=\"hl_operator\">(</span>OnlyOnce( A ) <span class=\"hl_operator\">@</span> #i<span class=\"hl_operator\">)</span> <span class=\"hl_operator\">∧</span> <span class=\"hl_operator\">(</span>OnlyOnce( B ) <span class=\"hl_operator\">@</span> #j<span class=\"hl_operator\">)</span><span class=\"hl_operator\">)</span> <span class=\"hl_operator\">∧</span> <span class=\"hl_operator\">(</span>A <span class=\"hl_operator\">=</span> B<span class=\"hl_operator\">)</span><span class=\"hl_operator\">)</span> <span class=\"hl_operator\">⇒</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">(</span>#i <span class=\"hl_operator\">=</span> #j<span class=\"hl_operator\">)</span>&quot;<br/>\n&nbsp;&nbsp;*/</span></p><br/>\n","title":"Multiset rewriting rules and restrictions"}