{"html":"<h2>Signature</h2><br/>\n<p class=\"monospace rules\"><span class=\"hl_keyword\">functions:</span> adec/2, aenc/2, decp/2, encp/3, fst/1, h/1, pair/2,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;pk/1, sg/2, snd/1, ver/2, verzkp/4, zkp/3<br/>\n<span class=\"hl_keyword\">equations:</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;adec(aenc(x.1, pk(x.2)), x.2) <span class=\"hl_operator\">=</span> x.1,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;decp(encp(x, r, pk(sk)), sk) <span class=\"hl_operator\">=</span> x,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;fst(&lt;x.1, x.2&gt;) <span class=\"hl_operator\">=</span> x.1,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;snd(&lt;x.1, x.2&gt;) <span class=\"hl_operator\">=</span> x.2,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;ver(sg(m, sk), pk(sk)) <span class=\"hl_operator\">=</span> m</p><br/>\n<h2>Construction Rules</h2><br/>\n<p class=\"monospace rules\"><span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) c_adec:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( x ), !KU( x.1 ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> !KU( adec(x, x.1) ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( adec(x, x.1) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) c_aenc:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( x ), !KU( x.1 ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> !KU( aenc(x, x.1) ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( aenc(x, x.1) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) c_decp:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( x ), !KU( x.1 ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> !KU( decp(x, x.1) ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( decp(x, x.1) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) c_encp:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( x ), !KU( x.1 ), !KU( x.2 ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> !KU( encp(x, x.1, x.2) ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( encp(x, x.1, x.2) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) c_fst:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> !KU( fst(x) ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> !KU( fst(x) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) c_h:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> !KU( h(x) ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> !KU( h(x) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) c_pair:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( x ), !KU( x.1 ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> !KU( &lt;x, x.1&gt; ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( &lt;x, x.1&gt; ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) c_pk:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> !KU( pk(x) ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> !KU( pk(x) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) c_sg:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( x ), !KU( x.1 ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> !KU( sg(x, x.1) ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( sg(x, x.1) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) c_snd:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> !KU( snd(x) ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> !KU( snd(x) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) c_ver:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( x ), !KU( x.1 ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> !KU( ver(x, x.1) ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( ver(x, x.1) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) c_verzkp:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( x ), !KU( x.1 ), !KU( x.2 ), !KU( x.3 ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> !KU( verzkp(x, x.1, x.2, x.3) ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( verzkp(x, x.1, x.2, x.3) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) c_zkp:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( x ), !KU( x.1 ), !KU( x.2 ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> !KU( zkp(x, x.1, x.2) ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( zkp(x, x.1, x.2) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) coerce:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> !KU( x ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> !KU( x ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) pub:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> !KU( $x ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> !KU( $x ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) fresh:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Fr( ~x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> !KU( ~x ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> !KU( ~x ) <span class=\"hl_operator\">]</span></p><br/>\n<h2>Deconstruction Rules</h2><br/>\n<p class=\"monospace rules\"><span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) d_0_adec:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( aenc(x.1, pk(x.2)) ), !KU( x.2 ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--&gt;</span> <span class=\"hl_operator\">[</span> !KD( x.1 ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) d_0_decp:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( encp(x, r, pk(sk)) ), !KU( sk ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--&gt;</span> <span class=\"hl_operator\">[</span> !KD( x ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) d_0_fst:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( &lt;x.1, x.2&gt; ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--&gt;</span> <span class=\"hl_operator\">[</span> !KD( x.1 ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) d_0_snd:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( &lt;x.1, x.2&gt; ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--&gt;</span> <span class=\"hl_operator\">[</span> !KD( x.2 ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) d_0_ver:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( sg(m, sk) ), !KU( pk(sk) ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--&gt;</span> <span class=\"hl_operator\">[</span> !KD( m ) <span class=\"hl_operator\">]</span></p><br/>\n","title":"Message theory"}