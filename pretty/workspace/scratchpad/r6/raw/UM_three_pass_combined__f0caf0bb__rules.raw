nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z     = z.47<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;3. ~ex   = ~ex.435<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Y     = x.863^x.864<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z     = x.863^(~ex.435*x.864)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;4. ~ex   = ~ex.436<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Y     = x.865^inv((~ex.436*x.866))<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z     = x.865^inv(x.866)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;5. ~ex   = ~ex.436<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Y     = x.865^(x.866*inv(~ex.436))<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z     = x.865^x.866<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;6. ~ex   = ~ex.437<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Y     = x.866^(x.867*inv((~ex.437*x.868)))<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z     = x.866^(x.867*inv(x.868))<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;7. Y     = DH_neutral<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z     = DH_neutral<br/>\n&nbsp;&nbsp;*/</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) I_Expire:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> I_Comp( sid ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> Expire( sid ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) R_Activate:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Fr( ~ey ), In( X ), !Ltk( $B, ~eb ), !Pk( $A, &#39;g&#39;^~ea ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span><br/>\n&nbsp;&nbsp;Activate( &lt;&