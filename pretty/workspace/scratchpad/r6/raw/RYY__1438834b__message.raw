n><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) d_em:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;!KD( pmult((x.2*inv((x.3*x.4))), x.5) ),<br/>\n&nbsp;&nbsp;&nbsp;!KD( pmult((x.4*inv((x.2*x.6))), x.7) )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( em(x.5, x.7)^inv((x.3*x.6)) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) d_em:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;!KD( pmult((x.4*x.6*inv((x.2*x.7))), x.8) ),<br/>\n&nbsp;&nbsp;&nbsp;!KD( pmult((x.2*x.3*inv(x.4)), x.5) )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( em(x.5, x.8)^(x.3*x.6*inv(x.7)) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) d_em:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;!KD( pmult((x.2*inv((x.3*x.4))), x.5) ),<br/>\n&nbsp;&nbsp;&nbsp;!KD( pmult((x.4*x.6*inv((x.2*x.7))), x.8) )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( em(x.5, x.8)^(x.6*inv((x.3*x.7))) ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) d_em:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;!KD( pmult((x.2*x.3*inv((x.4*x.5))), x.6) ),<br/>\n&nbsp;&nbsp;&nbsp;!KD( pmult((x.5*x.7*inv((x.2*x.8))), x.9) )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KD( em(x.6, x.9)^(x.3*x.7*inv((x.4*x.8))) ) <span class=\"hl_operator\">]</span></p><br/>\n","title":"Message theory"}