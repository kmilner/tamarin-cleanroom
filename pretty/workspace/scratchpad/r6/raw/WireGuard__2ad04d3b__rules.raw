{"html":"<br/>\n<h2>Fact Symbols with Injective Instances</h2><br/>\n<p class=\"monospace rules\">L_State(id,.)</p><br/>\n<h2>Multiset Rewriting Rules</h2><br/>\n<p class=\"monospace rules\"><span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) isend:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !KU( x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> K( x ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> In( x ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) irecv:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out( x ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--&gt;</span> <span class=\"hl_operator\">[</span> !KD( x ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<br/>\n<br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) AgentKeyGen:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Fr( ~ltk ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> DHKey( ~ltk ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !F_AgentKey( ~ltk ), Out( &#39;g&#39;^~ltk ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) PSKKeyGen:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Fr( ~psk ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> PSKey( ~psk ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> !F_AgentPSK( ~psk ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) PSK_reveal:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !F_AgentPSK( k ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> Reveal_PSK( k ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> Out( k ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/* has exactly the trivial AC variant */</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) AgentKey_reveal:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !F_AgentKey( k ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> Reveal_AK( &#39;g&#39;^k ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out( k ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/*<br/>\n&nbsp;&nbsp;<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) AgentKey_reveal:<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !F_AgentKey( k ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> Reveal_AK( z ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> Out( k ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_keyword\">variants</span> (<span class=\"hl_keyword\">modulo</span> AC)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;1. k     = k.3<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z     = &#39;g&#39;^k.3<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;2. k     = one<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z     = &#39;g&#39;<br/>\n&nbsp;&nbsp;*/</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) EphKey_reveal:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !EphKeytoReveal( k ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--[</span> Reveal_EphK( &#39;g&#39;^k ) <span class=\"hl_operator\">]-&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> Out( k ) <span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/*<br/>\n&nbsp;&nbsp;<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) EphKey_reveal:<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span> !EphKeytoReveal( k ) <span class=\"hl_operator\">]</span> <span class=\"hl_operator\">--[</span> Reveal_EphK( z ) <span class=\"hl_operator\">]-&gt;</span> <span class=\"hl_operator\">[</span> Out( k ) <span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_keyword\">variants</span> (<span class=\"hl_keyword\">modulo</span> AC)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;1. k     = k.3<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z     = &#39;g&#39;^k.3<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;2. k     = one<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;z     = &#39;g&#39;<br/>\n&nbsp;&nbsp;*/</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) AddPublicKey:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;!F_AgentKey( ~ltkA ), !F_AgentKey( ~ltkB ), !F_AgentPSK( ~psk ),<br/>\n&nbsp;&nbsp;&nbsp;Fr( ~id )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;L_State( ~id, &#39;no_message_state&#39; ),<br/>\n&nbsp;&nbsp;&nbsp;!F_StateInvariants( ~id, ~psk, ~ltkA, &#39;g&#39;^~ltkB,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&#39;g&#39;^~ltkB^~ltkA<br/>\n&nbsp;&nbsp;&nbsp;)<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n<br/>\n&nbsp;&nbsp;<span class=\"hl_comment\">/*<br/>\n&nbsp;&nbsp;<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> AC) AddPublicKey:<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;!F_AgentKey( ~ltkA ), !F_AgentKey( ~ltkB ), !F_AgentPSK( ~psk ),<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Fr( ~id )<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">--&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;L_State( ~id, &#39;no_message_state&#39; ),<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;!F_StateInvariants( ~id, ~psk, ~ltkA, &#39;g&#39;^~ltkB,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&#39;g&#39;^(~ltkA*~ltkB)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;*/</span><br/>\n<span class=\"hl_keyword\">rule</span> (<span class=\"hl_keyword\">modulo</span> E) Handshake_Init:<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;L_State( ~id, anything ),<br/>\n&nbsp;&nbsp;&nbsp;!F_StateInvariants( ~id, ~psk, ~ltkI, pkR, sisr ), Fr( ~sidI ),<br/>\n&nbsp;&nbsp;&nbsp;Fr( ~ekI ), Fr( ~pkISurrogate )<br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">]</span><br/>\n&nbsp;&nbsp;<span class=\"hl_operator\">--&gt;</span><br/>\n&nbsp;&nbsp;&nbsp;<span class=\"hl_operator\">[</span><br/>\n&nbsp;&nbsp;&nbsp;L_State( ~id,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;&#39;init&#39;, ~sidI, ~ekI, <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;h(&#39;noise&#39;), &#39;g&#39;^~ekI, &#39;1&#39;&gt;), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;pkR^~ekI, &#39;1&#39;&gt;), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;sisr, &#39;1&#39;&gt;), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;h(&#39;noise&#39;), &#39;g&#39;^~ekI, &#39;1&#39;&gt;), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;pkR^~ekI, &#39;1&#39;&gt;), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;sisr, &#39;2&#39;&gt;), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;h(&#39;noise&#39;), &#39;id&#39;, pkR, &#39;g&#39;^~ekI<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&gt;), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;aead(h(&lt;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;h(&#39;noise&#39;), &#39;g&#39;^~ekI, &#39;1&#39;&gt;), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;pkR^~ekI, &#39;2&#39;&gt;),<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;&#39;g&#39;^~ltkI, ~pkISurrogate&gt;,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;h(&#39;noise&#39;), &#39;id&#39;, pkR, &#39;g&#39;^~ekI&gt;))<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&gt;), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;aead(h(&lt;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;h(&#39;noise&#39;), &#39;g&#39;^~ekI, &#39;1&#39;&gt;), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;pkR^~ekI, &#39;1&#39;&gt;), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;sisr, &#39;2&#39;&gt;),<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;$ts,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;h(&#39;noise&#39;), &#39;id&#39;, pkR, &#39;g&#39;^~ekI<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&gt;), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;aead(h(&lt;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;h(&#39;noise&#39;), &#39;g&#39;^~ekI, &#39;1&#39;&gt;), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;pkR^~ekI, &#39;2&#39;&gt;),<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;&#39;g&#39;^~ltkI, ~pkISurrogate&gt;,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;h(&#39;noise&#39;), &#39;id&#39;, pkR, &#39;g&#39;^~ekI&gt;))<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&gt;))<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&gt;)<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&gt;<br/>\n&nbsp;&nbsp;&nbsp;),<br/>\n&nbsp;&nbsp;&nbsp;F_SolveInit( ~id, ~psk,<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;&#39;init&#39;, ~sidI, ~ekI, <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;h(&#39;noise&#39;), &#39;g&#39;^~ekI, &#39;1&#39;&gt;), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;pkR^~ekI, &#39;1&#39;&gt;), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;sisr, &#39;1&#39;&gt;), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;h(&#39;noise&#39;), &#39;g&#39;^~ekI, &#39;1&#39;&gt;), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;pkR^~ekI, &#39;1&#39;&gt;), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;sisr, &#39;2&#39;&gt;), <br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;<br/>\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;h(&lt;<br/>\n&nbsp;&nbsp