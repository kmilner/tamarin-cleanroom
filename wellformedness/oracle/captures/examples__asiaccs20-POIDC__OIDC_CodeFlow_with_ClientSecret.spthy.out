theory OIDC_CodeFlow_with_ClientSecret

begin

// Function signature and definition of the equational theory E

functions: e1/1[private,constructor], e2/1[private,constructor],
           e3/1[private,constructor], false/0, fst/1, mangle/2, pair/2, pk/1,
           sign/3, snd/1, true/0
equations:
    e1(sign(x, y, z)) = x,
    e2(sign(x, y, z)) = y,
    e3(sign(x, y, z)) = z,
    fst(<x.1, x.2>) = x.1,
    mangle(sign(m, r1, sk), r2) = sign(m, r2, sk),
    snd(<x.1, x.2>) = x.2

rule (modulo E) reSign:
   [ In( <sk1, r1> ), In( sign(m, r2, sk2) ) ]
  -->
   [ Out( sign(m, r1, sk1) ) ]

  /* has exactly the trivial AC variant */

