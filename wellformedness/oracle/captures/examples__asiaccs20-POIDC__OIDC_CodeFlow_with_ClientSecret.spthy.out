            $redirect_uri_RP, $authEP_uri_IdP, $tokenEP_uri_IdP, code,
            ~client_ID_TLS_IdP
   ),
   !Pk( $IdP, pk_idp )
   ]
  --[
  Finish( ), RP_gets_IDToken( $RP, userID, $IdP ),
  Verified( id_token_sig, e1(id_token_sig), pk(e3(id_token_sig)),
            <'idToken', <'iss', $IdP>, <'sub', userID>, 'aud', $client_id>, pk_idp,
            true
  )
  ]->
   [ ]

