  --[ ChanOut_IR_PS( $A, $B, m ) ]->
   [ Out( <$A, $B, m> ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) ChanIn_IR_PS:
   [ In( <$A, $B, m> ) ]
  --[ ChanIn_IR_PS( $A, $B, m ) ]->
   [ In_IR_PS( $A, $B, m ) ]

  /* has exactly the trivial AC variant */

restriction Chan_R_PS:
  "∀ A B m #i.
    (Send_R_PS( A, B, m ) @ #i) ⇒ (∃ #j. Receive_R_PS( A, B, m ) @ #j)"

  /*
  expanded formula:
  "∀ A B m #i.
    (Send_R_PS( A, B, m ) @ #i) ⇒ (∃ #j. Receive_R_PS( A, B, m ) @ #j)"
  */

rule (modulo E) fakeEvidence:
   [ In( <ballot, evidence> ) ] --[ Evidence( ballot, evidence ) ]-> [ ]

  /* has exactly the trivial AC variant */

rule (modulo E) publickeyinfrastructure:
   [ Fr( ~skX ) ]
  --[ LongtermKey( $X, ~skX ) ]->
   [ !Ltk( $X, ~skX ), !Pk( $X, pk(~skX) ), Out( pk(~skX) ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Setup:
   [ !Ltk( 'P', ~skP ) ]
  --[
  Setup( ), Voter( 'H' ), Server( 'S' ), Honest( 'S' ),
  BB_pkP( 'BB', <'pkPs', pk(~skP)> )
  ]->
   [
   AgSt_H0( 'H', <'BB', 'P', $v> ), AgSt_BB0( 'BB', 'S' ),
   AgSt_P0( 'P', <'S', ~skP> ), AgSt_S0( 'S', 'empty' ),
   Out_A( 'BB', <'pkPs', pk(~skP)> )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) H_1:
   [ AgSt_H0( $H, <$BB, $P, $v> ) ]
  --[ Vote( $H, $v ), Ballot( $H, <$v, $H> ), Send_R_HP( $H, $P, <$v, $H> )
  ]->
   [ AgSt_H1( $H, <$BB, $P, $v> ), Out_IR_HP( $H, $P, <$v, $H> ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) P:
   [ AgSt_P0( $P, <$S, ~skP> ), In_IR_HP( $H, $P, <$v, $H> ) ]
  --[
  Receive_R_HP( $H, $P, <$v, $H> ),
  Evidence( <$v, $H>, sg(<$v, $H>, ~skP) ), Send_R_PS( $P, $S, <$v, $H> )
  ]->
   [ Out_IR_PS( $P, $S, <$v, $H> ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) S_1:
   [ AgSt_S0( $S, 'empty' ), In_IR_PS( $P, $S, <$v, $H> ) ]
  --[ Receive_R_PS( $P, $S, <$v, $H> ) ]->
   [ Out_A( $S, <'bs', $v, $H> ), Out_A( $S, <'vs', $v> ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) BB:
   [ AgSt_BB0( $BB, $S ), In_A( $S, <'bs', bs> ), In_A( $S, <'vs', vs> ) ]
  --[ BB_recorded( $BB, <'bs', bs> ), BB_tallied( $BB, <'vs', vs> ), End( )
