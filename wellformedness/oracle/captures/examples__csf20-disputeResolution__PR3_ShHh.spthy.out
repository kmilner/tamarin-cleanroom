theory PR3_ShHh

begin

// Function signature and definition of the equational theory E

builtins: multiset
functions: fst/1, pair/2, pk/1, sg/2, sign/2, snd/1, true/0, ver/2,
           verify/3
equations:
    fst(<x.1, x.2>) = x.1,
    snd(<x.1, x.2>) = x.2,
    ver(sg(m, sk), pk(sk)) = m,
    verify(sign(x.1, x.2), x.1, pk(x.2)) = true

rule (modulo E) ChanOut_A:
   [ Out_A( $A, x ) ]
  --[ ChanOut_A( $A, x ) ]->
   [ !Auth( $A, x ), Out( <$A, x> ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) ChanIn_A:
   [ !Auth( $A, x ) ] --[ ChanIn_A( $A, x ) ]-> [ In_A( $A, x ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) ChanOut_IR_HP:
   [ Out_IR_HP( $A, $B, m ) ]
  --[ ChanOut_IR_HP( $A, $B, m ) ]->
   [ Out( <$A, $B, m> ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) ChanIn_IR_HP:
   [ In( <$A, $B, m> ) ]
  --[ ChanIn_IR_HP( $A, $B, m ) ]->
   [ In_IR_HP( $A, $B, m ) ]

  /* has exactly the trivial AC variant */

restriction Chan_R_HP:
  "∀ A B m #i.
    (Send_R_HP( A, B, m ) @ #i) ⇒ (∃ #j. Receive_R_HP( A, B, m ) @ #j)"

  /*
  expanded formula:
  "∀ A B m #i.
    (Send_R_HP( A, B, m ) @ #i) ⇒ (∃ #j. Receive_R_HP( A, B, m ) @ #j)"
  */

