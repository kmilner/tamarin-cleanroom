rule (modulo E) Host_ReceiveCurlyK:
   [
   In_S( $PS, $AS, <curlyK(K_1), 'ret_TPM2_ActivateCredentials'> ),
   !Pk( 'Issuer', PkX(x, 'P2'), PkY(y, 'P2') ),
   Host_State_03( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)), Q_PD, Q_SD )
   ]
  --[ Received_CurlyK( $PS, $AS ), OnlyOnce( 'Host_ReceiveCurlyK' ) ]->
   [
   Out_S( $AS, $PS,
          <BSN('bottom'), BSN('bottom'), BSN('bottom'), 'TPM2_Commit'>
   ),
   Host_CurlyK1( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)), curlyK(K_1) ),
   Host_State_04( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)), Q_PD, Q_SD,
                  <PkX(x, 'P2'), PkY(y, 'P2'), curlyK(K_1), pk(KDF_EK(~TPM_EK_Seed))>
   )
   ]

  // loop breaker: [0]
  /* has exactly the trivial AC variant */

rule (modulo E) TPM2_Commit:
   [
   In_S( $AS, $PS,
         <BSN('bottom'), BSN('bottom'), BSN('bottom'), 'TPM2_Commit'>
   ),
   Fr( ~cv ), Fr( ~r_cv )
   ]
  --[ TPM2_Commited( $PS, $AS ), OnlyOnce( 'TPM2_Commit' ) ]->
   [
   Out_S( $PS, $AS, <E(~r_cv, 'P1'), Nonce(~cv), 'retTPM2_commit'> ),
   TPM_CV_E( $PS, Nonce(~cv), ~r_cv )
   ]

  // loop breaker: [0]
  /* has exactly the trivial AC variant */

rule (modulo E) Host_ReceiveEAndCV:
   [
   In_S( $PS, $AS, <E(r_cv, 'P1'), Nonce(cv), 'retTPM2_commit'> ),
   Host_State_04( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)),
                  <'DAA_public_data', multp(~f, 'P1')>, Q_SD, str
   )
   ]
  --[ Host_Created_p( $PS, $AS ), OnlyOnce( 'Host_ReceiveEAndCV' ) ]->
   [
   Out_S( $AS, $PS,
          <H_k_4('P1', multp(~f, 'P1'), E(r_cv, 'P1'), str), 'TPM2_Hash'>
   ),
   Host_cv( $PS, $AS, Nonce(cv) ),
   Host_State_05( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)),
                  <'DAA_public_data', multp(~f, 'P1')>, Q_SD
   )
   ]

  // loop breaker: [0]
  /* has exactly the trivial AC variant */

rule (modulo E) TPM2_Hash:
   [ In_S( $AS, $PS, <p, 'TPM2_Hash'> ), Fr( ~tkt ) ]
  --[ TPM2_Created_P_TPM( $PS, $AS ), OnlyOnce( 'TPM2_Hash' ) ]->
   [
   Out_S( $PS, $AS, <H_k_1(p), Nonce(~tkt), 'ret_TPM2_Hash'> ),
   TPM_tkt( $PS, Nonce(~tkt) )
   ]

  // loop breaker: [0]
  /* has exactly the trivial AC variant */

rule (modulo E) Host_Receive_P_TPM_TKT:
   [
   In_S( $PS, $AS, <H_k_1(p), Nonce(tkt), 'ret_TPM2_Hash'> ),
   Host_cv( $PS, $AS, Nonce(cv) )
   ]
  --[ Host_Received_P_TPM( $PS, $AS ), OnlyOnce( 'Host_Receive_P_TPM_TKT' )
  ]->
   [
   Out_S( $AS, $PS, <H_k_1(p), Nonce(tkt), Nonce(cv), 'TPM2_Sign'> ),
   Host_Store_P_TPM( $AS, H_k_1(p) )
   ]

  // loop breaker: [0]
  /* has exactly the trivial AC variant */

rule (modulo E) TPM2_Sign:
   [
   In_S( $AS, $PS, <p_tpm, ticket_host, cv1, 'TPM2_Sign'> ),
   TPM_tkt( $PS, ticket ), !TPM_DAA_SK( $PS, pk(KDF_EK(~TPM_EK_Seed)), ~f ),
   TPM_CV_E( $PS, cvval, ~r_cv ), Fr( ~n_J )
   ]
  --[
  TPM2_Signed_P_TPM( $PS, $AS ), Eq( cvval, cv1 ),
  Eq( ticket_host, ticket ), OnlyOnce( 'TPM2_Sign' )
  ]->
   [
   Out_S( $PS, $AS,
          <Nonce(~n_J), plus(~r_cv, multp(H_n_2(Nonce(~n_J), p_tpm), ~f)), 
           'ret_TPM2_Sign'>
   )
   ]

  // loop breaker: [0]
  /* has exactly the trivial AC variant */

rule (modulo E) Host_Receive_Signature_P_TPM:
   [
   In_S( $PS, $AS,
         <Nonce(n_J), plus(r_cv, multp(H_n_2(Nonce(n_J), p_tpm), f)), 
          'ret_TPM2_Sign'>
   ),
   Host_Store_P_TPM( $AS, p_tpm ),
   Host_CurlyK1( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)), curlyK(K_1) )
   ]
  --[
  Host_Received_Signed_P_TPM( $PS, $AS ),
  Running( pk(KDF_EK(~TPM_EK_Seed)), 'Issuer', curlyK(K_1) ), Alive( $AS ),
  Honest( $AS ), Honest( pk(KDF_EK(~TPM_EK_Seed)) ), Honest( 'Issuer' ),
  Role( 'Platform' ), OnlyOnce( 'Host_Receive_Signature_P_TPM' )
  ]->
   [
   Out( <curlyK(K_1), Nonce(n_J), H_n_2(Nonce(n_J), p_tpm), 
         plus(r_cv, multp(H_n_2(Nonce(n_J), p_tpm), f)), 
         'Issuer_SendChallengeResponse'>
   )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) Issuer_Verify_Challenge_Issue_Credentials:
   [
   In( <curlyK(K_rec), Nonce(n_J), H_n_2(n_J_1, p_tpm_1), 
        plus(r_cv, multp(v_1, f_1)), 'Issuer_SendChallengeResponse'>
   ),
   Issuer_State_01( 'Issuer', curlyK(K_1), pk(KDF_EK(TPM_EK_Seed)),
                    <'DAA_public_data', multp(f, 'P1')>
   ),
   !Pk( 'Issuer', PkX(~x, 'P2'), PkY(~y, 'P2') ), !Ltk( 'Issuer', ~x, ~y ),
   Fr( ~r ), Fr( ~l ), Fr( ~s_2 ), Fr( ~K_2 )
   ]
  --[
  Eq( curlyK(K_rec), curlyK(K_1) ),
  Eq( H_n_2(n_J_1, p_tpm_1),
      H_n_2(Nonce(n_J),
            H_k_1(H_k_4('P1', multp(f, 'P1'),
                        calcE(minus(multp(plus(r_cv, multp(v_1, f_1)), 'P1'),
                                    multp(H_n_2(n_J_1, p_tpm_1), multp(f, 'P1')))),
                        <PkX(~x, 'P2'), PkY(~y, 'P2'), curlyK(K_1), pk(KDF_EK(TPM_EK_Seed))>)))
  ),
  Commit( 'Issuer', pk(KDF_EK(TPM_EK_Seed)), curlyK(K_1) ),
  Running( 'Issuer', pk(KDF_EK(TPM_EK_Seed)),
           <multp(~r, 'P1'), multp(~y, multp(~r, 'P1')), 
            plus(multp(~x, multp(~r, 'P1')),
                 multp(multp(multp(~r, ~x), ~y), multp(f, 'P1'))), 
            multp(multp(~r, ~y), multp(f, 'P1'))>
  ),
  Alive( 'Issuer' ), Honest( 'Issuer' ), Honest( pk(KDF_EK(TPM_EK_Seed)) ),
  Issuer_VerifyChallengeIssueCredentials( 'Issuer', pk(KDF_EK(TPM_EK_Seed))
  ),
  OnlyOnce( 'Issuer_Verify_Challenge' )
  ]->
   [
   Out( <
         MAC(<
              len16(senc(curlyK(~K_2),
                         KDF_a(~s_2, 'STORAGE',
                               <'SHA256', H_SHA256(<'DAA_public_data', multp(f, 'P1')>)>))), 
              senc(curlyK(~K_2),
                   KDF_a(~s_2, 'STORAGE',
                         <'SHA256', H_SHA256(<'DAA_public_data', multp(f, 'P1')>)>)), 
              'SHA256', H_SHA256(<'DAA_public_data', multp(f, 'P1')>)>,
             KDF_a(~s_2, 'INTEGRITY', 'NULL')), 
         len16(senc(curlyK(~K_2),
                    KDF_a(~s_2, 'STORAGE',
                          <'SHA256', H_SHA256(<'DAA_public_data', multp(f, 'P1')>)>))), 
         senc(curlyK(~K_2),
              KDF_a(~s_2, 'STORAGE',
                    <'SHA256', H_SHA256(<'DAA_public_data', multp(f, 'P1')>)>)), 
         aenc(~s_2, pk(KDF_EK(TPM_EK_Seed))), 
         senc(<multp(~r, 'P1'), multp(~y, multp(~r, 'P1')), 
               plus(multp(~x, multp(~r, 'P1')),
                    multp(multp(multp(~r, ~x), ~y), multp(f, 'P1'))), 
               multp(multp(~r, ~y), multp(f, 'P1')), 
               H_n_8('P1', multp(f, 'P1'), RB(~l, 'P1'), RD(~l, multp(f, 'P1')),
                     multp(~r, 'P1'), multp(~y, multp(~r, 'P1')),
                     plus(multp(~x, multp(~r, 'P1')),
                          multp(multp(multp(~r, ~x), ~y), multp(f, 'P1'))),
                     multp(multp(~r, ~y), multp(f, 'P1'))), 
               plus(~l,
                    multp(multp(~y, ~r),
                          H_n_8('P1', multp(f, 'P1'), RB(~l, 'P1'), RD(~l, multp(f, 'P1')),
                                multp(~r, 'P1'), multp(~y, multp(~r, 'P1')),
                                plus(multp(~x, multp(~r, 'P1')),
                                     multp(multp(multp(~r, ~x), ~y), multp(f, 'P1'))),
                                multp(multp(~r, ~y), multp(f, 'P1')))))
              >,
              curlyK(~K_2)), 
         'Host_CompleteJoin'>
   )
   ]

  /*
  rule (modulo AC) Issuer_Verify_Challenge_Issue_Credentials:
     [
     In( <curlyK(K_rec), Nonce(n_J), H_n_2(n_J_1, p_tpm_1), 
          plus(r_cv, multp(v_1, f_1)), 'Issuer_SendChallengeResponse'>
     ),
     Issuer_State_01( 'Issuer', curlyK(K_1), pk(KDF_EK(TPM_EK_Seed)),
                      <'DAA_public_data', multp(f, 'P1')>
     ),
     !Pk( 'Issuer', PkX(~x, 'P2'), PkY(~y, 'P2') ), !Ltk( 'Issuer', ~x, ~y ),
     Fr( ~r ), Fr( ~l ), Fr( ~s_2 ), Fr( ~K_2 )
     ]
    --[
    Eq( curlyK(K_rec), curlyK(K_1) ),
    Eq( H_n_2(n_J_1, p_tpm_1),
        H_n_2(Nonce(n_J),
              H_k_1(H_k_4('P1', multp(f, 'P1'), z,
                          <PkX(~x, 'P2'), PkY(~y, 'P2'), curlyK(K_1), pk(KDF_EK(TPM_EK_Seed))>)))
    ),
    Commit( 'Issuer', pk(KDF_EK(TPM_EK_Seed)), curlyK(K_1) ),
    Running( 'Issuer', pk(KDF_EK(TPM_EK_Seed)),
             <multp(~r, 'P1'), multp(~y, multp(~r, 'P1')), 
              plus(multp(~x, multp(~r, 'P1')),
                   multp(multp(multp(~r, ~x), ~y), multp(f, 'P1'))), 
              multp(multp(~r, ~y), multp(f, 'P1'))>
    ),
    Alive( 'Issuer' ), Honest( 'Issuer' ), Honest( pk(KDF_EK(TPM_EK_Seed)) ),
    Issuer_VerifyChallengeIssueCredentials( 'Issuer', pk(KDF_EK(TPM_EK_Seed))
    ),
    OnlyOnce( 'Issuer_Verify_Challenge' )
    ]->
     [
     Out( <
           MAC(<
                len16(senc(curlyK(~K_2),
                           KDF_a(~s_2, 'STORAGE',
                                 <'SHA256', H_SHA256(<'DAA_public_data', multp(f, 'P1')>)>))), 
                senc(curlyK(~K_2),
                     KDF_a(~s_2, 'STORAGE',
                           <'SHA256', H_SHA256(<'DAA_public_data', multp(f, 'P1')>)>)), 
                'SHA256', H_SHA256(<'DAA_public_data', multp(f, 'P1')>)>,
               KDF_a(~s_2, 'INTEGRITY', 'NULL')), 
           len16(senc(curlyK(~K_2),
                      KDF_a(~s_2, 'STORAGE',
                            <'SHA256', H_SHA256(<'DAA_public_data', multp(f, 'P1')>)>))), 
           senc(curlyK(~K_2),
                KDF_a(~s_2, 'STORAGE',
                      <'SHA256', H_SHA256(<'DAA_public_data', multp(f, 'P1')>)>)), 
           aenc(~s_2, pk(KDF_EK(TPM_EK_Seed))), 
           senc(<multp(~r, 'P1'), multp(~y, multp(~r, 'P1')), 
                 plus(multp(~x, multp(~r, 'P1')),
                      multp(multp(multp(~r, ~x), ~y), multp(f, 'P1'))), 
                 multp(multp(~r, ~y), multp(f, 'P1')), 
                 H_n_8('P1', multp(f, 'P1'), RB(~l, 'P1'), RD(~l, multp(f, 'P1')),
                       multp(~r, 'P1'), multp(~y, multp(~r, 'P1')),
                       plus(multp(~x, multp(~r, 'P1')),
                            multp(multp(multp(~r, ~x), ~y), multp(f, 'P1'))),
                       multp(multp(~r, ~y), multp(f, 'P1'))), 
                 plus(~l,
                      multp(multp(~y, ~r),
                            H_n_8('P1', multp(f, 'P1'), RB(~l, 'P1'), RD(~l, multp(f, 'P1')),
                                  multp(~r, 'P1'), multp(~y, multp(~r, 'P1')),
                                  plus(multp(~x, multp(~r, 'P1')),
                                       multp(multp(multp(~r, ~x), ~y), multp(f, 'P1'))),
                                  multp(multp(~r, ~y), multp(f, 'P1')))))
                >,
                curlyK(~K_2)), 
           'Host_CompleteJoin'>
     )
     ]
    variants (modulo AC)
    1. f     = f.35
       f_1   = f_1.36
       n_J_1 = n_J_1.38
       p_tpm_1
             = p_tpm_1.39
       r_cv  = r_cv.40
       v_1   = v_1.41
       z     = calcE(minus(multp(plus(r_cv.40, multp(v_1.41, f_1.36)), 'P1'),
                           multp(H_n_2(n_J_1.38, p_tpm_1.39), multp(f.35, 'P1'))))
    
    2. f     = f.224
       f_1   = f.224
       n_J_1 = n_J_1.227
       p_tpm_1
             = H_k_1(H_k_4('P1', x.435, E(r_cv.229, 'P1'), x.437))
       r_cv  = r_cv.229
       v_1   = H_n_2(n_J_1.227,
                     H_k_1(H_k_4('P1', x.435, E(r_cv.229, 'P1'), x.437)))
       z     = E(r_cv.229, 'P1')
  */

rule (modulo E) Host_Passthrough_2:
   [
   In( <curlyH, len16(curlyK_2_hat), curlyK_2_hat, 
        aenc(~s_2, pk(KDF_EK(~TPM_EK_Seed))), C_hat, 'Host_CompleteJoin'>
   ),
   Host_State_05( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)), Q_PD, Q_SD )
   ]
  --[
  Passthrough_ActivateCred2( $PS, $AS ), OnlyOnce( 'Host_Passthrough_2' )
  ]->
   [
   Out_S( $AS, $PS,
          <Q_SD, Q_PD, curlyH, len16(curlyK_2_hat), curlyK_2_hat, 
           aenc(~s_2, pk(KDF_EK(~TPM_EK_Seed))), 'TPM2_ActivateCredentials_2'>
   ),
   Host_State_06( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)), Q_PD, C_hat )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) TPM2_ActivateCredential_2:
   [
   In_S( $AS, $PS,
         <Q_SD, <'DAA_public_data', multp(~f, 'P1')>, curlyH, 
          len16(senc(curlyK(K_2), k_e)), senc(curlyK(K_2), k_e), 
          aenc(s_2, pk(KDF_EK(~TPM_EK_Seed))), 'TPM2_ActivateCredentials_2'>
   ),
   !TPM_AES_Key( $PS, aes_key ),
   !TPM_ENDORSEMENT_SK( $PS, e, pk(KDF_EK(~TPM_EK_Seed)) )
   ]
  --[
  Eq( MAC(<len16(senc(curlyK(K_2), k_e)), senc(curlyK(K_2), k_e), 
           'SHA256', H_SHA256(<'DAA_public_data', multp(~f, 'P1')>)>,
          KDF_a(s_2, 'INTEGRITY', 'NULL')),
      curlyH
  ),
  Eq( k_e,
      KDF_a(s_2, 'STORAGE',
            <'SHA256', H_SHA256(<'DAA_public_data', multp(~f, 'P1')>)>)
  ),
  CurlyK2_recomputed( $PS, $AS ), OnlyOnce( 'TPM2_ActivateCredential_2' )
  ]->
   [
   Out_S( $PS, $AS,
          <
           sdec(senc(curlyK(K_2), k_e),
                KDF_a(s_2, 'STORAGE',
                      <'SHA256', H_SHA256(<'DAA_public_data', multp(~f, 'P1')>)>)), 
           'ret_TPM2_ActivateCredentials_2'>
   )
   ]

  // loop breaker: [0]
