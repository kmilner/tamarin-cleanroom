           PointG1/2, QName/2, QPub/2, Q_K/1, RB/2, RD/2, accept/0, adec/2, aenc/2,
           calcE/1, calcE_S_cert/4, calcL_J_cert/4, calcRB/1, calcRD/1, certData/2,
           certify/1, curlyK/1, fst/1, len16/1, minus/2, multp/2, pair/2, pk/1,
           plus/2, publicData/1, sdec/2, senc/2, snd/1, verifyCre1/4, verifyCre2/5,
           verifyCre3/4, verifyCre4/5
equations:
    adec(aenc(x.1, pk(x.2)), x.2) = x.1,
    calcE(minus(multp(plus(r_cv,
                           multp(H_n_2(n_J, H_k_1(H_k_4(P1, Q, E(r_cv, P1), str))), f)),
                      P1),
                multp(H_n_2(n_J, H_k_1(H_k_4(P1, Q, E(r_cv, P1), str))), multp(f, P1))))
  = E(r_cv, P1),
    calcE_S_cert(plus(r_cv1,
                      multp(H_n_2(n_C, H_k_2(small_c, H_6(certData(certificationData, Qk_n)))),
                            f)),
                 multp(l, multp(y, multp(r, P1))),
                 H_n_2(n_C, H_k_2(small_c, H_6(certData(certificationData, Qk_n)))),
                 multp(l, multp(multp(r, y), multp(f, P1))))
  = E_S(r_cv1, multp(l, multp(y, multp(r, P1)))),
    calcL_J_cert(plus(r_cv1,
                      multp(H_n_2(n_C, H_k_2(small_c, H_6(certData(certificationData, Qk_n)))),
                            f)),
                 PointG1(H_p(F1(bsn)), F2(bsn)),
                 H_n_2(n_C, H_k_2(small_c, H_6(certData(certificationData, Qk_n)))),
                 multp(f, J))
  = L_J(r_cv1, PointG1(H_p(F1(bsn)), F2(bsn))),
    calcRB(minus(multp(plus(l,
                            multp(multp(y, r),
                                  H_n_8(P1, multp(f, P1), RB(l, P1), RD(l, multp(f, P1)), multp(r, P1),
                                        multp(y, multp(r, P1)),
                                        plus(multp(x, multp(r, P1)), multp(multp(multp(r, x), y), Q)),
                                        multp(multp(r, y), Q)))),
                       P1),
                 multp(H_n_8(P1, multp(f, P1), RB(l, P1), RD(l, multp(f, P1)),
                             multp(r, P1), multp(y, multp(r, P1)),
                             plus(multp(x, multp(r, P1)), multp(multp(multp(r, x), y), Q)),
                             multp(multp(r, y), Q)),
                       multp(y, multp(r, P1)))))
  = RB(l, P1),
    calcRD(minus(multp(plus(l,
                            multp(multp(y, r),
                                  H_n_8(P1, multp(f, P1), RB(l, P1), RD(l, multp(f, P1)), multp(r, P1),
                                        multp(y, multp(r, P1)),
                                        plus(multp(x, multp(r, P1)), multp(multp(multp(r, x), y), Q)),
                                        multp(multp(r, y), Q)))),
                       multp(f, P1)),
                 multp(H_n_8(P1, multp(f, P1), RB(l, P1), RD(l, multp(f, P1)),
                             multp(r, P1), multp(y, multp(r, P1)),
                             plus(multp(x, multp(r, P1)), multp(multp(multp(r, x), y), Q)),
                             multp(multp(r, y), Q)),
                       multp(multp(r, y), multp(f, P1)))))
  = RD(l, multp(f, P1)),
    fst(<x.1, x.2>) = x.1,
    sdec(senc(x.1, x.2), x.2) = x.1,
    snd(<x.1, x.2>) = x.2,
    verifyCre1(multp(r, P1), PkY(y, P2), multp(y, multp(r, P1)), P2)
  = accept,
    verifyCre2(multp(r, P1), multp(multp(~r, y), multp(f, P1)), PkX(x, P2),
               plus(multp(x, multp(r, P1)), multp(multp(multp(r, x), y), multp(f, P1))),
               P2)
  = accept,
    verifyCre3(multp(l, multp(r, P1)), PkY(y, P2),
               multp(l, multp(y, multp(r, P1))), P2)
  = accept,
    verifyCre4(multp(l, multp(r, P1)),
               multp(l, multp(multp(r, y), multp(f, P1))), PkX(x, P2),
               multp(l,
                     plus(multp(x, multp(r, P1)),
                          multp(multp(multp(r, x), y), multp(f, P1)))),
               P2)
  = accept

