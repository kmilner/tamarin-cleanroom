                                   multp(multp(~x.329, x.327), multp(x.328, x.323)))))
        z.2   = verifyCre1(multp(x.322, x.323), PkY(y.180, 'P2'),
                           multp(x.324, multp(x.325, 'P1')), 'P2')
        z.3   = accept
    // loop breaker: [0]
  */

rule (modulo E) Host_CredentialsReveal:
   [ Host_Org_Creds( $PS, $AS, pk(KDF_EK(TPM_EK_Seed)), A, B, C, D ) ]
  --[
  KeyReveal( 'Host_OrgCred_Reveal', $AS ),
  KeyReveal( 'TPM_OrgCred_Reveal', $PS ),
  KeyReveal( 'PKE_OrgCred_Reveal', pk(KDF_EK(TPM_EK_Seed)) )
  ]->
   [ Out( <A, B, C, D> ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Host_Randomise_Credentials:
   [
   !Host_State_RNDCreds( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)), A, B, C, D ),
   Fr( ~l )
   ]
  --[ RandomisedCredentials( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)) ) ]->
   [
   !Host_Random_Credentials( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)),
                             multp(~l, A), multp(~l, B), multp(~l, C), multp(~l, D)
   )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) Generate_Basename:
   [
   !Host_Join_Complete( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)) ),
   Fr( ~BaseName )
   ]
  --[ GenerateBasename( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)) ) ]->
   [ !Host_BaseName( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)), BSN(~BaseName) ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Host_Basename:
   [
   !Host_Random_Credentials( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)), R, S, T, W
   ),
   !Host_BaseName( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)), bsn )
   ]
  --[ SetBasename( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)), bsn ) ]->
   [ !Host_State_07( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)), R, S, T, W, bsn ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Host_Process_Credentials:
   [
   !Host_State_07( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)),
                   multp(~l, multp(r, 'P1')), multp(~l, multp(y, multp(r, 'P1'))),
                   multp(~l,
                         plus(multp(x, multp(r, 'P1')), multp(multp(multp(r, x), y), Q))),
                   multp(~l, multp(multp(r, y), Q)), BSN(basename)
   )
   ]
  --[
  ProcessRandomisedCredentials( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)),
                                BSN(basename)
  ),
  CertifyOnlyOnce( 'Host_Process_Credentials' )
  ]->
   [
   Out_S( $AS, $PS,
          <F1(BSN(basename)), F2(BSN(basename)), 
           multp(~l, multp(y, multp(r, 'P1'))), 'TPM2_Commit_rand'>
   ),
   Host_State_08( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)), BSN(basename),
                  multp(~l, multp(r, 'P1')), multp(~l, multp(y, multp(r, 'P1'))),
                  multp(~l,
                        plus(multp(x, multp(r, 'P1')), multp(multp(multp(r, x), y), Q))),
                  multp(~l, multp(multp(r, y), Q)),
                  PointG1(H_p(F1(BSN(basename))), F2(BSN(basename)))
   ),
   Host_Rnd_Creds( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)), BSN(basename),
                   multp(~l, multp(r, 'P1')), multp(~l, multp(y, multp(r, 'P1'))),
                   multp(~l,
                         plus(multp(x, multp(r, 'P1')), multp(multp(multp(r, x), y), Q))),
                   multp(~l, multp(multp(r, y), Q))
   )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) Host_RandomCredentialsReveal:
   [ Host_Rnd_Creds( $PS, $AS, pk(KDF_EK(TPM_EK_Seed)), bsn, R, S, T, W ) ]
  --[
  KeyReveal( 'Host_RndCred_Reveal', $AS ),
  KeyReveal( 'TPM_RndCred_Reveal', $PS ),
  KeyReveal( 'PKE_RndCred_Reveal', pk(KDF_EK(TPM_EK_Seed)) )
  ]->
   [ Out( <bsn, R, S, T, W> ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) TPM2_Commit_2:
   [
   In_S( $AS, $PS, <F1(bsn), F2(bsn), S, 'TPM2_Commit_rand'> ),
   !TPM_DAA_SK( $PS, pk(KDF_EK(~TPM_EK_Seed)), ~f ), Fr( ~cv1 ),
   Fr( ~r_cv1 )
   ]
  --[
  TPMCommitRandomised( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)), bsn ),
  CheckInG1( PointG1(H_p(F1(bsn)), F2(bsn)) ),
  CertifyOnlyOnce( 'TPM2_Commit_2' )
  ]->
   [
   Out_S( $PS, $AS,
          <S, multp(~f, PointG1(H_p(F1(bsn)), F2(bsn))), 
           L_J(~r_cv1, PointG1(H_p(F1(bsn)), F2(bsn))), E_S(~r_cv1, S), 
           Nonce(~cv1), 'ret_TPM2_Commit_rand'>
   ),
   !TPM_Commit_RCV1( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)), Nonce(~cv1), ~r_cv1
   )
   ]

  // loop breaker: [0]
  /* has exactly the trivial AC variant */

rule (modulo E) Host_Store_Randomised_Credentials:
   [
   In_S( $PS, $AS, <multp(sl, B), K, L, E, cv1val, 'ret_TPM2_Commit_rand'>
   ),
   Host_State_08( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)), BSN(basename),
                  multp(sl, A), multp(sl, B), multp(sl, C), multp(sl, D),
                  PointG1(H_p(s_2_bar), y_2)
   )
   ]
  --[ StoreRandomisedCredentials( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)) ) ]->
   [
   !Host_State_09( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)), BSN(basename),
                   multp(sl, A), multp(sl, B), multp(sl, C), multp(sl, D),
                   PointG1(H_p(s_2_bar), y_2), K, L, E, cv1val
   )
   ]

  // loop breaker: [0]
  /* has exactly the trivial AC variant */

rule (modulo E) Create_Generic_DAA_Key:
   [ !TPM_AES_Key( $PS, aes_key ), Fr( ~g ), Fr( ~genP ), Fr( ~keyID ) ]
  --[
  TPM2_Generic_DAA_Created( $PS, $AS, DAAKeyID(~keyID),
                            QPub('Generic_DAA_public_data', multp(~g, ~genP))
  ),
  DeriveGenericDAAKey( ~g ), CertifyOnlyOnce( 'Create_Generic_DAA_Key' )
  ]->
   [
   TPM_Created_DAA_Key( $PS, $AS,
                        <DAAKeyID(~keyID), senc(~g, aes_key), 
                         QPub('Generic_DAA_public_data', multp(~g, ~genP)), 'createdGenericDAAKey'
                        >
   ),
   TPM_Generic_DAA_SK( $PS,
                       QPub('Generic_DAA_public_data', multp(~g, ~genP))
   )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) TPM_Generic_DAAReveal:
   [
   TPM_Generic_DAA_SK( $PS,
                       QPub('Generic_DAA_public_data', multp(~g, ~genP))
   )
   ]
  --[ KeyReveal( 'TPM_DAAReveal_tpm', $PS ) ]->
   [ Out( ~g ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Host_Load_Qk_For_Ceritfication:
   [
   TPM_Created_DAA_Key( $PS, $AS,
                        <DAAKeyID(keyID), senc(g, aes_key), 
                         QPub('Generic_DAA_public_data', multp(g, genP)), 'createdGenericDAAKey'>
   ),
   !Host_State_09( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)), BSN(basename),
                   multp(sl, multp(r, 'P1')), multp(sl, multp(y, multp(r, 'P1'))),
                   multp(sl,
                         plus(multp(x, multp(r, 'P1')), multp(multp(multp(r, x), y), Q))),
                   multp(sl, multp(multp(r, y), Q)), J, K, L, E, Nonce(cv1)
   )
   ]
  --[
  LoadKeyForCertification( $PS, $AS, DAAKeyID(keyID),
                           QPub('Generic_DAA_public_data', multp(g, genP))
  ),
  CertifyOnlyOnce( 'Host_Load_Qk_For_Ceritfication' )
  ]->
   [
   Out_S( $AS, $PS,
          <pk(KDF_EK(~TPM_EK_Seed)), DAAKeyID(keyID), senc(g, aes_key), 
           QPub('Generic_DAA_public_data', multp(g, genP)), 
           H_k_9('CredentialData', multp(sl, multp(r, 'P1')),
                 multp(sl, multp(y, multp(r, 'P1'))),
                 multp(sl,
                       plus(multp(x, multp(r, 'P1')), multp(multp(multp(r, x), y), Q))),
                 multp(sl, multp(multp(r, y), Q)), J, K, L, E), 
           Nonce(cv1), 'TPM2_Certify'>
   ),
   Host_State_10( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)), DAAKeyID(keyID),
                  multp(g, genP),
                  H_k_9('CredentialData', multp(sl, multp(r, 'P1')),
                        multp(sl, multp(y, multp(r, 'P1'))),
                        multp(sl,
                              plus(multp(x, multp(r, 'P1')), multp(multp(multp(r, x), y), Q))),
                        multp(sl, multp(multp(r, y), Q)), J, K, L, E),
                  'CredentialData', BSN(basename), multp(sl, multp(r, 'P1')),
                  multp(sl, multp(y, multp(r, 'P1'))),
                  multp(sl,
                        plus(multp(x, multp(r, 'P1')), multp(multp(multp(r, x), y), Q))),
                  multp(sl, multp(multp(r, y), Q)), J, K, L, E
   )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) TPM2_Load_And_Certify:
   [
   In_S( $AS, $PS,
         <pk(KDF_EK(~TPM_EK_Seed)), DAAKeyID(keyID), senc(~g, aes_key), 
          QPub('Generic_DAA_public_data', multp(~g, ~genP)), 
          H_k_9('CredentialData', R, S, T, W, J, K, L, E), cv1val_in, 
          'TPM2_Certify'>
   ),
   !TPM_DAA_SK( $PS, pk(KDF_EK(~TPM_EK_Seed)), ~f ),
   !TPM_AES_Key( $PS, aes_key ),
   !TPM_Commit_RCV1( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)), cv1val, ~r_cv1 ),
   Fr( ~rnd_n_C )
   ]
  --[
  TPM2_Created_Cert_TPM( $PS, $AS, DAAKeyID(keyID),
                         QPub('Generic_DAA_public_data', multp(~g, ~genP))
  ),
  Eq( cv1val_in, cv1val ), CertifyOnlyOnce( 'TPM2_Load_And_Certify' )
  ]->
   [
   Out_S( $PS, $AS,
          <DAAKeyID(keyID), 
           certData('certificationData',
                    QName('SHA256',
                          H_SHA256(QPub('Generic_DAA_public_data', multp(~g, ~genP))))), 
           plus(~r_cv1,
                multp(H_n_2(Nonce(~rnd_n_C),
                            H_k_2(H_k_9('CredentialData', R, S, T, W, J, K, L, E),
                                  H_6(certData('certificationData',
                                               QName('SHA256',
                                                     H_SHA256(QPub('Generic_DAA_public_data',
                                                                   multp(~g, ~genP)))))))),
                      ~f)), 
           Nonce(~rnd_n_C), 'ret_TPM2_Certify'>
   )
   ]

  // loop breaker: [0]
  /* has exactly the trivial AC variant */

rule (modulo E) Host_Receive_Certified_Q_k:
   [
   In_S( $PS, $AS,
         <DAAKeyID(keyID), 
          certData('certificationData',
                   QName('SHA256',
                         H_SHA256(QPub('Generic_DAA_public_data', multp(g, genP))))), 
          plus(r_cv1, multp(h2, f)), Nonce(rnd_n_C), 'ret_TPM2_Certify'>
   ),
   Host_State_10( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)), DAAKeyID(keyID),
                  multp(g, genP), small_c, 'CredentialData', BSN(basename), multp(sl, A),
                  multp(sl, B), multp(sl, C), multp(sl, D),
                  PointG1(H_p(F1(BSN(basename))), F2(BSN(basename))),
                  multp(f, PointG1(H_p(F1(BSN(basename))), F2(BSN(basename)))),
                  L_J(r_cv1, PointG1(H_p(F1(BSN(basename))), F2(BSN(basename)))),
                  E_S(r_cv1, S)
   )
   ]
  --[
  Host_Receive_Certified_Q_K( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)),
                              DAAKeyID(keyID), QPub('Generic_DAA_public_data', multp(g, genP))
  ),
  Host_Sends_Certified_Q_K( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)),
                            <QPub('Generic_DAA_public_data', multp(g, genP)), 
                             certData('certificationData',
                                      QName('SHA256',
                                            H_SHA256(QPub('Generic_DAA_public_data', multp(g, genP))))), 
                             BSN(basename), multp(sl, A), multp(sl, B), multp(sl, C), multp(sl, D), 
                             PointG1(H_p(F1(BSN(basename))), F2(BSN(basename))), 
                             multp(f, PointG1(H_p(F1(BSN(basename))), F2(BSN(basename)))), 
                             H_n_2(Nonce(rnd_n_C),
                                   H_k_2(small_c,
                                         H_6(certData('certificationData',
                                                      QName('SHA256',
                                                            H_SHA256(QPub('Generic_DAA_public_data',
                                                                          multp(g, genP)))))))), 
                             plus(r_cv1, multp(h2, f)), Nonce(rnd_n_C)>
  ),
  Host_Sends_Certified_Q_K_With_BSN( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)),
                                     BSN(basename),
                                     <QPub('Generic_DAA_public_data', multp(g, genP)), 
                                      certData('certificationData',
                                               QName('SHA256',
                                                     H_SHA256(QPub('Generic_DAA_public_data',
                                                                   multp(g, genP))))), 
                                      BSN(basename), multp(sl, A), multp(sl, B), multp(sl, C), multp(sl, D), 
                                      PointG1(H_p(F1(BSN(basename))), F2(BSN(basename))), 
                                      multp(f, PointG1(H_p(F1(BSN(basename))), F2(BSN(basename)))), 
                                      H_n_2(Nonce(rnd_n_C),
                                            H_k_2(small_c,
                                                  H_6(certData('certificationData',
                                                               QName('SHA256',
                                                                     H_SHA256(QPub('Generic_DAA_public_data',
                                                                                   multp(g, genP)))))))), 
                                      plus(r_cv1, multp(h2, f)), Nonce(rnd_n_C)>
  ),
  Host_Sends_Certified_Q_K_cred( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)),
                                 BSN(basename), multp(sl, A), multp(sl, B), multp(sl, C), multp(sl, D),
                                 <QPub('Generic_DAA_public_data', multp(g, genP)), 
                                  certData('certificationData',
                                           QName('SHA256',
                                                 H_SHA256(QPub('Generic_DAA_public_data', multp(g, genP))))), 
                                  BSN(basename), multp(sl, A), multp(sl, B), multp(sl, C), multp(sl, D), 
                                  PointG1(H_p(F1(BSN(basename))), F2(BSN(basename))), 
                                  multp(f, PointG1(H_p(F1(BSN(basename))), F2(BSN(basename)))), 
                                  H_n_2(Nonce(rnd_n_C),
                                        H_k_2(small_c,
                                              H_6(certData('certificationData',
                                                           QName('SHA256',
                                                                 H_SHA256(QPub('Generic_DAA_public_data',
                                                                               multp(g, genP)))))))), 
                                  plus(r_cv1, multp(h2, f)), Nonce(rnd_n_C)>
  ),
  Honest( $PS ), Honest( $AS ), Honest( pk(KDF_EK(~TPM_EK_Seed)) ),
  CertifyOnlyOnce( 'Host_Receive_Certified_Q_K' )
  ]->
   [
   Out( <QPub('Generic_DAA_public_data', multp(g, genP)), 
         certData('certificationData',
                  QName('SHA256',
                        H_SHA256(QPub('Generic_DAA_public_data', multp(g, genP))))), 
         BSN(basename), multp(sl, A), multp(sl, B), multp(sl, C), multp(sl, D), 
         PointG1(H_p(F1(BSN(basename))), F2(BSN(basename))), 
         multp(f, PointG1(H_p(F1(BSN(basename))), F2(BSN(basename)))), 
         H_n_2(Nonce(rnd_n_C),
               H_k_2(small_c,
                     H_6(certData('certificationData',
                                  QName('SHA256',
                                        H_SHA256(QPub('Generic_DAA_public_data', multp(g, genP)))))))), 
         plus(r_cv1, multp(h2, f)), Nonce(rnd_n_C)>
   )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) Verifier_Check_TPM_Certificate:
   [
   In( <
        <QPub('Generic_DAA_public_data', multp(g, genP)), 
         certData('certificationData',
                  QName('SHA256',
                        H_SHA256(QPub('Generic_DAA_public_data', multp(g, genP))))), 
         BSN(basename), multp(sl, A), multp(sl, B), multp(sl, C), multp(sl, D), 
         PointG1(H_p(s_2_bar), y_2), multp(f, PointG1(H_p(s_2_bar), y_2)), 
         h2_host, plus(r_cv1, multp(h2, f)), Nonce(rnd_n_C)>, 
        'TPM_Certificate_Of_Q_K'>
   ),
   !Pk( 'Issuer', pkX, pkY )
   ]
  --[
  Eq( PointG1(H_p(F1(BSN(basename))), F2(BSN(basename))),
      PointG1(H_p(s_2_bar), y_2)
  ),
  Eq( verifyCre3(multp(sl, A), pkY, multp(sl, B), 'P2'), accept ),
  Eq( verifyCre4(multp(sl, A), multp(sl, D), pkX, multp(sl, C), 'P2'),
      accept
  ),
  Eq( H_n_2(Nonce(rnd_n_C),
            H_k_2(H_k_9('CredentialData', multp(sl, A), multp(sl, B), multp(sl, C),
                        multp(sl, D), PointG1(H_p(F1(BSN(basename))), F2(BSN(basename))),
                        multp(f, PointG1(H_p(s_2_bar), y_2)),
                        calcL_J_cert(plus(r_cv1, multp(h2, f)), PointG1(H_p(s_2_bar), y_2),
                                     h2_host, multp(f, PointG1(H_p(s_2_bar), y_2))),
                        calcE_S_cert(plus(r_cv1, multp(h2, f)), multp(sl, B), h2_host,
                                     multp(sl, D))),
                  H_6(certData('certificationData',
                               QName('SHA256',
                                     H_SHA256(QPub('Generic_DAA_public_data', multp(g, genP)))))))),
      h2_host
  ),
  VerifiedCertificate( $V,
                       <QPub('Generic_DAA_public_data', multp(g, genP)), 
                        certData('certificationData',
                                 QName('SHA256',
                                       H_SHA256(QPub('Generic_DAA_public_data', multp(g, genP))))), 
                        BSN(basename), multp(sl, A), multp(sl, B), multp(sl, C), multp(sl, D), 
                        PointG1(H_p(s_2_bar), y_2), multp(f, PointG1(H_p(s_2_bar), y_2)), 
                        h2_host, plus(r_cv1, multp(h2, f)), Nonce(rnd_n_C)>
  ),
  VerifiedCertificateDeAnonymised( BSN(basename),
                                   <QPub('Generic_DAA_public_data', multp(g, genP)), 
                                    certData('certificationData',
                                             QName('SHA256',
                                                   H_SHA256(QPub('Generic_DAA_public_data',
                                                                 multp(g, genP))))), 
                                    BSN(basename), multp(sl, A), multp(sl, B), multp(sl, C), multp(sl, D), 
                                    PointG1(H_p(s_2_bar), y_2), multp(f, PointG1(H_p(s_2_bar), y_2)), 
                                    h2_host, plus(r_cv1, multp(h2, f)), Nonce(rnd_n_C)>,
                                   f
  ),
  CertifyOnlyOnce( 'Verifier_Check_TPM_Certificate' )
  ]->
   [
   !SignatureVerified( $V,
                       <QPub('Generic_DAA_public_data', multp(g, genP)), 
                        certData('certificationData',
                                 QName('SHA256',
                                       H_SHA256(QPub('Generic_DAA_public_data', multp(g, genP))))), 
                        BSN(basename), multp(sl, A), multp(sl, B), multp(sl, C), multp(sl, D), 
                        PointG1(H_p(s_2_bar), y_2), multp(f, PointG1(H_p(s_2_bar), y_2)), 
                        h2_host, plus(r_cv1, multp(h2, f)), Nonce(rnd_n_C)>
   )
   ]

  /*
  rule (modulo AC) Verifier_Check_TPM_Certificate:
     [
     In( <
          <QPub('Generic_DAA_public_data', multp(g, genP)), 
           certData('certificationData',
                    QName('SHA256',
                          H_SHA256(QPub('Generic_DAA_public_data', multp(g, genP))))), 
           BSN(basename), multp(sl, A), multp(sl, B), multp(sl, C), multp(sl, D), 
           PointG1(H_p(s_2_bar), y_2), multp(f, PointG1(H_p(s_2_bar), y_2)), 
           h2_host, plus(r_cv1, multp(h2, f)), Nonce(rnd_n_C)>, 
          'TPM_Certificate_Of_Q_K'>
     ),
     !Pk( 'Issuer', pkX, pkY )
     ]
    --[
    Eq( PointG1(H_p(F1(BSN(basename))), F2(BSN(basename))),
        PointG1(H_p(s_2_bar), y_2)
    ),
