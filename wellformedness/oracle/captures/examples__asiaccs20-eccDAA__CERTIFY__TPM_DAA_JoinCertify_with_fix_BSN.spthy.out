restriction equality:
  "∀ #i x y. (Eq( x, y ) @ #i) ⇒ (x = y)"
  // safety formula

  /*
  expanded formula:
  "∀ #i x y. (Eq( x, y ) @ #i) ⇒ (x = y)"
  */

restriction notlinked:
  "∀ #i J1 J2 K1 K2.
    (NotLinked( J1, J2, K1, K2 ) @ #i) ⇒ ((¬(J1 = J2)) ∨ (¬(K1 = K2)))"
  // safety formula

  /*
  expanded formula:
  "∀ #i J1 J2 K1 K2.
    (NotLinked( J1, J2, K1, K2 ) @ #i) ⇒ ((¬(J1 = J2)) ∨ (¬(K1 = K2)))"
  */

restriction single_issuer_single_init:
  "∀ I1 I2 #i #j.
    ((Issuer_Init( I1 ) @ #i) ∧ (Issuer_Init( I2 ) @ #j)) ⇒ (#i = #j)"
  // safety formula

  /*
  expanded formula:
  "∀ I1 I2 #i #j.
    ((Issuer_Init( I1 ) @ #i) ∧ (Issuer_Init( I2 ) @ #j)) ⇒ (#i = #j)"
  */

restriction single_host_init:
  "∀ Host #i #j.
    ((Host_Init( Host ) @ #i) ∧ (Host_Init( Host ) @ #j)) ⇒ (#i = #j)"
  // safety formula

  /*
  expanded formula:
  "∀ Host #i #j.
    ((Host_Init( Host ) @ #i) ∧ (Host_Init( Host ) @ #j)) ⇒ (#i = #j)"
  */

restriction single_tpm_init:
  "∀ PS #i #j. ((TPM_Init( PS ) @ #i) ∧ (TPM_Init( PS ) @ #j)) ⇒ (#i = #j)"
  // safety formula

  /*
  expanded formula:
  "∀ PS #i #j. ((TPM_Init( PS ) @ #i) ∧ (TPM_Init( PS ) @ #j)) ⇒ (#i = #j)"
  */

restriction every_id_must_be_one_of_tpm_host_issuer:
  "∀ Ent1 Ent2 Ent3 #i #j #k.
    (((Host_Init( Ent1 ) @ #i) ∧ (TPM_Init( Ent2 ) @ #j)) ∧
     (Issuer_Init( Ent3 ) @ #k)) ⇒
    (((¬(Ent1 = Ent2)) ∧ (¬(Ent1 = Ent3))) ∧ (¬(Ent2 = Ent3)))"
  // safety formula

  /*
  expanded formula:
  "∀ Ent1 Ent2 Ent3 #i #j #k.
    (((Host_Init( Ent1 ) @ #i) ∧ (TPM_Init( Ent2 ) @ #j)) ∧
     (Issuer_Init( Ent3 ) @ #k)) ⇒
    (((¬(Ent1 = Ent2)) ∧ (¬(Ent1 = Ent3))) ∧ (¬(Ent2 = Ent3)))"
  */

rule (modulo E) ChanOut_S[color=#ffffff]:
   [ Out_S( $A, $B, x ), !F_Paired( $A, $B ) ]
  --[ ChanOut_S( $A, $B, x ) ]->
   [ Sec( $A, $B, x ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) ChanIn_S[color=#ffffff]:
   [ Sec( $A, $B, x ) ] --[ ChanIn_S( $A, $B, x ) ]-> [ In_S( $A, $B, x ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Issuer_Init:
   [ Fr( ~x ), Fr( ~y ) ]
  --[ Issuer_Init( 'Issuer' ), OnlyOnce( 'Issuer_Init' ) ]->
   [
   !Ltk( 'Issuer', ~x, ~y ), !Pk( 'Issuer', PkX(~x, 'P2'), PkY(~y, 'P2') ),
   Out( <PkX(~x, 'P2'), PkY(~y, 'P2')> ), !Issuer_Initialised( 'Issuer' )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) Issuer_KeyReveal:
   [ !Ltk( I, ~x, ~y ) ]
  --[ KeyReveal( 'Issuer_KeyReveal', I ) ]->
   [ Out( <~x, ~y> ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) TPM_INIT:
   [ Fr( ~TPM_AES_Seed ), Fr( ~TPM_EK_Seed ) ]
  --[ TPM_Init( $PS ), OnlyOnce( 'TPM_INIT' ) ]->
   [
   !TPM_AES_Key( $PS, KDF_AES(~TPM_AES_Seed) ),
   TPM_EK_SEED( $PS, ~TPM_EK_Seed ), TPM_Initialised( $PS )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) TPM_AESReveal:
   [ !TPM_AES_Key( PS, aes_key ) ]
  --[ KeyReveal( 'TPM_AESReveal', PS ) ]->
   [ Out( aes_key ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Host_Init:
   [ ]
  --[ Host_Init( $AS ), OnlyOnce( 'Host_Init' ) ]->
   [ Host_Initialised( $AS ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Platform_Setup:
   [
   TPM_Initialised( $PS ), Host_Initialised( $AS ), !Issuer_Initialised( I )
   ]
  --[ Bind( $PS, $AS, I ), OnlyOnce( 'Platform_Setup' ) ]->
   [
   Out_S( $AS, $PS, 'createPrimary' ), !F_Paired( $AS, $PS ),
   !F_Paired( $PS, $AS )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) TPM2_CreatePrimary:
   [ In_S( $AS, $PS, 'createPrimary' ), TPM_EK_SEED( $PS, ~TPM_EK_Seed ) ]
  --[
  TPM2_EK_Created( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)) ),
  OnlyOnce( 'TPM2_CreatePrimary' )
  ]->
   [
   Out_S( $PS, $AS,
          <<'EK_public_data', pk(KDF_EK(~TPM_EK_Seed))>, 'returnEK'>
   ),
   !TPM_ENDORSEMENT_SK( $PS, KDF_EK(~TPM_EK_Seed), pk(KDF_EK(~TPM_EK_Seed))
   ),
   !TPM_ENDORSEMENT_PK( $PS, <'EK_public_data', pk(KDF_EK(~TPM_EK_Seed))> )
   ]

  // loop breaker: [0]
  /* has exactly the trivial AC variant */

rule (modulo E) TPM_EKReveal:
   [
   !TPM_ENDORSEMENT_SK( PS, KDF_EK(~TPM_EK_Seed), pk(KDF_EK(~TPM_EK_Seed)) )
   ]
  --[
  KeyReveal( 'TPM_EKReveal_tpm', PS ),
  KeyReveal( 'TPM_EKReveal_pke', pk(KDF_EK(~TPM_EK_Seed)) )
  ]->
   [ Out( KDF_EK(~TPM_EK_Seed) ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Host_Store_EK:
   [
   In_S( $PS, $AS,
         <<'EK_public_data', pk(KDF_EK(~TPM_EK_Seed))>, 'returnEK'>
   )
   ]
  --[ Store_EK( $PS, $AS ), OnlyOnce( 'Host_Store_EK' ) ]->
   [
   Out_S( $AS, $PS, <pk(KDF_EK(~TPM_EK_Seed)), 'createDAAKey'> ),
   Host_State_01( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)) )
   ]

  // loop breaker: [0]
  /* has exactly the trivial AC variant */

rule (modulo E) TPM2_Create:
   [
   In_S( $AS, $PS, <pk(KDF_EK(~TPM_EK_Seed)), 'createDAAKey'> ),
   !TPM_AES_Key( $PS, aes_key ), Fr( ~f )
   ]
  --[
  TPM2_DAA_Created( $PS, $AS ),
  DeriveDAAKey( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)), ~f ),
  OnlyOnce( 'TPM2_Create' )
  ]->
   [
   Out_S( $PS, $AS,
          <senc(~f, aes_key), <'DAA_public_data', multp(~f, 'P1')>, 'returnDAAKey'>
   ),
   !TPM_DAA_SK( $PS, pk(KDF_EK(~TPM_EK_Seed)), ~f )
   ]

  // loop breaker: [0]
  /* has exactly the trivial AC variant */

rule (modulo E) TPM_DAAReveal:
   [ !TPM_DAA_SK( PS, pk(KDF_EK(~TPM_EK_Seed)), ~f ) ]
  --[
  KeyReveal( 'TPM_DAAReveal_tpm', PS ),
  KeyReveal( 'TPM_DAAReveal_pke', pk(KDF_EK(~TPM_EK_Seed)) )
  ]->
   [ Out( ~f ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Host_Store_DAA_Key:
   [
   In_S( $PS, $AS,
         <senc(~f, KDF_AES(~TPM_AES_Seed)), <'DAA_public_data', multp(~f, 'P1')>, 
          'returnDAAKey'>
   ),
   Host_State_01( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)) )
   ]
  --[
  Store_DAA( $PS, $AS ),
  PlatformSendKeys( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)),
                    <'DAA_public_data', multp(~f, 'P1')>, 'Issuer'
  ),
  Alive( $AS ), Role( 'Platform' ), Honest( $PS ), Honest( $AS ),
  Honest( pk(KDF_EK(~TPM_EK_Seed)) ), Honest( 'Issuer' ),
  OnlyOnce( 'Host_Store_DAA_Key' )
  ]->
   [
   !EK_FOR_ISSUER( pk(KDF_EK(~TPM_EK_Seed)) ),
   Out( <pk(KDF_EK(~TPM_EK_Seed)), <'DAA_public_data', multp(~f, 'P1')>, 
         'join_Issuer_1'>
   ),
   Host_State_02( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)),
                  <'DAA_public_data', multp(~f, 'P1')>, senc(~f, KDF_AES(~TPM_AES_Seed))
   )
   ]

  // loop breaker: [0]
  /* has exactly the trivial AC variant */

rule (modulo E) Issuer_Check_EK_Send_Challenge:
   [
   In( <pk(KDF_EK(TPM_EK_Seed)), <'DAA_public_data', multp(f, 'P1')>, 
        'join_Issuer_1'>
   ),
   Fr( ~K_1 ), Fr( ~s ), !EK_FOR_ISSUER( pk(KDF_EK(TPM_EK_Seed)) )
   ]
  --[
  Check_Ek( pk(KDF_EK(TPM_EK_Seed)) ),
  Check_QPD( <'DAA_public_data', multp(f, 'P1')> ),
  Associate( curlyK(~K_1), pk(KDF_EK(TPM_EK_Seed)),
             <'DAA_public_data', multp(f, 'P1')>
  ),
  Alive( 'Issuer' ), Honest( 'Issuer' ), Honest( pk(KDF_EK(TPM_EK_Seed)) ),
  IssuerReceivedKeys( 'Issuer', pk(KDF_EK(TPM_EK_Seed)),
                      <'DAA_public_data', multp(f, 'P1')>
  ),
  OnlyOnce( 'Issuer_Check_EK_Send_Challenge' )
  ]->
   [
   Out( <
         MAC(<'1', 
              len16(senc(<'1', curlyK(~K_1)>,
                         KDF_a(<'1', ~s>, 'STORAGE',
                               <'1', 'SHA256', H_SHA256(<'DAA_public_data', multp(f, 'P1')>)>))), 
              senc(<'1', curlyK(~K_1)>,
                   KDF_a(<'1', ~s>, 'STORAGE',
                         <'1', 'SHA256', H_SHA256(<'DAA_public_data', multp(f, 'P1')>)>)), 
              '1', 'SHA256', H_SHA256(<'DAA_public_data', multp(f, 'P1')>)>,
             KDF_a(<'1', ~s>, 'INTEGRITY', 'NULL')), 
         len16(senc(<'1', curlyK(~K_1)>,
                    KDF_a(<'1', ~s>, 'STORAGE',
                          <'1', 'SHA256', H_SHA256(<'DAA_public_data', multp(f, 'P1')>)>))), 
         senc(<'1', curlyK(~K_1)>,
              KDF_a(<'1', ~s>, 'STORAGE',
                    <'1', 'SHA256', H_SHA256(<'DAA_public_data', multp(f, 'P1')>)>)), 
         aenc(<'1', ~s>, pk(KDF_EK(TPM_EK_Seed))), 'Host_SendChallenge'>
   ),
   Issuer_State_01( 'Issuer', curlyK(~K_1), pk(KDF_EK(TPM_EK_Seed)),
                    <'DAA_public_data', multp(f, 'P1')>
   )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) Host_Passthrough_1:
   [
   In( <curlyH, len16(curlyK_hat), curlyK_hat, 
        aenc(s, pk(KDF_EK(~TPM_EK_Seed))), 'Host_SendChallenge'>
   ),
   Host_State_02( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)), Q_PD, Q_SD )
   ]
  --[ Passthrough_ActivateCred( $PS, $AS ), OnlyOnce( 'Host_Passthrough' )
  ]->
   [
   Out_S( $AS, $PS,
          <Q_SD, Q_PD, curlyH, len16(curlyK_hat), curlyK_hat, 
           aenc(s, pk(KDF_EK(~TPM_EK_Seed))), 'TPM2_ActivateCredentials'>
   ),
   Host_State_03( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)), Q_PD, Q_SD )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) TPM2_ActivateCredential:
   [
   In_S( $AS, $PS,
         <senc(~f, aes_key), <'DAA_public_data', multp(~f, 'P1')>, curlyH, 
          len16(senc(<'1', curlyK(K_1)>, k_e)), senc(<'1', curlyK(K_1)>, k_e), 
          aenc(<'1', s>, pk(KDF_EK(~TPM_EK_Seed))), 'TPM2_ActivateCredentials'>
   ),
   !TPM_AES_Key( $PS, aes_key ),
   !TPM_ENDORSEMENT_SK( $PS, e, pk(KDF_EK(~TPM_EK_Seed)) )
   ]
  --[
  Eq( MAC(<'1', len16(senc(<'1', curlyK(K_1)>, k_e)), 
           senc(<'1', curlyK(K_1)>, k_e), '1', 'SHA256', 
           H_SHA256(<'DAA_public_data', multp(~f, 'P1')>)>,
          KDF_a(<'1', snd(adec(aenc(<'1', s>, pk(KDF_EK(~TPM_EK_Seed))), e))>,
                'INTEGRITY', 'NULL')),
      curlyH
  ),
  Eq( k_e,
      KDF_a(<'1', snd(adec(aenc(<'1', s>, pk(KDF_EK(~TPM_EK_Seed))), e))>,
            'STORAGE',
            <'1', 'SHA256', H_SHA256(<'DAA_public_data', multp(~f, 'P1')>)>)
  ),
  CurlyK_recomputed( $PS, $AS ), OnlyOnce( 'TPM2_ActivateCredential' )
  ]->
   [
   Out_S( $PS, $AS,
          <
           snd(sdec(senc(<'1', curlyK(K_1)>, k_e),
                    KDF_a(<'1', snd(adec(aenc(<'1', s>, pk(KDF_EK(~TPM_EK_Seed))), e))>,
                          'STORAGE',
                          <'1', 'SHA256', H_SHA256(<'DAA_public_data', multp(~f, 'P1')>)>))), 
           'ret_TPM2_ActivateCredentials'>
   )
   ]

