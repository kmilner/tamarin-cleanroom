        D     = multp(multp(x.385, x.389), multp(x.390, x.386))
        f     = f.201
        h2    = h2.204
        h2_host
              = h2_host.205
        pkX   = PkX(x.388, 'P2')
        pkY   = pkY.207
        r_cv1 = r_cv1.208
        s_2_bar
              = s_2_bar.210
        sl    = sl.211
        y_2   = y_2.212
        z     = verifyCre3(multp(sl.211, multp(x.385, x.386)), pkY.207,
                           multp(sl.211, B.197), 'P2')
        z.1   = accept
        z.2   = calcL_J_cert(plus(r_cv1.208, multp(h2.204, f.201)),
                             PointG1(H_p(s_2_bar.210), y_2.212), h2_host.205,
                             multp(f.201, PointG1(H_p(s_2_bar.210), y_2.212)))
        z.3   = calcE_S_cert(plus(r_cv1.208, multp(h2.204, f.201)),
                             multp(sl.211, B.197), h2_host.205,
                             multp(sl.211, multp(multp(x.385, x.389), multp(x.390, x.386))))
    
    16. A     = multp(x.397, x.398)
        B     = B.209
        C     = plus(multp(x.400, multp(x.397, x.398)),
                     multp(multp(multp(x.397, x.400), x.401), multp(x.402, x.398)))
        D     = multp(multp(x.397, x.401), multp(x.402, x.398))
        f     = f.213
        h2    = H_n_2(x.407, H_k_2(x.408, H_6(certData(x.409, x.410))))
        h2_host
              = H_n_2(x.407, H_k_2(x.408, H_6(certData(x.409, x.410))))
        pkX   = PkX(x.400, 'P2')
        pkY   = pkY.219
        r_cv1 = r_cv1.220
        s_2_bar
              = F1(x.414)
        sl    = sl.223
        y_2   = F2(x.414)
        z     = verifyCre3(multp(sl.223, multp(x.397, x.398)), pkY.219,
                           multp(sl.223, B.209), 'P2')
        z.1   = accept
        z.2   = L_J(r_cv1.220, PointG1(H_p(F1(x.414)), F2(x.414)))
        z.3   = calcE_S_cert(plus(r_cv1.220,
                                  multp(H_n_2(x.407, H_k_2(x.408, H_6(certData(x.409, x.410)))), f.213)),
                             multp(sl.223, B.209),
                             H_n_2(x.407, H_k_2(x.408, H_6(certData(x.409, x.410)))),
                             multp(sl.223, multp(multp(x.397, x.401), multp(x.402, x.398))))
  */

rule (modulo E) Signatures_Linked:
   [
   !SignatureVerified( $V,
                       <Qk_PD1, curlyA1, bsn_in1, R1, S1, T1, W1, J1, K1, h2_host1, small_s1, 
                        n_C1>
   ),
   !SignatureVerified( $V,
                       <Qk_PD2, curlyA2, bsn_in2, R2, S2, T2, W2, J2, K2, h2_host2, small_s2, 
                        n_C2>
   )
   ]
  --[
  Eq( bsn_in1, bsn_in2 ), Eq( J1, J2 ), Eq( K1, K2 ),
  LinkedSignatures( bsn_in1,
                    <Qk_PD1, curlyA1, bsn_in1, R1, S1, T1, W1, J1, K1, h2_host1, small_s1, 
                     n_C1>,
                    <Qk_PD2, curlyA2, bsn_in2, R2, S2, T2, W2, J2, K2, h2_host2, small_s2, 
                     n_C2>
  )
  ]->
   [ ]

  /* has exactly the trivial AC variant */

rule (modulo E) Signatures_NotLinked:
   [
   !SignatureVerified( $V,
                       <Qk_PD1, curlyA1, bsn_in1, R1, S1, T1, W1, J1, K1, h2_host1, small_s1, 
                        n_C1>
   ),
   !SignatureVerified( $V,
                       <Qk_PD2, curlyA2, bsn_in2, R2, S2, T2, W2, J2, K2, h2_host2, small_s2, 
                        n_C2>
   )
   ]
  --[
  NotLinked( J1, J2, K1, K2 ),
  UnlinkedSignatures( <Qk_PD1, curlyA1, bsn_in1, R1, S1, T1, W1, J1, K1, 
                       h2_host1, small_s1, n_C1>,
                      <Qk_PD2, curlyA2, bsn_in2, R2, S2, T2, W2, J2, K2, h2_host2, small_s2, 
                       n_C2>
  )
  ]->
   [ ]

  /* has exactly the trivial AC variant */

lemma auto_bind_restriction:
  all-traces
  "∀ Ent1 Ent2 Ent3 #i.
    (Bind( Ent1, Ent2, Ent3 ) @ #i) ⇒
    (((¬(Ent1 = Ent2)) ∧ (¬(Ent1 = Ent3))) ∧ (¬(Ent2 = Ent3)))"
/*
guarded formula characterizing all counter-examples:
"∃ Ent1 Ent2 Ent3 #i.
  (Bind( Ent1, Ent2, Ent3 ) @ #i)
 ∧
  ((Ent1 = Ent2) ∨ (Ent1 = Ent3) ∨ (Ent2 = Ent3))"
*/
by sorry

lemma auto_restriction_one_host_per_tpm:
  all-traces
  "∀ TPM Host1 Host2 #i #j.
    ((Bind( Host1, TPM, 'Issuer' ) @ #i) ∧
     (Bind( Host2, TPM, 'Issuer' ) @ #j)) ⇒
    (#i = #j)"
/*
guarded formula characterizing all counter-examples:
"∃ TPM Host1 Host2 #i #j.
  (Bind( Host1, TPM, 'Issuer' ) @ #i) ∧ (Bind( Host2, TPM, 'Issuer' ) @ #j)
 ∧
  ¬(#i = #j)"
*/
by sorry

lemma auto_restriction_one_tpm_per_host:
  all-traces
  "∀ TPM1 TPM2 Host #i #j.
    ((Bind( Host, TPM1, 'Issuer' ) @ #i) ∧
     (Bind( Host, TPM2, 'Issuer' ) @ #j)) ⇒
    (#i = #j)"
/*
guarded formula characterizing all counter-examples:
"∃ TPM1 TPM2 Host #i #j.
  (Bind( Host, TPM1, 'Issuer' ) @ #i) ∧ (Bind( Host, TPM2, 'Issuer' ) @ #j)
 ∧
  ¬(#i = #j)"
*/
by sorry

lemma auto_restricition_pke_comes_from_tpm:
  all-traces
  "∀ pke #i.
    (Check_Ek( pke ) @ #i) ⇒
    (∃ TPM Host #j. TPM2_EK_Created( TPM, Host, pke ) @ #j)"
/*
guarded formula characterizing all counter-examples:
"∃ pke #i.
  (Check_Ek( pke ) @ #i)
 ∧
  ∀ TPM Host #j. (TPM2_EK_Created( TPM, Host, pke ) @ #j) ⇒ ⊥"
*/
by sorry

lemma auto_restriction_single_issuer:
  all-traces
  "∀ I1 I2 #i #j.
    ((Issuer_Init( I1 ) @ #i) ∧ (Issuer_Init( I2 ) @ #j)) ⇒ (I1 = I2)"
/*
guarded formula characterizing all counter-examples:
"∃ I1 I2 #i #j.
  (Issuer_Init( I1 ) @ #i) ∧ (Issuer_Init( I2 ) @ #j) ∧ ¬(I1 = I2)"
*/
by sorry

lemma auto_verify_multiple_pkes:
  exists-trace
  "∃ TPM1 TPM2 Host1 Host2 pke1 qpd1 pke2 qpd2 #t1 #t2 #t3 #t4.
    ((((((((PlatformSendKeys( TPM1, Host1, pke1, qpd1, 'Issuer' ) @ #t1) ∧
           (PlatformSendKeys( TPM2, Host2, pke2, qpd2, 'Issuer' ) @ #t2)) ∧
          (IssuerReceivedKeys( 'Issuer', pke1, qpd1 ) @ #t3)) ∧
         (IssuerReceivedKeys( 'Issuer', pke2, qpd2 ) @ #t4)) ∧
        (¬(pke1 = pke2))) ∧
       (¬(qpd1 = qpd2))) ∧
      (¬(Host1 = Host2))) ∧
     (¬(TPM1 = TPM2))) ∧
    (¬(∃ RevealEvent ENTITY #k1. KeyReveal( RevealEvent, ENTITY ) @ #k1))"
/*
guarded formula characterizing all satisfying traces:
"∃ TPM1 TPM2 Host1 Host2 pke1 qpd1 pke2 qpd2 #t1 #t2 #t3 #t4.
  (PlatformSendKeys( TPM1, Host1, pke1, qpd1, 'Issuer' ) @ #t1) ∧
  (PlatformSendKeys( TPM2, Host2, pke2, qpd2, 'Issuer' ) @ #t2) ∧
  (IssuerReceivedKeys( 'Issuer', pke1, qpd1 ) @ #t3) ∧
  (IssuerReceivedKeys( 'Issuer', pke2, qpd2 ) @ #t4)
 ∧
  (¬(pke1 = pke2)) ∧
  (¬(qpd1 = qpd2)) ∧
  (¬(Host1 = Host2)) ∧
  (¬(TPM1 = TPM2)) ∧
  (∀ RevealEvent ENTITY #k1. (KeyReveal( RevealEvent, ENTITY ) @ #k1) ⇒ ⊥)"
*/
by sorry

lemma oracle_correctness_two_certs_same_credentials_same_bsn [heuristic={oracle_corr}]:
  exists-trace
  "∃ TPM Host pke bsn R S T W sigma1 sigma2 #t01 #t02.
    (((((Host_Sends_Certified_Q_K_cred( TPM, Host, pke, bsn, R, S, T, W,
                                        sigma1
         ) @ #t01) ∧
        (Host_Sends_Certified_Q_K_cred( TPM, Host, pke, bsn, R, S, T, W, sigma2
         ) @ #t02)) ∧
       (#t01 < #t02)) ∧
      (¬(sigma1 = sigma2))) ∧
     (¬(∃ RevealEvent ENTITY #k1. KeyReveal( RevealEvent, ENTITY ) @ #k1))) ∧
    (∀ event #i #j.
      ((OnlyOnce( event ) @ #i) ∧ (OnlyOnce( event ) @ #j)) ⇒ (#i = #j))"
/*
guarded formula characterizing all satisfying traces:
"∃ TPM Host pke bsn R S T W sigma1 sigma2 #t01 #t02.
  (Host_Sends_Certified_Q_K_cred( TPM, Host, pke, bsn, R, S, T, W, sigma1
   ) @ #t01) ∧
  (Host_Sends_Certified_Q_K_cred( TPM, Host, pke, bsn, R, S, T, W, sigma2
   ) @ #t02)
 ∧
  (#t01 < #t02) ∧
  (¬(sigma1 = sigma2)) ∧
  (∀ RevealEvent ENTITY #k1.
    (KeyReveal( RevealEvent, ENTITY ) @ #k1) ⇒ ⊥) ∧
  (∀ event #i #j.
    (OnlyOnce( event ) @ #i) ∧ (OnlyOnce( event ) @ #j) ⇒ #i = #j)"
*/
by sorry

