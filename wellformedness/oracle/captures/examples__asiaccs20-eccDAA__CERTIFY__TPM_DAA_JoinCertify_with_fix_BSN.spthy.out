  */

rule (modulo E) Host_JoinComplete:
   [
   In_S( $PS, $AS, <curlyK(K_2_rec), 'ret_TPM2_ActivateCredentials_2'> ),
   !Pk( 'Issuer', PkX(x, 'P2'), PkY(y, 'P2') ),
   Host_State_06( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)),
                  <'DAA_public_data', multp(~f, 'P1')>, senc(<A, B, C, D, u, j>, curlyK_2)
   )
   ]
  --[
  Eq( curlyK_2, curlyK(K_2_rec) ),
  Eq( u,
      H_n_8('P1', multp(~f, 'P1'), calcRB(minus(multp(j, 'P1'), multp(u, B))),
            calcRD(minus(multp(j, multp(~f, 'P1')), multp(u, D))), A, B, C, D)
  ),
  Eq( verifyCre1(A, PkY(y, 'P2'), B, 'P2'), accept ),
  Eq( verifyCre2(A, D, PkX(x, 'P2'), C, 'P2'), accept ),
  JoinCompleted( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)) ),
  Commit( pk(KDF_EK(~TPM_EK_Seed)), 'Issuer', <A, B, C, D> ),
  Role( 'Platform' ),
  Secret( pk(KDF_EK(~TPM_EK_Seed)), 'Issuer', <A, B, C, D> ),
  Honest( $PS ), Honest( $AS ), Honest( pk(KDF_EK(~TPM_EK_Seed)) ),
  Honest( 'Issuer' ), OnlyOnce( 'Host_JoinComplete' )
  ]->
   [
   !Host_State_RNDCreds( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)), A, B, C, D ),
   !Host_Join_Complete( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)) ),
   Host_Org_Creds( $PS, $AS, pk(KDF_EK(~TPM_EK_Seed)), A, B, C, D )
   ]

