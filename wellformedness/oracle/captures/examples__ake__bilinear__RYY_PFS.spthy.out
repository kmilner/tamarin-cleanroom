rule (modulo E) Resp_1:
   [ Fr( ~ey ), !LTK( $B, skB ), In( X ) ]
  --[
  Accept( ~ey, kdf(<X^~ey, em(skB, hp($A)), $A, $B, X, 'g'^~ey>) ),
  Sid( ~ey, <$B, $A, 'g'^~ey, X, 'Resp'> )
  ]->
   [
   Out( 'g'^~ey ),
   !Sessk( ~ey, kdf(<X^~ey, em(skB, hp($A)), $A, $B, X, 'g'^~ey>) )
   ]

