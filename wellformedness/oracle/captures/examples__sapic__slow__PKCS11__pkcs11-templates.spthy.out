)<=>((wrap1 = 'on') ∧ (extr2 = 'on')) ∧
((wwt2 = 'off') ∨ ((wwt2 = 'on') ∧ (trus1 = 'on')))

predicate: Can_unwrap( wrap, unwrap, enc, dec, sens, extr, trus, wwt, wt, ut )<=>unwrap = 'on'

predicate: Can_get_keyvalue( wrap, unwrap, enc, dec, sens, extr, trus, wwt,
