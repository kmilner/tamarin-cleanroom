)<=>sens = 'off'

predicate: Permits( t_wrap, t_unwrap, t_enc, t_dec, t_sens, t_extr, t_trus,
         t_wwt, t_wt, t_ut, wrap, unwrap, enc, dec, sens, extr, trus, wwt,
