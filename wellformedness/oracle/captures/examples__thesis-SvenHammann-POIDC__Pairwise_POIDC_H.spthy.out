rule (modulo E) Registration_RP[color=#f9e79f]:
   [ !St_IdP_Init( $IdP ), !Ltk( $IdP, ~ltk ) ]
  --[
  Neq( $RP, $IdP ), RPRegisters( $RP, $IdP ), Not_an_IdP( $RP ),
