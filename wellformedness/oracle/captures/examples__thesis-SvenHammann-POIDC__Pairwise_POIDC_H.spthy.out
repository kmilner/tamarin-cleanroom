             ((UserRegisters( x ) @ #i.1) ∧ (UserRegisters( y ) @ #j)) ⇒ (x = y))) ∧
          (∀ x y #i.1 #j.
            ((IdPInitializes( x ) @ #i.1) ∧ (IdPInitializes( y ) @ #j)) ⇒ (x = y))) ∧
         (∀ rp1 rp2 idp #i.1 #j.
           ((RPRegisters( rp1, idp ) @ #i.1) ∧ (RPRegisters( rp2, idp ) @ #j)) ⇒
           (rp1 = rp2))) ∧
        (∀ x y a b #i.1 #j.
          ((UserStarts( x, a ) @ #i.1) ∧ (UserStarts( y, b ) @ #j)) ⇒
