lemma functional:
  exists-trace
  "∃ H v #s #i #i2 D P #d b #h #h2 #k #l BB #m A r skS #o #p.
    (((((((((((InitK( H, 'v', v ) @ #s) ∧ (Send( H, D, <'v', v> ) @ #i)) ∧
             (Claim( H, 'vote' ) @ #i2)) ∧
            (D1( ) @ #d)) ∧
           (Send( H, P, <'b', b> ) @ #h)) ∧
          (Claim( H, 'ballot' ) @ #h2)) ∧
         (BB_rec( BB, <'bs', b> ) @ #k)) ∧
        (BB_tal( BB, <'vs', v> ) @ #l)) ∧
       (Receive( BB, H, <'bs', b> ) @ #m)) ∧
      (From( 'BB' ) @ #m)) ∧
     (VerifyA2( A,
                verzkp(zkp(encp(v, r, pk(skS)), v, skS), encp(v, r, pk(skS)), v, pk(skS))
      ) @ #o)) ∧
    (Claim( H, 'IVHE4' ) @ #p)"
