   ]

  /* has exactly the trivial AC variant */

rule (modulo E) A_1:
   [
   AgSt_A0( $A, <$S, $BB, pkS> ), In_A( $BB, <'bs', sg(bPrimea, sskDa)> ),
   In_A( $BB, <'bPrime', bPrimea> ), In_A( $BB, <'vs', va> ),
   In_A( $BB, <'zkp', p> ), In_A( $BB, <'spkD', pk(sskDa)> )
   ]
  --[
  Learn_A_proof( $A, <'zkp', p> ),
  Learn_A_spkDSG( $A, <'spkD', pk(sskDa)> ), Learn_A_Vs( $A, <'vs', va> ),
  Learn_A_Bs( $A, <'bs', sg(bPrimea, sskDa)> ),
  Learn_A_bPrimes( $A, <'bPrime', bPrimea> ),
  VerifyA2( $A, verzkp(p, bPrimea, va, pkS) ),
  Learn_A_ballot( $A, sg(bPrimea, sskDa) ), A1( )
  ]->
   [ ]

  /* has exactly the trivial AC variant */

rule (modulo E) H_3:
   [ AgSt_H2( $H, <$D, $BB, $v, b> ), In_A( $BB, <'bs', b> ) ]
