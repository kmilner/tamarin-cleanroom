theory aletheaD_vot_HE_SmHh

begin

// Function signature and definition of the equational theory E

functions: adec/2, aenc/2, decp/2, encp/3, fst/1, h/1, pair/2, pk/1,
           sg/2, snd/1, ver/2, verzkp/4, zkp/3
equations:
    adec(aenc(x.1, pk(x.2)), x.2) = x.1,
    decp(encp(x, r, pk(sk)), sk) = x,
    fst(<x.1, x.2>) = x.1,
    snd(<x.1, x.2>) = x.2,
    ver(sg(m, sk), pk(sk)) = m

rule (modulo E) H_Fresh:
   [ Fr( ~x ) ]
  --[ Fresh( $H, $t, ~x ), HK_event( $H, $t, ~x ), Untrained( $H ) ]->
   [ !HK( $H, $t, ~x ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) H_Send_I:
   [ !HK( $H, $t, x ) ]
  --[ Send( $H, $A, <$t, x> ), Untrained( $H ) ]->
   [ Out( <$t, x> ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) H_Receive_I:
   [ In( <$t, x> ) ]
  --[ Receive( $A, $H, <$t, x> ), HK_event( $H, $t, x ), Untrained( $H )
  ]->
   [ !HK( $H, $t, x ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) H_Send_S:
   [ !HK( $H, $t, x ) ]
  --[ Send( $H, $A, <$t, x> ), To( $A ), Untrained( $H ) ]->
   [ Out_S( $H, $A, <$t, x> ) ]

  // loop breaker: [0]
  /* has exactly the trivial AC variant */

rule (modulo E) H_Receive_S:
   [ In_S( $A, $H, <$t, x> ) ]
  --[
  Receive( $A, $H, <$t, x> ), From( $A ), HK_event( $H, $t, x ),
  Untrained( $H )
  ]->
   [ !HK( $H, $t, x ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) H_Receive_A:
   [ In_A( $A, <$t, x> ) ]
  --[
  Receive( $A, $H, <$t, x> ), From( $A ), HK_event( $H, $t, x ),
  Untrained( $H )
  ]->
   [ !HK( $H, $t, x ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) H_Claim:
   [ ] --[ Claim( $H, $goal ), Untrained( $H ) ]-> [ ]

  /* has exactly the trivial AC variant */

rule (modulo E) ChanOut_S:
   [ Out_S( $A, $B, x ) ]
  --[ ChanOut_S( $A, $B, x ) ]->
   [ !Sec( $A, $B, x ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) ChanIn_S:
   [ !Sec( $A, $B, x ) ] --[ ChanIn_S( $A, $B, x ) ]-> [ In_S( $A, $B, x ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) ChanOut_A:
   [ Out_A( $A, x ) ]
  --[ ChanOut_A( $A, x ) ]->
   [ !Auth( $A, x ), Out( <$A, x> ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) ChanIn_A:
   [ !Auth( $A, x ) ] --[ ChanIn_A( $A, x ) ]-> [ In_A( $A, x ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) publickeyinfrastructure:
   [ Fr( ~skX ) ]
  --[ LongtermKey( $X, ~skX ) ]->
   [ !Ltk( $X, ~skX ), !Pk( $X, pk(~skX) ), Out( pk(~skX) ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Setup:
   [ !Ltk( 'S', ~skS ), !Ltk( 'D1', ~sskD1 ) ]
  --[
  Setup( ), BB_pskDs( 'BB', <'spkD', pk(~sskD1)> ), SecretKeyD( ~sskD1 ),
  DeviceKey( 'D1', 'H1', ~sskD1 ), Pseudonym( 'H1', pk(~sskD1) ),
  Human( 'H1' ), Goal( 'H1', 'IVHE', <<'v', 'b'>, $v1, 'ukn'> ),
  Goal( 'H1', 'IVHE2', <'v', $v1> ), Goal( 'H1', 'vote', <'v', $v1> ),
  Goal( 'H1', 'ballot', <'b', 'ukn'> ),
  Goal( 'H1', 'IVHE4', <<'b', 'bs'>, 'ukn', 'ukn'> ),
  HK_event( 'H1', 'D', 'D1' ), HK_event( 'H1', 'BB', 'BB' ),
  HK_event( 'H1', 'v', $v1 ), InitK( 'H1', 'D', 'D1' ),
  InitK( 'H1', 'BB', 'BB' ), InitK( 'H1', 'v', $v1 ),
  NoOverwrite( 'H1', 'v' ), GetFrom( 'H1', 'bs', 'BB' ),
  GetFrom( 'H1', 'b', 'D' ), Compare( 'H1', 'b', 'bs' )
  ]->
   [
   AgSt_H0( 'H1', <'D1', 'BB', $v1> ),
   AgSt_D0( 'D1', <'H1', 'S', pk(~skS), ~sskD1> ),
   AgSt_A0( 'A', <'S', 'BB', pk(~skS)> ),
   AgSt_BB0( 'BB', <'S', pk(~sskD1)> ), Out_A( 'BB', <'spkD', pk(~sskD1)> ),
   Out( <'S', ~skS, pk(~sskD1)> ), !HK( 'H1', 'D', 'D1' ),
   !HK( 'H1', 'BB', 'BB' ), !HK( 'H1', 'v', $v1 )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) H_1:
   [ AgSt_H0( $H, <$D, $BB, $v> ) ]
  --[
