   (∀ d k l h #keyImport.
     (ImportKey( d, k, l, h ) @ #keyImport) ⇒
     (∃ #keyCreate.
       (CreateKey( k, h, l ) @ #keyCreate) ∧ (#keyCreate < #keyImport)))"
