  expanded formula:
  "∀ #i #j. ((Setup( ) @ #i) ∧ (Setup( ) @ #j)) ⇒ (#i = #j)"
  */

lemma functional_env1:
  exists-trace
  "(∀ #s1 #s2. ((Setup( ) @ #s1) ∧ (Setup( ) @ #s2)) ⇒ (#s1 = #s2)) ∧
   (∃ #s #j1 #j2 #k1 #k2 #e #m1 #m2 #a S HSel HNotsel xSel xNotsel noSel
      noNotsel DSel DNotsel E A.
     ((((((((((((((¬(HSel = HNotsel)) ∧ (H_x_no( HSel, xSel, noSel ) @ #s)) ∧
                 (H_x_no( HNotsel, xNotsel, noNotsel ) @ #s)) ∧
                (Comm_D_Y( DSel, h(<HSel, xSel>) ) @ #j1)) ∧
               (Comm_D_Y( DNotsel, h(<HNotsel, xNotsel>) ) @ #j2)) ∧
              (Learn_H_yD( HSel, DSel, h(<HSel, xSel>) ) @ #k1)) ∧
             (Learn_H_yD( HNotsel, DNotsel, h(<HNotsel, xNotsel>) ) @ #k2)) ∧
            (Learn_H_Ys( HSel, S,
                         <'ys', (<h(<HNotsel, xNotsel>), noNotsel>++<h(<HSel, xSel>), noSel>)>
             ) @ #k1)) ∧
           (Learn_H_Ys( HNotsel, S,
                        <'ys', (<h(<HNotsel, xNotsel>), noNotsel>++<h(<HSel, xSel>), noSel>)>
            ) @ #k2)) ∧
          (Env_No( E, noSel ) @ #e)) ∧
         (Env_No( E, '1' ) @ #e)) ∧
        (Learn_H_ySG( HSel, S, <'ySG', h(<HSel, xSel>)> ) @ #m1)) ∧
       (Learn_H_ySG( HNotsel, S, <'ySG', h(<HSel, xSel>)> ) @ #m2)) ∧
      (Learn_A_noSel( A, E, noSel ) @ #a)) ∧
     (Learn_A_ySG( A, S, h(<HSel, xSel>) ) @ #a))"
