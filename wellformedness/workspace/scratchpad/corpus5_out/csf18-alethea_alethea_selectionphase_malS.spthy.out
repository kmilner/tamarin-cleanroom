lemma universalVerifiability_sel:
  all-traces
  "∀ #a1 #a2 #a3 S A y1 no1 y2 no2 E.
    (((Learn_A_Ys( A, S, <'ys', (<y1, no1>++<y2, no2>)> ) @ #a1) ∧
      (Learn_A_noSel( A, E, no1 ) @ #a2)) ∧
     (Learn_A_ySG( A, S, y1 ) @ #a3)) ⇒
    (∃ BB #b1 #b2.
      (BB_Ys( BB, 'ys', (<y1, no1>++<y2, no2>) ) @ #b1) ∧
      (BB_YSG( BB, <'ySG', y1> ) @ #b2))"
