theory alethea_selectionphase_malS

begin

// Function signature and definition of the equational theory E

builtins: multiset
functions: adec/2, aenc/2, fst/1, h/1, pair/2, pk/1, sdec/2, senc/2,
           sign/2, snd/1, true/0, verify/3
equations:
    adec(aenc(x.1, pk(x.2)), x.2) = x.1,
    fst(<x.1, x.2>) = x.1,
    sdec(senc(x.1, x.2), x.2) = x.1,
    snd(<x.1, x.2>) = x.2,
    verify(sign(x.1, x.2), x.1, pk(x.2)) = true

rule (modulo E) ChanOut_S:
   [ Out_S( $A, $B, x ) ]
  --[ ChanOut_S( $A, $B, x ) ]->
   [ !Sec( $A, $B, x ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) ChanIn_S:
   [ !Sec( $A, $B, x ) ] --[ ChanIn_S( $A, $B, x ) ]-> [ In_S( $A, $B, x ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) ChanOut_A:
   [ Out_A( $A, x ) ]
  --[ ChanOut_A( $A, x ) ]->
   [ !Auth( $A, x ), Out( <$A, x> ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) ChanIn_A:
   [ !Auth( $A, x ) ] --[ ChanIn_A( $A, x ) ]-> [ In_A( $A, x ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) publickeyinfrastructure:
   [ Fr( ~skX ) ]
  --[ LongtermKey( $X, ~skX ) ]->
   [ !Ltk( $X, ~skX ), !Pk( $X, pk(~skX) ), Out( pk(~skX) ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Setup:
   [ Fr( ~x1 ), Fr( ~x2 ), !Ltk( 'D1', ~skD1 ), !Ltk( 'D2', ~skD2 ) ]
  --[ Setup( ), H_x_no( 'H1', ~x1, '1' ), H_x_no( 'H2', ~x2, '2' ) ]->
   [
   AgSt_D0( 'D1', <~skD1, 'S', 'H1'> ), AgSt_D0( 'D2', <~skD2, 'S', 'H2'> ),
   Out( <'S', 'BB', 'E', 
         (<'H1', 'D1', pk(~skD1), ~x1, '1'>++<'H2', 'D2', pk(~skD2), ~x2, '2'>)>
   ),
   AgSt_H0( 'H1', <'D1', 'S', 'BB'> ), AgSt_H0( 'H2', <'D2', 'S', 'BB'> ),
   AgSt_A0( 'A', <'S', 'BB', 'E'> ), Env( 'E' ), AgSt_BB0( 'BB', 'S' )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) BB_2:
   [ AgSt_BB0( $BB, $S ), In( <$S, 'ys', (<y1, no1>++<y2, no2>)> ) ]
  --[ BB_Ys( $BB, 'ys', (<y1, no1>++<y2, no2>) ) ]->
   [
   AgSt_BB2( $BB, <$S, 'ys', (<y1, no1>++<y2, no2>)> ),
   Out_A( $BB, <'ys', (<y1, no1>++<y2, no2>)> ), YPublished( )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) A_3:
   [
   AgSt_A0( $A, <$S, $BB, $E> ), In_A( $BB, <'ys', (<y1, no1>++<y2, no2>)> )
   ]
  --[ Learn_A_Ys( $A, $S, <'ys', (<y1, no1>++<y2, no2>)> ) ]->
   [ AgSt_A3( $A, <$S, $BB, $E, 'ys', (<y1, no1>++<y2, no2>)> ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) D_4:
   [ AgSt_D0( $D, <~skD, $S, $H> ), In( <$S, aenc(x, pk(~skD))> ) ]
  --[ Comm_D_Y( $D, h(<$H, x>) ), Commit( $D, $S, $H, x ) ]->
   [ Out_S( $D, $H, h(<$H, x>) ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) H_5:
   [
   AgSt_H0( $H, <$D, $S, $BB> ), In_S( $D, $H, yD ),
   In_A( $BB, <'ys', (<y1, no1>++<y2, no2>)> )
   ]
  --[
  Learn_H_yD( $H, $D, yD ),
  Learn_H_Ys( $H, $S, <'ys', (<y1, no1>++<y2, no2>)> )
  ]->
   [ AgSt_H5( $H, <$D, $S, $BB, yD, y1, y2> ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) environment_1:
   [ Env( $E ), YPublished( ) ]
  --[ Env_No( $E, '1' ) ]->
   [ Out_A( $E, '1' ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) environment_2:
   [ Env( $E ), YPublished( ) ]
  --[ Env_No( $E, '2' ) ]->
   [ Out_A( $E, '2' ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) BB_8:
   [
   AgSt_BB2( $BB, <$S, 'ys', (<y1, no1>++<y2, no2>)> ),
   In( <$S, 'ySG', ySG> )
   ]
  --[ BB_YSG( $BB, <'ySG', ySG> ) ]->
   [ Out_A( $BB, <'ySG', ySG> ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) H_9:
   [ AgSt_H5( $H, <$D, $S, $BB, yD, y1, y2> ), In_A( $BB, <'ySG', ySG> ) ]
  --[ Learn_H_ySG( $H, $S, <'ySG', ySG> ) ]->
   [ ]

  /* has exactly the trivial AC variant */

rule (modulo E) A_9:
   [
   AgSt_A3( $A, <$S, $BB, $E, 'ys', (<y1, no1>++<y2, no2>)> ),
   In_A( $E, noSel ), In_A( $BB, <'ySG', ySG> )
   ]
  --[ Learn_A_noSel( $A, $E, noSel ), Learn_A_ySG( $A, $S, ySG ) ]->
   [ ]

  /* has exactly the trivial AC variant */

restriction OneSetup:
  "∀ #i #j. ((Setup( ) @ #i) ∧ (Setup( ) @ #j)) ⇒ (#i = #j)"
  // safety formula

