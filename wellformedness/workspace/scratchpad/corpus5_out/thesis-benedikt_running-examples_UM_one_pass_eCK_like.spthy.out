theory UM_one_pass_eCK_like

begin

// Function signature and definition of the equational theory E

builtins: diffie-hellman
functions: fst/1, h/1, pair/2, snd/1
equations: fst(<x.1, x.2>) = x.1, snd(<x.1, x.2>) = x.2

rule (modulo E) Generate_key:
   [ Fr( ~ea ) ] --> [ !Ltk( $A, ~ea ), !Pk( $A, 'g'^~ea ), Out( 'g'^~ea ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Initiator:
   [ Fr( ~ex ), !Ltk( $A, ~ea ), !Pk( $B, 'g'^~eb ) ]
  --[
  Accept( <$A, $B, 'g'^~ex, 'I'>,
          h(<'g'^~eb^~ex, 'g'^~eb^~ea, $A, $B, 'g'^~ex>)
  )
  ]->
   [ Out( 'g'^~ex ), !Ephk( <$A, $B, 'g'^~ex, 'I'>, ~ex ) ]

  /*
  rule (modulo AC) Initiator:
     [ Fr( ~ex ), !Ltk( $A, ~ea ), !Pk( $B, 'g'^~eb ) ]
    --[
    Accept( <$A, $B, 'g'^~ex, 'I'>,
            h(<'g'^(~eb*~ex), 'g'^(~ea*~eb), $A, $B, 'g'^~ex>)
    )
    ]->
     [ Out( 'g'^~ex ), !Ephk( <$A, $B, 'g'^~ex, 'I'>, ~ex ) ]
  */

rule (modulo E) Responder:
   [ In( X ), !Ltk( $B, ~eb ), !Pk( $A, 'g'^~ea ) ]
  --[ Accept( <$B, $A, X, 'R'>, h(<X^~eb, 'g'^~ea^~eb, $A, $B, X>) ) ]->
   [ ]

  /*
  rule (modulo AC) Responder:
     [ In( X ), !Ltk( $B, ~eb ), !Pk( $A, 'g'^~x ) ]
    --[ Accept( <$B, $A, X, 'R'>, h(<z, 'g'^(~eb*~x), $A, $B, X>) ) ]->
     [ ]
    variants (modulo AC)
    1. ~eb   = ~eb.28
       X     = X.29
       z     = X.29^~eb.28
    
    2. ~eb   = ~eb.28
       X     = z.32^inv(~eb.28)
       z     = z.32
    
    3. ~eb   = ~eb.137
       X     = x.268^x.269
       z     = x.268^(~eb.137*x.269)
    
    4. ~eb   = ~eb.138
       X     = x.270^inv((~eb.138*x.271))
       z     = x.270^inv(x.271)
    
    5. ~eb   = ~eb.138
       X     = x.270^(x.271*inv(~eb.138))
       z     = x.270^x.271
    
    6. ~eb   = ~eb.139
       X     = x.271^(x.272*inv((~eb.139*x.273)))
       z     = x.271^(x.272*inv(x.273))
    
    7. X     = DH_neutral
       z     = DH_neutral
  */

rule (modulo E) Ephemeral_Reveal:
   [ !Ephk( sid, ~x ) ] --[ RevealEphk( sid ) ]-> [ Out( ~x ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Ltk_Reveal:
   [ !Ltk( $A, ~ea ) ] --[ RevealLtk( $A ) ]-> [ Out( ~ea ) ]

  /* has exactly the trivial AC variant */

lemma UM_secure_responder:
  all-traces
  "∀ #i #j A B X key msid.
    (((Accept( <B, A, X, 'R'>, key ) @ #i) ∧ (K( key ) @ #j)) ∧
     (msid = <A, B, X, 'I'>)) ⇒
    (((∃ #k. RevealLtk( B ) @ #k) ∨
      (∃ #k #l. (RevealEphk( msid ) @ #k) ∧ (RevealLtk( A ) @ #l))) ∨
     ((¬(∃ #k key_. Accept( msid, key_ ) @ #k)) ∧
      (∃ #k. RevealLtk( A ) @ #k)))"
/*
guarded formula characterizing all counter-examples:
"∃ #i #j A B X key msid.
  (Accept( <B, A, X, 'R'>, key ) @ #i) ∧
  (K( key ) @ #j) ∧
  (msid = <A, B, X, 'I'>)
 ∧
  (∀ #k. (RevealLtk( B ) @ #k) ⇒ ⊥) ∧
  (∀ #k #l. (RevealEphk( msid ) @ #k) ∧ (RevealLtk( A ) @ #l) ⇒ ⊥) ∧
  (((∃ #k key_. (Accept( msid, key_ ) @ #k)) ∨
    (∀ #k. (RevealLtk( A ) @ #k) ⇒ ⊥)))"
*/
by sorry

