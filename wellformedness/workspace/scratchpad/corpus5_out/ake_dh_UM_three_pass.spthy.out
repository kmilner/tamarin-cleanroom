                  <'R', $B, $A, Y, 'g'^~ex>)
             >
            )
           >
   ),
   Out( MAC(first(h(<Y^~ex, 'g'^~eb^~ea, $A, $B, 'g'^~ex, Y>)),
            <'R', $B, $A, Y, 'g'^~ex>)
   ),
