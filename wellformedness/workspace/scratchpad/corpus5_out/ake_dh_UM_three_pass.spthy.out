                   <'I', $A, $B, 'g'^~ex, Y>)
              >++
              <'3', 
               MAC(first(h(<Y^~ex, 'g'^~eb^~ea, $A, $B, 'g'^~ex, Y>)),
                   <'R', $B, $A, Y, 'g'^~ex>)
              >
             )
            >,
            'I', second(h(<Y^~ex, 'g'^~eb^~ea, $A, $B, 'g'^~ex, Y>))
  ),
  SidUpdated( <'UM3', $A, $B, '1', 'g'^~ex> ),
  Sid( <'UM3', $A, $B, 
        (<'1', 'g'^~ex>++
         <'2', Y, 
          MAC(first(h(<Y^~ex, 'g'^~eb^~ea, $A, $B, 'g'^~ex, Y>)),
              <'I', $A, $B, 'g'^~ex, Y>)
         >++
         <'3', 
          MAC(first(h(<Y^~ex, 'g'^~eb^~ea, $A, $B, 'g'^~ex, Y>)),
              <'R', $B, $A, Y, 'g'^~ex>)
         >
        )
       >
  )
  ]->
   [
   I_Comp( <'UM3', $A, $B, 
            (<'1', 'g'^~ex>++
             <'2', Y, 
              MAC(first(h(<Y^~ex, 'g'^~eb^~ea, $A, $B, 'g'^~ex, Y>)),
                  <'I', $A, $B, 'g'^~ex, Y>)
             >++
