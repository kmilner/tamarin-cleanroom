lemma acc_VoterC_faultyS_strong_H4_suff:
  exists-trace
  "∃ S sid Sp BB ba sskDa #i #j #k #l.
    (((((((S = <sid, Sp>) ∧ (Server( S ) @ #i)) ∧
         (BB_rec( <sid, BB>, <'b', ba> ) @ #j)) ∧
        (BB_pskDs( <sid, BB>, <'spkD', pk(sskDa)> ) @ #k)) ∧
       (¬(∃ bPrimeb. ba = sg(bPrimeb, sskDa)))) ∧
      (H4( sid ) @ #l)) ∧
     (∀ S.1 sid.1 Sp.1 BB.1 ba.1 sskDa.1 #i.1 #j.1 #k.1 #l.1.
       ((((((S.1 = <sid.1, Sp.1>) ∧ (Server( S.1 ) @ #i.1)) ∧
           (BB_rec( <sid.1, BB.1>, <'b', ba.1> ) @ #j.1)) ∧
          (BB_pskDs( <sid.1, BB.1>, <'spkD', pk(sskDa.1)> ) @ #k.1)) ∧
         (¬(∃ bPrimeb. ba.1 = sg(bPrimeb, sskDa.1)))) ∧
        (H4( sid.1 ) @ #l.1)) ⇒
       (S.1 = S))) ∧
    (∀ a #i.1. (Corrupted( a ) @ #i.1) ⇒ (a = S))"
/*
guarded formula characterizing all satisfying traces:
"∃ S sid Sp BB ba sskDa #i #j #k #l.
