lemma Uniqueness:
  all-traces
  "∀ #i bs sid BB BBp.
    ((((BB = <sid, BBp>) ∧
       (¬(∃ b BB.1 BBp.1 skS #k #l #m ba.
           ((((BB.1 = <sid, BBp.1>) ∧ (BB_rec( BB.1, <'b', ba> ) @ #k)) ∧
             (¬(b = ba))) ∧
            (Evidence( sid, b, sg(b, skS) ) @ #l)) ∧
           (BB_pkS( BB.1, <'spkS', pk(skS)> ) @ #m)))) ∧
      (¬(∃ BB.1 BBp.1 ba bPrimea sskDa #k #l #m.
          ((((BB.1 = <sid, BBp.1>) ∧ (BB_rec( BB.1, <'b', ba> ) @ #k)) ∧
            (BB_woS( BB.1, <'bPrime', bPrimea> ) @ #l)) ∧
           (BB_pskDs( BB.1, <'spkD', pk(sskDa)> ) @ #m)) ∧
          (¬(ba = sg(bPrimea, sskDa)))))) ∧
     (BB_rec( BB, <'b', bs> ) @ #i)) ⇒
    (∃ BB.1 BBp.1 H H1 H1p bPrime1 sskD1 #bb #s #h1 P.
      ((((((BB.1 = <sid, BBp.1>) ∧ (H = <sid, 'H'>)) ∧ (H1 = <sid, H1p>)) ∧
         (BB_H( BB.1, <H, H1> ) @ #bb)) ∧
        (bs = sg(bPrime1, sskD1))) ∧
       (CastByCorresp( H1, pk(sskD1) ) @ #s)) ∧
      (Send( H1, P, bs ) @ #h1))"
/*
guarded formula characterizing all counter-examples:
"∃ #i bs sid BB BBp.
  (BB = <sid, BBp>) ∧ (BB_rec( BB, <'b', bs> ) @ #i)
 ∧
  (∀ b BB.1 BBp.1 skS #k #l #m ba.
    (BB.1 = <sid, BBp.1>) ∧
    (BB_rec( BB.1, <'b', ba> ) @ #k) ∧
    (Evidence( sid, b, sg(b, skS) ) @ #l) ∧
    (BB_pkS( BB.1, <'spkS', pk(skS)> ) @ #m)
   ⇒
    b = ba) ∧
  (∀ BB.1 BBp.1 ba bPrimea sskDa #k #l #m.
    (BB.1 = <sid, BBp.1>) ∧
    (BB_rec( BB.1, <'b', ba> ) @ #k) ∧
    (BB_woS( BB.1, <'bPrime', bPrimea> ) @ #l) ∧
    (BB_pskDs( BB.1, <'spkD', pk(sskDa)> ) @ #m)
   ⇒
    ba = sg(bPrimea, sskDa)) ∧
  (∀ BB.1 BBp.1 H H1 H1p bPrime1 sskD1 #bb #s #h1 P.
    (BB.1 = <sid, BBp.1>) ∧
    (H = <sid, 'H'>) ∧
    (H1 = <sid, H1p>) ∧
    (BB_H( BB.1, <H, H1> ) @ #bb) ∧
    (bs = sg(bPrime1, sskD1)) ∧
    (CastByCorresp( H1, pk(sskD1) ) @ #s) ∧
    (Send( H1, P, bs ) @ #h1)
   ⇒
    ⊥)"
*/
by sorry

