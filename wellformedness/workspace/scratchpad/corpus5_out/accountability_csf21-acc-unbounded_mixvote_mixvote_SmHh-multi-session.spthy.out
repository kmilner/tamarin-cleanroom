lemma TalliedAsRecorded:
  all-traces
  "∀ sid A Ap #a spkD p votes ballots bPrimes sk xa ra.
    (((((((A = <sid, Ap>) ∧ (Learn_A_spkDSG( A, <'spkD', spkD> ) @ #a)) ∧
         (Learn_A_proof( A, <'zkp', p> ) @ #a)) ∧
        (Learn_A_Vs( A, <'v', votes> ) @ #a)) ∧
       (Learn_A_Bs( A, <'b', ballots> ) @ #a)) ∧
      (Learn_A_bPrimes( A, <'bPrime', bPrimes> ) @ #a)) ∧
     (VerifyA2( A,
                verzkp(zkp(encp(xa, ra, pk(sk)), xa, sk), encp(xa, ra, pk(sk)), xa,
                       pk(sk))
      ) @ #a)) ⇒
    (∃ #b BB BBp r1 sskD1 #b2.
      (((((BB = <sid, BBp>) ∧ (BB_rec( BB, <'b', ballots> ) @ #b)) ∧
         (BB_tal( BB, <'v', votes> ) @ #b)) ∧
        (BB_pskDs( BB, <'spkD', spkD> ) @ #b2)) ∧
       (spkD = pk(sskD1))) ∧
      (ballots = sg(encp(votes, r1, pk(sk)), sskD1)))"
