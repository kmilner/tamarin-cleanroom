lemma functional:
  exists-trace
  "∃ sid H1 H1p v #i #d #h b P Pp #p S Sp #s c #p2 #i2 #k #l BB BBp #m A Ap
     bPrimea skS #o.
    (((((((((((((((((H1 = <sid, H1p>) ∧ (P = <sid, Pp>)) ∧ (S = <sid, Sp>)) ∧
                  (BB = <sid, BBp>)) ∧
                 (A = <sid, Ap>)) ∧
                (Vote( H1, v ) @ #i)) ∧
               (D1( sid ) @ #d)) ∧
              (Ballot( H1, b ) @ #h)) ∧
             (Receive_R_HP( H1, P, b ) @ #p)) ∧
            (Receive_R_PS( P, S, b ) @ #s)) ∧
           (Send_R_SP( S, P, c ) @ #s)) ∧
          (Receive_R_SP( S, P, c ) @ #p2)) ∧
         (Send_R_PH( P, H1, c ) @ #p2)) ∧
        (Evidence( sid, b, c ) @ #i2)) ∧
       (BB_rec( BB, <'b', b> ) @ #k)) ∧
      (BB_tal( BB, <'v', v> ) @ #l)) ∧
     (Verify( H1, b, b ) @ #m)) ∧
    (VerifyA2( A, verzkp(zkp(bPrimea, v, skS), bPrimea, v, pk(skS)) ) @ #o)"
/*
guarded formula characterizing all satisfying traces:
"∃ sid H1 H1p v #i #d #h b P Pp #p S Sp #s c #p2 #i2 #k #l BB BBp #m A Ap
   bPrimea skS #o.
  (H1 = <sid, H1p>) ∧
  (P = <sid, Pp>) ∧
  (S = <sid, Sp>) ∧
  (BB = <sid, BBp>) ∧
  (A = <sid, Ap>) ∧
  (Vote( H1, v ) @ #i) ∧
  (D1( sid ) @ #d) ∧
  (Ballot( H1, b ) @ #h) ∧
  (Receive_R_HP( H1, P, b ) @ #p) ∧
  (Receive_R_PS( P, S, b ) @ #s) ∧
  (Send_R_SP( S, P, c ) @ #s) ∧
  (Receive_R_SP( S, P, c ) @ #p2) ∧
  (Send_R_PH( P, H1, c ) @ #p2) ∧
  (Evidence( sid, b, c ) @ #i2) ∧
  (BB_rec( BB, <'b', b> ) @ #k) ∧
  (BB_tal( BB, <'v', v> ) @ #l) ∧
  (Verify( H1, b, b ) @ #m) ∧
  (VerifyA2( A, verzkp(zkp(bPrimea, v, skS), bPrimea, v, pk(skS)) ) @ #o)"
*/
by sorry

lemma indivVerif:
  all-traces
  "∀ sid H Hp v #i b #j.
    (((H = <sid, Hp>) ∧ (Vote( H, v ) @ #i)) ∧ (Verify( H, b, b ) @ #j)) ⇒
    (∃ BB BBp #l r pkS sskD.
      ((BB = <sid, BBp>) ∧ (BB_rec( BB, <'b', b> ) @ #l)) ∧
      (b = sg(encp(v, r, pkS), sskD)))"
/*
guarded formula characterizing all counter-examples:
"∃ sid H Hp v #i b #j.
  (H = <sid, Hp>) ∧ (Vote( H, v ) @ #i) ∧ (Verify( H, b, b ) @ #j)
 ∧
  ∀ BB BBp #l r pkS sskD.
   (BB = <sid, BBp>) ∧
   (BB_rec( BB, <'b', b> ) @ #l) ∧
   (b = sg(encp(v, r, pkS), sskD))
  ⇒
   ⊥"
*/
by sorry

lemma VoterC:
  all-traces
  "∀ sid H Hp b #j b1.
    ((H = <sid, Hp>) ∧ (Verify( H, b, b1 ) @ #j)) ⇒
    (((∃ BB BBp #k. (BB = <sid, BBp>) ∧ (BB_rec( BB, <'b', b> ) @ #k)) ∨
      (∃ BB BBp skS #k #l #m ba.
        ((((BB = <sid, BBp>) ∧ (BB_rec( BB, <'b', ba> ) @ #k)) ∧ (¬(b = ba))) ∧
         (Evidence( sid, b, sg(b, skS) ) @ #l)) ∧
