  "∀ x y #i. (Eq( x, y ) @ #i) ⇒ (x = y)"
  */

restriction InEq_testing:
  "∀ x y #i. (InEq( x, y ) @ #i) ⇒ (¬(x = y))"
  // safety formula

  /*
  expanded formula:
  "∀ x y #i. (InEq( x, y ) @ #i) ⇒ (¬(x = y))"
  */

