lemma invariant_sources [sources]:
  all-traces
  "(∀ id ka kb #i.
     (Invariant_C( id, ka, kb ) @ #i) ⇒
     (∃ #j. (F_InvariantSource_C( id, ka, kb ) @ #j) ∧ (#j < #i))) ∧
   (∀ id ka kb #i.
     (Invariant_W( id, ka, kb ) @ #i) ⇒
     (∃ #j. (F_InvariantSource_W( id, ka, kb ) @ #j) ∧ (#j < #i)))"
/*
guarded formula characterizing all counter-examples:
"((∃ id ka kb #i.
    (Invariant_C( id, ka, kb ) @ #i)
   ∧
    ∀ #j. (F_InvariantSource_C( id, ka, kb ) @ #j) ⇒ ¬(#j < #i)) ∨
  (∃ id ka kb #i.
    (Invariant_W( id, ka, kb ) @ #i)
   ∧
    ∀ #j. (F_InvariantSource_W( id, ka, kb ) @ #j) ⇒ ¬(#j < #i)))"
*/
by sorry

lemma count_unique [reuse, use_induction]:
  all-traces
  "∀ id c #i #j.
    ((Counter( id, c ) @ #i) ∧ (Counter( id, c ) @ #j)) ⇒ (#i = #j)"
/*
guarded formula characterizing all counter-examples:
"∃ id c #i #j.
  (Counter( id, c ) @ #i) ∧ (Counter( id, c ) @ #j) ∧ ¬(#i = #j)"
*/
by sorry

lemma nonces_unique [reuse, use_induction]:
  all-traces
  "∀ id ni nr #i #j.
    ((Nonces( id, ni, nr ) @ #i) ∧ (Nonces( id, ni, nr ) @ #j)) ⇒ (#i = #j)"
/*
guarded formula characterizing all counter-examples:
"∃ id ni nr #i #j.
  (Nonces( id, ni, nr ) @ #i) ∧ (Nonces( id, ni, nr ) @ #j) ∧ ¬(#i = #j)"
*/
by sorry

lemma force_nonce_ordering [reuse]:
  all-traces
  "((∀ role pks nc nw c #i #j.
      ((Session( role, pks, <nc, nw>, c ) @ #i) ∧ (Gen( nc ) @ #j)) ⇒
      (#j < #i)) ∧
    (∀ role pks nc nw c #i #j.
      ((Session( role, pks, <nc, nw>, c ) @ #i) ∧ (Gen( nw ) @ #j)) ⇒
      (#j < #i))) ∧
   (∀ id nc nw #i #j.
     ((Nonces( id, nc, nw ) @ #i) ∧ (Gen( nc ) @ #j)) ⇒ (#j < #i))"
/*
guarded formula characterizing all counter-examples:
"((∃ role pks nc nw c #i #j.
    (Session( role, pks, <nc, nw>, c ) @ #i) ∧ (Gen( nc ) @ #j)
   ∧
    ¬(#j < #i)) ∨
  (∃ role pks nc nw c #i #j.
    (Session( role, pks, <nc, nw>, c ) @ #i) ∧ (Gen( nw ) @ #j)
