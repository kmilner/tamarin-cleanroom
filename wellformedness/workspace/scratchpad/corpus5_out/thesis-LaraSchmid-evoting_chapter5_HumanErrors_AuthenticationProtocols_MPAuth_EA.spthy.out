rule (modulo E) ChanOut_S:
   [ Out_S( $A, $B, xn, x ) ]
  --[ ChanOut_S( $A, $B, xn, x ) ]->
   [ !Sec( $A, $B, xn, x ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) ChanIn_S:
   [ !Sec( $A, $B, xn, x ) ]
  --[ ChanIn_S( $A, $B, xn, x ) ]->
   [ In_S( $A, $B, xn, x ) ]

  /* has exactly the trivial AC variant */

