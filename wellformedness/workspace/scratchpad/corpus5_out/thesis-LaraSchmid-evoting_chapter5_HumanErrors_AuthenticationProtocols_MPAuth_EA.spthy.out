    sdec(senc(x.1, x.2), x.2) = x.1,
    snd(<x.1, x.2>) = x.2,
    verify(sign(x.1, x.2), x.1, pk(x.2)) = true

rule (modulo E) H_fresh:
   [ Fr( ~x ) ]
  --[ Fresh( $H, $x.1, ~x ), !HK( $H, $x.1, ~x ), H( $H ) ]->
