restriction setup_for_IK:
  "∀ H #i. (H( H ) @ #i) ⇒ (∃ #j. (Setup( H ) @ #j) ∧ (#j < #i))"

  /*
  expanded formula:
  "∀ H #i. (H( H ) @ #i) ⇒ (∃ #j. (Setup( H ) @ #j) ∧ (#j < #i))"
  */

restriction not_Chan_S_human_to_human:
  "∀ A B mn m #i #j #k.
    (((ChanOut_S( A, B, mn, m ) @ #i) ∧ (H( A ) @ #j)) ∧ (H( B ) @ #k)) ⇒
    (⊥)"
  // safety formula

  /*
  expanded formula:
  "∀ A B mn m #i #j #k.
    (((ChanOut_S( A, B, mn, m ) @ #i) ∧ (H( A ) @ #j)) ∧ (H( B ) @ #k)) ⇒
    (⊥)"
  */

restriction notSameRole:
  "∀ H1 H2 D1 D2 P1 P2 S1 S2 #i #j.
    ((Roles( H1, D1, P1, S1 ) @ #i) ∧ (Roles( H2, D2, P2, S2 ) @ #j)) ⇒
    ((((((((((((¬(H1 = D1)) ∧ (¬(H1 = D2))) ∧ (¬(H1 = P1))) ∧ (¬(H1 = P2))) ∧
            (¬(H1 = S1))) ∧
           (¬(H1 = S2))) ∧
          (¬(D1 = P1))) ∧
         (¬(D1 = P2))) ∧
        (¬(D1 = S1))) ∧
       (¬(D1 = S2))) ∧
      (¬(P1 = S1))) ∧
     (¬(P1 = S2)))"
  // safety formula

  /*
  expanded formula:
  "∀ H1 H2 D1 D2 P1 P2 S1 S2 #i #j.
    ((Roles( H1, D1, P1, S1 ) @ #i) ∧ (Roles( H2, D2, P2, S2 ) @ #j)) ⇒
    ((((((((((((¬(H1 = D1)) ∧ (¬(H1 = D2))) ∧ (¬(H1 = P1))) ∧ (¬(H1 = P2))) ∧
            (¬(H1 = S1))) ∧
           (¬(H1 = S2))) ∧
          (¬(D1 = P1))) ∧
         (¬(D1 = P2))) ∧
        (¬(D1 = S1))) ∧
       (¬(D1 = S2))) ∧
      (¬(P1 = S1))) ∧
     (¬(P1 = S2)))"
  */

restriction Device:
  "∀ H1 H2 D #i #j.
    ((Device( H1, D ) @ #i) ∧ (Device( H2, D ) @ #j)) ⇒ (H1 = H2)"
  // safety formula

  /*
  expanded formula:
  "∀ H1 H2 D #i #j.
    ((Device( H1, D ) @ #i) ∧ (Device( H2, D ) @ #j)) ⇒ (H1 = H2)"
  */

restriction DeviceImmediateProcessing:
  "∀ D H xn x #i #k.
    (((Send( H, xn, x ) @ #i) ∧ (To( D ) @ #i)) ∧
     (DfromHx( D, H, xn, x ) @ #k)) ⇒
    (¬(∃ #j. ((D( D ) @ #j) ∧ (#i < #j)) ∧ (#j < #k)))"
  // safety formula

  /*
  expanded formula:
  "∀ D H xn x #i #k.
    (((Send( H, xn, x ) @ #i) ∧ (To( D ) @ #i)) ∧
