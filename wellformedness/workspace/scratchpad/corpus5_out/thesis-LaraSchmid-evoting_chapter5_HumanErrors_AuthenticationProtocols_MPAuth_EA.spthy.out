theory MPAuth_EA

begin

// Function signature and definition of the equational theory E

functions: adec/2, aenc/2, f/1, fst/1, h/1, pair/2, pk/1, pw/1, r/1,
           sdec/2, senc/2, sign/2, snd/1, true/0, verify/3
