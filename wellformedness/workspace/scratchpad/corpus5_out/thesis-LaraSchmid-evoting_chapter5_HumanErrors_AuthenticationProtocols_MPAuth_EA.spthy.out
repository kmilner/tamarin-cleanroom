    (¬(∃ #j. ((D( D ) @ #j) ∧ (#i < #j)) ∧ (#j < #k)))"
  */

restriction uniqueUserID:
  "∀ idH H1 H2 #i #j.
    ((User( idH, H1 ) @ #i) ∧ (User( idH, H2 ) @ #j)) ⇒ (H1 = H2)"
  // safety formula

  /*
  expanded formula:
  "∀ idH H1 H2 #i #j.
    ((User( idH, H1 ) @ #i) ∧ (User( idH, H2 ) @ #j)) ⇒ (H1 = H2)"
  */

lemma functional_withAgreement:
  exists-trace
  "(∀ H1 H2 #i #j. ((Setup( H1 ) @ #i) ∧ (Setup( H2 ) @ #j)) ⇒ (#i = #j)) ∧
   (∃ D #j S k m #k.1.
     ((CommitD( D, S, <'Human', k> ) @ #j) ∧
      (Commit( S, 'Human', m ) @ #k.1)) ∧
     (RunningS( S, D, <'Human', k> ) @ #k.1))"
/*
guarded formula characterizing all satisfying traces:
"(∀ H1 H2 #i #j. (Setup( H1 ) @ #i) ∧ (Setup( H2 ) @ #j) ⇒ #i = #j) ∧
 (∃ D #j S k m #k.1.
   (CommitD( D, S, <'Human', k> ) @ #j) ∧
   (Commit( S, 'Human', m ) @ #k.1) ∧
   (RunningS( S, D, <'Human', k> ) @ #k.1))"
*/
by sorry

lemma functional:
  exists-trace
  "(∀ H1 H2 #i #j. ((Setup( H1 ) @ #i) ∧ (Setup( H2 ) @ #j)) ⇒ (#i = #j)) ∧
   (∃ #k #n S m. (Dfin( ) @ #k) ∧ (Commit( S, 'Human', m ) @ #n))"
/*
guarded formula characterizing all satisfying traces:
"(∀ H1 H2 #i #j. (Setup( H1 ) @ #i) ∧ (Setup( H2 ) @ #j) ⇒ #i = #j) ∧
 (∃ #k #n S m. (Dfin( ) @ #k) ∧ (Commit( S, 'Human', m ) @ #n))"
*/
by sorry

lemma entity_authentication:
  all-traces
  "∀ S m #k.
    (Commit( S, 'Human', m ) @ #k) ⇒
    ((∃ #i #j.
       (((Sstart( S ) @ #i) ∧ (H( 'Human' ) @ #j)) ∧ (#i < #j)) ∧ (#j < #k)) ∨
     (∃ x #i #j.
       (((Sstart( S ) @ #i) ∧ (H_role( 'Human', x ) @ #j)) ∧ (#i < #j)) ∧
       (#j < #k)))"
/*
guarded formula characterizing all counter-examples:
"∃ S m #k.
  (Commit( S, 'Human', m ) @ #k)
 ∧
  (∀ #i #j.
    (Sstart( S ) @ #i) ∧ (H( 'Human' ) @ #j)
   ⇒
