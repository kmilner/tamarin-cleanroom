rule (modulo E) Setup:
   [ !Password( $H, $S, ~pw ), !Ltk( $S, ~skS ) ]
  --[
  Setup( $H ), Roles( $H, $D, $P, $S ), Device( $H, $D ), User( $idH, $H ),
  InitK( $H, 'D', $D ), InitK( $H, 'P', $P ), InitK( $H, 'S', $S ),
  InitK( $H, 'pw', pw(~pw) ), InitK( $H, 'idH', $idH ),
  InitK( $H, 'idS', $idS ), Rule4( $H, 'noTellEx', 'pw', $D )
  ]->
   [
   AgSt_D0( $D, 'D_0', <$H, $idH, pk(~skS)> ),
   AgSt_S0( $S, 'S_0', <~skS, $H, $idS, pw(~pw), $idH> ), !ID_S( $S, $idS ),
   !HK( $H, 'D', $D ), !HK( $H, 'P', $P ), !HK( $H, 'S', $S ),
   !HK( $H, 'pw', pw(~pw) ), !HK( $H, 'idH', $idH ), !HK( $H, 'idS', $idS ),
   AgSt_H0( $H, 'H_0', <$D, $P, $S, pw(~pw), $idH, $idS> )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) D_4:
   [
   AgSt_D0( $D, 'D_0', <$H, $idH, pk(~skS)> ), In( <$idS, r(~rS)> ),
   !ID_S( $S, $idS ), !Ltk( $S, ~skS )
   ]
  --[ D( $D ) ]->
   [
   AgSt_D5( $D, 'D_5', <$H, $idH, pk(~skS), $idS, $S, r(~rS)> ),
   Out_S( $D, $H, 'idS', $idS )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) D_6:
   [
   AgSt_D5( $D, 'D_5', <$H, $idH, pk(~skS), $idS, $S, r(~rS)> ),
   In_S( $H, $D, <'pw', 'idH'>, <pw(~pw), $idH> ), Fr( ~rD )
   ]
  --[
  DfromHx( $D, $H, 'pw', pw(~pw) ), DfromHx( $D, $H, 'idH', $idH ),
  RunningD( $D, $S, <$H, f(<r(~rS), r(~rD)>)> ), D( $D )
  ]->
   [
   AgSt_D7( $D, 'D_7',
            <$H, $idH, pk(~skS), $idS, $S, r(~rS), r(~rD), pw(~pw)>
   ),
   Out( <aenc(r(~rD), pk(~skS)), 
         senc(<f(r(~rS)), $idH, pw(~pw)>, f(<r(~rS), r(~rD)>))>
   )
   ]

