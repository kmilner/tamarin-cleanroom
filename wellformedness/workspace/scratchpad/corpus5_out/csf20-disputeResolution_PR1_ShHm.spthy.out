theory PR1_ShHm

begin

// Function signature and definition of the equational theory E

builtins: multiset
functions: fst/1, pair/2, pk/1, sg/2, sign/2, snd/1, true/0, ver/2,
           verify/3
equations:
    fst(<x.1, x.2>) = x.1,
    snd(<x.1, x.2>) = x.2,
    ver(sg(m, sk), pk(sk)) = m,
    verify(sign(x.1, x.2), x.1, pk(x.2)) = true

rule (modulo E) ChanOut_A:
   [ Out_A( $A, x ) ]
  --[ ChanOut_A( $A, x ) ]->
   [ !Auth( $A, x ), Out( <$A, x> ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) ChanIn_A:
   [ !Auth( $A, x ) ] --[ ChanIn_A( $A, x ) ]-> [ In_A( $A, x ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) ChanOut_IR:
   [ Out_IR( $A, $B, m ) ]
  --[ ChanOut_IR( $A, $B, m ) ]->
   [ Out( <$A, $B, m> ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) ChanIn_IR:
   [ In( <$A, $B, m> ) ]
  --[ ChanIn_IR( $A, $B, m ) ]->
   [ In_IR( $A, $B, m ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) ChanOut_IU:
   [ Out_IU( $A, $B, m ) ]
  --[ ChanOut_IU( $A, $B, m ) ]->
   [ Out( <$A, $B, m> ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) ChanIn_IU:
   [ In( <$A, $B, m> ) ]
  --[ ChanIn_IU( $A, $B, m ) ]->
   [ In_IU( $A, $B, m ) ]

  /* has exactly the trivial AC variant */

restriction Chan_U:
  "∀ A B m #i.
    (Send_U( A, B, m ) @ #i) ⇒ (∃ #j. Receive_U( A, B, m ) @ #j)"

  /*
  expanded formula:
  "∀ A B m #i.
    (Send_U( A, B, m ) @ #i) ⇒ (∃ #j. Receive_U( A, B, m ) @ #j)"
  */

rule (modulo E) fakeEvidence:
   [ In( <ballot, evidence> ) ] --[ Evidence( ballot, evidence ) ]-> [ ]

  /* has exactly the trivial AC variant */

rule (modulo E) publickeyinfrastructure:
   [ Fr( ~skX ) ]
  --[ LongtermKey( $X, ~skX ) ]->
   [ !Ltk( $X, ~skX ), !Pk( $X, pk(~skX) ), Out( pk(~skX) ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Setup:
   [ ]
  --[ Setup( ), Voter( 'H' ), Server( 'S' ), Honest( 'S' ) ]->
   [
   Out( <'H', 'BB', 'P', $v> ), AgSt_BB0( 'BB', 'S' ), AgSt_P0( 'P', 'S' ),
   AgSt_S0( 'S', 'empty' )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) P:
   [ AgSt_P0( $P, $S ), In_IR( $H, $P, b ) ]
  --[ Receive_R( $H, $P, b ), Send_U( $P, $S, b ), Pub( $P, $S, b ) ]->
   [ Out_IU( $P, $S, b ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) S_1:
   [ AgSt_S0( $S, 'empty' ), In_IU( $P, $S, <$v, $H> ) ]
  --[ Receive_U( $P, $S, <$v, $H> ), Pub( $P, $S, <$v, $H> ) ]->
   [ Out_A( $S, <'bs', $v, $H> ), Out_A( $S, <'vs', $v> ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) BB:
   [ AgSt_BB0( $BB, $S ), In_A( $S, <'bs', bs> ), In_A( $S, <'vs', vs> ) ]
  --[ BB_recorded( $BB, <'bs', bs> ), BB_tallied( $BB, <'vs', vs> ), End( )
  ]->
   [ Out_A( $BB, <'bs', bs> ), Out_A( $BB, <'vs', vs> ) ]

  // loop breakers: [1,2]
  /* has exactly the trivial AC variant */

restriction OneSetup:
  "∀ #i #j. ((Setup( ) @ #i) ∧ (Setup( ) @ #j)) ⇒ (#i = #j)"
  // safety formula

  /*
  expanded formula:
  "∀ #i #j. ((Setup( ) @ #i) ∧ (Setup( ) @ #j)) ⇒ (#i = #j)"
  */

lemma functional:
  exists-trace
  "∃ BB #k.
    (BB_recorded( BB, <'bs', 'v', 'H'> ) @ #k) ∧
    (BB_tallied( BB, <'vs', 'v'> ) @ #k)"
