rule (modulo E) ProvisionerEndProvisioning:
   [
   ProvisionerSendNetKey( pkP, pkD, dh, ck, ~Np, Nd, sk, nk, dev_key ),
   In( prov_complete )
   ]
  --[
  ProvisionerFinishedProvisioning( pkP, pkD, dh, ck, ~Np, Nd, sk, nk,
                                   dev_key, app_key
  )
  ]->
   [
   ProvisionerFinishedProvisioning( pkP, pkD, dh, ck, ~Np, Nd, sk, nk,
                                    dev_key, app_key
   ),
   Out( aes_ccm_enc(dev_key, '0', app_key) )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) DeviceEndKeyDistribution:
   [ DeviceRecvNetKey( pkD, pkP, dh, ck, ~Nd, Np, sk, nk, dev_key ), In( c )
   ]
  --[
  IsTrue( aes_ccm_verify(c, dev_key, '0', aes_ccm_dec(dev_key, '0', c)) ),
  DeviceFinishedKeyDistribution( pkD, pkP, dh, ck, ~Nd, Np, sk, nk,
                                 dev_key, aes_ccm_dec(dev_key, '0', c)
  )
  ]->
   [
   DeviceFinishedKeyDistribution( pkD, pkP, dh, ck, ~Nd, Np, sk, nk,
                                  dev_key, aes_ccm_dec(dev_key, '0', c)
   )
   ]

  /*
