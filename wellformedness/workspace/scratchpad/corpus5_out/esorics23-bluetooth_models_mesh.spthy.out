    variants (modulo AC)
    1. N     = N.5
       auth  = auth.5
       ck    = ck.5
       z     = aes_cmac(ck.5, <N.5, auth.5>)
    
    2. N     = x.5
       auth  = get_b2(x.6, x.7, x.5)
       ck    = x.7
       z     = x.6
    
    3. N     = get_b1(x.5, x.6, x.7)
       auth  = x.7
       ck    = x.6
       z     = x.5
  */

restriction DeviceOnlyOnceProv:
  "∀ #i #j.
    ((DeviceOnlyOnceProv( ) @ #i) ∧ (DeviceOnlyOnceProv( ) @ #j)) ⇒
    (#i = #j)"
  // safety formula

  /*
  expanded formula:
  "∀ #i #j.
    ((DeviceOnlyOnceProv( ) @ #i) ∧ (DeviceOnlyOnceProv( ) @ #j)) ⇒
    (#i = #j)"
  */

restriction ProvisionerOnlyOnceProv:
  "∀ #i #j.
    ((ProvisionerOnlyOnceProv( ) @ #i) ∧ (ProvisionerOnlyOnceProv( ) @ #j)) ⇒
    (#i = #j)"
  // safety formula

  /*
  expanded formula:
  "∀ #i #j.
    ((ProvisionerOnlyOnceProv( ) @ #i) ∧ (ProvisionerOnlyOnceProv( ) @ #j)) ⇒
    (#i = #j)"
  */

restriction IsTrue:
  "∀ t #i. (IsTrue( t ) @ #i) ⇒ (t = true_val)"
  // safety formula

  /*
  expanded formula:
  "∀ t #i. (IsTrue( t ) @ #i) ⇒ (t = true_val)"
  */

restriction NotEq:
  "∀ c #i. (NotEq( c, c ) @ #i) ⇒ (⊥)"
  // safety formula

  /*
  expanded formula:
  "∀ c #i. (NotEq( c, c ) @ #i) ⇒ (⊥)"
  */

restriction DHConsistency:
  "∀ t s r1 r2 y #i #j.
    ((Raised( t, s, r1, y ) @ #i) ∧ (Raised( t, s, r2, y ) @ #j)) ⇒
    (r1 = r2)"
  // safety formula

  /*
  expanded formula:
  "∀ t s r1 r2 y #i #j.
    ((Raised( t, s, r1, y ) @ #i) ∧ (Raised( t, s, r2, y ) @ #j)) ⇒
    (r1 = r2)"
  */

restriction DHIdentity:
  "∀ t r y #i. (Raised( t, DH_neutral, r, y ) @ #i) ⇒ (r = DH_neutral)"
  // safety formula

  /*
  expanded formula:
  "∀ t r y #i. (Raised( t, DH_neutral, r, y ) @ #i) ⇒ (r = DH_neutral)"
  */

restriction ValidPt:
  "∀ x y #i. (ValidPt( x, y ) @ #i) ⇒ (x = y)"
  // safety formula

  /*
  expanded formula:
  "∀ x y #i. (ValidPt( x, y ) @ #i) ⇒ (x = y)"
  */

restriction InvalidPt:
  "∀ x #i. (InvalidPt( x, x ) @ #i) ⇒ (⊥)"
  // safety formula

