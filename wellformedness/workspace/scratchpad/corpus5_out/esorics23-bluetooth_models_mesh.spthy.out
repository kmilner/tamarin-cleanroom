theory BluetoothMeshProvisioning

begin

// Function signature and definition of the equational theory E

builtins: diffie-hellman
functions: aes_ccm_dec/3, aes_ccm_enc/3, aes_ccm_verify/4, aes_cmac/2,
           app_key/0[private,constructor], e/3, extract_e/1, fst/1, get_b1/3,
           get_b2/3, id6/0, id7/0, k1/3, k2/2, k3/1, k4/1, nb_one/0, nb_three/0,
           nb_two/0, net_key/0[private,constructor], null/0, pair/2,
           prov_capabilities/0, prov_complete/0, prov_invite/0, prov_start/0, s1/1,
           sdec/2, senc/2, smk2/0, smk3/0, smk4/0, snd/1,
           static_oob/0[private,constructor], true_val/0
equations:
    aes_ccm_dec(k, n, aes_ccm_enc(k, n, m)) = m,
    aes_ccm_enc(k, n, aes_ccm_dec(k, n, m)) = m,
    aes_ccm_verify(aes_ccm_enc(k, n, m), k, n, m) = true_val,
    aes_cmac(k, <b1, get_b2(c, k, b1)>) = c,
    aes_cmac(k, <get_b1(c, k, b2), b2>) = c,
    extract_e(e(t, s, n)) = n,
    fst(<x.1, x.2>) = x.1,
    get_b1(cnf, k, get_b2(cnf, dh, b1)) = b1,
    get_b1(aes_cmac(k, <b1, b2>), k, b2) = b1,
    get_b2(cnf, k, get_b1(cnf, dh, b2)) = b2,
    get_b2(aes_cmac(k, <b1, b2>), k, b1) = b2,
    k1(n, salt, p) = aes_cmac(aes_cmac(salt, n), p),
    k2(n, p)
  = <aes_cmac(aes_cmac(s1(smk2), n), <p, nb_one>), 
     aes_cmac(aes_cmac(s1(smk2), n),
              <aes_cmac(aes_cmac(s1(smk2), n), <p, nb_one>), p, nb_two>), 
     aes_cmac(aes_cmac(s1(smk2), n),
              <
               aes_cmac(aes_cmac(s1(smk2), n),
                        <aes_cmac(aes_cmac(s1(smk2), n), <p, nb_one>), p, nb_two>), 
               p, nb_three>)
    >,
    k3(n) = aes_cmac(aes_cmac(s1(smk3), n), id7),
    k4(n) = aes_cmac(aes_cmac(s1(smk4), n), id6),
    s1(m) = aes_cmac(null, m),
    sdec(senc(x.1, x.2), x.2) = x.1,
    snd(<x.1, x.2>) = x.2

rule (modulo E) ProvisionerSendProvInvite:
   [ ProvisionerStartProvisioning( ) ]
  -->
   [ ProvisionerReadyToStart( ), Out( prov_invite ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) DeviceSendProvCapabilities:
   [ DeviceStartProvisioning( ), In( prov_invite ) ]
  -->
   [ DeviceReadyToStart( ), Out( prov_capabilities ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) ProvisionerSendStart:
   [ ProvisionerReadyToStart( ), In( prov_capabilities ) ]
  -->
   [ ProvisionerReadyECDH( ), Out( prov_start ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) DeviceRecvStart:
   [ DeviceReadyToStart( ), In( prov_start ) ] --> [ DeviceReadyECDH( ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) ProvisionerWaitingUser:
   [
   ProvisionerWaitingUserInteraction( pkP, pkD, dh ),
   ProvisionerAuthProceed( auth )
   ]
  -->
   [ ProvisionerCanStartAuth( pkP, pkD, dh, auth ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) DeviceWaitingUser:
   [ DeviceWaitingUserInteraction( pkD, pkP, dh ), DeviceAuthProceed( auth )
   ]
  -->
   [ DeviceCanStartAuth( pkD, pkP, dh, auth ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) ProvisionerSendConfirm:
   [ ProvisionerCanStartAuth( pkP, pkD, dh, auth ), Fr( ~Np ) ]
  --[
  ProvisionerSendConfirm( pkP, pkD, dh,
                          k1(dh, s1(<prov_invite, prov_capabilities, prov_start, pkP, pkD>),
                             'prck'),
                          ~Np, auth
  )
  ]->
   [
   ProvisionerSendConfirm( pkP, pkD, dh,
                           k1(dh, s1(<prov_invite, prov_capabilities, prov_start, pkP, pkD>),
                              'prck'),
                           ~Np, auth
   ),
   Out( aes_cmac(k1(dh,
                    s1(<prov_invite, prov_capabilities, prov_start, pkP, pkD>), 'prck'),
                 <~Np, auth>)
   )
   ]

