                         k1(dh,
                            s1(<s1(<prov_invite, prov_capabilities, prov_start, pkP, pkD>), ~Np, Nd
                               >),
                            'prsk'),
                         net_key,
                         k1(dh,
                            s1(<s1(<prov_invite, prov_capabilities, prov_start, pkP, pkD>), ~Np, Nd
                               >),
                            'prdk')
  )
  ]->
   [
   ProvisionerSendNetKey( pkP, pkD, dh, ck, ~Np, Nd,
                          k1(dh,
                             s1(<s1(<prov_invite, prov_capabilities, prov_start, pkP, pkD>), ~Np, Nd
                                >),
                             'prsk'),
                          net_key,
                          k1(dh,
                             s1(<s1(<prov_invite, prov_capabilities, prov_start, pkP, pkD>), ~Np, Nd
                                >),
                             'prdk')
   ),
   Out( aes_ccm_enc(k1(dh,
                       s1(<s1(<prov_invite, prov_capabilities, prov_start, pkP, pkD>), ~Np, Nd
                          >),
                       'prsk'),
                    k1(dh,
                       s1(<s1(<prov_invite, prov_capabilities, prov_start, pkP, pkD>), ~Np, Nd
                          >),
                       'prsn'),
                    net_key)
