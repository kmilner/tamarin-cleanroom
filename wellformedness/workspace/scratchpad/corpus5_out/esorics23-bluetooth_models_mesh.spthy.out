   [
   DeviceSendConfirm( pkD, pkP, dh, ck, ~Nd, aes_cmac(ck, <Np, auth>), auth
   ),
   In( Np )
   ]
  --[ DeviceSendRandom( pkD, pkP, dh, ck, ~Nd, Np, auth ) ]->
   [ DeviceSendRandom( pkD, pkP, dh, ck, ~Nd, Np, auth ), Out( ~Nd ) ]

