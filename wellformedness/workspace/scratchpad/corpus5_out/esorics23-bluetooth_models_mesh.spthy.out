rule (modulo E) DeviceRecvNetKey:
   [ DeviceSendRandom( pkD, pkP, dh, ck, ~Nd, Np, auth ), In( prov_data ) ]
  --[
  IsTrue( aes_ccm_verify(prov_data,
                         k1(dh,
                            s1(<s1(<prov_invite, prov_capabilities, prov_start, pkP, pkD>), Np, ~Nd
                               >),
                            'prsk'),
                         k1(dh,
                            s1(<s1(<prov_invite, prov_capabilities, prov_start, pkP, pkD>), Np, ~Nd
                               >),
                            'prsn'),
                         aes_ccm_dec(k1(dh,
                                        s1(<s1(<prov_invite, prov_capabilities, prov_start, pkP, pkD>), Np, 
                                            ~Nd>),
                                        'prsk'),
                                     k1(dh,
                                        s1(<s1(<prov_invite, prov_capabilities, prov_start, pkP, pkD>), Np, 
                                            ~Nd>),
                                        'prsn'),
                                     prov_data))
  ),
  DeviceRecvNetKey( pkD, pkP, dh, ck, ~Nd, Np,
                    k1(dh,
                       s1(<s1(<prov_invite, prov_capabilities, prov_start, pkP, pkD>), Np, ~Nd
                          >),
                       'prsk'),
                    aes_ccm_dec(k1(dh,
                                   s1(<s1(<prov_invite, prov_capabilities, prov_start, pkP, pkD>), Np, ~Nd
                                      >),
                                   'prsk'),
                                k1(dh,
                                   s1(<s1(<prov_invite, prov_capabilities, prov_start, pkP, pkD>), Np, ~Nd
                                      >),
                                   'prsn'),
                                prov_data),
                    k1(dh,
                       s1(<s1(<prov_invite, prov_capabilities, prov_start, pkP, pkD>), Np, ~Nd
                          >),
                       'prdk')
  ),
  DeviceFinishedProvisioning( pkD, pkP, dh, ck, ~Nd, Np,
                              k1(dh,
                                 s1(<s1(<prov_invite, prov_capabilities, prov_start, pkP, pkD>), Np, ~Nd
                                    >),
                                 'prsk'),
                              aes_ccm_dec(k1(dh,
                                             s1(<s1(<prov_invite, prov_capabilities, prov_start, pkP, pkD>), 
                                                 Np, ~Nd>),
                                             'prsk'),
                                          k1(dh,
                                             s1(<s1(<prov_invite, prov_capabilities, prov_start, pkP, pkD>), 
                                                 Np, ~Nd>),
                                             'prsn'),
                                          prov_data),
                              k1(dh,
                                 s1(<s1(<prov_invite, prov_capabilities, prov_start, pkP, pkD>), Np, ~Nd
                                    >),
                                 'prdk')
  )
  ]->
   [
   DeviceRecvNetKey( pkD, pkP, dh, ck, ~Nd, Np,
                     k1(dh,
                        s1(<s1(<prov_invite, prov_capabilities, prov_start, pkP, pkD>), Np, ~Nd
                           >),
                        'prsk'),
                     aes_ccm_dec(k1(dh,
                                    s1(<s1(<prov_invite, prov_capabilities, prov_start, pkP, pkD>), Np, ~Nd
                                       >),
                                    'prsk'),
                                 k1(dh,
                                    s1(<s1(<prov_invite, prov_capabilities, prov_start, pkP, pkD>), Np, ~Nd
                                       >),
                                    'prsn'),
                                 prov_data),
                     k1(dh,
                        s1(<s1(<prov_invite, prov_capabilities, prov_start, pkP, pkD>), Np, ~Nd
                           >),
                        'prdk')
   ),
   DeviceFinishedProvisioning( pkD, pkP, dh, ck, ~Nd, Np,
                               k1(dh,
                                  s1(<s1(<prov_invite, prov_capabilities, prov_start, pkP, pkD>), Np, ~Nd
                                     >),
                                  'prsk'),
                               aes_ccm_dec(k1(dh,
                                              s1(<s1(<prov_invite, prov_capabilities, prov_start, pkP, pkD>), 
                                                  Np, ~Nd>),
                                              'prsk'),
                                           k1(dh,
                                              s1(<s1(<prov_invite, prov_capabilities, prov_start, pkP, pkD>), 
                                                  Np, ~Nd>),
                                              'prsn'),
                                           prov_data),
                               k1(dh,
                                  s1(<s1(<prov_invite, prov_capabilities, prov_start, pkP, pkD>), Np, ~Nd
                                     >),
                                  'prdk')
   ),
   Out( prov_complete )
   ]

