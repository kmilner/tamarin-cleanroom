   ⇒
    ((¬(#i < #j)) ∨ (¬(#j < #k)))) ∧
  (∀ x #i #j.
    (Sstart( S ) @ #i) ∧ (H_role( 'Human', x ) @ #j)
   ⇒
    ((¬(#i < #j)) ∨ (¬(#j < #k))))"
*/
by sorry

lemma device_authentication:
