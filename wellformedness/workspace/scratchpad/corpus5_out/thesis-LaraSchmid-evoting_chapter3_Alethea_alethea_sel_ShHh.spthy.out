   ]
  --[ Pseudonym( $H1, pk(h(<$H1, ~x1>)), $H2, pk(h(<$H2, ~x2>)) ) ]->
   [
   AgSt_S1( $S, <$E, ~skS, $H1, $D1, epkD1, $H2, $D2, epkD2, ~x1, ~x2> ),
