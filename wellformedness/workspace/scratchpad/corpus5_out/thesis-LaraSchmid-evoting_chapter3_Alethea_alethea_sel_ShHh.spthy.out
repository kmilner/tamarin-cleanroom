  Device( 'H2', 'D2' )
  ]->
   [
   AgSt_D0( 'D1', <'H1', 'S', ~eskD1, pk(~skS)> ),
   AgSt_D0( 'D2', <'H2', 'S', ~eskD2, pk(~skS)> ),
   AgSt_S0( 'S', <'E', ~skS, 'H1', 'D1', pk(~eskD1), 'H2', 'D2', pk(~eskD2)>
   ),
   AgSt_A0( 'A', <'S', 'BB', 'E'> ), AgSt_BB0( 'BB', 'S' ), Env( 'E' ),
   AgSt_H0( 'H1', <'D1', 'BB'> ), AgSt_H0( 'H2', <'D2', 'BB'> )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) S_1a:
   [
   AgSt_S0( $S, <$E, ~skS, $H1, $D1, epkD1, $H2, $D2, epkD2> ), Fr( ~x1 ),
