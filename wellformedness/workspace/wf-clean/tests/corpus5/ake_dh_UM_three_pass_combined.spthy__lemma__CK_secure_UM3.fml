∀ #i #j role A B k s comm. (((Complete( <'UM3', A, B, comm>, role, k ) @ #i) ∧ (K( k ) @ #j)) ∧ (s = <'UM3', A, B, comm>)) ⇒ (((((∃ #k.1. SessionKeyReveal( s ) @ #k.1) ∨ (∃ #k.1. (Corrupt( A ) @ #k.1) ∧ (¬(∃ #l. (Expire( s ) @ #l) ∧ (#l < #k.1))))) ∨ (∃ #k.1. (SessionStateReveal( s ) @ #k.1) ∧ ((∃ #l. Corrupt( A ) @ #l) ∨ (∃ #l. Corrupt( B ) @ #l)))) ∨ (∃ #l ms matchingComm. ((((Sid( <'UM3', B, A, matchingComm> ) @ #l) ∧ (ms = <'UM3', B, A, matchingComm>)) ∧ ((∃ rest. (matchingComm++rest) = comm) ∨ (matchingComm = comm))) ∧ (¬(∃ #v. SidUpdated( ms ) @ #v))) ∧ (((∃ #k.1. SessionKeyReveal( ms ) @ #k.1) ∨ (∃ #k.1. (Corrupt( B ) @ #k.1) ∧ (¬(∃ #l.1. (Expire( ms ) @ #l.1) ∧ (#l.1 < #k.1))))) ∨ (∃ #k.1. (SessionStateReveal( ms ) @ #k.1) ∧ ((∃ #l.1. Corrupt( A ) @ #l.1) ∨ (∃ #l.1. Corrupt( B ) @ #l.1)))))) ∨ ((¬(∃ #l matchingComm. ((Sid( <'UM3', B, A, matchingComm> ) @ #l) ∧ ((∃ rest. (matchingComm++rest) = comm) ∨ (matchingComm = comm))) ∧ (¬(∃ #v. SidUpdated( <'UM3', B, A, matchingComm> ) @ #v)))) ∧ (∃ #k.1. (Corrupt( B ) @ #k.1) ∧ (¬(∃ #l. (Expire( s ) @ #l) ∧ (#l < #k.1))))))
