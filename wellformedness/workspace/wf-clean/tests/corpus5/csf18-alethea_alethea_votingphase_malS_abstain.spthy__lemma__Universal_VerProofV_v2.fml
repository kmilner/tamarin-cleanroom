∀ S A x1 x2 skS #a #i BB v1 v2 codes. (((Learn_A_Vs( S, A, <'votes', (v1++v2)> ) @ #a) ∧ (Learn_A_Cs( S, A, <'codes', codes> ) @ #a)) ∧ (VerProofV( A, BB, PeqPVote(<cp(x1, pk(skS)), cp(x2, pk(skS))>, <x1, x2>, skS), <cp(x1, pk(skS)), cp(x2, pk(skS))>, <x2, x1> ) @ #i)) ⇒ (∃ #b hV1 hV2 sndcode1 sndcode2 n1 n2. (((BB_Cs( BB, <'codes', codes> ) @ #b) ∧ (BB_V( n1, BB, v1 ) @ #b)) ∧ (BB_V( n2, BB, v2 ) @ #b)) ∧ (codes = (<cp(<v1, hV1>, pk(skS)), sndcode1>++<cp(<v2, hV2>, pk(skS)), sndcode2> )))
