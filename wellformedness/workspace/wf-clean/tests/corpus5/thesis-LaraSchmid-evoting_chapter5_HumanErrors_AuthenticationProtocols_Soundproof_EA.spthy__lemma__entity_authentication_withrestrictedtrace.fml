(((∀ pw1 pw2 H S #i #j. ((PwdServer( S, H, pw1 ) @ #i) ∧ (PwdServer( S, H, pw2 ) @ #j)) ⇒ (pw1 = pw2)) ∧ (∀ S H1 H2 idH #i #j. ((IdHs( S, H1, idH ) @ #i) ∧ (IdHs( S, H2, idH ) @ #j)) ⇒ ((H1 = H2) ∧ (∀ S.1 H idH1 idH2 #i.1 #j.1. ((IdHs( S.1, H, idH1 ) @ #i.1) ∧ (IdHs( S.1, H, idH2 ) @ #j.1)) ⇒ (idH1 = idH2))))) ∧ (∀ H D2 D1 #i #j. ((Device( H, D1 ) @ #i) ∧ (Device( H, D2 ) @ #j)) ⇒ (D1 = D2))) ⇒ (∀ S m #k. (Commit( S, 'Human', m ) @ #k) ⇒ ((∃ #i #j. (((Sstart( S ) @ #i) ∧ (H( 'Human' ) @ #j)) ∧ (#i < #j)) ∧ (#j < #k)) ∨ (∃ x #i #j. (((Sstart( S ) @ #i) ∧ (H_role( 'Human', x ) @ #j)) ∧ (#i < #j)) ∧ (#j < #k))))
