∀ x a id #i #j. ((((Log( x, a, id ) @ #i) ∧ (Execute( a, id ) @ #j)) ∧ (¬((a = SpecialReq) ∨ (a = NormalReq)))) ∧ (¬(∃ a.1 b. x = <a.1, b>))) ⇒ ((¬(∃ x.1 a.1 id.1 #i.1 #j.1. ((((Log( x.1, a.1, id.1 ) @ #i.1) ∧ (Execute( a.1, id.1 ) @ #j.1)) ∧ (¬((a.1 = SpecialReq) ∨ (a.1 = NormalReq)))) ∧ (¬(∃ a.2 b. x.1 = <a.2, b>))) ∧ ((x.1 = x) ∧ (¬(x = x.1))))) ∧ (¬(∃ x.1 y a.1 id.1 #i.1 #j.1. (((((Log( <x.1, y>, a.1, id.1 ) @ #i.1) ∧ (Execute( a.1, id.1 ) @ #j.1)) ∧ (¬(x.1 = y))) ∧ (¬((a.1 = SpecialReq) ∨ (a.1 = NormalReq)))) ∧ (¬(∃ z a.2 id.2 #i.2 #j.2. ((((Log( z, a.2, id.2 ) @ #i.2) ∧ (Execute( a.2, id.2 ) @ #j.2)) ∧ (¬((a.2 = SpecialReq) ∨ (a.2 = NormalReq)))) ∧ (¬(∃ a.3 b. x.1 = <a.3, b>))) ∧ ((z = x.1) ∨ (z = y))))) ∧ (((x.1 = x) ∧ (y = x)) ∧ ((¬(x = x.1)) ∧ (¬(x = y)))))))
