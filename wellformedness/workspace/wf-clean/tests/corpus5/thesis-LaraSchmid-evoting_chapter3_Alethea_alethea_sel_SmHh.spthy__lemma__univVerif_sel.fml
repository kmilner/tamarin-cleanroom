∀ A spkD1 spkD2 #a1. (Verify_SG( A, spkD1, '1', spkD1, spkD2 ) @ #a1) ⇒ (∃ BB #b1 #b2. ((BB_spkDs( BB, <'spkDs', spkD1, spkD2> ) @ #b1) ∧ (BB_SG( BB, <'SG', spkD1> ) @ #b2)) ∧ (∀ A.1 spkD1.1 spkD2.1 #a1.1. (Verify_SG( A.1, spkD2.1, '2', spkD1.1, spkD2.1 ) @ #a1.1) ⇒ (∃ BB.1 #b1.1 #b2.1. (BB_spkDs( BB.1, <'spkDs', spkD1.1, spkD2.1> ) @ #b1.1) ∧ (BB_SG( BB.1, <'SG', spkD2.1> ) @ #b2.1))))
