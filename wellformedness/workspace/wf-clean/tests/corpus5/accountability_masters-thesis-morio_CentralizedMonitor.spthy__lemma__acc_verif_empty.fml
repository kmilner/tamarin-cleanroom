(¬((∃ x a id #i #j. (((Log( x, a, id ) @ #i) ∧ (Execute( a, id ) @ #j)) ∧ (¬((a = SpecialReq) ∨ (a = NormalReq)))) ∧ (¬(∃ a.1 b. x = <a.1, b>))) ∨ (∃ x y a id #i #j. ((((Log( <x, y>, a, id ) @ #i) ∧ (Execute( a, id ) @ #j)) ∧ (¬(x = y))) ∧ (¬((a = SpecialReq) ∨ (a = NormalReq)))) ∧ (¬(∃ z a.1 id.1 #i.1 #j.1. ((((Log( z, a.1, id.1 ) @ #i.1) ∧ (Execute( a.1, id.1 ) @ #j.1)) ∧ (¬((a.1 = SpecialReq) ∨ (a.1 = NormalReq)))) ∧ (¬(∃ a.2 b. x = <a.2, b>))) ∧ ((z = x) ∨ (z = y))))))) ⇒ (∀ a id #i. (Execute( a, id ) @ #i) ⇒ ((a = SpecialReq) ∨ (a = NormalReq)))
