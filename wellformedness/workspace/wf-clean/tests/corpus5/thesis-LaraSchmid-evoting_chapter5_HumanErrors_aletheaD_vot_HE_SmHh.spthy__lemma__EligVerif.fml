∀ A #a spkD votes sk xa ra. (((Learn_A_spkDSG( A, <'spkD', spkD> ) @ #a) ∧ (Learn_A_Vs( A, <'vs', votes> ) @ #a)) ∧ (VerifyA2( A, verzkp(zkp(encp(xa, ra, pk(sk)), xa, sk), encp(xa, ra, pk(sk)), xa, pk(sk)) ) @ #a)) ⇒ (∃ #b BB H1 #h1 A.1 #b2 #s. (((BB_tal( BB, <'vs', votes> ) @ #b) ∧ (BB_pskDs( BB, <'spkD', spkD> ) @ #b2)) ∧ (Send( H1, A.1, <'v', votes> ) @ #h1)) ∧ (Pseudonym( H1, spkD ) @ #s))
