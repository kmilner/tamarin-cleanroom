# Subterm-convergence layout (probes t5_*)
t5_sub_ground/t5_sub_groundapp :: ground RHS (nullary or compound, no vars) -> NOT flagged
t5_sub_order/2/3 :: flagged equations SORTED by rendered string ("aa"<"zz", "f(a)"<"f(z)"), not source order
t5_wl55..66 :: one-line equation "    lhs = rhs" fits at total width 71, breaks at 72 (margin = 4-nest + ribbon 67)
t5_last33..42 :: tuple ">" closer: glues while end<=69 (line nest 2 + 67); breaks to the TUPLE START column when over; after a fill-broken single-line last element the ">" glues at the element line
t5_tup3/t5_tup3b/t5_tup_small :: tuple elements fill left-to-right; mid elements carry ", " (kept at line end when the break follows); fit margin = min(100, 67 + nest of the line on which the governing construct starts)
mesh k2 target trace :: app args fill at col(fn)+len(fn)+1 with "," glued (no trailing space); a construct starting on a broken line uses that line's nest for its margin; ">" goes to its own line when the last element is multi-line; app ")" always glues
s5_capord :: [$aB, $Ab] same sort -> "1. $Ab, $aB" (same-sort variants ordered by exact name, ASCII; not first-seen)
s5_groups :: zz-group and aa-group in one rule -> groups SORTED by lowercased key with a 4-space separator line between numbered groups
s5_all4 / s5_all4b :: $x,~x,x,%x one rule (natural-numbers) -> "1. $x, ~x, x, %x" -> variant order pub < fresh < msg < nat (Node unobserved)
s5_node :: In(x)/M(x)/Out(x) consistent -> silent (control)
t5_align :: 10 lhs-only facts -> numbered items right-aligned to widest index ("   1." .. "  10."), suggestions unchanged
t5_lemdup :: lemma uses Bt(a,b,k) at two binder depths + rule arity clash -> lemma items NOT deduped when renders differ (Bound 3,2,1 AND Bound 4,3,2)
t5_lookup :: hand-built SAPIC-style lookup rule (State premise, IsIn('time',~t) action, ~t in conclusion) -> Unbound variables `~t' + lhs-not-rhs State suggestion (mirrors OCSPS/CertTransparency targets)
corpus5_out/*.out :: oracle full outputs for all 71 gate-diff theories (default flags); NONE contains a guardedness/QS/FT block; 459 lemma + 225 restriction formulas extracted to wf-clean/tests/corpus5/*.fml with per-theory nullary-function sidecars (*.fns)
