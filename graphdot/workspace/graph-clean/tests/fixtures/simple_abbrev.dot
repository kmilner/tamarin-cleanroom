n9 -> n7[color="red",style="dashed"];
n10 -> n6[color="red",style="dashed"];
{
rank="sink";
n11[shape="plain",label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="3" CELLPADDING="1"><TR><TD ALIGN="LEFT" VALIGN="TOP"><FONT COLOR="#000000">SI1</FONT></TD> <TD ALIGN="LEFT" VALIGN="TOP">=</TD> <TD ALIGN="LEFT" VALIGN="TOP">sign(&lt;'2', $I, $R, hki, 'g'^~ekR&gt;, ~ltkI)</TD></TR></TABLE>>];

}
n5:n3 -> n11[style="invis"];
n6 -> n11[style="invis"];

}
