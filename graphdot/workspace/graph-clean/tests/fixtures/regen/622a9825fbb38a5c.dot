digraph "G" {
nodesep="0.3";
ranksep="0.3";
node[fontsize="8",fontname="Helvetica",width="0.3",height="0.2"];
edge[fontsize="8",fontname="Helvetica"];
n3[shape="record",label="{{<n0> Fr( ~n )}|{<n1> #i : Start[Start( ~n )]}|{<n2> A( ~n )}}",fillcolor="#d5d897",style="filled",fontcolor="black",role="Undefined"];
n6[shape="record",label="{{<n4> A( ~n )}|{<n5> #j : Stop[Stop( ~n )]}}",fillcolor="#c3da98",style="filled",fontcolor="black",role="Undefined"];
n10[shape="record",label="{{<n7> A( ~n )}|{<n8> #vr : Loop[Loop( ~n )]}|{<n9> A( ~n )}}",fillcolor="#b1dc9a",style="filled",fontcolor="black",role="Undefined"];
n10:n9 -> n6:n4[style="bold",weight="10.0"];
n3:n1 -> n10:n8[color="purple",style="dashed"];

}
