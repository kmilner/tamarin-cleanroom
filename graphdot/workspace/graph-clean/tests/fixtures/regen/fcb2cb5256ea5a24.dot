n13[shape="record",label="{{<n8> Fr( ~tid )|<n9> Fr( ~x )}|{<n10> #vr : Step1}|{<n11> Out( \<g^~x, mac(shk, \<g^~x, $A, $B\>)\> )|<n12> Step1( ~tid, $A, $B, ~x )}}",fillcolor="#acdc9a",style="filled",fontcolor="black",role="Undefined"];
n14[label="#vk.1 : coerce[!KU( EX1 )]",shape="ellipse"];
n20[shape="record",label="{{<n15> Fr( ~tid.1 )|<n16> Fr( ~x.1 )}|{<n17> #vr.1 : Step1}|{<n18> Out( \<g^~x.1, MA1\> )|<n19> Step1( ~tid.1, $B, $A, ~x.1 )}}",fillcolor="#acdc9a",style="filled",fontcolor="black",role="Undefined"];
n21[label="#vr.3 : d_0_fst",shape="ellipse"];
n22[label="#vr.4 : d_exp",shape="ellipse"];
n23[label="!KU( g^~x.1 ) @ #vk.3",shape="ellipse",color="gray"];
n24[label="!KU( ~x ) @ #vk.4",shape="ellipse",color="gray"];
n5 -> n3:n1[color="gray30"];
