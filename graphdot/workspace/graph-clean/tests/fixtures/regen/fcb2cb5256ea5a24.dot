n21 -> n22[color="orangered2"];
n22 -> n14[color="orangered2"];
n6 -> n5[color="red",style="dashed"];
n7 -> n5[color="red",style="dashed"];
n13:n10 -> n22[color="blue3",style="dashed"];
n14 -> n4[color="red",style="dashed"];
n23 -> n5[color="red",style="dashed"];
n21 -> n23[color="darkorange3",style="dashed"];
n24 -> n22[color="red",style="dashed"];
{
