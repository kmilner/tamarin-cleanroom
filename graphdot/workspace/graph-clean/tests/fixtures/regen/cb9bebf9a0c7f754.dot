digraph "G" {
nodesep="0.3";
ranksep="0.3";
node[fontsize="8",fontname="Helvetica",width="0.3",height="0.2"];
edge[fontsize="8",fontname="Helvetica"];
n3[shape="record",label="{{<n0> Fr( ~n )}|{<n1> #i : Start[Start( ~n )]}|{<n2> A( ~n )}}",fillcolor="#d5d897",style="filled",fontcolor="black",role="Undefined"];
n7[shape="record",label="{{<n4> A( ~n )}|{<n5> #j : Loop[Loop( ~n )]}|{<n6> A( ~n )}}",fillcolor="#badb99",style="filled",fontcolor="black",role="Undefined"];
n8[label="#last",shape="ellipse"];
n3:n1 -> n7:n5[color="blue3",style="dashed"];
n3:n1 -> n8[color="black",style="dashed"];

}
