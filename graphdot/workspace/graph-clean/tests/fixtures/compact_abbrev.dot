digraph "G" {
nodesep="0.8";
ranksep="0.8";
sep="4";
splines="true";
overlap="false";
pack="true";
packmode="cluster";
concentrate="true";
compound="true";
remincross="true";
mclimit="10";
nslimit="20";
nslimit1="20";
ordering="out";
rankdir="TB";
showboxes="false";
clusterrank="local";
node[fontsize="8",fontname="Helvetica",width="0.3",height="0.2",margin="0.05,0.05",shape="ellipse"];
edge[fontsize="8",fontname="Helvetica",penwidth="1.5",arrowsize="0.5",color="black",style="solid",weight="8"];
subgraph "cluster_v_Session_1" {
nodesep="0.6";
ranksep="0.6";
label="v_Session_1";
style="filled";
color="#36D8874C";
penwidth="2";
fillcolor="#36D8874C";
overlap="false";
sep="4";
n3[shape="record",label="{{<n0> State_1211111111111( ST1, lock, state2, i.1, lio, o, r )}|{<n1> #i : eventLocaloilioloc[Local( \<o, i.1, lio\>, 'loc' )]}|{<n2> State_12111111111111( ST1, lock, state2, i.1, lio, o, r )}}",fillcolor="#658040",style="filled",fontcolor="white",role="v"];

}
{
rank="sink";
n4[shape="plain",label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="3" CELLPADDING="1"><TR><TD ALIGN="LEFT" VALIGN="TOP"><FONT COLOR="#000000">ST1</FONT></TD> <TD ALIGN="LEFT" VALIGN="TOP">=</TD> <TD ALIGN="LEFT" VALIGN="TOP">StateChannel</TD></TR></TABLE>>];

}
