{"parentUuid":"db13d898-5289-4c1d-afd6-697523a2573b","isSidechain":true,"promptId":"a3a1890b-4356-4bf6-b523-7534e72cab2b","agentId":"aac7737a5d3b7d6e7","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01J2NknsoGNgMLbxGuPg3ZKf","type":"tool_result","content":"1\t//! Single-line unicode pretty-printer for trace formulas, calibrated from the\n2\t//! oracle (e.g. ks1 lemma L2 -> \"∀ x #i #j. (Act( x ) @ #i) ⇒ (x = x)\").\n3\t//! Wide formulas in the oracle wrap across multiple indented lines; this\n4\t//! printer emits a single line and is therefore exact only for formulas that\n5\t//! the oracle also keeps on one line (see BEHAVIOR.md gaps).\n6\t\n7\tuse crate::ast::*;\n8\tuse crate::pretty::{pp_fact, pp_term};\n9\t\n10\tpub fn pp_formula(f: &Formula) -> String {\n11\t    match f {\n12\t        Formula::False => \"⊥\".to_string(),\n13\t        Formula::True => \"⊤\".to_string(),\n14\t        Formula::Atom(a) => pp_atom(a),\n15\t        Formula::Not(g) => format!(\"¬({})\", pp_formula(g)),\n16\t        Formula::And(a, b) => format!(\"({}) ∧ ({})\", pp_formula(a), pp_formula(b)),\n17\t        Formula::Or(a, b) => format!(\"({}) ∨ ({})\", pp_formula(a), pp_formula(b)),\n18\t        Formula::Implies(a, b) => format!(\"({}) ⇒ ({})\", pp_formula(a), pp_formula(b)),\n19\t        Formula::Iff(a, b) => format!(\"({}) ⇔ ({})\", pp_formula(a), pp_formula(b)),\n20\t        Formula::Forall(vs, g) => format!(\"∀ {}. {}\", pp_bound_vars(vs), pp_formula(g)),\n21\t        Formula::Exists(vs, g) => format!(\"∃ {}. {}\", pp_bound_vars(vs), pp_formula(g)),\n22\t    }\n23\t}\n24\t\n25\tfn pp_bound_vars(vs: &[VarSpec]) -> String {\n26\t    vs.iter()\n27\t        .map(crate::pretty::pp_var)\n28\t        .collect::<Vec<_>>()\n29\t        .join(\" \")\n30\t}\n31\t\n32\tfn pp_atom(a: &Atom) -> String {\n33\t    match a {\n34\t        Atom::Eq(x, y) => format!(\"{} = {}\", pp_term(x), pp_term(y)),\n35\t        Atom::Less(x, y) => format!(\"{} < {}\", pp_term(x), pp_term(y)),\n36\t        Atom::LessMset(x, y) => format!(\"{} ⋖ {}\", pp_term(x), pp_term(y)),\n37\t        Atom::Subterm(x, y) => format!(\"{} ⊏ {}\", pp_term(x), pp_term(y)),\n38\t        Atom::Action(f, t) => format!(\"{} @ {}\", pp_fact(f), pp_term(t)),\n39\t        Atom::Last(t) => format!(\"last({})\", pp_term(t)),\n40\t        Atom::Pred(f) => pp_fact(f),\n41\t    }\n42\t}\n43\t"}]},"uuid":"c1245e87-1e9f-4920-9181-12c57e3a4a90","timestamp":"2026-07-17T12:16:57.383Z","toolUseResult":{"type":"text","file":{"filePath":"/home/kamilner/tamarin-cleanroom/wellformedness/workspace/wf-clean/src/formula.rs","content":"//! Single-line unicode pretty-printer for trace formulas, calibrated from the\n//! oracle (e.g. ks1 lemma L2 -> \"∀ x #i #j. (Act( x ) @ #i) ⇒ (x = x)\").\n//! Wide formulas in the oracle wrap across multiple indented lines; this\n//! printer emits a single line and is therefore exact only for formulas that\n//! the oracle also keeps on one line (see BEHAVIOR.md gaps).\n\nuse crate::ast::*;\nuse crate::pretty::{pp_fact, pp_term};\n\npub fn pp_formula(f: &Formula) -> String {\n    match f {\n        Formula::False => \"⊥\".to_string(),\n        Formula::True => \"⊤\".to_string(),\n        Formula::Atom(a) => pp_atom(a),\n        Formula::Not(g) => format!(\"¬({})\", pp_formula(g)),\n        Formula::And(a, b) => format!(\"({}) ∧ ({})\", pp_formula(a), pp_formula(b)),\n        Formula::Or(a, b) => format!(\"({}) ∨ ({})\", pp_formula(a), pp_formula(b)),\n        Formula::Implies(a, b) => format!(\"({}) ⇒ ({})\", pp_formula(a), pp_formula(b)),\n        Formula::Iff(a, b) => format!(\"({}) ⇔ ({})\", pp_formula(a), pp_formula(b)),\n        Formula::Forall(vs, g) => format!(\"∀ {}. {}\", pp_bound_vars(vs), pp_formula(g)),\n        Formula::Exists(vs, g) => format!(\"∃ {}. {}\", pp_bound_vars(vs), pp_formula(g)),\n    }\n}\n\nfn pp_bound_vars(vs: &[VarSpec]) -> String {\n    vs.iter()\n        .map(crate::pretty::pp_var)\n        .collect::<Vec<_>>()\n        .join(\" \")\n}\n\nfn pp_atom(a: &Atom) -> String {\n    match a {\n        Atom::Eq(x, y) => format!(\"{} = {}\", pp_term(x), pp_term(y)),\n        Atom::Less(x, y) => format!(\"{} < {}\", pp_term(x), pp_term(y)),\n        Atom::LessMset(x, y) => format!(\"{} ⋖ {}\", pp_term(x), pp_term(y)),\n        Atom::Subterm(x, y) => format!(\"{} ⊏ {}\", pp_term(x), pp_term(y)),\n        Atom::Action(f, t) => format!(\"{} @ {}\", pp_fact(f), pp_term(t)),\n        Atom::Last(t) => format!(\"last({})\", pp_term(t)),\n        Atom::Pred(f) => pp_fact(f),\n    }\n}\n","numLines":43,"startLine":1,"totalLines":43}},"sourceToolAssistantUUID":"db13d898-5289-4c1d-afd6-697523a2573b","userType":"external","entrypoint":"cli","cwd":"/home/kamilner/tamarin-rs","sessionId":"57f8e1bc-d495-4b36-93c0-033347d5034a","version":"2.1.212","gitBranch":"main"}
