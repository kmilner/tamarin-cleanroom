{"parentUuid":"cc51f95a-5502-42a6-adef-04a3707d903d","isSidechain":true,"promptId":"a3a1890b-4356-4bf6-b523-7534e72cab2b","agentId":"aac7737a5d3b7d6e7","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Pjpxn6wfaGdo3PM6ZVvbjY","type":"tool_result","content":"210\tisAC _                           = False\n211\t\n212\t----------------------------------------------------------------------\n213\t-- Convert Diff Terms\n214\t----------------------------------------------------------------------\n215\t\n216\tgetSide :: DiffType -> Term a -> Term a\n217\tgetSide _  (LIT l) = LIT l\n218\tgetSide dt (FAPP (NoEq o) [t1,t2]) = case dt of\n219\t    DiffLeft  | o == diffSym -> getSide dt t1\n220\t    DiffRight | o == diffSym -> getSide dt t2\n221\t    DiffBoth  | o == diffSym -> FAPP (NoEq o) [(getSide dt t1),(getSide dt t2)]\n222\t    DiffNone  | o == diffSym -> error $ \"getSide: illegal use of diff\"\n223\t    _                        -> FAPP (NoEq o) [(getSide dt t1),(getSide dt t2)]\n224\tgetSide dt (FAPP sym ts) = FAPP sym (map (getSide dt) ts)\n225\t\n226\tgetLeftTerm :: Term a -> Term a\n227\tgetLeftTerm t = getSide DiffLeft t\n228\t\n229\tgetRightTerm :: Term a -> Term a\n230\tgetRightTerm t = getSide DiffRight t\n231\t\n232\t----------------------------------------------------------------------\n233\t-- \"protected\" subterms\n234\t-- NB: here anything but a pair or an AC symbol is protected!\n235\t----------------------------------------------------------------------\n236\t\n237\t-- | Given a term, compute all protected subterms, i.e. all terms\n238\t-- which top symbol is a function, but not a pair, nor an AC symbol\n239\tallProtSubterms :: Show a => Term a -> [Term a]\n240\tallProtSubterms t@(viewTerm -> FApp _ as) | isPair t || isAC t\n241\t        = concatMap allProtSubterms as\n242\tallProtSubterms t@(viewTerm -> FApp _ as) | otherwise\n243\t        = t:concatMap allProtSubterms as\n244\tallProtSubterms _                                     = []\n245\t\n246\t-- | Is term @inner@ in term @outer@ and not below a reducible function symbol?\n247\t-- This is used for the Subterm relation\n248\t-- INLINABLE so the call site (the subterm store, at the concrete 'LNTerm'\n249\t-- type in another package) can specialise away the @Eq@/@Ord FunSym@"}]},"uuid":"6f51cbd9-e3ee-46f4-81bd-92b9995672ca","timestamp":"2026-07-17T12:18:08.129Z","toolUseResult":{"type":"text","file":{"filePath":"/home/kamilner/tamarin-rs/tamarin-prover/lib/term/src/Term/Term.hs","content":"isAC _                           = False\n\n----------------------------------------------------------------------\n-- Convert Diff Terms\n----------------------------------------------------------------------\n\ngetSide :: DiffType -> Term a -> Term a\ngetSide _  (LIT l) = LIT l\ngetSide dt (FAPP (NoEq o) [t1,t2]) = case dt of\n    DiffLeft  | o == diffSym -> getSide dt t1\n    DiffRight | o == diffSym -> getSide dt t2\n    DiffBoth  | o == diffSym -> FAPP (NoEq o) [(getSide dt t1),(getSide dt t2)]\n    DiffNone  | o == diffSym -> error $ \"getSide: illegal use of diff\"\n    _                        -> FAPP (NoEq o) [(getSide dt t1),(getSide dt t2)]\ngetSide dt (FAPP sym ts) = FAPP sym (map (getSide dt) ts)\n\ngetLeftTerm :: Term a -> Term a\ngetLeftTerm t = getSide DiffLeft t\n\ngetRightTerm :: Term a -> Term a\ngetRightTerm t = getSide DiffRight t\n\n----------------------------------------------------------------------\n-- \"protected\" subterms\n-- NB: here anything but a pair or an AC symbol is protected!\n----------------------------------------------------------------------\n\n-- | Given a term, compute all protected subterms, i.e. all terms\n-- which top symbol is a function, but not a pair, nor an AC symbol\nallProtSubterms :: Show a => Term a -> [Term a]\nallProtSubterms t@(viewTerm -> FApp _ as) | isPair t || isAC t\n        = concatMap allProtSubterms as\nallProtSubterms t@(viewTerm -> FApp _ as) | otherwise\n        = t:concatMap allProtSubterms as\nallProtSubterms _                                     = []\n\n-- | Is term @inner@ in term @outer@ and not below a reducible function symbol?\n-- This is used for the Subterm relation\n-- INLINABLE so the call site (the subterm store, at the concrete 'LNTerm'\n-- type in another package) can specialise away the @Eq@/@Ord FunSym@","numLines":40,"startLine":210,"totalLines":301}},"sourceToolAssistantUUID":"cc51f95a-5502-42a6-adef-04a3707d903d","userType":"external","entrypoint":"cli","cwd":"/home/kamilner/tamarin-rs","sessionId":"57f8e1bc-d495-4b36-93c0-033347d5034a","version":"2.1.212","gitBranch":"main"}
