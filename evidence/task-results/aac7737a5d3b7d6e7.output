on {\n55\t    pub lhs: Term,\n56\t    pub rhs: Term,\n57\t}\n58\t\n59\t#[derive(Debug, Clone, PartialEq)]\n60\tpub struct Macro {\n61\t    pub name: String,\n62\t    pub args: Vec<VarSpec>,\n63\t    pub body: Term,\n64\t}\n65\t\n66\t#[derive(Debug, Clone, PartialEq)]\n67\tpub struct Predicate {\n68\t    pub fact: Fact,\n69\t    pub formula: Formula,\n70\t}\n71\t\n72\t#[derive(Debug, Clone, PartialEq)]\n73\tpub struct Restriction {\n74\t    pub name: String,\n75\t    pub formula: Formula,\n76\t    pub attributes: Vec<RestrictionAttr>,\n77\t}\n78\t\n79\t#[derive(Debug, Clone, PartialEq)]\n80\tpub enum RestrictionAttr {\n81\t    LeftRestriction,\n82\t    RightRestriction,\n83\t}\n84\t\n85\t#[derive(Debug, Clone, PartialEq)]\n86\tpub struct Rule {\n87\t    pub name: String,\n88\t    pub modulo: Option<String>,\n89\t    pub attributes: Vec<RuleAttr>,\n90\t    pub let_block: Vec<LetBinding>,\n91\t    pub premises: Vec<Fact>,\n92\t    pub actions: Vec<Fact>,\n93\t    pub conclusions: Vec<Fact>,\n94\t    pub embedded_restrictions: Vec<Formula>,\n95\t    pub variants: Vec<Rule>,\n96\t    pub left_right: Option<(Box<Rule>, Box<Rule>)>,\n97\t}\n98\t\n99\t#[derive(Debug, Clone, PartialEq)]\n100\tpub enum RuleAttr {\n101\t    Color(String),\n102\t    NoDerivCheck,\n103\t    Role(String),\n104\t    IsSapicRule,\n105\t    Process(String),\n106\t    External(String, Option<String>),\n107\t}\n108\t\n109\t#[derive(Debug, Clone, PartialEq)]\n110\tpub struct LetBinding {\n111\t    pub var: Term,\n112\t    pub value: Term,\n113\t}\n114\t\n115\t#[derive(Debug, Clone, PartialEq)]\n116\tpub struct Lemma {\n117\t    pub name: String,\n118\t    pub modulo: Option<String>,\n119\t    pub attributes: Vec<LemmaAttr>,\n120\t    pub trace_quantifier: TraceQuantifier,\n121\t    pub formula: Formula,\n122\t    pub proof: Option<ProofSkeleton>,\n123\t    pub plaintext: String,\n124\t}\n125\t\n126\t#[derive(Debug, Clone, PartialEq)]\n127\tpub struct DiffLemma {\n128\t    pub name: String,\n129\t    pu