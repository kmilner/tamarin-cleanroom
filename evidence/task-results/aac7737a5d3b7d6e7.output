{"parentUuid":"a220c0b5-1393-4690-a6b5-d5ca39ec7ee4","isSidechain":true,"promptId":"a3a1890b-4356-4bf6-b523-7534e72cab2b","agentId":"aac7737a5d3b7d6e7","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CtspUDR14Fh6iGqysjyGjV","type":"tool_result","content":"370\t      concatMap (unfoldRuleVariants . ClosedProtoRule ruE) $\n371\t      maybeToList (variantsProtoRule hnd (applyMacroInRule macros ruE))\n372\t    sameVariantsUpToActions parsed computed = all (\\x -> any (equalUpToAddedActions x) computed) parsed\n373\t\n374\t-- | Report on missing or different variants.\n375\truleVariantsReport :: SignatureWithMaude -> OpenTranslatedTheory -> WfErrorReport\n376\truleVariantsReport sig thy = do\n377\t    ru <- [ ru | RuleItem ru <- get thyItems thy ]\n378\t    variantsCheck hnd (theoryMacros thy) (\"Rule \" ++ quote (showRuleCaseName (get oprRuleE ru)) ++\n379\t                     \" cannot confirm manual variants:\") ru\n380\t  where\n381\t    hnd = get sigmMaudeHandle sig\n382\t\n383\t-- | Report on missing or different variants in case of diff rules.\n384\truleVariantsReportDiff :: SignatureWithMaude -> OpenDiffTheory -> WfErrorReport\n385\truleVariantsReportDiff sig thy = do\n386\t    lrRu <- [ get dprLeftRight ru | DiffRuleItem ru <- get diffThyItems thy ]\n387\t    case lrRu of\n388\t      Just (lr, rr) -> (variantsCheck hnd (diffTheoryMacros thy) (\"Left rule \" ++ quote (showRuleCaseName (get oprRuleE lr)) ++\n389\t                     \" cannot confirm manual variants:\") lr) ++\n390\t                      (variantsCheck hnd (diffTheoryMacros thy) (\"Right rule \" ++ quote (showRuleCaseName (get oprRuleE rr)) ++\n391\t                      \" cannot confirm manual variants:\") rr)\n392\t      Nothing -> []\n393\t  where\n394\t    hnd = get sigmMaudeHandle sig\n395\t\n396\t-- | Report on inconsistent left/right rules. This does not check the variants (done by ruleVariantsReportDiff).\n397\tleftRightRuleReportDiff :: OpenDiffTheory -> WfErrorReport\n398\tleftRightRuleReportDiff thy = do\n399\t    ru <- [ ru | DiffRuleItem ru <- get diffThyItems thy ]\n400\t    case get dprLeftRight ru of\n401\t      Just ((OpenProtoRule lr _), _) | not (equalUpToAddedActions lr (getLeftRule (applyMacroInRule (diffTheoryMacros thy) (get dprRule ru)))) -> return $\n402\t              ( (underlineTopic \"Left rule\")\n403\t              , text \"Inconsistent left rule\" $-$ (nest 2 $ prettyProtoRuleE lr)\n404\t                $--$ text \"w.r.t.\" $--$\n405\t                (nest 2 $ prettyProtoRuleE (get dprRule ru))\n406\t              )\n407\t      Just (_, (OpenProtoRule rr _)) | not (equalUpToAddedActions rr (getRightRule (applyMacroInRule (diffTheoryMacros thy) (get dprRule ru)))) -> return $\n408\t              ( (underlineTopic \"Right rule\")\n409\t              , text \"Inconsistent right rule\" $-$ (nest 2 $ prettyProtoRuleE rr)\n410\t                $--$ text \"w.r.t.\" $--$\n411\t                (nest 2 $ prettyProtoRuleE (get dprRule ru))\n412\t              )\n413\t      Just (_, _) | otherwise -> []\n414\t      Nothing -> []\n415\t\n416\t-- | Report on sort clashes.\n417\truleSortsReportDiff :: OpenDiffTheory -> WfErrorReport\n418\truleSortsReportDiff thy = do\n419\t    ru <- diffThyProtoRules thy\n420\t    sortsClashCheck (\"rule \" ++ quote (showRuleCaseName ru) ++\n421\t                     \":\") ru\n422\t\n423\t-- -- | Report on rule name clashes.\n424\t-- -- Unnecessary, is already checked during parsing!\n425\t-- ruleNameReportDiff :: OpenDiffTheory -> WfErrorReport\n426\t-- ruleNameReportDiff thy =\n427\t--   nameClashCheck (\"clashing rule names:\") (diffThyProtoRules thy)\n428\t--\n429\t--\n430\t-- --- | Check that the protocol rules are well-formed.\n431\t-- nameClashCheck :: String -> [(ProtoRuleE)] -> WfErrorReport\n432\t-- nameClashCheck info t = case clashes ruleName t of\n433\t--     [] -> []\n434\t--     cs -> return $\n435\t--             ( \"names\"\n436\t--             , text info $-$ (nest 2 $ numbered' $ map (text . getRuleNameDiff) cs)\n437\t--             )\n438\t--     where\n439\t--       ruleName r = map toLower $ getRuleNameDiff r\n440\t--       grp f xs = groupOn f $ sortOn f xs\n441\t--       clashes f xs = map head $ filter (\\x -> length x >= 2) (grp f xs)\n442\t\n443\t-- | Report on fresh names.\n444\tfreshNamesReport' :: [ProtoRuleE] -> WfErrorReport\n445\tfreshNamesReport' rules = do\n446\t    ru <- rules\n447\t    case filter ((LSortFresh ==) . sortOfName) $ universeBi ru of\n448\t      []    -> []\n449\t      names -> return $ (,) (underlineTopic \"Fresh public constants\") $ fsep $\n450\t          text ( \"rule \" ++ quote (showRuleCaseName ru) ++ \": \" ++\n451\t                 \"fresh public constants are not allowed:\" )\n452\t        : punctuate comma (map (nest 2 . text . show) names)\n453\t\n454\t-- | Report on fresh names.\n455\tfreshNamesReport :: OpenTranslatedTheory -> WfErrorReport\n456\tfreshNamesReport thy = freshNamesReport' $ thyProtoRules thy\n457\t\n458\t-- | Report on fresh names.\n459\tfreshNamesReportDiff :: OpenDiffTheory -> WfErrorReport\n460\tfreshNamesReportDiff thy = freshNamesReport' $ diffThyProtoRules thy\n461\t\n462\t-- | Report on capitalization of public names.\n463\tpublicNamesReport' :: [ProtoRuleE] -> WfErrorReport\n464\tpublicNamesReport' rules =\n465\t    case findClashes publicNames of\n466\t      []      -> []\n467\t      clashes -> return $ (,) (topic++notif) $ numbered' $\n468\t          map (nest 2 . fsep . punctuate comma . map ppRuleAndName. (groupOn fst)) clashes\n469\t  where\n470\t    topic       = underlineTopic \"Public constants with mismatching capitalization\" ++ \"\\n\"\n471\t    notif       = \"Identifiers are case-sensitive, \"++\n472\t                  \"mismatched capitalizations are considered as different, \"++\n473\t                  \"i.e., 'ID' is different from 'id'. \"++\n474\t                  \"Check the capitalization of your identifiers.\\n\"\n475\t    publicNames = do\n476\t        ru <- rules\n477\t        (,) (showRuleCaseName ru) <$>\n478\t            filter ((LSortPub ==) . sortOfName) (universeBi ru)\n479\t    findClashes   = clashesOn (map toLower . show . snd) (show . snd)\n480\t    ppRuleAndName ((ruName, pub):rest) =\n481\t        text $ \"rule \" ++ show ruName ++ \": \"++\" name \" ++\n482\t         show (pub) ++ concatMap ((\", \" ++) . show . snd) rest\n483\t    ppRuleAndName [] = text \"Error: empty clash\"\n484\t\n485\tpublicNamesReport :: OpenTranslatedTheory -> WfErrorReport\n486\tpublicNamesReport thy = publicNamesReport' $ thyProtoRules thy\n487\t\n488\t-- | Report on capitalization of public names.\n489\tpublicNamesReportDiff :: OpenDiffTheory -> WfErrorReport"}]},"uuid":"1b088855-dd6d-4cd1-9417-da2f15e462f4","timestamp":"2026-07-17T12:17:17.393Z","toolUseResult":{"type":"text","file":{"filePath":"/home/kamilner/tamarin-rs/tamarin-prover/lib/theory/src/Theory/Tools/Wellformedness.hs","content":"      concatMap (unfoldRuleVariants . ClosedProtoRule ruE) $\n      maybeToList (variantsProtoRule hnd (applyMacroInRule macros ruE))\n    sameVariantsUpToActions parsed computed = all (\\x -> any (equalUpToAddedActions x) computed) parsed\n\n-- | Report on missing or different variants.\nruleVariantsReport :: SignatureWithMaude -> OpenTranslatedTheory -> WfErrorReport\nruleVariantsReport sig thy = do\n    ru <- [ ru | RuleItem ru <- get thyItems thy ]\n    variantsCheck hnd (theoryMacros thy) (\"Rule \" ++ quote (showRuleCaseName (get oprRuleE ru)) ++\n                     \" cannot confirm manual variants:\") ru\n  where\n    hnd = get sigmMaudeHandle sig\n\n-- | Report on missing or different variants in case of diff rules.\nruleVariantsReportDiff :: SignatureWithMaude -> OpenDiffTheory -> WfErrorReport\nruleVariantsReportDiff sig thy = do\n    lrRu <- [ get dprLeftRight ru | DiffRuleItem ru <- get diffThyItems thy ]\n    case lrRu of\n      Just (lr, rr) -> (variantsCheck hnd (diffTheoryMacros thy) (\"Left rule \" ++ quote (showRuleCaseName (get oprRuleE lr)) ++\n                     \" cannot confirm manual variants:\") lr) ++\n                      (variantsCheck hnd (diffTheoryMacros thy) (\"Right rule \" ++ quote (showRuleCaseName (get oprRuleE rr)) ++\n                      \" cannot confirm manual variants:\") rr)\n      Nothing -> []\n  where\n    hnd = get sigmMaudeHandle sig\n\n-- | Report on inconsistent left/right rules. This does not check the variants (done by ruleVariantsReportDiff).\nleftRightRuleReportDiff :: OpenDiffTheory -> WfErrorReport\nleftRightRuleReportDiff thy = do\n    ru <- [ ru | DiffRuleItem ru <- get diffThyItems thy ]\n    case get dprLeftRight ru of\n      Just ((OpenProtoRule lr _), _) | not (equalUpToAddedActions lr (getLeftRule (applyMacroInRule (diffTheoryMacros thy) (get dprRule ru)))) -> return $\n              ( (underlineTopic \"Left rule\")\n              , text \"Inconsistent left rule\" $-$ (nest 2 $ prettyProtoRuleE lr)\n                $--$ text \"w.r.t.\" $--$\n                (nest 2 $ prettyProtoRuleE (get dprRule ru))\n              )\n      Just (_, (OpenProtoRule rr _)) | not (equalUpToAddedActions rr (getRightRule (applyMacroInRule (diffTheoryMacros thy) (get dprRule ru)))) -> return $\n              ( (underlineTopic \"Right rule\")\n              , text \"Inconsistent right rule\" $-$ (nest 2 $ prettyProtoRuleE rr)\n                $--$ text \"w.r.t.\" $--$\n                (nest 2 $ prettyProtoRuleE (get dprRule ru))\n              )\n      Just (_, _) | otherwise -> []\n      Nothing -> []\n\n-- | Report on sort clashes.\nruleSortsReportDiff :: OpenDiffTheory -> WfErrorReport\nruleSortsReportDiff thy = do\n    ru <- diffThyProtoRules thy\n    sortsClashCheck (\"rule \" ++ quote (showRuleCaseName ru) ++\n                     \":\") ru\n\n-- -- | Report on rule name clashes.\n-- -- Unnecessary, is already checked during parsing!\n-- ruleNameReportDiff :: OpenDiffTheory -> WfErrorReport\n-- ruleNameReportDiff thy =\n--   nameClashCheck (\"clashing rule names:\") (diffThyProtoRules thy)\n--\n--\n-- --- | Check that the protocol rules are well-formed.\n-- nameClashCheck :: String -> [(ProtoRuleE)] -> WfErrorReport\n-- nameClashCheck info t = case clashes ruleName t of\n--     [] -> []\n--     cs -> return $\n--             ( \"names\"\n--             , text info $-$ (nest 2 $ numbered' $ map (text . getRuleNameDiff) cs)\n--             )\n--     where\n--       ruleName r = map toLower $ getRuleNameDiff r\n--       grp f xs = groupOn f $ sortOn f xs\n--       clashes f xs = map head $ filter (\\x -> length x >= 2) (grp f xs)\n\n-- | Report on fresh names.\nfreshNamesReport' :: [ProtoRuleE] -> WfErrorReport\nfreshNamesReport' rules = do\n    ru <- rules\n    case filter ((LSortFresh ==) . sortOfName) $ universeBi ru of\n      []    -> []\n      names -> return $ (,) (underlineTopic \"Fresh public constants\") $ fsep $\n          text ( \"rule \" ++ quote (showRuleCaseName ru) ++ \": \" ++\n                 \"fresh public constants are not allowed:\" )\n        : punctuate comma (map (nest 2 . text . show) names)\n\n-- | Report on fresh names.\nfreshNamesReport :: OpenTranslatedTheory -> WfErrorReport\nfreshNamesReport thy = freshNamesReport' $ thyProtoRules thy\n\n-- | Report on fresh names.\nfreshNamesReportDiff :: OpenDiffTheory -> WfErrorReport\nfreshNamesReportDiff thy = freshNamesReport' $ diffThyProtoRules thy\n\n-- | Report on capitalization of public names.\npublicNamesReport' :: [ProtoRuleE] -> WfErrorReport\npublicNamesReport' rules =\n    case findClashes publicNames of\n      []      -> []\n      clashes -> return $ (,) (topic++notif) $ numbered' $\n          map (nest 2 . fsep . punctuate comma . map ppRuleAndName. (groupOn fst)) clashes\n  where\n    topic       = underlineTopic \"Public constants with mismatching capitalization\" ++ \"\\n\"\n    notif       = \"Identifiers are case-sensitive, \"++\n                  \"mismatched capitalizations are considered as different, \"++\n                  \"i.e., 'ID' is different from 'id'. \"++\n                  \"Check the capitalization of your identifiers.\\n\"\n    publicNames = do\n        ru <- rules\n        (,) (showRuleCaseName ru) <$>\n            filter ((LSortPub ==) . sortOfName) (universeBi ru)\n    findClashes   = clashesOn (map toLower . show . snd) (show . snd)\n    ppRuleAndName ((ruName, pub):rest) =\n        text $ \"rule \" ++ show ruName ++ \": \"++\" name \" ++\n         show (pub) ++ concatMap ((\", \" ++) . show . snd) rest\n    ppRuleAndName [] = text \"Error: empty clash\"\n\npublicNamesReport :: OpenTranslatedTheory -> WfErrorReport\npublicNamesReport thy = publicNamesReport' $ thyProtoRules thy\n\n-- | Report on capitalization of public names.\npublicNamesReportDiff :: OpenDiffTheory -> WfErrorReport","numLines":120,"startLine":370,"totalLines":1287}},"sourceToolAssistantUUID":"a220c0b5-1393-4690-a6b5-d5ca39ec7ee4","userType":"external","entrypoint":"cli","cwd":"/home/kamilner/tamarin-rs","sessionId":"57f8e1bc-d495-4b36-93c0-033347d5034a","version":"2.1.212","gitBranch":"main"}
