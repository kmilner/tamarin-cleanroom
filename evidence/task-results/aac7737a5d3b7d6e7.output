{"parentUuid":"1f5e9b0b-bda3-4fe3-9316-39818aef48b6","isSidechain":true,"agentId":"aac7737a5d3b7d6e7","message":{"model":"claude-opus-4-8","id":"msg_011Cd7cbPxrSG8tL7MYyzxQ7","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_011YH8Yhv6AWZod6JbviYgVe","name":"Read","input":{"file_path":"/home/kamilner/tamarin-cleanroom/wellformedness/workspace/wf-clean/src/pretty.rs"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":22414,"cache_read_input_tokens":24177,"cache_creation":{"ephemeral_5m_input_tokens":22414,"ephemeral_1h_input_tokens":0},"output_tokens":6,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Cd7cbNfTng51xSDTT514b","attributionAgent":"general-purpose","type":"assistant","uuid":"d91e515e-581b-4c31-a72c-16cbf83200c7","timestamp":"2026-07-17T12:16:54.880Z","effort":"xhigh","userType":"external","entrypoint":"cli","cwd":"/home/kamilner/tamarin-rs","sessionId":"57f8e1bc-d495-4b36-93c0-033347d5034a","version":"2.1.212","gitBranch":"main"}
{"parentUuid":"d91e515e-581b-4c31-a72c-16cbf83200c7","isSidechain":true,"promptId":"a3a1890b-4356-4bf6-b523-7534e72cab2b","agentId":"aac7737a5d3b7d6e7","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011YH8Yhv6AWZod6JbviYgVe","type":"tool_result","content":"1\t//! Term / fact pretty-printer reproducing the oracle's rendering.\n2\t//!\n3\t//! Every rule here traces to an oracle observation (see workspace/BEHAVIOR.md\n4\t//! and the probes t_terms, t_xor, t_nat, f_nullary).\n5\t\n6\tuse crate::ast::*;\n7\t\n8\t/// Render a variable: sort prefix + base name + optional \".idx\" (idx > 0).\n9\tpub fn pp_var(v: &VarSpec) -> String {\n10\t    let prefix = match v.sort {\n11\t        SortHint::Fresh => \"~\",\n12\t        SortHint::Pub => \"$\",\n13\t        SortHint::Nat => \"%\",\n14\t        SortHint::Node => \"#\",\n15\t        SortHint::Msg | SortHint::Untagged => \"\",\n16\t        // Suffix-sorted variables carry an explicit \":sort\"; best-effort.\n17\t        SortHint::Suffix(_) => \"\",\n18\t    };\n19\t    if v.idx > 0 {\n20\t        format!(\"{}{}.{}\", prefix, v.name, v.idx)\n21\t    } else {\n22\t        format!(\"{}{}\", prefix, v.name)\n23\t    }\n24\t}\n25\t\n26\t/// Flatten a right-nested pair term into its element list.\n27\tfn flatten_pair(t: &Term, out: &mut Vec<String>) {\n28\t    match t {\n29\t        Term::Pair(items) => {\n30\t            for it in items {\n31\t                flatten_pair(it, out);\n32\t            }\n33\t        }\n34\t        Term::App(name, args) if name == \"pair\" && args.len() == 2 => {\n35\t            flatten_pair(&args[0], out);\n36\t            flatten_pair(&args[1], out);\n37\t        }\n38\t        other => out.push(pp_term(other)),\n39\t    }\n40\t}\n41\t\n42\t/// Collect the operands of a left/right-nested chain of the same binary op.\n43\tfn flatten_binop(op: BinOp, t: &Term, out: &mut Vec<Term>) {\n44\t    if let Term::BinOp(o, a, b) = t {\n45\t        if *o == op {\n46\t            flatten_binop(op, a, out);\n47\t            flatten_binop(op, b, out);\n48\t            return;\n49\t        }\n50\t    }\n51\t    out.push(t.clone());\n52\t}\n53\t\n54\tfn pp_binop(op: BinOp, a: &Term, b: &Term) -> String {\n55\t    match op {\n56\t        // Exponentiation is shown infix without surrounding parentheses.\n57\t        BinOp::Exp => format!(\"{}^{}\", pp_term(a), pp_term(b)),\n58\t        // The AC operators are parenthesised and joined by their symbol.\n59\t        BinOp::Mult | BinOp::Union | BinOp::Xor | BinOp::NatPlus => {\n60\t            let sym = match op {\n61\t                BinOp::Mult => \"*\",\n62\t                BinOp::Union => \"++\",\n63\t                BinOp::Xor => \"\\u{2295}\", // (+)\n64\t                BinOp::NatPlus => \"%+\",\n65\t                BinOp::Exp => unreachable!(),\n66\t            };\n67\t            let whole = Term::BinOp(op, Box::new(a.clone()), Box::new(b.clone()));\n68\t            let mut operands = Vec::new();\n69\t            flatten_binop(op, &whole, &mut operands);\n70\t            let mut parts: Vec<String> = operands.iter().map(pp_term).collect();\n71\t            // XOR arguments are normalised (sorted); observed in probe t_xor.\n72\t            if op == BinOp::Xor {\n73\t                parts.sort();\n74\t            }\n75\t            format!(\"({})\", parts.join(sym))\n76\t        }\n77\t    }\n78\t}\n79\t\n80\t/// Render a term the way the oracle prints it inside facts.\n81\tpub fn pp_term(t: &Term) -> String {\n82\t    match t {\n83\t        Term::Var(v) => pp_var(v),\n84\t        Term::PubLit(s) => format!(\"'{}'\", s),\n85\t        Term::FreshLit(s) => format!(\"~'{}'\", s),\n86\t        Term::NatLit(s) => format!(\"%'{}'\", s),\n87\t        Term::Number(n) => n.to_string(),\n88\t        Term::NumberOne => \"1\".to_string(),\n89\t        Term::NatOne => \"%1\".to_string(),\n90\t        Term::DhNeutral => \"DH_neutral\".to_string(),\n91\t        Term::App(name, args) => {\n92\t            if name == \"pair\" && args.len() == 2 {\n93\t                let mut elems = Vec::new();\n94\t                flatten_pair(t, &mut elems);\n95\t                format!(\"<{}>\", elems.join(\", \"))\n96\t            } else if args.is_empty() {\n97\t                name.clone()\n98\t            } else {\n99\t                let parts: Vec<String> = args.iter().map(pp_term).collect();\n100\t                format!(\"{}({})\", name, parts.join(\", \"))\n101\t            }\n102\t        }\n103\t        Term::AlgApp(name, a, b) => format!(\"{}({}, {})\", name, pp_term(a), pp_term(b)),\n104\t        Term::Pair(_) => {\n105\t            let mut elems = Vec::new();\n106\t            flatten_pair(t, &mut elems);\n107\t            format!(\"<{}>\", elems.join(\", \"))\n108\t        }\n109\t        Term::Diff(a, b) => format!(\"diff({}, {})\", pp_term(a), pp_term(b)),\n110\t        Term::BinOp(op, a, b) => pp_binop(*op, a, b),\n111\t        Term::PatMatch(inner) => format!(\"={}\", pp_term(inner)),\n112\t    }\n113\t}\n114\t\n115\t/// Render a fact: optional `!` for persistent, then `Name( args )`.\n116\t/// Empty argument list renders as `Name( )`.\n117\tpub fn pp_fact(f: &Fact) -> String {\n118\t    let bang = if f.persistent { \"!\" } else { \"\" };\n119\t    if f.args.is_empty() {\n120\t        format!(\"{}{}( )\", bang, f.name)\n121\t    } else {\n122\t        let parts: Vec<String> = f.args.iter().map(pp_term).collect();\n123\t        format!(\"{}{}( {} )\", bang, f.name, parts.join(\", \"))\n124\t    }\n125\t}\n126\t\n127\t/// Render a bracketed fact list as it appears inside a rule: `[ f1, f2 ]`, or\n128\t/// `[ ]` when empty.\n129\tpub fn pp_fact_list(fs: &[Fact]) -> String {\n130\t    if fs.is_empty() {\n131\t        \"[ ]\".to_string()\n132\t    } else {\n133\t        let parts: Vec<String> = fs.iter().map(pp_fact).collect();\n134\t        format!(\"[ {} ]\", parts.join(\", \"))\n135\t    }\n136\t}\n137\t\n138\t/// Render a rule the way the oracle prints it (single-line body; the oracle\n139\t/// wraps very long rules across several lines - see BEHAVIOR.md gaps):\n140\t///\n141\t/// ```text\n142\t/// rule (modulo E) Name:\n143\t///    [ prems ] --> [ concls ]\n144\t/// ```\n145\t///\n146\t/// with `--[ acts ]->` in place of `-->` when the rule has action facts.\n147\tpub fn pp_rule(r: &Rule) -> String {\n148\t    let modulo = r.modulo.as_deref().unwrap_or(\"E\");\n149\t    let prems = pp_fact_list(&r.premises);\n150\t    let concls = pp_fact_list(&r.conclusions);\n151\t    let arrow = if r.actions.is_empty() {\n152\t        \"-->\".to_string()\n153\t    } else {\n154\t        let acts: Vec<String> = r.actions.iter().map(pp_fact).collect();\n155\t        format!(\"--[ {} ]->\", acts.join(\", \"))\n156\t    };\n157\t    format!(\"rule (modulo {}) {}:\\n   {} {} {}\", modulo, r.name, prems, arrow, concls)\n158\t}\n159\t"}]},"uuid":"f758210b-aabb-4400-b77a-c72468892920","timestamp":"2026-07-17T12:16:54.893Z","toolUseResult":{"type":"text","file":{"filePath":"/home/kamilner/tamarin-cleanroom/wellformedness/workspace/wf-clean/src/pretty.rs","content":"//! Term / fact pretty-printer reproducing the oracle's rendering.\n//!\n//! Every rule here traces to an oracle observation (see workspace/BEHAVIOR.md\n//! and the probes t_terms, t_xor, t_nat, f_nullary).\n\nuse crate::ast::*;\n\n/// Render a variable: sort prefix + base name + optional \".idx\" (idx > 0).\npub fn pp_var(v: &VarSpec) -> String {\n    let prefix = match v.sort {\n        SortHint::Fresh => \"~\",\n        SortHint::Pub => \"$\",\n        SortHint::Nat => \"%\",\n        SortHint::Node => \"#\",\n        SortHint::Msg | SortHint::Untagged => \"\",\n        // Suffix-sorted variables carry an explicit \":sort\"; best-effort.\n        SortHint::Suffix(_) => \"\",\n    };\n    if v.idx > 0 {\n        format!(\"{}{}.{}\", prefix, v.name, v.idx)\n    } else {\n        format!(\"{}{}\", prefix, v.name)\n    }\n}\n\n/// Flatten a right-nested pair term into its element list.\nfn flatten_pair(t: &Term, out: &mut Vec<String>) {\n    match t {\n        Term::Pair(items) => {\n            for it in items {\n                flatten_pair(it, out);\n            }\n        }\n        Term::App(name, args) if name == \"pair\" && args.len() == 2 => {\n            flatten_pair(&args[0], out);\n            flatten_pair(&args[1], out);\n        }\n        other => out.push(pp_term(other)),\n    }\n}\n\n/// Collect the operands of a left/right-nested chain of the same binary op.\nfn flatten_binop(op: BinOp, t: &Term, out: &mut Vec<Term>) {\n    if let Term::BinOp(o, a, b) = t {\n        if *o == op {\n            flatten_binop(op, a, out);\n            flatten_binop(op, b, out);\n            return;\n        }\n    }\n    out.push(t.clone());\n}\n\nfn pp_binop(op: BinOp, a: &Term, b: &Term) -> String {\n    match op {\n        // Exponentiation is shown infix without surrounding parentheses.\n        BinOp::Exp => format!(\"{}^{}\", pp_term(a), pp_term(b)),\n        // The AC operators are parenthesised and joined by their symbol.\n        BinOp::Mult | BinOp::Union | BinOp::Xor | BinOp::NatPlus => {\n            let sym = match op {\n                BinOp::Mult => \"*\",\n                BinOp::Union => \"++\",\n                BinOp::Xor => \"\\u{2295}\", // (+)\n                BinOp::NatPlus => \"%+\",\n                BinOp::Exp => unreachable!(),\n            };\n            let whole = Term::BinOp(op, Box::new(a.clone()), Box::new(b.clone()));\n            let mut operands = Vec::new();\n            flatten_binop(op, &whole, &mut operands);\n            let mut parts: Vec<String> = operands.iter().map(pp_term).collect();\n            // XOR arguments are normalised (sorted); observed in probe t_xor.\n            if op == BinOp::Xor {\n                parts.sort();\n            }\n            format!(\"({})\", parts.join(sym))\n        }\n    }\n}\n\n/// Render a term the way the oracle prints it inside facts.\npub fn pp_term(t: &Term) -> String {\n    match t {\n        Term::Var(v) => pp_var(v),\n        Term::PubLit(s) => format!(\"'{}'\", s),\n        Term::FreshLit(s) => format!(\"~'{}'\", s),\n        Term::NatLit(s) => format!(\"%'{}'\", s),\n        Term::Number(n) => n.to_string(),\n        Term::NumberOne => \"1\".to_string(),\n        Term::NatOne => \"%1\".to_string(),\n        Term::DhNeutral => \"DH_neutral\".to_string(),\n        Term::App(name, args) => {\n            if name == \"pair\" && args.len() == 2 {\n                let mut elems = Vec::new();\n                flatten_pair(t, &mut elems);\n                format!(\"<{}>\", elems.join(\", \"))\n            } else if args.is_empty() {\n                name.clone()\n            } else {\n                let parts: Vec<String> = args.iter().map(pp_term).collect();\n                format!(\"{}({})\", name, parts.join(\", \"))\n            }\n        }\n        Term::AlgApp(name, a, b) => format!(\"{}({}, {})\", name, pp_term(a), pp_term(b)),\n        Term::Pair(_) => {\n            let mut elems = Vec::new();\n            flatten_pair(t, &mut elems);\n            format!(\"<{}>\", elems.join(\", \"))\n        }\n        Term::Diff(a, b) => format!(\"diff({}, {})\", pp_term(a), pp_term(b)),\n        Term::BinOp(op, a, b) => pp_binop(*op, a, b),\n        Term::PatMatch(inner) => format!(\"={}\", pp_term(inner)),\n    }\n}\n\n/// Render a fact: optional `!` for persistent, then `Name( args )`.\n/// Empty argument list renders as `Name( )`.\npub fn pp_fact(f: &Fact) -> String {\n    let bang = if f.persistent { \"!\" } else { \"\" };\n    if f.args.is_empty() {\n        format!(\"{}{}( )\", bang, f.name)\n    } else {\n        let parts: Vec<String> = f.args.iter().map(pp_term).collect();\n        format!(\"{}{}( {} )\", bang, f.name, parts.join(\", \"))\n    }\n}\n\n/// Render a bracketed fact list as it appears inside a rule: `[ f1, f2 ]`, or\n/// `[ ]` when empty.\npub fn pp_fact_list(fs: &[Fact]) -> String {\n    if fs.is_empty() {\n        \"[ ]\".to_string()\n    } else {\n        let parts: Vec<String> = fs.iter().map(pp_fact).collect();\n        format!(\"[ {} ]\", parts.join(\", \"))\n    }\n}\n\n/// Render a rule the way the oracle prints it (single-line body; the oracle\n/// wraps very long rules across several lines - see BEHAVIOR.md gaps):\n///\n/// ```text\n/// rule (modulo E) Name:\n///    [ prems ] --> [ concls ]\n/// ```\n///\n/// with `--[ acts ]->` in place of `-->` when the rule has action facts.\npub fn pp_rule(r: &Rule) -> String {\n    let modulo = r.modulo.as_deref().unwrap_or(\"E\");\n    let prems = pp_fact_list(&r.premises);\n    let concls = pp_fact_list(&r.conclusions);\n    let arrow = if r.actions.is_empty() {\n        \"-->\".to_string()\n    } else {\n        let acts: Vec<String> = r.actions.iter().map(pp_fact).collect();\n        format!(\"--[ {} ]->\", acts.join(\", \"))\n    };\n    format!(\"rule (modulo {}) {}:\\n   {} {} {}\", modulo, r.name, prems, arrow, concls)\n}\n","numLines":159,"startLine":1,"totalLines":159}},"sourceToolAssistantUUID":"d91e515e-581b-4c31-a72c-16cbf83200c7","userType":"external","entrypoint":"cli","cwd":"/home/kamilner/tamarin-rs","sessionId":"57f8e1bc-d495-4b36-93c0-033347d5034a","version":"2.1.212","gitBranch":"main"}
