on(Fact, Term),\n    Last(Term),\n    Pred(Fact),\n}\n\n#[derive(Debug, Clone, PartialEq)]\npub enum Term {\n    Var(VarSpec),\n    PubLit(String),\n    FreshLit(String),\n    NatLit(String),\n    Number(u64),\n    NumberOne,\n    NatOne,\n    DhNeutral,\n    App(String, Vec<Term>),\n    AlgApp(String, Box<Term>, Box<Term>),\n    Pair(Vec<Term>),\n    Diff(Box<Term>, Box<Term>),\n    BinOp(BinOp, Box<Term>, Box<Term>),\n    PatMatch(Box<Term>),\n}\n\n#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]\npub enum BinOp {\n    Exp,\n    Mult,\n    Union,\n    Xor,\n    NatPlus,\n}\n\n#[derive(Debug, Clone, PartialEq, Eq, Hash)]\npub struct VarSpec {\n    pub name: String,\n    pub idx: u64,\n    pub sort: SortHint,\n    pub typ: Option<String>,\n}\n\n#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, Default)]\npub enum SortHint {\n    Msg,\n    Pub,\n    Fresh,\n    Node,\n    Nat,\n    Suffix(SuffixSort),\n    #[default]\n    Untagged,\n}\n\n#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]\npub enum SuffixSort { Msg, Pub, Fresh, Node, Nat }\n\n#[derive(Debug, Clone, PartialEq)]\npub enum FlagFormula {\n    Atom(String),\n    Not(Box<FlagFormula>),\n    And(Box<FlagFormula>, Box<FlagFormula>),\n    Or(Box<FlagFormula>, Box<FlagFormula>),\n}\n","numLines":379,"startLine":1,"totalLines":379}},"sourceToolAssistantUUID":"d9c95d2a-ee31-4469-aee6-2ae844ec2f5f","userType":"external","entrypoint":"cli","cwd":"/home/kamilner/tamarin-rs","sessionId":"57f8e1bc-d495-4b36-93c0-033347d5034a","version":"2.1.212","gitBranch":"main"}
