 :: HighlightDocument d => ProtoRuleAC -> d\n1337\tprettyProtoRuleAC = prettyNamedRule (kwRuleModulo \"AC\") prettyProtoRuleACInfo\n1338\t\n1339\tprettyRuleACInst :: HighlightDocument d => RuleACInst -> d\n1340\tprettyRuleACInst = prettyNamedRule (kwInstanceModulo \"AC\") (const emptyDoc)\n1341\t\n1342\t-- | Pretty-print a non-empty bunch of intruder rules.\n1343\tprettyIntruderVariants :: HighlightDocument d => [IntrRuleAC] -> d\n1344\tprettyIntruderVariants vs = vcat . intersperse (text \"\") $ map prettyIntrRuleAC vs\n1345\t\n1346\t{-\n1347\t-- | Pretty-print the intruder variants section.\n1348\tprettyIntrVariantsSection :: HighlightDocument d => [IntrRuleAC] -> d\n1349\tprettyIntrVariantsSection rules =\n1350\t    prettyFormalComment \"section\" \" Finite Variants of the Intruder Rules \" $--$\n1351\t    nest 1 (prettyIntruderVariants rules)\n1352\t-}\n1353\t"}]},"uuid":"2ee617c6-af9a-49ec-8af8-fe5d7564ec84","timestamp":"2026-07-17T12:17:49.250Z","toolUseResult":{"type":"text","file":{"filePath":"/home/kamilner/tamarin-rs/tamarin-prover/lib/theory/src/Theory/Model/Rule.hs","content":"    ppVariants substs = kwVariantsModulo \"AC\" $-$ prettyDisjLNSubstsVFresh substs\n\nprettyProtoRuleACInstInfo :: HighlightDocument d => ProtoRuleACInstInfo -> d\nprettyProtoRuleACInstInfo i = prettyInstLoopBreakers i\n\nprettyLoopBreakers :: HighlightDocument d => ProtoRuleACInfo -> d\nprettyLoopBreakers i = case breakers of\n    []  -> emptyDoc\n    [_] -> lineComment_ $ \"loop breaker: \"  ++ show breakers\n    _   -> lineComment_ $ \"loop breakers: \" ++ show breakers\n  where\n    breakers = getPremIdx <$> L.get pracLoopBreakers i\n\nprettyInstLoopBreakers :: HighlightDocument d => ProtoRuleACInstInfo -> d\nprettyInstLoopBreakers i = case breakers of\n    []  -> emptyDoc\n    [_] -> lineComment_ $ \"loop breaker: \"  ++ show breakers\n    _   -> lineComment_ $ \"loop breakers: \" ++ show breakers\n  where\n    breakers = getPremIdx <$> L.get praciLoopBreakers i\n\nprettyProt