{"parentUuid":"93613d71-72a5-4a2b-ada6-132e53d6dae7","isSidechain":true,"promptId":"a3a1890b-4356-4bf6-b523-7534e72cab2b","agentId":"aac7737a5d3b7d6e7","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BuWnrCZjbeJGqKG828pG4L","type":"tool_result","content":"total 84\ndrwxrwxr-x 2 kamilner kamilner  4096 Jul 17 13:07 .\ndrwxrwxr-x 5 kamilner kamilner  4096 Jul 17 11:59 ..\n-rw-rw-r-- 1 kamilner kamilner  8102 Jul 17 11:43 ast.rs\n-rw-rw-r-- 1 kamilner kamilner 46747 Jul 17 13:06 checks.rs\n-rw-rw-r-- 1 kamilner kamilner  1883 Jul 17 11:59 formula.rs\n-rw-rw-r-- 1 kamilner kamilner  3471 Jul 17 13:07 lib.rs\n-rw-rw-r-- 1 kamilner kamilner  5635 Jul 17 13:05 pretty.rs\n-rw-rw-r-- 1 kamilner kamilner  2487 Jul 17 11:48 report.rs","is_error":false}]},"uuid":"75b92bc3-2bf5-45cd-b529-c93103dd7406","timestamp":"2026-07-17T12:16:48.380Z","toolUseResult":{"stdout":"total 84\ndrwxrwxr-x 2 kamilner kamilner  4096 Jul 17 13:07 .\ndrwxrwxr-x 5 kamilner kamilner  4096 Jul 17 11:59 ..\n-rw-rw-r-- 1 kamilner kamilner  8102 Jul 17 11:43 ast.rs\n-rw-rw-r-- 1 kamilner kamilner 46747 Jul 17 13:06 checks.rs\n-rw-rw-r-- 1 kamilner kamilner  1883 Jul 17 11:59 formula.rs\n-rw-rw-r-- 1 kamilner kamilner  3471 Jul 17 13:07 lib.rs\n-rw-rw-r-- 1 kamilner kamilner  5635 Jul 17 13:05 pretty.rs\n-rw-rw-r-- 1 kamilner kamilner  2487 Jul 17 11:48 report.rs","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false},"sourceToolAssistantUUID":"93613d71-72a5-4a2b-ada6-132e53d6dae7","userType":"external","entrypoint":"cli","cwd":"/home/kamilner/tamarin-rs","sessionId":"57f8e1bc-d495-4b36-93c0-033347d5034a","version":"2.1.212","gitBranch":"main"}
{"parentUuid":"75b92bc3-2bf5-45cd-b529-c93103dd7406","isSidechain":true,"agentId":"aac7737a5d3b7d6e7","message":{"model":"claude-opus-4-8","id":"msg_011Cd7cb3peHLfpnqpZCyCdY","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01KY62s3VNruwDQEUs5YuqSq","name":"Read","input":{"file_path":"/home/kamilner/tamarin-cleanroom/wellformedness/workspace/wf-clean/src/checks.rs"},"caller":{"type":"direct"}}],"stop_reason":"tool_use","stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":9445,"cache_read_input_tokens":14732,"output_tokens":266,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":9445},"inference_geo":"not_available","iterations":[{"input_tokens":2,"output_tokens":266,"cache_read_input_tokens":14732,"cache_creation_input_tokens":9445,"cache_creation":{"ephemeral_5m_input_tokens":9445,"ephemeral_1h_input_tokens":0},"type":"message"}],"speed":"standard"},"diagnostics":null},"requestId":"req_011Cd7cb2m9LW2TfMcAqutjZ","attributionAgent":"general-purpose","type":"assistant","uuid":"468e9316-604b-4a7c-9a31-7a3a1ab3070b","timestamp":"2026-07-17T12:16:48.776Z","effort":"xhigh","userType":"external","entrypoint":"cli","cwd":"/home/kamilner/tamarin-rs","sessionId":"57f8e1bc-d495-4b36-93c0-033347d5034a","version":"2.1.212","gitBranch":"main"}
{"parentUuid":"468e9316-604b-4a7c-9a31-7a3a1ab3070b","isSidechain":true,"promptId":"a3a1890b-4356-4bf6-b523-7534e72cab2b","agentId":"aac7737a5d3b7d6e7","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KY62s3VNruwDQEUs5YuqSq","type":"tool_result","content":"1\t//! The individual wellformedness checks. Each produces zero or one `WfError`\n2\t//! (one topic block). Message bodies reproduce oracle byte formatting.\n3\t\n4\tuse crate::ast::*;\n5\tuse crate::pretty::{pp_fact, pp_rule, pp_term, pp_var};\n6\tuse crate::report::WfError;\n7\t\n8\t// ---- Topic strings (exact, including significant whitespace) ----\n9\tpub const T_UNBOUND: &str = \"Unbound variables\";\n10\tpub const T_FRESH_PUB: &str = \"Fresh public constants\";\n11\tpub const T_PUBNAMES: &str = \"Public constants with mismatching capitalization\";\n12\tpub const T_SORTS: &str = \"Variable with mismatching sorts or capitalization\";\n13\tpub const T_RESERVED: &str = \"Reserved names\";\n14\tpub const T_RESERVED_PREFIX: &str = \"Reserved prefixes\";\n15\tpub const T_FR: &str = \"Fr facts must only use a fresh- or a msg-variable\";\n16\tpub const T_SPECIAL: &str = \"Special facts\";\n17\tpub const T_ARITY: &str = \"Fact arity issues\";\n18\tpub const T_MULT: &str = \"Fact multiplicity issues\";\n19\tpub const T_LHSRHS: &str = \"Facts occur in the left-hand-side but not in any right-hand-side \";\n20\tpub const T_LEFT: &str = \"Left rule\";\n21\tpub const T_RIGHT: &str = \"Right rule\";\n22\tpub const T_FORMULA_TERMS: &str = \"Formula terms\";\n23\tpub const T_GUARD: &str = \" Formula guardedness\";\n24\tpub const T_LEMMA_ANNOT: &str = \"Lemma annotations\";\n25\tpub const T_MULRESTRICT: &str = \"Multiplication restriction of rules\";\n26\tpub const T_NAT: &str = \"Nat Sorts\";\n27\tpub const T_SUBTERM: &str = \"Subterm Convergence Warning\";\n28\t\n29\t/// Fact-name prefixes reserved for the diff-mode translation (observed in the\n30\t/// \"Reserved prefixes\" check, diff mode only).\n31\tconst RESERVED_PREFIXES: &[&str] = &[\"DiffIntr\", \"DiffProto\"];\n32\t\n33\t/// Word-fill width used by the oracle's pretty-printer for the wrapped\n34\t/// \"Reserved prefixes\" header (measured empirically: a line breaks before the\n35\t/// next word once it would exceed column 69).\n36\tconst FILL_WIDTH: usize = 69;\n37\t\n38\t/// Reserved fact names (used as protocol facts -> \"Reserved names\").\n39\tconst RESERVED_FACTS: &[&str] = &[\"K\", \"KU\", \"KD\"];\n40\t/// Special I/O facts handled by the special-fact / Fr checks.\n41\tconst SPECIAL_FACTS: &[&str] = &[\"In\", \"Out\", \"Fr\"];\n42\t\n43\tfn is_reserved(name: &str) -> bool {\n44\t    RESERVED_FACTS.contains(&name)\n45\t}\n46\tfn is_special(name: &str) -> bool {\n47\t    SPECIAL_FACTS.contains(&name)\n48\t}\n49\tfn is_builtin_factname(name: &str) -> bool {\n50\t    is_reserved(name) || is_special(name)\n51\t}\n52\t\n53\t// ---------------------------------------------------------------------------\n54\t// AST traversal helpers\n55\t// ---------------------------------------------------------------------------\n56\t\n57\t/// The protocol rules of a theory (excludes intruder rules).\n58\tpub fn protocol_rules(thy: &Theory) -> Vec<&Rule> {\n59\t    thy.items\n60\t        .iter()\n61\t        .filter_map(|it| match it {\n62\t            TheoryItem::Rule(r) => Some(r),\n63\t            _ => None,\n64\t        })\n65\t        .collect()\n66\t}\n67\t\n68\tfn collect_term_vars(t: &Term, out: &mut Vec<VarSpec>) {\n69\t    match t {\n70\t        Term::Var(v) => out.push(v.clone()),\n71\t        Term::App(_, args) | Term::Pair(args) => {\n72\t            for a in args {\n73\t                collect_term_vars(a, out);\n74\t            }\n75\t        }\n76\t        Term::AlgApp(_, a, b) | Term::Diff(a, b) | Term::BinOp(_, a, b) => {\n77\t            collect_term_vars(a, out);\n78\t            collect_term_vars(b, out);\n79\t        }\n80\t        Term::PatMatch(inner) => collect_term_vars(inner, out),\n81\t        _ => {}\n82\t    }\n83\t}\n84\t\n85\tfn collect_fact_vars(f: &Fact, out: &mut Vec<VarSpec>) {\n86\t    for a in &f.args {\n87\t        collect_term_vars(a, out);\n88\t    }\n89\t}\n90\t\n91\tfn collect_facts_vars(fs: &[Fact], out: &mut Vec<VarSpec>) {\n92\t    for f in fs {\n93\t        collect_fact_vars(f, out);\n94\t    }\n95\t}\n96\t\n97\t/// Collect public-constant literals (name only) from a term.\n98\tfn collect_pub_lits(t: &Term, out: &mut Vec<String>) {\n99\t    match t {\n100\t        Term::PubLit(s) => out.push(s.clone()),\n101\t        Term::App(_, args) | Term::Pair(args) => {\n102\t            for a in args {\n103\t                collect_pub_lits(a, out);\n104\t            }\n105\t        }\n106\t        Term::AlgApp(_, a, b) | Term::Diff(a, b) | Term::BinOp(_, a, b) => {\n107\t            collect_pub_lits(a, out);\n108\t            collect_pub_lits(b, out);\n109\t        }\n110\t        Term::PatMatch(inner) => collect_pub_lits(inner, out),\n111\t        _ => {}\n112\t    }\n113\t}\n114\t\n115\t/// Collect fresh-name literals (`~'foo'`) from a term, rendered as the oracle\n116\t/// prints them.\n117\tfn collect_fresh_lits(t: &Term, out: &mut Vec<String>) {\n118\t    match t {\n119\t        Term::FreshLit(_) => out.push(pp_term(t)),\n120\t        Term::App(_, args) | Term::Pair(args) => {\n121\t            for a in args {\n122\t                collect_fresh_lits(a, out);\n123\t            }\n124\t        }\n125\t        Term::AlgApp(_, a, b) | Term::Diff(a, b) | Term::BinOp(_, a, b) => {\n126\t            collect_fresh_lits(a, out);\n127\t            collect_fresh_lits(b, out);\n128\t        }\n129\t        Term::PatMatch(inner) => collect_fresh_lits(inner, out),\n130\t        _ => {}\n131\t    }\n132\t}\n133\t\n134\t/// Collect maximal multiplication (`*`) subterms of a term, rendered as the\n135\t/// oracle prints them. A product is maximal: its own operands are not\n136\t/// descended into.\n137\tfn collect_mult_terms(t: &Term, out: &mut Vec<String>) {\n138\t    if let Term::BinOp(BinOp::Mult, _, _) = t {\n139\t        out.push(pp_term(t));\n140\t        return;\n141\t    }\n142\t    match t {\n143\t        Term::App(_, args) | Term::Pair(args) => {\n144\t            for a in args {\n145\t                collect_mult_terms(a, out);\n146\t            }\n147\t        }\n148\t        Term::AlgApp(_, a, b) | Term::Diff(a, b) | Term::BinOp(_, a, b) => {\n149\t            collect_mult_terms(a, out);\n150\t            collect_mult_terms(b, out);\n151\t        }\n152\t        Term::PatMatch(inner) => collect_mult_terms(inner, out),\n153\t        _ => {}\n154\t    }\n155\t}\n156\t\n157\t/// Indent every line of a (possibly multi-line) block by `n` spaces.\n158\tfn indent_block(s: &str, n: usize) -> String {\n159\t    let pad = \" \".repeat(n);\n160\t    s.lines()\n161\t        .map(|l| format!(\"{}{}\", pad, l))\n162\t        .collect::<Vec<_>>()\n163\t        .join(\"\\n\")\n164\t}\n165\t\n166\t/// Word-fill (Wadler/Leijen `fillSep`) at the given `width` with a leading\n167\t/// `indent` of spaces on every line. A word is pushed onto the current line\n168\t/// while it fits (column + 1 + word <= width), otherwise a new line begins.\n169\tfn fill_words(words: &[String], indent: usize, width: usize) -> String {\n170\t    let pad = \" \".repeat(indent);\n171\t    let mut lines: Vec<String> = Vec::new();\n172\t    let mut cur = String::new();\n173\t    let mut col = 0usize;\n174\t    for w in words {\n175\t        let wlen = w.chars().count();\n176\t        if cur.is_empty() {\n177\t            cur = format!(\"{}{}\", pad, w);\n178\t            col = indent + wlen;\n179\t        } else if col + 1 + wlen <= width {\n180\t            cur.push(' ');\n181\t            cur.push_str(w);\n182\t            col += 1 + wlen;\n183\t        } else {\n184\t            lines.push(std::mem::take(&mut cur));\n185\t            cur = format!(\"{}{}\", pad, w);\n186\t            col = indent + wlen;\n187\t        }\n188\t    }\n189\t    if !cur.is_empty() {\n190\t        lines.push(cur);\n191\t    }\n192\t    lines.join(\"\\n\")\n193\t}\n194\t\n195\tfn var_needs_binding(v: &VarSpec) -> bool {\n196\t    matches!(\n197\t        v.sort,\n198\t        SortHint::Fresh | SortHint::Msg | SortHint::Untagged | SortHint::Nat\n199\t    )\n200\t}\n201\t\n202\tfn var_key(v: &VarSpec) -> (String, u64, i32) {\n203\t    (v.name.clone(), v.idx, sort_rank(v.sort))\n204\t}\n205\t\n206\tfn sort_rank(s: SortHint) -> i32 {\n207\t    match s {\n208\t        SortHint::Msg => 0,\n209\t        SortHint::Pub => 1,\n210\t        SortHint::Fresh => 2,\n211\t        SortHint::Node => 3,\n212\t        SortHint::Nat => 4,\n213\t        SortHint::Untagged => 5,\n214\t        SortHint::Suffix(_) => 6,\n215\t    }\n216\t}\n217\t\n218\tfn dedup_vars(mut vs: Vec<VarSpec>) -> Vec<VarSpec> {\n219\t    vs.sort_by_key(var_key);\n220\t    vs.dedup_by_key(|v| var_key(v));\n221\t    vs\n222\t}\n223\t\n224\t// ---------------------------------------------------------------------------\n225\t// 1. Unbound variables\n226\t// ---------------------------------------------------------------------------\n227\tpub fn unbound_variables(thy: &Theory) -> Vec<WfError> {\n228\t    let mut entries: Vec<String> = Vec::new();\n229\t    for r in protocol_rules(thy) {\n230\t        // Bound = variables in premises plus let-bound variables.\n231\t        let mut bound: Vec<VarSpec> = Vec::new();\n232\t        collect_facts_vars(&r.premises, &mut bound);\n233\t        for lb in &r.let_block {\n234\t            collect_term_vars(&lb.var, &mut bound);\n235\t        }\n236\t        let bound: std::collections::HashSet<(String, u64, i32)> =\n237\t            bound.iter().map(var_key).collect();\n238\t\n239\t        // Used = variables in actions, conclusions, embedded restrictions,\n240\t        // and the right-hand-sides of let bindings.\n241\t        let mut used: Vec<VarSpec> = Vec::new();\n242\t        collect_facts_vars(&r.actions, &mut used);\n243\t        collect_facts_vars(&r.conclusions, &mut used);\n244\t        for lb in &r.let_block {\n245\t            collect_term_vars(&lb.value, &mut used);\n246\t        }\n247\t\n248\t        let mut unbound: Vec<VarSpec> = used\n249\t            .into_iter()\n250\t            .filter(var_needs_binding)\n251\t            .filter(|v| !bound.contains(&var_key(v)))\n252\t            .collect();\n253\t        unbound = dedup_vars(unbound);\n254\t        // Report order: by base name then index.\n255\t        unbound.sort_by(|a, b| a.name.cmp(&b.name).then(a.idx.cmp(&b.idx)));\n256\t\n257\t        if !unbound.is_empty() {\n258\t            let names: Vec<String> = unbound.iter().map(pp_var).collect();\n259\t            entries.push(format!(\n260\t                \"  rule `{}' has unbound variables: \\n    {}\",\n261\t                r.name,\n262\t                names.join(\", \")\n263\t            ));\n264\t        }\n265\t    }\n266\t    if entries.is_empty() {\n267\t        vec![]\n268\t    } else {\n269\t        vec![WfError::new(T_UNBOUND, entries.join(\"\\n  \\n\"))]\n270\t    }\n271\t}\n272\t\n273\t// ---------------------------------------------------------------------------\n274\t// 3. Variable with mismatching sorts or capitalization\n275\t// ---------------------------------------------------------------------------\n276\tpub fn mismatching_sorts(thy: &Theory) -> Vec<WfError> {\n277\t    let mut rule_entries: Vec<String> = Vec::new();\n278\t    for r in protocol_rules(thy) {\n279\t        let mut vars: Vec<VarSpec> = Vec::new();\n280\t        collect_facts_vars(&r.premises, &mut vars);\n281\t        collect_facts_vars(&r.actions, &mut vars);\n282\t        collect_facts_vars(&r.conclusions, &mut vars);\n283\t\n284\t        // Group by lowercased base name; a group with >1 distinct variant\n285\t        // (prefix+name, ignoring index) is a conflict.\n286\t        let mut groups: Vec<(String, Vec<String>)> = Vec::new(); // (lc key, variants)\n287\t        for v in &vars {\n288\t            let key = v.name.to_lowercase();\n289\t            let variant = variant_repr(v);\n290\t            match groups.iter_mut().find(|(k, _)| *k == key) {\n291\t                Some((_, variants)) => {\n292\t                    if !variants.contains(&variant) {\n293\t                        variants.push(variant);\n294\t                    }\n295\t                }\n296\t                None => groups.push((key, vec![variant])),\n297\t            }\n298\t        }\n299\t        let mut conflicts: Vec<Vec<String>> = groups\n300\t            .into_iter()\n301\t            .filter(|(_, vs)| vs.len() > 1)\n302\t            .map(|(_, mut vs)| {\n303\t                vs.sort();\n304\t                vs\n305\t            })\n306\t            .collect();\n307\t        if conflicts.is_empty() {\n308\t            continue;\n309\t        }\n310\t        // deterministic ordering of groups within a rule\n311\t        conflicts.sort();\n312\t        let mut body = format!(\"  rule `{}': \", r.name);\n313\t        for (i, variants) in conflicts.iter().enumerate() {\n314\t            body.push_str(&format!(\"\\n    {}. {}\", i + 1, variants.join(\", \")));\n315\t        }\n316\t        rule_entries.push(body);\n317\t    }\n318\t    if rule_entries.is_empty() {\n319\t        return vec![];\n320\t    }\n321\t    let header = \"Possible reasons:\\n1. Identifiers are case sensitive, i.e.,'x' and 'X' are considered to be different.\\n2. The same holds for sorts:, i.e., '$x', 'x', and '~x' are considered to be different.\\n\";\n322\t    let msg = format!(\"{}\\n{}\", header, rule_entries.join(\"\\n  \\n\"));\n323\t    vec![WfError::new(T_SORTS, msg)]\n324\t}\n325\t\n326\t/// A variable's sort+name representation without the numeric index.\n327\tfn variant_repr(v: &VarSpec) -> String {\n328\t    let prefix = match v.sort {\n329\t        SortHint::Fresh => \"~\",\n330\t        SortHint::Pub => \"$\",\n331\t        SortHint::Nat => \"%\",\n332\t        SortHint::Node => \"#\",\n333\t        _ => \"\",\n334\t    };\n335\t    format!(\"{}{}\", prefix, v.name)\n336\t}\n337\t\n338\t// ---------------------------------------------------------------------------\n339\t// 4. Reserved names\n340\t// ---------------------------------------------------------------------------\n341\tpub fn reserved_names(thy: &Theory) -> Vec<WfError> {\n342\t    let mut entries: Vec<String> = Vec::new();\n343\t    for r in protocol_rules(thy) {\n344\t        // On the left/right the reserved set is {K,KU,KD}; in the middle\n345\t        // (actions) the I/O facts In/Out/Fr are reserved too (observed z9/z11).\n346\t        for (facts, phrase, middle) in [\n347\t            (&r.premises, \"left-hand-side\", false),\n348\t            (&r.actions, \"the middle\", true),\n349\t            (&r.conclusions, \"the right-hand-side\", false),\n350\t        ] {\n351\t            let hits: Vec<&Fact> = facts\n352\t                .iter()\n353\t                .filter(|f| is_reserved(&f.name) || (middle && is_special(&f.name)))\n354\t                .collect();\n355\t            if hits.is_empty() {\n356\t                continue;\n357\t            }\n358\t            let rendered: Vec<String> = hits.iter().map(|f| pp_fact(f)).collect();\n359\t            entries.push(format!(\n360\t                \"  Rule `{}' contains facts with reserved names on {}:\\n    {}\",\n361\t                r.name,\n362\t                phrase,\n363\t                rendered.join(\", \")\n364\t            ));\n365\t        }\n366\t    }\n367\t    if entries.is_empty() {\n368\t        vec![]\n369\t    } else {\n370\t        vec![WfError::new(T_RESERVED, entries.join(\"\\n  \\n\"))]\n371\t    }\n372\t}\n373\t\n374\t// ---------------------------------------------------------------------------\n375\t// 5. Fr facts must only use a fresh- or a msg-variable\n376\t// ---------------------------------------------------------------------------\n377\tpub fn fr_facts(thy: &Theory) -> Vec<WfError> {\n378\t    let mut entries: Vec<String> = Vec::new();\n379\t    for r in protocol_rules(thy) {\n380\t        for facts in [&r.premises, &r.conclusions] {\n381\t            for f in facts {\n382\t                if f.name != \"Fr\" {\n383\t                    continue;\n384\t                }\n385\t                let ok = f.args.len() == 1\n386\t                    && matches!(\n387\t                        &f.args[0],\n388\t                        Term::Var(v) if matches!(v.sort, SortHint::Fresh | SortHint::Msg | SortHint::Untagged)\n389\t                    );\n390\t                if !ok {\n391\t                    entries.push(format!(\"  rule `{}' fact: {}\", r.name, pp_fact(f)));\n392\t                }\n393\t            }\n394\t        }\n395\t    }\n396\t    if entries.is_empty() {\n397\t        vec![]\n398\t    } else {\n399\t        vec![WfError::new(T_FR, entries.join(\"\\n  \\n\"))]\n400\t    }\n401\t}\n402\t\n403\t// ---------------------------------------------------------------------------\n404\t// 6. Special facts (disallowed I/O facts in wrong position)\n405\t// ---------------------------------------------------------------------------\n406\tpub fn special_facts(thy: &Theory) -> Vec<WfError> {\n407\t    let mut entries: Vec<String> = Vec::new();\n408\t    for r in protocol_rules(thy) {\n409\t        // Premise side: `Out` is disallowed.\n410\t        let lhs: Vec<String> = r\n411\t            .premises\n412\t            .iter()\n413\t            .filter(|f| f.name == \"Out\")\n414\t            .map(|f| pp_fact(f))\n415\t            .collect();\n416\t        if !lhs.is_empty() {\n417\t            entries.push(format!(\n418\t                \"  rule `{}' uses disallowed facts on left-hand-side:\\n    {}\",\n419\t                r.name,\n420\t                lhs.join(\", \")\n421\t            ));\n422\t        }\n423\t        // Conclusion side: `In` and `Fr` are disallowed.\n424\t        let rhs: Vec<String> = r\n425\t            .conclusions\n426\t            .iter()\n427\t            .filter(|f| f.name == \"In\" || f.name == \"Fr\")\n428\t            .map(|f| pp_fact(f))\n429\t            .collect();\n430\t        if !rhs.is_empty() {\n431\t            entries.push(format!(\n432\t                \"  rule `{}' uses disallowed facts on right-hand-side:\\n    {}\",\n433\t                r.name,\n434\t                rhs.join(\", \")\n435\t            ));\n436\t        }\n437\t    }\n438\t    if entries.is_empty() {\n439\t        vec![]\n440\t    } else {\n441\t        vec![WfError::new(T_SPECIAL, entries.join(\"\\n  \\n\"))]\n442\t    }\n443\t}\n444\t\n445\t// ---------------------------------------------------------------------------\n446\t// 7 & 8. Fact arity / multiplicity issues\n447\t// ---------------------------------------------------------------------------\n448\t\n449\tstruct FactUse {\n450\t    rule: String,\n451\t    arity: usize,\n452\t    persistent: bool,\n453\t    pp: String,\n454\t}\n455\t\n456\t/// Gather every fact occurrence in protocol rules (name -> uses), in source\n457\t/// order.\n458\tfn gather_fact_uses(thy: &Theory) -> Vec<(String, Vec<FactUse>)> {\n459\t    let mut map: Vec<(String, Vec<FactUse>)> = Vec::new();\n460\t    for r in protocol_rules(thy) {\n461\t        for facts in [&r.premises, &r.actions, &r.conclusions] {\n462\t            for f in facts {\n463\t                let entry = FactUse {\n464\t                    rule: r.name.clone(),\n465\t                    arity: f.args.len(),\n466\t                    persistent: f.persistent,\n467\t                    pp: pp_fact(f),\n468\t                };\n469\t                match map.iter_mut().find(|(n, _)| *n == f.name) {\n470\t                    Some((_, uses)) => uses.push(entry),\n471\t                    None => map.push((f.name.clone(), vec![entry])),\n472\t                }\n473\t            }\n474\t        }\n475\t    }\n476\t    map\n477\t}\n478\t\n479\tfn render_fact_blocks(conflicts: &[(String, Vec<String>)], intro1: &str, intro2: &str) -> String {\n480\t    // conflicts: (lowercased fact name, item lines) already ordered.\n481\t    let mut body = format!(\"{}\\n{}\\n  \", intro1, intro2);\n482\t    for (i, (lname, items)) in conflicts.iter().enumerate() {\n483\t        let block = format!(\"  Fact `{}':\\n\\n{}\\n  \", lname, items.join(\"\\n    \\n\"));\n484\t        if i == 0 {\n485\t            body.push_str(\"\\n\\n\");\n486\t        } else {\n487\t            body.push('\\n');\n488\t        }\n489\t        body.push_str(&block);\n490\t    }\n491\t    body\n492\t}\n493\t\n494\tpub fn fact_arity(thy: &Theory) -> Vec<WfError> {\n495\t    let uses = gather_fact_uses(thy);\n496\t    let mut conflicts: Vec<(String, Vec<String>)> = Vec::new();\n497\t    for (name, us) in &uses {\n498\t        let arities: std::collections::BTreeSet<usize> = us.iter().map(|u| u.arity).collect();\n499\t        if arities.len() < 2 {\n500\t            continue;\n501\t        }\n502\t        // one item per distinct (rule, arity), first pp kept, source order.\n503\t        let mut seen: Vec<(String, usize)> = Vec::new();\n504\t        let mut items: Vec<String> = Vec::new();\n505\t        for u in us {\n506\t            let k = (u.rule.clone(), u.arity);\n507\t            if seen.contains(&k) {\n508\t                continue;\n509\t            }\n510\t            seen.push(k);\n511\t            let n = items.len() + 1;\n512\t            items.push(format!(\n513\t                \"    {}. Rule `{}', arity {}\\n         {}\",\n514\t                n, u.rule, u.arity, u.pp\n515\t            ));\n516\t        }\n517\t        conflicts.push((name.to_lowercase(), items));\n518\t    }\n519\t    if conflicts.is_empty() {\n520\t        return vec![];\n521\t    }\n522\t    conflicts.sort_by(|a, b| a.0.cmp(&b.0));\n523\t    let msg = render_fact_blocks(\n524\t        &conflicts,\n525\t        \"Same fact is used with different arities, i.e., Fact('A','B') is different from Fact('A'). \",\n526\t        \"Check the arguments of your facts.\",\n527\t    );\n528\t    vec![WfError::new(T_ARITY, msg)]\n529\t}\n530\t\n531\tpub fn fact_multiplicity(thy: &Theory) -> Vec<WfError> {\n532\t    let uses = gather_fact_uses(thy);\n533\t    let mut conflicts: Vec<(String, Vec<String>)> = Vec::new();\n534\t    for (name, us) in &uses {\n535\t        let mults: std::collections::BTreeSet<bool> = us.iter().map(|u| u.persistent).collect();\n536\t        if mults.len() < 2 {\n537\t            continue;\n538\t        }\n539\t        let mut seen: Vec<(String, bool)> = Vec::new();\n540\t        let mut items: Vec<String> = Vec::new();\n541\t        for u in us {\n542\t            let k = (u.rule.clone(), u.persistent);\n543\t            if seen.contains(&k) {\n544\t                continue;\n545\t            }\n546\t            seen.push(k);\n547\t            let n = items.len() + 1;\n548\t            let m = if u.persistent { \"Persistent\" } else { \"Linear\" };\n549\t            items.push(format!(\n550\t                \"    {}. Rule `{}', multiplicity (persistence) {}\\n         {}\",\n551\t                n, u.rule, m, u.pp\n552\t            ));\n553\t        }\n554\t        conflicts.push((name.to_lowercase(), items));\n555\t    }\n556\t    if conflicts.is_empty() {\n557\t        return vec![];\n558\t    }\n559\t    conflicts.sort_by(|a, b| a.0.cmp(&b.0));\n560\t    let msg = render_fact_blocks(\n561\t        &conflicts,\n562\t        \"Same fact is used with different multiplicities, i.e., !Fact() (Persistent fact) exists along with Fact() (Linear) in your rules. \",\n563\t        \"Check the multiplicity (persistence) of your facts.\",\n564\t    );\n565\t    vec![WfError::new(T_MULT, msg)]\n566\t}\n567\t\n568\t// ---------------------------------------------------------------------------\n569\t// 9. Facts occur in the left-hand-side but not in any right-hand-side\n570\t// ---------------------------------------------------------------------------\n571\t\n572\t#[derive(Clone)]\n573\tstruct FactId {\n574\t    name: String,\n575\t    arity: usize,\n576\t    persistent: bool,\n577\t    rule: String,\n578\t}\n579\t\n580\timpl FactId {\n581\t    fn ident(&self) -> (String, usize, bool) {\n582\t        (self.name.clone(), self.arity, self.persistent)\n583\t    }\n584\t    fn render(&self) -> String {\n585\t        format!(\n586\t            \"in rule \\\"{}\\\":  factName `{}' arity: {} multiplicity: {}\",\n587\t            self.rule,\n588\t            self.name,\n589\t            self.arity,\n590\t            if self.persistent { \"Persistent\" } else { \"Linear\" }\n591\t        )\n592\t    }\n593\t}\n594\t\n595\tpub fn fact_lhs_occur_no_rhs(thy: &Theory) -> Vec<WfError> {\n596\t    let mut lhs: Vec<FactId> = Vec::new();\n597\t    let mut rhs: Vec<FactId> = Vec::new();\n598\t    for r in protocol_rules(thy) {\n599\t        for f in &r.premises {\n600\t            if is_builtin_factname(&f.name) {\n601\t                continue;\n602\t            }\n603\t            lhs.push(FactId {\n604\t                name: f.name.clone(),\n605\t                arity: f.args.len(),\n606\t                persistent: f.persistent,\n607\t                rule: r.name.clone(),\n608\t            });\n609\t        }\n610\t        for f in &r.conclusions {\n611\t            if is_builtin_factname(&f.name) {\n612\t                continue;\n613\t            }\n614\t            rhs.push(FactId {\n615\t                name: f.name.clone(),\n616\t                arity: f.args.len(),\n617\t                persistent: f.persistent,\n618\t                rule: r.name.clone(),\n619\t            });\n620\t        }\n621\t    }\n622\t    let rhs_idents: std::collections::HashSet<(String, usize, bool)> =\n623\t        rhs.iter().map(|f| f.ident()).collect();\n624\t\n625\t    // LHS-only identities, first occurrence, in source order.\n626\t    let mut seen: Vec<(String, usize, bool)> = Vec::new();\n627\t    let mut items: Vec<String> = Vec::new();\n628\t    for f in &lhs {\n629\t        if rhs_idents.contains(&f.ident()) || seen.contains(&f.ident()) {\n630\t            continue;\n631\t        }\n632\t        seen.push(f.ident());\n633\t        let n = items.len() + 1;\n634\t        let mut line = format!(\"  {}. {}\", n, f.render());\n635\t        if let Some(sugg) = nearest_rhs(&f.name, &rhs) {\n636\t            line.push_str(&format!(\". Perhaps you want to use the fact {}\", sugg.render()));\n637\t        }\n638\t        items.push(line);\n639\t    }\n640\t    if items.is_empty() {\n641\t        vec![]\n642\t    } else {\n643\t        vec![WfError::new(T_LHSRHS, items.join(\"\\n  \\n\"))]\n644\t    }\n645\t}\n646\t\n647\t/// Nearest RHS fact by name edit distance, if within threshold (<= 3).\n648\tfn nearest_rhs<'a>(name: &str, rhs: &'a [FactId]) -> Option<&'a FactId> {\n649\t    let mut best: Option<(usize, &FactId)> = None;\n650\t    for f in rhs {\n651\t        let d = edit_distance(name, &f.name);\n652\t        match best {\n653\t            Some((bd, _)) if d >= bd => {}\n654\t            _ => best = Some((d, f)),\n655\t        }\n656\t    }\n657\t    match best {\n658\t        Some((d, f)) if d <= 3 => Some(f),\n659\t        _ => None,\n660\t    }\n661\t}\n662\t\n663\tfn edit_distance(a: &str, b: &str) -> usize {\n664\t    let a: Vec<char> = a.chars().collect();\n665\t    let b: Vec<char> = b.chars().collect();\n666\t    let mut prev: Vec<usize> = (0..=b.len()).collect();\n667\t    let mut cur = vec![0usize; b.len() + 1];\n668\t    for i in 1..=a.len() {\n669\t        cur[0] = i;\n670\t        for j in 1..=b.len() {\n671\t            let cost = if a[i - 1] == b[j - 1] { 0 } else { 1 };\n672\t            cur[j] = (prev[j] + 1).min(cur[j - 1] + 1).min(prev[j - 1] + cost);\n673\t        }\n674\t        std::mem::swap(&mut prev, &mut cur);\n675\t    }\n676\t    prev[b.len()]\n677\t}\n678\t\n679\t// ---------------------------------------------------------------------------\n680\t// 2. Public constants with mismatching capitalization (public-names report)\n681\t// ---------------------------------------------------------------------------\n682\t\n683\tpub fn public_names_report(thy: &Theory) -> Vec<WfError> {\n684\t    let mut pairs: Vec<(String, String)> = Vec::new(); // (constName, ruleName)\n685\t    for r in protocol_rules(thy) {\n686\t        let mut names: Vec<String> = Vec::new();\n687\t        for facts in [&r.premises, &r.actions, &r.conclusions] {\n688\t            for f in facts {\n689\t                for a in &f.args {\n690\t                    collect_pub_lits(a, &mut names);\n691\t                }\n692\t            }\n693\t        }\n694\t        for n in names {\n695\t            let pair = (n, r.name.clone());\n696\t            if !pairs.contains(&pair) {\n697\t                pairs.push(pair);\n698\t            }\n699\t        }\n700\t    }\n701\t    public_names_report_from_pairs(pairs)\n702\t}\n703\t\n704\tpub fn public_names_report_from_pairs(pairs: Vec<(String, String)>) -> Vec<WfError> {\n705\t    // Group by lowercased constant name, preserving first-seen order.\n706\t    let mut groups: Vec<(String, Vec<(String, String)>)> = Vec::new();\n707\t    for (name, rule) in &pairs {\n708\t        let key = name.to_lowercase();\n709\t        match groups.iter_mut().find(|(k, _)| *k == key) {\n710\t            Some((_, v)) => v.push((name.clone(), rule.clone())),\n711\t            None => groups.push((key, vec![(name.clone(), rule.clone())])),\n712\t        }\n713\t    }\n714\t    let mut items: Vec<String> = Vec::new();\n715\t    for (_, occ) in &groups {\n716\t        let distinct: std::collections::BTreeSet<&String> = occ.iter().map(|(n, _)| n).collect();\n717\t        if distinct.len() < 2 {\n718\t            continue; // no capitalization conflict\n719\t        }\n720\t        // Group occurrences by rule, preserving first-seen rule order.\n721\t        let mut by_rule: Vec<(String, Vec<String>)> = Vec::new();\n722\t        for (n, rule) in occ {\n723\t            match by_rule.iter_mut().find(|(rr, _)| rr == rule) {\n724\t                Some((_, ns)) => {\n725\t                    if !ns.contains(n) {\n726\t                        ns.push(n.clone());\n727\t                    }\n728\t                }\n729\t                None => by_rule.push((rule.clone(), vec![n.clone()])),\n730\t            }\n731\t        }\n732\t        let locs: Vec<String> = by_rule\n733\t            .into_iter()\n734\t            .map(|(rule, mut ns)| {\n735\t                ns.sort();\n736\t                let quoted: Vec<String> = ns.iter().map(|n| format!(\"'{}'\", n)).collect();\n737\t                format!(\"rule \\\"{}\\\":  name {}\", rule, quoted.join(\", \"))\n738\t            })\n739\t            .collect();\n740\t        let n = items.len() + 1;\n741\t        items.push(format!(\"  {}. {}\", n, locs.join(\", \")));\n742\t    }\n743\t    if items.is_empty() {\n744\t        return vec![];\n745\t    }\n746\t    let header = \"Identifiers are case-sensitive, mismatched capitalizations are considered as different, i.e., 'ID' is different from 'id'. Check the capitalization of your identifiers.\";\n747\t    let msg = format!(\"{}\\n\\n{}\", header, items.join(\"\\n  \\n\"));\n748\t    vec![WfError::new(T_PUBNAMES, msg)]\n749\t}\n750\t\n751\t// ---------------------------------------------------------------------------\n752\t// 10. Formula terms (free variables in lemma / restriction formulas)\n753\t// ---------------------------------------------------------------------------\n754\t\n755\tconst FORMULA_TERMS_HELP: &str = \"  The only allowed terms are public constants and bound node and\\n  message variables. If you encounter free message variables, then\\n  you might have forgotten a #-prefix. Sort prefixes can only be\\n  dropped where this is unambiguous. Moreover, reducible function\\n  symbols are disallowed.\";\n756\t\n757\t// Bound variables are matched by NAME only. The oracle treats a quantified\n758\t// message variable and its occurrences as the same variable even when the\n759\t// parsed AST tags them with different-but-compatible sorts (e.g. Msg vs the\n760\t// Untagged default, or a temporal written `@ i` vs a quantifier `#i`); matching\n761\t// on the full sort tag produces spurious \"free variable\" reports (observed on\n762\t// round2/exists_trace_reuse). See BEHAVIOR.md.\n763\tfn free_vars_formula(f: &Formula, bound: &mut Vec<String>, out: &mut Vec<VarSpec>) {\n764\t    match f {\n765\t        Formula::False | Formula::True => {}\n766\t        Formula::Atom(a) => {\n767\t            let mut vs = Vec::new();\n768\t            atom_vars(a, &mut vs);\n769\t            for v in vs {\n770\t                if !bound.contains(&v.name) {\n771\t                    out.push(v);\n772\t                }\n773\t            }\n774\t        }\n775\t        Formula::Not(g) => free_vars_formula(g, bound, out),\n776\t        Formula::And(a, b)\n777\t        | Formula::Or(a, b)\n778\t        | Formula::Implies(a, b)\n779\t        | Formula::Iff(a, b) => {\n780\t            free_vars_formula(a, bound, out);\n781\t            free_vars_formula(b, bound, out);\n782\t        }\n783\t        Formula::Forall(vs, g) | Formula::Exists(vs, g) => {\n784\t            let added: Vec<String> = vs.iter().map(|v| v.name.clone()).collect();\n785\t            let n = added.len();\n786\t            bound.extend(added);\n787\t            free_vars_formula(g, bound, out);\n788\t            for _ in 0..n {\n789\t                bound.pop();\n790\t            }\n791\t        }\n792\t    }\n793\t}\n794\t\n795\tfn atom_vars(a: &Atom, out: &mut Vec<VarSpec>) {\n796\t    match a {\n797\t        Atom::Eq(x, y)\n798\t        | Atom::Less(x, y)\n799\t        | Atom::LessMset(x, y)\n800\t        | Atom::Subterm(x, y) => {\n801\t            collect_term_vars(x, out);\n802\t            collect_term_vars(y, out);\n803\t        }\n804\t        Atom::Action(f, t) => {\n805\t            collect_fact_vars(f, out);\n806\t            collect_term_vars(t, out);\n807\t        }\n808\t        Atom::Last(t) => collect_term_vars(t, out),\n809\t        Atom::Pred(f) => collect_fact_vars(f, out),\n810\t    }\n811\t}\n812\t\n813\tfn formula_terms_entry(entity: &str, name: &str, free: &[VarSpec]) -> String {\n814\t    let terms: Vec<String> = free.iter().map(|v| format!(\"`Free {}'\", pp_var(v))).collect();\n815\t    let head = if terms.len() == 1 {\n816\t        format!(\n817\t            \"  {} `{}' uses terms of the wrong form: {}\",\n818\t            entity, name, terms[0]\n819\t        )\n820\t    } else {\n821\t        format!(\n822\t            \"  {} `{}' uses terms of the wrong form:\\n    {}\",\n823\t            entity,\n824\t            name,\n825\t            terms.join(\", \")\n826\t        )\n827\t    };\n828\t    format!(\"{}\\n  \\n{}\", head, FORMULA_TERMS_HELP)\n829\t}\n830\t\n831\tpub fn formula_terms(thy: &Theory) -> Vec<WfError> {\n832\t    let mut entries: Vec<String> = Vec::new();\n833\t    for it in &thy.items {\n834\t        let (entity, name, formula) = match it {\n835\t            TheoryItem::Lemma(l) => (\"Lemma\", &l.name, &l.formula),\n836\t            TheoryItem::Restriction(r) | TheoryItem::LegacyAxiom(r) => {\n837\t                (\"Restriction\", &r.name, &r.formula)\n838\t            }\n839\t            _ => continue,\n840\t        };\n841\t        let mut bound = Vec::new();\n842\t        let mut free = Vec::new();\n843\t        free_vars_formula(formula, &mut bound, &mut free);\n844\t        let free = dedup_vars(free);\n845\t        if !free.is_empty() {\n846\t            entries.push(formula_terms_entry(entity, name, &free));\n847\t        }\n848\t    }\n849\t    if entries.is_empty() {\n850\t        vec![]\n851\t    } else {\n852\t        vec![WfError::new(T_FORMULA_TERMS, entries.join(\"\\n\"))]\n853\t    }\n854\t}\n855\t\n856\t// ---------------------------------------------------------------------------\n857\t// 11. Formula guardedness (best-effort; single-line formula printer)\n858\t// ---------------------------------------------------------------------------\n859\t\n860\tpub fn formula_guardedness(thy: &Theory) -> Vec<WfError> {\n861\t    let mut entries: Vec<String> = Vec::new();\n862\t    for it in &thy.items {\n863\t        let (name, formula) = match it {\n864\t            TheoryItem::Lemma(l) => (&l.name, &l.formula),\n865\t            _ => continue,\n866\t        };\n867\t        if let Some((unguarded, sub)) = find_unguarded(formula) {\n868\t            let vars: Vec<String> = unguarded.iter().map(|v| format!(\"'{}'\", pp_var(v))).collect();\n869\t            let pp_sub = crate::formula::pp_formula(&sub);\n870\t            let pp_whole = crate::formula::pp_formula(formula);\n871\t            entries.push(format!(\n872\t                \"  Lemma `{}' cannot be converted to a guarded formula:\\n    unguarded variable(s) {} in the subformula\\n      \\\"{}\\\"\\n    in the formula\\n      \\\"{}\\\"\",\n873\t                name,\n874\t                vars.join(\", \"),\n875\t                pp_sub,\n876\t                pp_whole\n877\t            ));\n878\t        }\n879\t    }\n880\t    if entries.is_empty() {\n881\t        vec![]\n882\t    } else {\n883\t        vec![WfError::new(T_GUARD, entries.join(\"\\n\"))]\n884\t    }\n885\t}\n886\t\n887\t/// Variables appearing in any Action or Pred atom anywhere in `f` (the guard\n888\t/// positions). Used as a permissive over-approximation of \"guarded\".\n889\tfn guard_vars(f: &Formula, out: &mut Vec<VarSpec>) {\n890\t    match f {\n891\t        Formula::Atom(Atom::Action(fact, t)) => {\n892\t            collect_fact_vars(fact, out);\n893\t            collect_term_vars(t, out);\n894\t        }\n895\t        Formula::Atom(Atom::Pred(fact)) => collect_fact_vars(fact, out),\n896\t        Formula::Atom(_) | Formula::True | Formula::False => {}\n897\t        Formula::Not(g) => guard_vars(g, out),\n898\t        Formula::And(a, b)\n899\t        | Formula::Or(a, b)\n900\t        | Formula::Implies(a, b)\n901\t        | Formula::Iff(a, b) => {\n902\t            guard_vars(a, out);\n903\t            guard_vars(b, out);\n904\t        }\n905\t        Formula::Forall(_, g) | Formula::Exists(_, g) => guard_vars(g, out),\n906\t    }\n907\t}\n908\t\n909\t/// Returns the first quantifier whose bound variables are not all guarded,\n910\t/// together with that subformula.\n911\tfn find_unguarded(f: &Formula) -> Option<(Vec<VarSpec>, Formula)> {\n912\t    match f {\n913\t        Formula::Forall(vs, g) | Formula::Exists(vs, g) => {\n914\t            let mut gv = Vec::new();\n915\t            guard_vars(g, &mut gv);\n916\t            // Match guard variables by name (see free_vars_formula rationale).\n917\t            let gset: std::collections::HashSet<String> =\n918\t                gv.iter().map(|v| v.name.clone()).collect();\n919\t            let unguarded: Vec<VarSpec> = vs\n920\t                .iter()\n921\t                .filter(|v| !gset.contains(&v.name))\n922\t                .cloned()\n923\t                .collect();\n924\t            if !unguarded.is_empty() {\n925\t                return Some((unguarded, f.clone()));\n926\t            }\n927\t            find_unguarded(g)\n928\t        }\n929\t        Formula::Not(g) => find_unguarded(g),\n930\t        Formula::And(a, b)\n931\t        | Formula::Or(a, b)\n932\t        | Formula::Implies(a, b)\n933\t        | Formula::Iff(a, b) => find_unguarded(a).or_else(|| find_unguarded(b)),\n934\t        _ => None,\n935\t    }\n936\t}\n937\t\n938\t// ---------------------------------------------------------------------------\n939\t// 12. Nat Sorts\n940\t// ---------------------------------------------------------------------------\n941\t\n942\tpub fn nat_sorts(thy: &Theory) -> Vec<WfError> {\n943\t    let mut entries: Vec<String> = Vec::new();\n944\t    for r in protocol_rules(thy) {\n945\t        for facts in [&r.premises, &r.actions, &r.conclusions] {\n946\t            for f in facts {\n947\t                for a in &f.args {\n948\t                    collect_nat_issues(a, &mut entries);\n949\t                }\n950\t            }\n951\t        }\n952\t    }\n953\t    if entries.is_empty() {\n954\t        vec![]\n955\t    } else {\n956\t        vec![WfError::new(T_NAT, entries.join(\"\\n  \\n\"))]\n957\t    }\n958\t}\n959\t\n960\tfn collect_nat_issues(t: &Term, out: &mut Vec<String>) {\n961\t    if let Term::BinOp(BinOp::NatPlus, _, _) = t {\n962\t        let term_pp = pp_term(t);\n963\t        let mut vs = Vec::new();\n964\t        collect_term_vars(t, &mut vs);\n965\t        for v in vs {\n966\t            if v.sort != SortHint::Nat {\n967\t                let entry = format!(\"  {} in term {} must be of sort nat\", pp_var(&v), term_pp);\n968\t                if !out.contains(&entry) {\n969\t                    out.push(entry);\n970\t                }\n971\t            }\n972\t        }\n973\t    }\n974\t    // recurse\n975\t    match t {\n976\t        Term::App(_, args) | Term::Pair(args) => {\n977\t            for a in args {\n978\t                collect_nat_issues(a, out);\n979\t            }\n980\t        }\n981\t        Term::AlgApp(_, a, b) | Term::Diff(a, b) | Term::BinOp(_, a, b) => {\n982\t            collect_nat_issues(a, out);\n983\t            collect_nat_issues(b, out);\n984\t        }\n985\t        Term::PatMatch(inner) => collect_nat_issues(inner, out),\n986\t        _ => {}\n987\t    }\n988\t}\n989\t\n990\t// ---------------------------------------------------------------------------\n991\t// 13. Subterm Convergence Warning\n992\t// ---------------------------------------------------------------------------\n993\t\n994\tpub fn subterm_convergence(thy: &Theory) -> Vec<WfError> {\n995\t    let mut bad: Vec<String> = Vec::new();\n996\t    for it in &thy.items {\n997\t        if let TheoryItem::Equations { convergent, eqs } = it {\n998\t            if *convergent {\n999\t                continue; // user asserted convergence\n1000\t            }\n1001\t            for eq in eqs {\n1002\t                if !is_subterm(&eq.rhs, &eq.lhs) {\n1003\t                    bad.push(format!(\"    {} = {}\", pp_term(&eq.lhs), pp_term(&eq.rhs)));\n1004\t                }\n1005\t            }\n1006\t        }\n1007\t    }\n1008\t    if bad.is_empty() {\n1009\t        return vec![];\n1010\t    }\n1011\t    let intro = \"  User-defined equations must be convergent and have the finite variant property. The following equations are not subterm convergent. If you are sure that the set of equations is nevertheless convergent and has the finite variant property, you can ignore this warning and continue \";\n1012\t    let manual = \" For more information, please refer to the manual : https://tamarin-prover.com/manual/master/book/010_modeling-issues.html \";\n1013\t    let msg = format!(\"{}\\n\\n{}\\n   \\n{}\", intro, bad.join(\"\\n\"), manual);\n1014\t    vec![WfError::new(T_SUBTERM, msg)]\n1015\t}\n1016\t\n1017\t/// Structural subterm test: does `small` occur as a subterm of `big`?\n1018\tfn is_subterm(small: &Term, big: &Term) -> bool {\n1019\t    if small == big {\n1020\t        return true;\n1021\t    }\n1022\t    match big {\n1023\t        Term::App(_, args) | Term::Pair(args) => args.iter().any(|a| is_subterm(small, a)),\n1024\t        Term::AlgApp(_, a, b) | Term::Diff(a, b) | Term::BinOp(_, a, b) => {\n1025\t            is_subterm(small, a) || is_subterm(small, b)\n1026\t        }\n1027\t        Term::PatMatch(inner) => is_subterm(small, inner),\n1028\t        _ => false,\n1029\t    }\n1030\t}\n1031\t\n1032\t// ---------------------------------------------------------------------------\n1033\t// 2. Fresh public constants\n1034\t// ---------------------------------------------------------------------------\n1035\t// A fresh-name literal (`~'foo'`) used directly in a rule is rejected; fresh\n1036\t// names must come from `Fr(~x)` premises. Constants are collected in the order\n1037\t// premises, conclusions, actions (observed via probe fpc_positions).\n1038\tpub fn fresh_public_constants(thy: &Theory) -> Vec<WfError> {\n1039\t    let mut entries: Vec<String> = Vec::new();\n1040\t    for r in protocol_rules(thy) {\n1041\t        let mut lits: Vec<String> = Vec::new();\n1042\t        for facts in [&r.premises, &r.conclusions, &r.actions] {\n1043\t            for f in facts {\n1044\t                for a in &f.args {\n1045\t                    collect_fresh_lits(a, &mut lits);\n1046\t                }\n1047\t            }\n1048\t        }\n1049\t        if lits.is_empty() {\n1050\t            continue;\n1051\t        }\n1052\t        entries.push(format!(\n1053\t            \"  rule `{}': fresh public constants are not allowed: {}\",\n1054\t            r.name,\n1055\t            lits.join(\", \")\n1056\t        ));\n1057\t    }\n1058\t    if entries.is_empty() {\n1059\t        vec![]\n1060\t    } else {\n1061\t        vec![WfError::new(T_FRESH_PUB, entries.join(\"\\n  \\n\"))]\n1062\t    }\n1063\t}\n1064\t\n1065\t// ---------------------------------------------------------------------------\n1066\t// 5. Reserved prefixes (diff mode only)\n1067\t// ---------------------------------------------------------------------------\n1068\t// Fact names beginning with `DiffIntr`/`DiffProto` are reserved for the diff\n1069\t// translation. Only emitted for diff-mode theories (observed: silent otherwise).\n1070\tpub fn reserved_prefixes(thy: &Theory) -> Vec<WfError> {\n1071\t    if !thy.is_diff {\n1072\t        return vec![];\n1073\t    }\n1074\t    let mut entries: Vec<String> = Vec::new();\n1075\t    for r in protocol_rules(thy) {\n1076\t        // Order of collection: premises, actions, conclusions (probe rp_multi).\n1077\t        let mut hits: Vec<&Fact> = Vec::new();\n1078\t        for facts in [&r.premises, &r.actions, &r.conclusions] {\n1079\t            for f in facts {\n1080\t                if RESERVED_PREFIXES.iter().any(|p| f.name.starts_with(p)) {\n1081\t                    hits.push(f);\n1082\t                }\n1083\t            }\n1084\t        }\n1085\t        if hits.is_empty() {\n1086\t            continue;\n1087\t        }\n1088\t        let header = fill_words(&reserved_prefix_header_words(&r.name), 2, FILL_WIDTH);\n1089\t        let blocks: Vec<String> = hits\n1090\t            .iter()\n1091\t            .map(|f| {\n1092\t                let m = if f.persistent { \"Persistent\" } else { \"Linear\" };\n1093\t                format!(\n1094\t                    \"    {}\\n    (ProtoFact {} \\\"{}\\\" {},{},{})\",\n1095\t                    pp_fact(f),\n1096\t                    m,\n1097\t                    f.name,\n1098\t                    f.args.len(),\n1099\t                    f.args.len(),\n1100\t                    m\n1101\t                )\n1102\t            })\n1103\t            .collect();\n1104\t        entries.push(format!(\"{}\\n  \\n{}\", header, blocks.join(\"\\n  \\n\")));\n1105\t    }\n1106\t    if entries.is_empty() {\n1107\t        vec![]\n1108\t    } else {\n1109\t        vec![WfError::new(T_RESERVED_PREFIX, entries.join(\"\\n  \\n\"))]\n1110\t    }\n1111\t}\n1112\t\n1113\tfn reserved_prefix_header_words(rule: &str) -> Vec<String> {\n1114\t    [\n1115\t        \"The\",\n1116\t        \"Rule\",\n1117\t        &format!(\"`{}'\", rule),\n1118\t        \"contains\",\n1119\t        \"facts\",\n1120\t        \"with\",\n1121\t        \"reserved\",\n1122\t        \"prefixes\",\n1123\t        \"('DiffIntr',\",\n1124\t        \"'DiffProto')\",\n1125\t        \"inside\",\n1126\t        \"names:\",\n1127\t    ]\n1128\t    .iter()\n1129\t    .map(|s| s.to_string())\n1130\t    .collect()\n1131\t}\n1132\t\n1133\t// ---------------------------------------------------------------------------\n1134\t// 11 & 12. Left rule / Right rule (diff mode only)\n1135\t// ---------------------------------------------------------------------------\n1136\t// A diff rule may carry explicit `left`/`right` projections. Each explicit\n1137\t// projection must equal the corresponding projection of the parent diff rule\n1138\t// (diff(a,b) -> a on the left, -> b on the right). When it differs, the rule is\n1139\t// \"inconsistent\". For a single rule the left projection is checked first and,\n1140\t// if inconsistent, the right is not reported (observed via probe diff_both).\n1141\tpub fn diff_left_right(thy: &Theory) -> Vec<WfError> {\n1142\t    if !thy.is_diff {\n1143\t        return vec![];\n1144\t    }\n1145\t    let mut left_entries: Vec<String> = Vec::new();\n1146\t    let mut right_entries: Vec<String> = Vec::new();\n1147\t    for r in protocol_rules(thy) {\n1148\t        if let Some((left, right)) = &r.left_right {\n1149\t            if !rule_matches_projection(r, left, true) {\n1150\t                left_entries.push(inconsistent_entry(\"left\", left, r));\n1151\t            } else if !rule_matches_projection(r, right, false) {\n1152\t                right_entries.push(inconsistent_entry(\"right\", right, r));\n1153\t            }\n1154\t        }\n1155\t    }\n1156\t    let mut out = Vec::new();\n1157\t    if !left_entries.is_empty() {\n1158\t        out.push(WfError::new(T_LEFT, left_entries.join(\"\\n  \\n\")));\n1159\t    }\n1160\t    if !right_entries.is_empty() {\n1161\t        out.push(WfError::new(T_RIGHT, right_entries.join(\"\\n  \\n\")));\n1162\t    }\n1163\t    out\n1164\t}\n1165\t\n1166\tfn inconsistent_entry(side: &str, explicit: &Rule, parent: &Rule) -> String {\n1167\t    format!(\n1168\t        \"  Inconsistent {} rule\\n{}\\n  \\n  w.r.t.\\n  \\n{}\",\n1169\t        side,\n1170\t        indent_block(&pp_rule(explicit), 4),\n1171\t        indent_block(&pp_rule(parent), 4)\n1172\t    )\n1173\t}\n1174\t\n1175\t/// True iff the explicit rule's fact lists equal the parent rule's projection.\n1176\tfn rule_matches_projection(parent: &Rule, explicit: &Rule, left: bool) -> bool {\n1177\t    facts_pp(&project_facts(&parent.premises, left)) == facts_pp(&explicit.premises)\n1178\t        && facts_pp(&project_facts(&parent.actions, left)) == facts_pp(&explicit.actions)\n1179\t        && facts_pp(&project_facts(&parent.conclusions, left)) == facts_pp(&explicit.conclusions)\n1180\t}\n1181\t\n1182\tfn facts_pp(fs: &[Fact]) -> String {\n1183\t    fs.iter().map(pp_fact).collect::<Vec<_>>().join(\", \")\n1184\t}\n1185\t\n1186\tfn project_facts(fs: &[Fact], left: bool) -> Vec<Fact> {\n1187\t    fs.iter().map(|f| project_fact(f, left)).collect()\n1188\t}\n1189\t\n1190\tfn project_fact(f: &Fact, left: bool) -> Fact {\n1191\t    Fact {\n1192\t        persistent: f.persistent,\n1193\t        name: f.name.clone(),\n1194\t        args: f.args.iter().map(|a| project_term(a, left)).collect(),\n1195\t        annotations: f.annotations.clone(),\n1196\t    }\n1197\t}\n1198\t\n1199\t/// Project a diff term to one side: `diff(a, b)` becomes `a` (left) or `b`\n1200\t/// (right); all other terms are structurally mapped.\n1201\tfn project_term(t: &Term, left: bool) -> Term {\n1202\t    match t {\n1203\t        Term::Diff(a, b) => project_term(if left { a } else { b }, left),\n1204\t        Term::App(name, args) => {\n1205\t            Term::App(name.clone(), args.iter().map(|a| project_term(a, left)).collect())\n1206\t        }\n1207\t        Term::Pair(args) => Term::Pair(args.iter().map(|a| project_term(a, left)).collect()),\n1208\t        Term::AlgApp(name, a, b) => Term::AlgApp(\n1209\t            name.clone(),\n1210\t            Box::new(project_term(a, left)),\n1211\t            Box::new(project_term(b, left)),\n1212\t        ),\n1213\t        Term::BinOp(op, a, b) => Term::BinOp(\n1214\t            *op,\n1215\t            Box::new(project_term(a, left)),\n1216\t            Box::new(project_term(b, left)),\n1217\t        ),\n1218\t        Term::PatMatch(inner) => Term::PatMatch(Box::new(project_term(inner, left))),\n1219\t        other => other.clone(),\n1220\t    }\n1221\t}\n1222\t\n1223\t// ---------------------------------------------------------------------------\n1224\t// 15. Lemma annotations\n1225\t// ---------------------------------------------------------------------------\n1226\t// An `exists-trace` lemma marked `reuse` is rejected (observed trigger).\n1227\tpub fn lemma_annotations(thy: &Theory) -> Vec<WfError> {\n1228\t    let mut entries: Vec<String> = Vec::new();\n1229\t    for it in &thy.items {\n1230\t        if let TheoryItem::Lemma(l) = it {\n1231\t            let is_reuse = l.attributes.iter().any(|a| matches!(a, LemmaAttr::Reuse));\n1232\t            if is_reuse && l.trace_quantifier == TraceQuantifier::ExistsTrace {\n1233\t                entries.push(format!(\n1234\t                    \"  Lemma `{}': cannot reuse 'exists-trace' lemmas\",\n1235\t                    l.name\n1236\t                ));\n1237\t            }\n1238\t        }\n1239\t    }\n1240\t    if entries.is_empty() {\n1241\t        vec![]\n1242\t    } else {\n1243\t        vec![WfError::new(T_LEMMA_ANNOT, entries.join(\"\\n  \\n\"))]\n1244\t    }\n1245\t}\n1246\t\n1247\t// ---------------------------------------------------------------------------\n1248\t// 16. Multiplication restriction of rules\n1249\t// ---------------------------------------------------------------------------\n1250\t// A rule whose conclusions contain a multiplication (`*`) term is not\n1251\t// multiplication restricted. The \"After replacing reducible function symbols\"\n1252\t// rule renders identically to the original when the left-hand side has no\n1253\t// reducible symbols to replace (the general replacement is a documented gap).\n1254\tpub fn multiplication_restriction(thy: &Theory) -> Vec<WfError> {\n1255\t    let mut entries: Vec<String> = Vec::new();\n1256\t    for r in protocol_rules(thy) {\n1257\t        let mut mult_terms: Vec<String> = Vec::new();\n1258\t        for f in &r.conclusions {\n1259\t            for a in &f.args {\n1260\t                collect_mult_terms(a, &mut mult_terms);\n1261\t            }\n1262\t        }\n1263\t        if mult_terms.is_empty() {\n1264\t            continue;\n1265\t        }\n1266\t        let rule_pp = indent_block(&pp_rule(r), 4);\n1267\t        entries.push(format!(\n1268\t            \"  The following rule is not multiplication restricted:\\n{rule}\\n  \\n  After replacing reducible function symbols in lhs with variables:\\n{rule}\\n  \\n    Terms with multiplication:  {terms}\",\n1269\t            rule = rule_pp,\n1270\t            terms = mult_terms.join(\", \")\n1271\t        ));\n1272\t    }\n1273\t    if entries.is_empty() {\n1274\t        vec![]\n1275\t    } else {\n1276\t        vec![WfError::new(T_MULRESTRICT, entries.join(\"\\n  \\n\"))]\n1277\t    }\n1278\t}\n1279\t\n1280\t// ---------------------------------------------------------------------------\n1281\t// check_if_lemmas_in_theory (secondary entry point; render UNVERIFIED)\n1282\t// ---------------------------------------------------------------------------\n1283\t\n1284\t/// Names of every lemma-like item declared in the theory.\n1285\tpub fn theory_lemma_names(thy: &Theory) -> Vec<String> {\n1286\t    thy.items\n1287\t        .iter()\n1288\t        .filter_map(|it| match it {\n1289\t            TheoryItem::Lemma(l) => Some(l.name.clone()),\n1290\t            TheoryItem::DiffLemma(l) => Some(l.name.clone()),\n1291\t            TheoryItem::AccLemma(l) => Some(l.name.clone()),\n1292\t            _ => None,\n1293\t        })\n1294\t        .collect()\n1295\t}\n1296\t"}]},"uuid":"5197f63f-1220-4437-9ade-576260ef4519","timestamp":"2026-07-17T12:16:48.960Z","toolUseResult":{"type":"text","file":{"filePath":"/home/kamilner/tamarin-cleanroom/wellformedness/workspace/wf-clean/src/checks.rs","content":"//! The individual wellformedness checks. Each produces zero or one `WfError`\n//! (one topic block). Message bodies reproduce oracle byte formatting.\n\nuse crate::ast::*;\nuse crate::pretty::{pp_fact, pp_rule, pp_term, pp_var};\nuse crate::report::WfError;\n\n// ---- Topic strings (exact, including significant whitespace) ----\npub const T_UNBOUND: &str = \"Unbound variables\";\npub const T_FRESH_PUB: &str = \"Fresh public constants\";\npub const T_PUBNAMES: &str = \"Public constants with mismatching capitalization\";\npub const T_SORTS: &str = \"Variable with mismatching sorts or capitalization\";\npub const T_RESERVED: &str = \"Reserved names\";\npub const T_RESERVED_PREFIX: &str = \"Reserved prefixes\";\npub const T_FR: &str = \"Fr facts must only use a fresh- or a msg-variable\";\npub const T_SPECIAL: &str = \"Special facts\";\npub const T_ARITY: &str = \"Fact arity issues\";\npub const T_MULT: &str = \"Fact multiplicity issues\";\npub const T_LHSRHS: &str = \"Facts occur in the left-hand-side but not in any right-hand-side \";\npub const T_LEFT: &str = \"Left rule\";\npub const T_RIGHT: &str = \"Right rule\";\npub const T_FORMULA_TERMS: &str = \"Formula terms\";\npub const T_GUARD: &str = \" Formula guardedness\";\npub const T_LEMMA_ANNOT: &str = \"Lemma annotations\";\npub const T_MULRESTRICT: &str = \"Multiplication restriction of rules\";\npub const T_NAT: &str = \"Nat Sorts\";\npub const T_SUBTERM: &str = \"Subterm Convergence Warning\";\n\n/// Fact-name prefixes reserved for the diff-mode translation (observed in the\n/// \"Reserved prefixes\" check, diff mode only).\nconst RESERVED_PREFIXES: &[&str] = &[\"DiffIntr\", \"DiffProto\"];\n\n/// Word-fill width used by the oracle's pretty-printer for the wrapped\n/// \"Reserved prefixes\" header (measured empirically: a line breaks before the\n/// next word once it would exceed column 69).\nconst FILL_WIDTH: usize = 69;\n\n/// Reserved fact names (used as protocol facts -> \"Reserved names\").\nconst RESERVED_FACTS: &[&str] = &[\"K\", \"KU\", \"KD\"];\n/// Special I/O facts handled by the special-fact / Fr checks.\nconst SPECIAL_FACTS: &[&str] = &[\"In\", \"Out\", \"Fr\"];\n\nfn is_reserved(name: &str) -> bool {\n    RESERVED_FACTS.contains(&name)\n}\nfn is_special(name: &str) -> bool {\n    SPECIAL_FACTS.contains(&name)\n}\nfn is_builtin_factname(name: &str) -> bool {\n    is_reserved(name) || is_special(name)\n}\n\n// ---------------------------------------------------------------------------\n// AST traversal helpers\n// ---------------------------------------------------------------------------\n\n/// The protocol rules of a theory (excludes intruder rules).\npub fn protocol_rules(thy: &Theory) -> Vec<&Rule> {\n    thy.items\n        .iter()\n        .filter_map(|it| match it {\n            TheoryItem::Rule(r) => Some(r),\n            _ => None,\n        })\n        .collect()\n}\n\nfn collect_term_vars(t: &Term, out: &mut Vec<VarSpec>) {\n    match t {\n        Term::Var(v) => out.push(v.clone()),\n        Term::App(_, args) | Term::Pair(args) => {\n            for a in args {\n                collect_term_vars(a, out);\n            }\n        }\n        Term::AlgApp(_, a, b) | Term::Diff(a, b) | Term::BinOp(_, a, b) => {\n            collect_term_vars(a, out);\n            collect_term_vars(b, out);\n        }\n        Term::PatMatch(inner) => collect_term_vars(inner, out),\n        _ => {}\n    }\n}\n\nfn collect_fact_vars(f: &Fact, out: &mut Vec<VarSpec>) {\n    for a in &f.args {\n        collect_term_vars(a, out);\n    }\n}\n\nfn collect_facts_vars(fs: &[Fact], out: &mut Vec<VarSpec>) {\n    for f in fs {\n        collect_fact_vars(f, out);\n    }\n}\n\n/// Collect public-constant literals (name only) from a term.\nfn collect_pub_lits(t: &Term, out: &mut Vec<String>) {\n    match t {\n        Term::PubLit(s) => out.push(s.clone()),\n        Term::App(_, args) | Term::Pair(args) => {\n            for a in args {\n                collect_pub_lits(a, out);\n            }\n        }\n        Term::AlgApp(_, a, b) | Term::Diff(a, b) | Term::BinOp(_, a, b) => {\n            collect_pub_lits(a, out);\n            collect_pub_lits(b, out);\n        }\n        Term::PatMatch(inner) => collect_pub_lits(inner, out),\n        _ => {}\n    }\n}\n\n/// Collect fresh-name literals (`~'foo'`) from a term, rendered as the oracle\n/// prints them.\nfn collect_fresh_lits(t: &Term, out: &mut Vec<String>) {\n    match t {\n        Term::FreshLit(_) => out.push(pp_term(t)),\n        Term::App(_, args) | Term::Pair(args) => {\n            for a in args {\n                collect_fresh_lits(a, out);\n            }\n        }\n        Term::AlgApp(_, a, b) | Term::Diff(a, b) | Term::BinOp(_, a, b) => {\n            collect_fresh_lits(a, out);\n            collect_fresh_lits(b, out);\n        }\n        Term::PatMatch(inner) => collect_fresh_lits(inner, out),\n        _ => {}\n    }\n}\n\n/// Collect maximal multiplication (`*`) subterms of a term, rendered as the\n/// oracle prints them. A product is maximal: its own operands are not\n/// descended into.\nfn collect_mult_terms(t: &Term, out: &mut Vec<String>) {\n    if let Term::BinOp(BinOp::Mult, _, _) = t {\n        out.push(pp_term(t));\n        return;\n    }\n    match t {\n        Term::App(_, args) | Term::Pair(args) => {\n            for a in args {\n                collect_mult_terms(a, out);\n            }\n        }\n        Term::AlgApp(_, a, b) | Term::Diff(a, b) | Term::BinOp(_, a, b) => {\n            collect_mult_terms(a, out);\n            collect_mult_terms(b, out);\n        }\n        Term::PatMatch(inner) => collect_mult_terms(inner, out),\n        _ => {}\n    }\n}\n\n/// Indent every line of a (possibly multi-line) block by `n` spaces.\nfn indent_block(s: &str, n: usize) -> String {\n    let pad = \" \".repeat(n);\n    s.lines()\n        .map(|l| format!(\"{}{}\", pad, l))\n        .collect::<Vec<_>>()\n        .join(\"\\n\")\n}\n\n/// Word-fill (Wadler/Leijen `fillSep`) at the given `width` with a leading\n/// `indent` of spaces on every line. A word is pushed onto the current line\n/// while it fits (column + 1 + word <= width), otherwise a new line begins.\nfn fill_words(words: &[String], indent: usize, width: usize) -> String {\n    let pad = \" \".repeat(indent);\n    let mut lines: Vec<String> = Vec::new();\n    let mut cur = String::new();\n    let mut col = 0usize;\n    for w in words {\n        let wlen = w.chars().count();\n        if cur.is_empty() {\n            cur = format!(\"{}{}\", pad, w);\n            col = indent + wlen;\n        } else if col + 1 + wlen <= width {\n            cur.push(' ');\n            cur.push_str(w);\n            col += 1 + wlen;\n        } else {\n            lines.push(std::mem::take(&mut cur));\n            cur = format!(\"{}{}\", pad, w);\n            col = indent + wlen;\n        }\n    }\n    if !cur.is_empty() {\n        lines.push(cur);\n    }\n    lines.join(\"\\n\")\n}\n\nfn var_needs_binding(v: &VarSpec) -> bool {\n    matches!(\n        v.sort,\n        SortHint::Fresh | SortHint::Msg | SortHint::Untagged | SortHint::Nat\n    )\n}\n\nfn var_key(v: &VarSpec) -> (String, u64, i32) {\n    (v.name.clone(), v.idx, sort_rank(v.sort))\n}\n\nfn sort_rank(s: SortHint) -> i32 {\n    match s {\n        SortHint::Msg => 0,\n        SortHint::Pub => 1,\n        SortHint::Fresh => 2,\n        SortHint::Node => 3,\n        SortHint::Nat => 4,\n        SortHint::Untagged => 5,\n        SortHint::Suffix(_) => 6,\n    }\n}\n\nfn dedup_vars(mut vs: Vec<VarSpec>) -> Vec<VarSpec> {\n    vs.sort_by_key(var_key);\n    vs.dedup_by_key(|v| var_key(v));\n    vs\n}\n\n// ---------------------------------------------------------------------------\n// 1. Unbound variables\n// ---------------------------------------------------------------------------\npub fn unbound_variables(thy: &Theory) -> Vec<WfError> {\n    let mut entries: Vec<String> = Vec::new();\n    for r in protocol_rules(thy) {\n        // Bound = variables in premises plus let-bound variables.\n        let mut bound: Vec<VarSpec> = Vec::new();\n        collect_facts_vars(&r.premises, &mut bound);\n        for lb in &r.let_block {\n            collect_term_vars(&lb.var, &mut bound);\n        }\n        let bound: std::collections::HashSet<(String, u64, i32)> =\n            bound.iter().map(var_key).collect();\n\n        // Used = variables in actions, conclusions, embedded restrictions,\n        // and the right-hand-sides of let bindings.\n        let mut used: Vec<VarSpec> = Vec::new();\n        collect_facts_vars(&r.actions, &mut used);\n        collect_facts_vars(&r.conclusions, &mut used);\n        for lb in &r.let_block {\n            collect_term_vars(&lb.value, &mut used);\n        }\n\n        let mut unbound: Vec<VarSpec> = used\n            .into_iter()\n            .filter(var_needs_binding)\n            .filter(|v| !bound.contains(&var_key(v)))\n            .collect();\n        unbound = dedup_vars(unbound);\n        // Report order: by base name then index.\n        unbound.sort_by(|a, b| a.name.cmp(&b.name).then(a.idx.cmp(&b.idx)));\n\n        if !unbound.is_empty() {\n            let names: Vec<String> = unbound.iter().map(pp_var).collect();\n            entries.push(format!(\n                \"  rule `{}' has unbound variables: \\n    {}\",\n                r.name,\n                names.join(\", \")\n            ));\n        }\n    }\n    if entries.is_empty() {\n        vec![]\n    } else {\n        vec![WfError::new(T_UNBOUND, entries.join(\"\\n  \\n\"))]\n    }\n}\n\n// ---------------------------------------------------------------------------\n// 3. Variable with mismatching sorts or capitalization\n// ---------------------------------------------------------------------------\npub fn mismatching_sorts(thy: &Theory) -> Vec<WfError> {\n    let mut rule_entries: Vec<String> = Vec::new();\n    for r in protocol_rules(thy) {\n        let mut vars: Vec<VarSpec> = Vec::new();\n        collect_facts_vars(&r.premises, &mut vars);\n        collect_facts_vars(&r.actions, &mut vars);\n        collect_facts_vars(&r.conclusions, &mut vars);\n\n        // Group by lowercased base name; a group with >1 distinct variant\n        // (prefix+name, ignoring index) is a conflict.\n        let mut groups: Vec<(String, Vec<String>)> = Vec::new(); // (lc key, variants)\n        for v in &vars {\n            let key = v.name.to_lowercase();\n            let variant = variant_repr(v);\n            match groups.iter_mut().find(|(k, _)| *k == key) {\n                Some((_, variants)) => {\n                    if !variants.contains(&variant) {\n                        variants.push(variant);\n                    }\n                }\n                None => groups.push((key, vec![variant])),\n            }\n        }\n        let mut conflicts: Vec<Vec<String>> = groups\n            .into_iter()\n            .filter(|(_, vs)| vs.len() > 1)\n            .map(|(_, mut vs)| {\n                vs.sort();\n                vs\n            })\n            .collect();\n        if conflicts.is_empty() {\n            continue;\n        }\n        // deterministic ordering of groups within a rule\n        conflicts.sort();\n        let mut body = format!(\"  rule `{}': \", r.name);\n        for (i, variants) in conflicts.iter().enumerate() {\n            body.push_str(&format!(\"\\n    {}. {}\", i + 1, variants.join(\", \")));\n        }\n        rule_entries.push(body);\n    }\n    if rule_entries.is_empty() {\n        return vec![];\n    }\n    let header = \"Possible reasons:\\n1. Identifiers are case sensitive, i.e.,'x' and 'X' are considered to be different.\\n2. The same holds for sorts:, i.e., '$x', 'x', and '~x' are considered to be different.\\n\";\n    let msg = format!(\"{}\\n{}\", header, rule_entries.join(\"\\n  \\n\"));\n    vec![WfError::new(T_SORTS, msg)]\n}\n\n/// A variable's sort+name representation without the numeric index.\nfn variant_repr(v: &VarSpec) -> String {\n    let prefix = match v.sort {\n        SortHint::Fresh => \"~\",\n        SortHint::Pub => \"$\",\n        SortHint::Nat => \"%\",\n        SortHint::Node => \"#\",\n        _ => \"\",\n    };\n    format!(\"{}{}\", prefix, v.name)\n}\n\n// ---------------------------------------------------------------------------\n// 4. Reserved names\n// ---------------------------------------------------------------------------\npub fn reserved_names(thy: &Theory) -> Vec<WfError> {\n    let mut entries: Vec<String> = Vec::new();\n    for r in protocol_rules(thy) {\n        // On the left/right the reserved set is {K,KU,KD}; in the middle\n        // (actions) the I/O facts In/Out/Fr are reserved too (observed z9/z11).\n        for (facts, phrase, middle) in [\n            (&r.premises, \"left-hand-side\", false),\n            (&r.actions, \"the middle\", true),\n            (&r.conclusions, \"the right-hand-side\", false),\n        ] {\n            let hits: Vec<&Fact> = facts\n                .iter()\n                .filter(|f| is_reserved(&f.name) || (middle && is_special(&f.name)))\n                .collect();\n            if hits.is_empty() {\n                continue;\n            }\n            let rendered: Vec<String> = hits.iter().map(|f| pp_fact(f)).collect();\n            entries.push(format!(\n                \"  Rule `{}' contains facts with reserved names on {}:\\n    {}\",\n                r.name,\n                phrase,\n                rendered.join(\", \")\n            ));\n        }\n    }\n    if entries.is_empty() {\n        vec![]\n    } else {\n        vec![WfError::new(T_RESERVED, entries.join(\"\\n  \\n\"))]\n    }\n}\n\n// ---------------------------------------------------------------------------\n// 5. Fr facts must only use a fresh- or a msg-variable\n// ---------------------------------------------------------------------------\npub fn fr_facts(thy: &Theory) -> Vec<WfError> {\n    let mut entries: Vec<String> = Vec::new();\n    for r in protocol_rules(thy) {\n        for facts in [&r.premises, &r.conclusions] {\n            for f in facts {\n                if f.name != \"Fr\" {\n                    continue;\n                }\n                let ok = f.args.len() == 1\n                    && matches!(\n                        &f.args[0],\n                        Term::Var(v) if matches!(v.sort, SortHint::Fresh | SortHint::Msg | SortHint::Untagged)\n                    );\n                if !ok {\n                    entries.push(format!(\"  rule `{}' fact: {}\", r.name, pp_fact(f)));\n                }\n            }\n        }\n    }\n    if entries.is_empty() {\n        vec![]\n    } else {\n        vec![WfError::new(T_FR, entries.join(\"\\n  \\n\"))]\n    }\n}\n\n// ---------------------------------------------------------------------------\n// 6. Special facts (disallowed I/O facts in wrong position)\n// ---------------------------------------------------------------------------\npub fn special_facts(thy: &Theory) -> Vec<WfError> {\n    let mut entries: Vec<String> = Vec::new();\n    for r in protocol_rules(thy) {\n        // Premise side: `Out` is disallowed.\n        let lhs: Vec<String> = r\n            .premises\n            .iter()\n            .filter(|f| f.name == \"Out\")\n            .map(|f| pp_fact(f))\n            .collect();\n        if !lhs.is_empty() {\n            entries.push(format!(\n                \"  rule `{}' uses disallowed facts on left-hand-side:\\n    {}\",\n                r.name,\n                lhs.join(\", \")\n            ));\n        }\n        // Conclusion side: `In` and `Fr` are disallowed.\n        let rhs: Vec<String> = r\n            .conclusions\n            .iter()\n            .filter(|f| f.name == \"In\" || f.name == \"Fr\")\n            .map(|f| pp_fact(f))\n            .collect();\n        if !rhs.is_empty() {\n            entries.push(format!(\n                \"  rule `{}' uses disallowed facts on right-hand-side:\\n    {}\",\n                r.name,\n                rhs.join(\", \")\n            ));\n        }\n    }\n    if entries.is_empty() {\n        vec![]\n    } else {\n        vec![WfError::new(T_SPECIAL, entries.join(\"\\n  \\n\"))]\n    }\n}\n\n// ---------------------------------------------------------------------------\n// 7 & 8. Fact arity / multiplicity issues\n// ---------------------------------------------------------------------------\n\nstruct FactUse {\n    rule: String,\n    arity: usize,\n    persistent: bool,\n    pp: String,\n}\n\n/// Gather every fact occurrence in protocol rules (name -> uses), in source\n/// order.\nfn gather_fact_uses(thy: &Theory) -> Vec<(String, Vec<FactUse>)> {\n    let mut map: Vec<(String, Vec<FactUse>)> = Vec::new();\n    for r in protocol_rules(thy) {\n        for facts in [&r.premises, &r.actions, &r.conclusions] {\n            for f in facts {\n                let entry = FactUse {\n                    rule: r.name.clone(),\n                    arity: f.args.len(),\n                    persistent: f.persistent,\n                    pp: pp_fact(f),\n                };\n                match map.iter_mut().find(|(n, _)| *n == f.name) {\n                    Some((_, uses)) => uses.push(entry),\n                    None => map.push((f.name.clone(), vec![entry])),\n                }\n            }\n        }\n    }\n    map\n}\n\nfn render_fact_blocks(conflicts: &[(String, Vec<String>)], intro1: &str, intro2: &str) -> String {\n    // conflicts: (lowercased fact name, item lines) already ordered.\n    let mut body = format!(\"{}\\n{}\\n  \", intro1, intro2);\n    for (i, (lname, items)) in conflicts.iter().enumerate() {\n        let block = format!(\"  Fact `{}':\\n\\n{}\\n  \", lname, items.join(\"\\n    \\n\"));\n        if i == 0 {\n            body.push_str(\"\\n\\n\");\n        } else {\n            body.push('\\n');\n        }\n        body.push_str(&block);\n    }\n    body\n}\n\npub fn fact_arity(thy: &Theory) -> Vec<WfError> {\n    let uses = gather_fact_uses(thy);\n    let mut conflicts: Vec<(String, Vec<String>)> = Vec::new();\n    for (name, us) in &uses {\n        let arities: std::collections::BTreeSet<usize> = us.iter().map(|u| u.arity).collect();\n        if arities.len() < 2 {\n            continue;\n        }\n        // one item per distinct (rule, arity), first pp kept, source order.\n        let mut seen: Vec<(String, usize)> = Vec::new();\n        let mut items: Vec<String> = Vec::new();\n        for u in us {\n            let k = (u.rule.clone(), u.arity);\n            if seen.contains(&k) {\n                continue;\n            }\n            seen.push(k);\n            let n = items.len() + 1;\n            items.push(format!(\n                \"    {}. Rule `{}', arity {}\\n         {}\",\n                n, u.rule, u.arity, u.pp\n            ));\n        }\n        conflicts.push((name.to_lowercase(), items));\n    }\n    if conflicts.is_empty() {\n        return vec![];\n    }\n    conflicts.sort_by(|a, b| a.0.cmp(&b.0));\n    let msg = render_fact_blocks(\n        &conflicts,\n        \"Same fact is used with different arities, i.e., Fact('A','B') is different from Fact('A'). \",\n        \"Check the arguments of your facts.\",\n    );\n    vec![WfError::new(T_ARITY, msg)]\n}\n\npub fn fact_multiplicity(thy: &Theory) -> Vec<WfError> {\n    let uses = gather_fact_uses(thy);\n    let mut conflicts: Vec<(String, Vec<String>)> = Vec::new();\n    for (name, us) in &uses {\n        let mults: std::collections::BTreeSet<bool> = us.iter().map(|u| u.persistent).collect();\n        if mults.len() < 2 {\n            continue;\n        }\n        let mut seen: Vec<(String, bool)> = Vec::new();\n        let mut items: Vec<String> = Vec::new();\n        for u in us {\n            let k = (u.rule.clone(), u.persistent);\n            if seen.contains(&k) {\n                continue;\n            }\n            seen.push(k);\n            let n = items.len() + 1;\n            let m = if u.persistent { \"Persistent\" } else { \"Linear\" };\n            items.push(format!(\n                \"    {}. Rule `{}', multiplicity (persistence) {}\\n         {}\",\n                n, u.rule, m, u.pp\n            ));\n        }\n        conflicts.push((name.to_lowercase(), items));\n    }\n    if conflicts.is_empty() {\n        return vec![];\n    }\n    conflicts.sort_by(|a, b| a.0.cmp(&b.0));\n    let msg = render_fact_blocks(\n        &conflicts,\n        \"Same fact is used with different multiplicities, i.e., !Fact() (Persistent fact) exists along with Fact() (Linear) in your rules. \",\n        \"Check the multiplicity (persistence) of your facts.\",\n    );\n    vec![WfError::new(T_MULT, msg)]\n}\n\n// ---------------------------------------------------------------------------\n// 9. Facts occur in the left-hand-side but not in any right-hand-side\n// ---------------------------------------------------------------------------\n\n#[derive(Clone)]\nstruct FactId {\n    name: String,\n    arity: usize,\n    persistent: bool,\n    rule: String,\n}\n\nimpl FactId {\n    fn ident(&self) -> (String, usize, bool) {\n        (self.name.clone(), self.arity, self.persistent)\n    }\n    fn render(&self) -> String {\n        format!(\n            \"in rule \\\"{}\\\":  factName `{}' arity: {} multiplicity: {}\",\n            self.rule,\n            self.name,\n            self.arity,\n            if self.persistent { \"Persistent\" } else { \"Linear\" }\n        )\n    }\n}\n\npub fn fact_lhs_occur_no_rhs(thy: &Theory) -> Vec<WfError> {\n    let mut lhs: Vec<FactId> = Vec::new();\n    let mut rhs: Vec<FactId> = Vec::new();\n    for r in protocol_rules(thy) {\n        for f in &r.premises {\n            if is_builtin_factname(&f.name) {\n                continue;\n            }\n            lhs.push(FactId {\n                name: f.name.clone(),\n                arity: f.args.len(),\n                persistent: f.persistent,\n                rule: r.name.clone(),\n            });\n        }\n        for f in &r.conclusions {\n            if is_builtin_factname(&f.name) {\n                continue;\n            }\n            rhs.push(FactId {\n                name: f.name.clone(),\n                arity: f.args.len(),\n                persistent: f.persistent,\n                rule: r.name.clone(),\n            });\n        }\n    }\n    let rhs_idents: std::collections::HashSet<(String, usize, bool)> =\n        rhs.iter().map(|f| f.ident()).collect();\n\n    // LHS-only identities, first occurrence, in source order.\n    let mut seen: Vec<(String, usize, bool)> = Vec::new();\n    let mut items: Vec<String> = Vec::new();\n    for f in &lhs {\n        if rhs_idents.contains(&f.ident()) || seen.contains(&f.ident()) {\n            continue;\n        }\n        seen.push(f.ident());\n        let n = items.len() + 1;\n        let mut line = format!(\"  {}. {}\", n, f.render());\n        if let Some(sugg) = nearest_rhs(&f.name, &rhs) {\n            line.push_str(&format!(\". Perhaps you want to use the fact {}\", sugg.render()));\n        }\n        items.push(line);\n    }\n    if items.is_empty() {\n        vec![]\n    } else {\n        vec![WfError::new(T_LHSRHS, items.join(\"\\n  \\n\"))]\n    }\n}\n\n/// Nearest RHS fact by name edit distance, if within threshold (<= 3).\nfn nearest_rhs<'a>(name: &str, rhs: &'a [FactId]) -> Option<&'a FactId> {\n    let mut best: Option<(usize, &FactId)> = None;\n    for f in rhs {\n        let d = edit_distance(name, &f.name);\n        match best {\n            Some((bd, _)) if d >= bd => {}\n            _ => best = Some((d, f)),\n        }\n    }\n    match best {\n        Some((d, f)) if d <= 3 => Some(f),\n        _ => None,\n    }\n}\n\nfn edit_distance(a: &str, b: &str) -> usize {\n    let a: Vec<char> = a.chars().collect();\n    let b: Vec<char> = b.chars().collect();\n    let mut prev: Vec<usize> = (0..=b.len()).collect();\n    let mut cur = vec![0usize; b.len() + 1];\n    for i in 1..=a.len() {\n        cur[0] = i;\n        for j in 1..=b.len() {\n            let cost = if a[i - 1] == b[j - 1] { 0 } else { 1 };\n            cur[j] = (prev[j] + 1).min(cur[j - 1] + 1).min(prev[j - 1] + cost);\n        }\n        std::mem::swap(&mut prev, &mut cur);\n    }\n    prev[b.len()]\n}\n\n// ---------------------------------------------------------------------------\n// 2. Public constants with mismatching capitalization (public-names report)\n// ---------------------------------------------------------------------------\n\npub fn public_names_report(thy: &Theory) -> Vec<WfError> {\n    let mut pairs: Vec<(String, String)> = Vec::new(); // (constName, ruleName)\n    for r in protocol_rules(thy) {\n        let mut names: Vec<String> = Vec::new();\n        for facts in [&r.premises, &r.actions, &r.conclusions] {\n            for f in facts {\n                for a in &f.args {\n                    collect_pub_lits(a, &mut names);\n                }\n            }\n        }\n        for n in names {\n            let pair = (n, r.name.clone());\n            if !pairs.contains(&pair) {\n                pairs.push(pair);\n            }\n        }\n    }\n    public_names_report_from_pairs(pairs)\n}\n\npub fn public_names_report_from_pairs(pairs: Vec<(String, String)>) -> Vec<WfError> {\n    // Group by lowercased constant name, preserving first-seen order.\n    let mut groups: Vec<(String, Vec<(String, String)>)> = Vec::new();\n    for (name, rule) in &pairs {\n        let key = name.to_lowercase();\n        match groups.iter_mut().find(|(k, _)| *k == key) {\n            Some((_, v)) => v.push((name.clone(), rule.clone())),\n            None => groups.push((key, vec![(name.clone(), rule.clone())])),\n        }\n    }\n    let mut items: Vec<String> = Vec::new();\n    for (_, occ) in &groups {\n        let distinct: std::collections::BTreeSet<&String> = occ.iter().map(|(n, _)| n).collect();\n        if distinct.len() < 2 {\n            continue; // no capitalization conflict\n        }\n        // Group occurrences by rule, preserving first-seen rule order.\n        let mut by_rule: Vec<(String, Vec<String>)> = Vec::new();\n        for (n, rule) in occ {\n            match by_rule.iter_mut().find(|(rr, _)| rr == rule) {\n                Some((_, ns)) => {\n                    if !ns.contains(n) {\n                        ns.push(n.clone());\n                    }\n                }\n                None => by_rule.push((rule.clone(), vec![n.clone()])),\n            }\n        }\n        let locs: Vec<String> = by_rule\n            .into_iter()\n            .map(|(rule, mut ns)| {\n                ns.sort();\n                let quoted: Vec<String> = ns.iter().map(|n| format!(\"'{}'\", n)).collect();\n                format!(\"rule \\\"{}\\\":  name {}\", rule, quoted.join(\", \"))\n            })\n            .collect();\n        let n = items.len() + 1;\n        items.push(format!(\"  {}. {}\", n, locs.join(\", \")));\n    }\n    if items.is_empty() {\n        return vec![];\n    }\n    let header = \"Identifiers are case-sensitive, mismatched capitalizations are considered as different, i.e., 'ID' is different from 'id'. Check the capitalization of your identifiers.\";\n    let msg = format!(\"{}\\n\\n{}\", header, items.join(\"\\n  \\n\"));\n    vec![WfError::new(T_PUBNAMES, msg)]\n}\n\n// ---------------------------------------------------------------------------\n// 10. Formula terms (free variables in lemma / restriction formulas)\n// ---------------------------------------------------------------------------\n\nconst FORMULA_TERMS_HELP: &str = \"  The only allowed terms are public constants and bound node and\\n  message variables. If you encounter free message variables, then\\n  you might have forgotten a #-prefix. Sort prefixes can only be\\n  dropped where this is unambiguous. Moreover, reducible function\\n  symbols are disallowed.\";\n\n// Bound variables are matched by NAME only. The oracle treats a quantified\n// message variable and its occurrences as the same variable even when the\n// parsed AST tags them with different-but-compatible sorts (e.g. Msg vs the\n// Untagged default, or a temporal written `@ i` vs a quantifier `#i`); matching\n// on the full sort tag produces spurious \"free variable\" reports (observed on\n// round2/exists_trace_reuse). See BEHAVIOR.md.\nfn free_vars_formula(f: &Formula, bound: &mut Vec<String>, out: &mut Vec<VarSpec>) {\n    match f {\n        Formula::False | Formula::True => {}\n        Formula::Atom(a) => {\n            let mut vs = Vec::new();\n            atom_vars(a, &mut vs);\n            for v in vs {\n                if !bound.contains(&v.name) {\n                    out.push(v);\n                }\n            }\n        }\n        Formula::Not(g) => free_vars_formula(g, bound, out),\n        Formula::And(a, b)\n        | Formula::Or(a, b)\n        | Formula::Implies(a, b)\n        | Formula::Iff(a, b) => {\n            free_vars_formula(a, bound, out);\n            free_vars_formula(b, bound, out);\n        }\n        Formula::Forall(vs, g) | Formula::Exists(vs, g) => {\n            let added: Vec<String> = vs.iter().map(|v| v.name.clone()).collect();\n            let n = added.len();\n            bound.extend(added);\n            free_vars_formula(g, bound, out);\n            for _ in 0..n {\n                bound.pop();\n            }\n        }\n    }\n}\n\nfn atom_vars(a: &Atom, out: &mut Vec<VarSpec>) {\n    match a {\n        Atom::Eq(x, y)\n        | Atom::Less(x, y)\n        | Atom::LessMset(x, y)\n        | Atom::Subterm(x, y) => {\n            collect_term_vars(x, out);\n            collect_term_vars(y, out);\n        }\n        Atom::Action(f, t) => {\n            collect_fact_vars(f, out);\n            collect_term_vars(t, out);\n        }\n        Atom::Last(t) => collect_term_vars(t, out),\n        Atom::Pred(f) => collect_fact_vars(f, out),\n    }\n}\n\nfn formula_terms_entry(entity: &str, name: &str, free: &[VarSpec]) -> String {\n    let terms: Vec<String> = free.iter().map(|v| format!(\"`Free {}'\", pp_var(v))).collect();\n    let head = if terms.len() == 1 {\n        format!(\n            \"  {} `{}' uses terms of the wrong form: {}\",\n            entity, name, terms[0]\n        )\n    } else {\n        format!(\n            \"  {} `{}' uses terms of the wrong form:\\n    {}\",\n            entity,\n            name,\n            terms.join(\", \")\n        )\n    };\n    format!(\"{}\\n  \\n{}\", head, FORMULA_TERMS_HELP)\n}\n\npub fn formula_terms(thy: &Theory) -> Vec<WfError> {\n    let mut entries: Vec<String> = Vec::new();\n    for it in &thy.items {\n        let (entity, name, formula) = match it {\n            TheoryItem::Lemma(l) => (\"Lemma\", &l.name, &l.formula),\n            TheoryItem::Restriction(r) | TheoryItem::LegacyAxiom(r) => {\n                (\"Restriction\", &r.name, &r.formula)\n            }\n            _ => continue,\n        };\n        let mut bound = Vec::new();\n        let mut free = Vec::new();\n        free_vars_formula(formula, &mut bound, &mut free);\n        let free = dedup_vars(free);\n        if !free.is_empty() {\n            entries.push(formula_terms_entry(entity, name, &free));\n        }\n    }\n    if entries.is_empty() {\n        vec![]\n    } else {\n        vec![WfError::new(T_FORMULA_TERMS, entries.join(\"\\n\"))]\n    }\n}\n\n// ---------------------------------------------------------------------------\n// 11. Formula guardedness (best-effort; single-line formula printer)\n// ---------------------------------------------------------------------------\n\npub fn formula_guardedness(thy: &Theory) -> Vec<WfError> {\n    let mut entries: Vec<String> = Vec::new();\n    for it in &thy.items {\n        let (name, formula) = match it {\n            TheoryItem::Lemma(l) => (&l.name, &l.formula),\n            _ => continue,\n        };\n        if let Some((unguarded, sub)) = find_unguarded(formula) {\n            let vars: Vec<String> = unguarded.iter().map(|v| format!(\"'{}'\", pp_var(v))).collect();\n            let pp_sub = crate::formula::pp_formula(&sub);\n            let pp_whole = crate::formula::pp_formula(formula);\n            entries.push(format!(\n                \"  Lemma `{}' cannot be converted to a guarded formula:\\n    unguarded variable(s) {} in the subformula\\n      \\\"{}\\\"\\n    in the formula\\n      \\\"{}\\\"\",\n                name,\n                vars.join(\", \"),\n                pp_sub,\n                pp_whole\n            ));\n        }\n    }\n    if entries.is_empty() {\n        vec![]\n    } else {\n        vec![WfError::new(T_GUARD, entries.join(\"\\n\"))]\n    }\n}\n\n/// Variables appearing in any Action or Pred atom anywhere in `f` (the guard\n/// positions). Used as a permissive over-approximation of \"guarded\".\nfn guard_vars(f: &Formula, out: &mut Vec<VarSpec>) {\n    match f {\n        Formula::Atom(Atom::Action(fact, t)) => {\n            collect_fact_vars(fact, out);\n            collect_term_vars(t, out);\n        }\n        Formula::Atom(Atom::Pred(fact)) => collect_fact_vars(fact, out),\n        Formula::Atom(_) | Formula::True | Formula::False => {}\n        Formula::Not(g) => guard_vars(g, out),\n        Formula::And(a, b)\n        | Formula::Or(a, b)\n        | Formula::Implies(a, b)\n        | Formula::Iff(a, b) => {\n            guard_vars(a, out);\n            guard_vars(b, out);\n        }\n        Formula::Forall(_, g) | Formula::Exists(_, g) => guard_vars(g, out),\n    }\n}\n\n/// Returns the first quantifier whose bound variables are not all guarded,\n/// together with that subformula.\nfn find_unguarded(f: &Formula) -> Option<(Vec<VarSpec>, Formula)> {\n    match f {\n        Formula::Forall(vs, g) | Formula::Exists(vs, g) => {\n            let mut gv = Vec::new();\n            guard_vars(g, &mut gv);\n            // Match guard variables by name (see free_vars_formula rationale).\n            let gset: std::collections::HashSet<String> =\n                gv.iter().map(|v| v.name.clone()).collect();\n            let unguarded: Vec<VarSpec> = vs\n                .iter()\n                .filter(|v| !gset.contains(&v.name))\n                .cloned()\n                .collect();\n            if !unguarded.is_empty() {\n                return Some((unguarded, f.clone()));\n            }\n            find_unguarded(g)\n        }\n        Formula::Not(g) => find_unguarded(g),\n        Formula::And(a, b)\n        | Formula::Or(a, b)\n        | Formula::Implies(a, b)\n        | Formula::Iff(a, b) => find_unguarded(a).or_else(|| find_unguarded(b)),\n        _ => None,\n    }\n}\n\n// ---------------------------------------------------------------------------\n// 12. Nat Sorts\n// ---------------------------------------------------------------------------\n\npub fn nat_sorts(thy: &Theory) -> Vec<WfError> {\n    let mut entries: Vec<String> = Vec::new();\n    for r in protocol_rules(thy) {\n        for facts in [&r.premises, &r.actions, &r.conclusions] {\n            for f in facts {\n                for a in &f.args {\n                    collect_nat_issues(a, &mut entries);\n                }\n            }\n        }\n    }\n    if entries.is_empty() {\n        vec![]\n    } else {\n        vec![WfError::new(T_NAT, entries.join(\"\\n  \\n\"))]\n    }\n}\n\nfn collect_nat_issues(t: &Term, out: &mut Vec<String>) {\n    if let Term::BinOp(BinOp::NatPlus, _, _) = t {\n        let term_pp = pp_term(t);\n        let mut vs = Vec::new();\n        collect_term_vars(t, &mut vs);\n        for v in vs {\n            if v.sort != SortHint::Nat {\n                let entry = format!(\"  {} in term {} must be of sort nat\", pp_var(&v), term_pp);\n                if !out.contains(&entry) {\n                    out.push(entry);\n                }\n            }\n        }\n    }\n    // recurse\n    match t {\n        Term::App(_, args) | Term::Pair(args) => {\n            for a in args {\n                collect_nat_issues(a, out);\n            }\n        }\n        Term::AlgApp(_, a, b) | Term::Diff(a, b) | Term::BinOp(_, a, b) => {\n            collect_nat_issues(a, out);\n            collect_nat_issues(b, out);\n        }\n        Term::PatMatch(inner) => collect_nat_issues(inner, out),\n        _ => {}\n    }\n}\n\n// ---------------------------------------------------------------------------\n// 13. Subterm Convergence Warning\n// ---------------------------------------------------------------------------\n\npub fn subterm_convergence(thy: &Theory) -> Vec<WfError> {\n    let mut bad: Vec<String> = Vec::new();\n    for it in &thy.items {\n        if let TheoryItem::Equations { convergent, eqs } = it {\n            if *convergent {\n                continue; // user asserted convergence\n            }\n            for eq in eqs {\n                if !is_subterm(&eq.rhs, &eq.lhs) {\n                    bad.push(format!(\"    {} = {}\", pp_term(&eq.lhs), pp_term(&eq.rhs)));\n                }\n            }\n        }\n    }\n    if bad.is_empty() {\n        return vec![];\n    }\n    let intro = \"  User-defined equations must be convergent and have the finite variant property. The following equations are not subterm convergent. If you are sure that the set of equations is nevertheless convergent and has the finite variant property, you can ignore this warning and continue \";\n    let manual = \" For more information, please refer to the manual : https://tamarin-prover.com/manual/master/book/010_modeling-issues.html \";\n    let msg = format!(\"{}\\n\\n{}\\n   \\n{}\", intro, bad.join(\"\\n\"), manual);\n    vec![WfError::new(T_SUBTERM, msg)]\n}\n\n/// Structural subterm test: does `small` occur as a subterm of `big`?\nfn is_subterm(small: &Term, big: &Term) -> bool {\n    if small == big {\n        return true;\n    }\n    match big {\n        Term::App(_, args) | Term::Pair(args) => args.iter().any(|a| is_subterm(small, a)),\n        Term::AlgApp(_, a, b) | Term::Diff(a, b) | Term::BinOp(_, a, b) => {\n            is_subterm(small, a) || is_subterm(small, b)\n        }\n        Term::PatMatch(inner) => is_subterm(small, inner),\n        _ => false,\n    }\n}\n\n// ---------------------------------------------------------------------------\n// 2. Fresh public constants\n// ---------------------------------------------------------------------------\n// A fresh-name literal (`~'foo'`) used directly in a rule is rejected; fresh\n// names must come from `Fr(~x)` premises. Constants are collected in the order\n// premises, conclusions, actions (observed via probe fpc_positions).\npub fn fresh_public_constants(thy: &Theory) -> Vec<WfError> {\n    let mut entries: Vec<String> = Vec::new();\n    for r in protocol_rules(thy) {\n        let mut lits: Vec<String> = Vec::new();\n        for facts in [&r.premises, &r.conclusions, &r.actions] {\n            for f in facts {\n                for a in &f.args {\n                    collect_fresh_lits(a, &mut lits);\n                }\n            }\n        }\n        if lits.is_empty() {\n            continue;\n        }\n        entries.push(format!(\n            \"  rule `{}': fresh public constants are not allowed: {}\",\n            r.name,\n            lits.join(\", \")\n        ));\n    }\n    if entries.is_empty() {\n        vec![]\n    } else {\n        vec![WfError::new(T_FRESH_PUB, entries.join(\"\\n  \\n\"))]\n    }\n}\n\n// ---------------------------------------------------------------------------\n// 5. Reserved prefixes (diff mode only)\n// ---------------------------------------------------------------------------\n// Fact names beginning with `DiffIntr`/`DiffProto` are reserved for the diff\n// translation. Only emitted for diff-mode theories (observed: silent otherwise).\npub fn reserved_prefixes(thy: &Theory) -> Vec<WfError> {\n    if !thy.is_diff {\n        return vec![];\n    }\n    let mut entries: Vec<String> = Vec::new();\n    for r in protocol_rules(thy) {\n        // Order of collection: premises, actions, conclusions (probe rp_multi).\n        let mut hits: Vec<&Fact> = Vec::new();\n        for facts in [&r.premises, &r.actions, &r.conclusions] {\n            for f in facts {\n                if RESERVED_PREFIXES.iter().any(|p| f.name.starts_with(p)) {\n                    hits.push(f);\n                }\n            }\n        }\n        if hits.is_empty() {\n            continue;\n        }\n        let header = fill_words(&reserved_prefix_header_words(&r.name), 2, FILL_WIDTH);\n        let blocks: Vec<String> = hits\n            .iter()\n            .map(|f| {\n                let m = if f.persistent { \"Persistent\" } else { \"Linear\" };\n                format!(\n                    \"    {}\\n    (ProtoFact {} \\\"{}\\\" {},{},{})\",\n                    pp_fact(f),\n                    m,\n                    f.name,\n                    f.args.len(),\n                    f.args.len(),\n                    m\n                )\n            })\n            .collect();\n        entries.push(format!(\"{}\\n  \\n{}\", header, blocks.join(\"\\n  \\n\")));\n    }\n    if entries.is_empty() {\n        vec![]\n    } else {\n        vec![WfError::new(T_RESERVED_PREFIX, entries.join(\"\\n  \\n\"))]\n    }\n}\n\nfn reserved_prefix_header_words(rule: &str) -> Vec<String> {\n    [\n        \"The\",\n        \"Rule\",\n        &format!(\"`{}'\", rule),\n        \"contains\",\n        \"facts\",\n        \"with\",\n        \"reserved\",\n        \"prefixes\",\n        \"('DiffIntr',\",\n        \"'DiffProto')\",\n        \"inside\",\n        \"names:\",\n    ]\n    .iter()\n    .map(|s| s.to_string())\n    .collect()\n}\n\n// ---------------------------------------------------------------------------\n// 11 & 12. Left rule / Right rule (diff mode only)\n// ---------------------------------------------------------------------------\n// A diff rule may carry explicit `left`/`right` projections. Each explicit\n// projection must equal the corresponding projection of the parent diff rule\n// (diff(a,b) -> a on the left, -> b on the right). When it differs, the rule is\n// \"inconsistent\". For a single rule the left projection is checked first and,\n// if inconsistent, the right is not reported (observed via probe diff_both).\npub fn diff_left_right(thy: &Theory) -> Vec<WfError> {\n    if !thy.is_diff {\n        return vec![];\n    }\n    let mut left_entries: Vec<String> = Vec::new();\n    let mut right_entries: Vec<String> = Vec::new();\n    for r in protocol_rules(thy) {\n        if let Some((left, right)) = &r.left_right {\n            if !rule_matches_projection(r, left, true) {\n                left_entries.push(inconsistent_entry(\"left\", left, r));\n            } else if !rule_matches_projection(r, right, false) {\n                right_entries.push(inconsistent_entry(\"right\", right, r));\n            }\n        }\n    }\n    let mut out = Vec::new();\n    if !left_entries.is_empty() {\n        out.push(WfError::new(T_LEFT, left_entries.join(\"\\n  \\n\")));\n    }\n    if !right_entries.is_empty() {\n        out.push(WfError::new(T_RIGHT, right_entries.join(\"\\n  \\n\")));\n    }\n    out\n}\n\nfn inconsistent_entry(side: &str, explicit: &Rule, parent: &Rule) -> String {\n    format!(\n        \"  Inconsistent {} rule\\n{}\\n  \\n  w.r.t.\\n  \\n{}\",\n        side,\n        indent_block(&pp_rule(explicit), 4),\n        indent_block(&pp_rule(parent), 4)\n    )\n}\n\n/// True iff the explicit rule's fact lists equal the parent rule's projection.\nfn rule_matches_projection(parent: &Rule, explicit: &Rule, left: bool) -> bool {\n    facts_pp(&project_facts(&parent.premises, left)) == facts_pp(&explicit.premises)\n        && facts_pp(&project_facts(&parent.actions, left)) == facts_pp(&explicit.actions)\n        && facts_pp(&project_facts(&parent.conclusions, left)) == facts_pp(&explicit.conclusions)\n}\n\nfn facts_pp(fs: &[Fact]) -> String {\n    fs.iter().map(pp_fact).collect::<Vec<_>>().join(\", \")\n}\n\nfn project_facts(fs: &[Fact], left: bool) -> Vec<Fact> {\n    fs.iter().map(|f| project_fact(f, left)).collect()\n}\n\nfn project_fact(f: &Fact, left: bool) -> Fact {\n    Fact {\n        persistent: f.persistent,\n        name: f.name.clone(),\n        args: f.args.iter().map(|a| project_term(a, left)).collect(),\n        annotations: f.annotations.clone(),\n    }\n}\n\n/// Project a diff term to one side: `diff(a, b)` becomes `a` (left) or `b`\n/// (right); all other terms are structurally mapped.\nfn project_term(t: &Term, left: bool) -> Term {\n    match t {\n        Term::Diff(a, b) => project_term(if left { a } else { b }, left),\n        Term::App(name, args) => {\n            Term::App(name.clone(), args.iter().map(|a| project_term(a, left)).collect())\n        }\n        Term::Pair(args) => Term::Pair(args.iter().map(|a| project_term(a, left)).collect()),\n        Term::AlgApp(name, a, b) => Term::AlgApp(\n            name.clone(),\n            Box::new(project_term(a, left)),\n            Box::new(project_term(b, left)),\n        ),\n        Term::BinOp(op, a, b) => Term::BinOp(\n            *op,\n            Box::new(project_term(a, left)),\n            Box::new(project_term(b, left)),\n        ),\n        Term::PatMatch(inner) => Term::PatMatch(Box::new(project_term(inner, left))),\n        other => other.clone(),\n    }\n}\n\n// ---------------------------------------------------------------------------\n// 15. Lemma annotations\n// ---------------------------------------------------------------------------\n// An `exists-trace` lemma marked `reuse` is rejected (observed trigger).\npub fn lemma_annotations(thy: &Theory) -> Vec<WfError> {\n    let mut entries: Vec<String> = Vec::new();\n    for it in &thy.items {\n        if let TheoryItem::Lemma(l) = it {\n            let is_reuse = l.attributes.iter().any(|a| matches!(a, LemmaAttr::Reuse));\n            if is_reuse && l.trace_quantifier == TraceQuantifier::ExistsTrace {\n                entries.push(format!(\n                    \"  Lemma `{}': cannot reuse 'exists-trace' lemmas\",\n                    l.name\n                ));\n            }\n        }\n    }\n    if entries.is_empty() {\n        vec![]\n    } else {\n        vec![WfError::new(T_LEMMA_ANNOT, entries.join(\"\\n  \\n\"))]\n    }\n}\n\n// ---------------------------------------------------------------------------\n// 16. Multiplication restriction of rules\n// ---------------------------------------------------------------------------\n// A rule whose conclusions contain a multiplication (`*`) term is not\n// multiplication restricted. The \"After replacing reducible function symbols\"\n// rule renders identically to the original when the left-hand side has no\n// reducible symbols to replace (the general replacement is a documented gap).\npub fn multiplication_restriction(thy: &Theory) -> Vec<WfError> {\n    let mut entries: Vec<String> = Vec::new();\n    for r in protocol_rules(thy) {\n        let mut mult_terms: Vec<String> = Vec::new();\n        for f in &r.conclusions {\n            for a in &f.args {\n                collect_mult_terms(a, &mut mult_terms);\n            }\n        }\n        if mult_terms.is_empty() {\n            continue;\n        }\n        let rule_pp = indent_block(&pp_rule(r), 4);\n        entries.push(format!(\n            \"  The following rule is not multiplication restricted:\\n{rule}\\n  \\n  After replacing reducible function symbols in lhs with variables:\\n{rule}\\n  \\n    Terms with multiplication:  {terms}\",\n            rule = rule_pp,\n            terms = mult_terms.join(\", \")\n        ));\n    }\n    if entries.is_empty() {\n        vec![]\n    } else {\n        vec![WfError::new(T_MULRESTRICT, entries.join(\"\\n  \\n\"))]\n    }\n}\n\n// ---------------------------------------------------------------------------\n// check_if_lemmas_in_theory (secondary entry point; render UNVERIFIED)\n// ---------------------------------------------------------------------------\n\n/// Names of every lemma-like item declared in the theory.\npub fn theory_lemma_names(thy: &Theory) -> Vec<String> {\n    thy.items\n        .iter()\n        .filter_map(|it| match it {\n            TheoryItem::Lemma(l) => Some(l.name.clone()),\n            TheoryItem::DiffLemma(l) => Some(l.name.clone()),\n            TheoryItem::AccLemma(l) => Some(l.name.clone()),\n            _ => None,\n        })\n        .collect()\n}\n","numLines":1296,"startLine":1,"totalLines":1296}},"sourceToolAssistantUUID":"468e9316-604b-4a7c-9a31-7a3a1ab3070b","userType":"external","entrypoint":"cli","cwd":"/home/kamilner/tamarin-rs","sessionId":"57f8e1bc-d495-4b36-93c0-033347d5034a","version":"2.1.212","gitBranch":"main"}
