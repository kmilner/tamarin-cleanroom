{"parentUuid":"f97ced3a-ffbd-4727-a545-5c14603fd343","isSidechain":true,"promptId":"a3a1890b-4356-4bf6-b523-7534e72cab2b","agentId":"aac7737a5d3b7d6e7","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01G9T8B2vSRstDgorN5BZx7H","type":"tool_result","content":"1\t-- |\n2\t-- Copyright   : (c) 2011 Simon Meier\n3\t-- License     : GPL v3 (see LICENSE)\n4\t--\n5\t-- Portability : portable\n6\t--\n7\t-- General support for pretty printing theories.\n8\tmodule Theory.Text.Pretty (\n9\t  -- * General highlighters\n10\t    module Text.PrettyPrint.Highlight\n11\t\n12\t  -- * Additional combinators\n13\t  , vsep\n14\t  , fsepList\n15\t\n16\t  -- * Comments\n17\t  , lineComment\n18\t  , multiComment\n19\t  , closedComment\n20\t\n21\t  , lineComment_\n22\t  , multiComment_\n23\t  , closedComment_\n24\t\n25\t  -- * Keywords\n26\t  , kwTheoryName\n27\t  , kwTheoryBegin\n28\t  , kwTheoryHeader\n29\t  , kwEnd\n30\t  , kwModulo\n31\t  , kwBy\n32\t  , kwCase\n33\t  , kwNext\n34\t  , kwQED\n35\t  , kwTactic\n36\t  , kwPresort\n37\t  , kwPrio\n38\t  , kwDeprio\n39\t  , kwLemma\n40\t  , kwPredicates\n41\t  , kwPredicate\n42\t  , kwDiffLemma\n43\t  , kwRestriction\n44\t  , kwLeft\n45\t  , kwRight\n46\t  , kwVariants\n47\t\n48\t  -- ** Composed forms\n49\t  , kwRuleModulo\n50\t  , kwInstanceModulo\n51\t  , kwVariantsModulo\n52\t  , kwTypesModulo\n53\t\n54\t  -- * Operators\n55\t  , opProvides\n56\t  , opRequires\n57\t  , opAction\n58\t  , opPath\n59\t  , opSubterm\n60\t  , opLess\n61\t  , opEqual\n62\t  , opDedBefore\n63\t  , opEdge\n64\t\n65\t  , opExists\n66\t  , opForall\n67\t  , opLAnd\n68\t  , opLOr\n69\t  , opImp\n70\t  , opIff\n71\t  , opDot\n72\t\n73\t  ) where\n74\t\n75\timport Text.PrettyPrint.Highlight\n76\t\n77\t\n78\t------------------------------------------------------------------------------\n79\t-- Additional combinators\n80\t------------------------------------------------------------------------------\n81\t\n82\t-- | Vertically separate a list of documents by empty lines.\n83\tvsep :: Document d => [d] -> d\n84\tvsep = foldr ($--$) emptyDoc\n85\t\n86\t-- | Pretty print a list of values as a comma-separated list wrapped in\n87\t-- paragraph mode.\n88\tfsepList :: Document d => (a -> d) -> [a] -> d\n89\tfsepList pp = fsep . punctuate comma . map pp\n90\t\n91\t\n92\t------------------------------------------------------------------------------\n93\t-- Comments\n94\t------------------------------------------------------------------------------\n95\t\n96\tlineComment :: HighlightDocument d => d -> d\n97\tlineComment d = comment $ text \"//\" <-> d\n98\t\n99\tlineComment_ :: HighlightDocument d => String -> d\n100\tlineComment_ = lineComment . text\n101\t\n102\tmultiComment :: HighlightDocument d => d -> d\n103\tmultiComment d = comment $ fsep [text \"/*\", d, text \"*/\"]\n104\t\n105\tmultiComment_ :: HighlightDocument d => [String] -> d\n106\tmultiComment_ ls = comment $ fsep [text \"/*\", vcat $ map text ls, text \"*/\"]\n107\t\n108\tclosedComment :: HighlightDocument d => d -> d\n109\tclosedComment d = comment $ fsep [text \"/*\", d, text \"*/\"]\n110\t\n111\tclosedComment_ :: HighlightDocument d => String -> d\n112\tclosedComment_ ls = comment $ fsep [text \"/*\", text ls, text \"*/\"]\n113\t\n114\t------------------------------------------------------------------------------\n115\t-- Keywords\n116\t------------------------------------------------------------------------------\n117\t\n118\t-- Split the theory header into two parts to allow for configuration blocks.\n119\tkwTheoryName :: HighlightDocument d => d -> d\n120\tkwTheoryName name = keyword_ \"theory\" <-> name\n121\t\n122\tkwTheoryBegin :: HighlightDocument d => d\n123\tkwTheoryBegin = keyword_ \"begin\"\n124\t\n125\tkwTheoryHeader :: HighlightDocument d => d -> d\n126\tkwTheoryHeader name = kwTheoryName name <-> kwTheoryBegin\n127\t\n128\t\n129\tkwEnd, kwBy, kwCase, kwNext, kwQED, kwRestriction, kwTactic, kwPresort, kwPrio, kwDeprio, kwLemma, kwPredicates, kwPredicate, kwDiffLemma, kwLeft, kwRight, kwVariants :: HighlightDocument d => d\n130\tkwEnd         = keyword_ \"end\"\n131\tkwBy          = keyword_ \"by\"\n132\tkwCase        = keyword_ \"case\"\n133\tkwNext        = keyword_ \"next\"\n134\tkwQED         = keyword_ \"qed\"\n135\tkwRestriction = keyword_ \"restriction\"\n136\tkwTactic      = keyword_ \"tactic\"\n137\tkwPresort     = keyword_ \"presort\"\n138\tkwPrio        = keyword_ \"prio\"\n139\tkwDeprio      = keyword_ \"deprio\"\n140\tkwLemma       = keyword_ \"lemma\"\n141\tkwPredicates  = keyword_ \"predicates\"\n142\tkwPredicate   = keyword_ \"predicate\"\n143\tkwDiffLemma   = keyword_ \"diffLemma\"\n144\tkwLeft        = keyword_ \"left\"\n145\tkwRight       = keyword_ \"right\"\n146\tkwVariants    = keyword_ \"variants\"\n147\t\n148\tkwModulo :: HighlightDocument d\n149\t         => String  -- ^ What\n150\t         -> String  -- ^ modulo theory\n151\t         -> d\n152\tkwModulo what thy = keyword_ what <-> parens (keyword_ \"modulo\" <-> text thy)\n153\t\n154\tkwRuleModulo, kwInstanceModulo, kwTypesModulo, kwVariantsModulo\n155\t  :: HighlightDocument d => String -> d\n156\tkwRuleModulo     = kwModulo \"rule\"\n157\tkwInstanceModulo = kwModulo \"instance\"\n158\tkwTypesModulo    = kwModulo \"type assertions\"\n159\tkwVariantsModulo = kwModulo \"variants\"\n160\t\n161\t------------------------------------------------------------------------------\n162\t-- Operators\n163\t------------------------------------------------------------------------------\n164\t\n165\topProvides, opRequires, opAction, opPath, opSubterm, opLess, opEqual, opDedBefore, opEdge,\n166\t  opExists, opForall, opLAnd, opLOr, opImp, opIff, opDot\n167\t    :: HighlightDocument d => d\n168\topProvides  = operator_ \":>\"\n169\topRequires  = operator_ \"<:\"\n170\topAction    = operator_ \"@\"\n171\topPath      = operator_ \">+>\"\n172\topLess      = operator_ \"<\"\n173\topSubterm   = operator_ \"⊏\"\n174\topEqual     = operator_ \"=\"\n175\topDedBefore = operator_ \"--|\"\n176\topEdge      = operator_ \">->\"\n177\topExists    = operator_ \"∃ \" -- \"Ex \"\n178\topForall    = operator_ \"∀ \" -- \"All \"\n179\topLAnd      = operator_ \"∧\" -- \"&\"\n180\topLOr       = operator_ \"∨\" -- \"|\"\n181\topImp       = operator_ \"⇒\" -- \"==>\"\n182\topIff       = operator_ \"⇔\" -- \"<=>\"\n183\topDot       = operator_ \".\"\n184\t"}]},"uuid":"2e4fd92f-9feb-446d-8021-fb4ee56a3a9b","timestamp":"2026-07-17T12:18:21.822Z","toolUseResult":{"type":"text","file":{"filePath":"/home/kamilner/tamarin-rs/tamarin-prover/lib/theory/src/Theory/Text/Pretty.hs","content":"-- |\n-- Copyright   : (c) 2011 Simon Meier\n-- License     : GPL v3 (see LICENSE)\n--\n-- Portability : portable\n--\n-- General support for pretty printing theories.\nmodule Theory.Text.Pretty (\n  -- * General highlighters\n    module Text.PrettyPrint.Highlight\n\n  -- * Additional combinators\n  , vsep\n  , fsepList\n\n  -- * Comments\n  , lineComment\n  , multiComment\n  , closedComment\n\n  , lineComment_\n  , multiComment_\n  , closedComment_\n\n  -- * Keywords\n  , kwTheoryName\n  , kwTheoryBegin\n  , kwTheoryHeader\n  , kwEnd\n  , kwModulo\n  , kwBy\n  , kwCase\n  , kwNext\n  , kwQED\n  , kwTactic\n  , kwPresort\n  , kwPrio\n  , kwDeprio\n  , kwLemma\n  , kwPredicates\n  , kwPredicate\n  , kwDiffLemma\n  , kwRestriction\n  , kwLeft\n  , kwRight\n  , kwVariants\n\n  -- ** Composed forms\n  , kwRuleModulo\n  , kwInstanceModulo\n  , kwVariantsModulo\n  , kwTypesModulo\n\n  -- * Operators\n  , opProvides\n  , opRequires\n  , opAction\n  , opPath\n  , opSubterm\n  , opLess\n  , opEqual\n  , opDedBefore\n  , opEdge\n\n  , opExists\n  , opForall\n  , opLAnd\n  , opLOr\n  , opImp\n  , opIff\n  , opDot\n\n  ) where\n\nimport Text.PrettyPrint.Highlight\n\n\n------------------------------------------------------------------------------\n-- Additional combinators\n------------------------------------------------------------------------------\n\n-- | Vertically separate a list of documents by empty lines.\nvsep :: Document d => [d] -> d\nvsep = foldr ($--$) emptyDoc\n\n-- | Pretty print a list of values as a comma-separated list wrapped in\n-- paragraph mode.\nfsepList :: Document d => (a -> d) -> [a] -> d\nfsepList pp = fsep . punctuate comma . map pp\n\n\n------------------------------------------------------------------------------\n-- Comments\n------------------------------------------------------------------------------\n\nlineComment :: HighlightDocument d => d -> d\nlineComment d = comment $ text \"//\" <-> d\n\nlineComment_ :: HighlightDocument d => String -> d\nlineComment_ = lineComment . text\n\nmultiComment :: HighlightDocument d => d -> d\nmultiComment d = comment $ fsep [text \"/*\", d, text \"*/\"]\n\nmultiComment_ :: HighlightDocument d => [String] -> d\nmultiComment_ ls = comment $ fsep [text \"/*\", vcat $ map text ls, text \"*/\"]\n\nclosedComment :: HighlightDocument d => d -> d\nclosedComment d = comment $ fsep [text \"/*\", d, text \"*/\"]\n\nclosedComment_ :: HighlightDocument d => String -> d\nclosedComment_ ls = comment $ fsep [text \"/*\", text ls, text \"*/\"]\n\n------------------------------------------------------------------------------\n-- Keywords\n------------------------------------------------------------------------------\n\n-- Split the theory header into two parts to allow for configuration blocks.\nkwTheoryName :: HighlightDocument d => d -> d\nkwTheoryName name = keyword_ \"theory\" <-> name\n\nkwTheoryBegin :: HighlightDocument d => d\nkwTheoryBegin = keyword_ \"begin\"\n\nkwTheoryHeader :: HighlightDocument d => d -> d\nkwTheoryHeader name = kwTheoryName name <-> kwTheoryBegin\n\n\nkwEnd, kwBy, kwCase, kwNext, kwQED, kwRestriction, kwTactic, kwPresort, kwPrio, kwDeprio, kwLemma, kwPredicates, kwPredicate, kwDiffLemma, kwLeft, kwRight, kwVariants :: HighlightDocument d => d\nkwEnd         = keyword_ \"end\"\nkwBy          = keyword_ \"by\"\nkwCase        = keyword_ \"case\"\nkwNext        = keyword_ \"next\"\nkwQED         = keyword_ \"qed\"\nkwRestriction = keyword_ \"restriction\"\nkwTactic      = keyword_ \"tactic\"\nkwPresort     = keyword_ \"presort\"\nkwPrio        = keyword_ \"prio\"\nkwDeprio      = keyword_ \"deprio\"\nkwLemma       = keyword_ \"lemma\"\nkwPredicates  = keyword_ \"predicates\"\nkwPredicate   = keyword_ \"predicate\"\nkwDiffLemma   = keyword_ \"diffLemma\"\nkwLeft        = keyword_ \"left\"\nkwRight       = keyword_ \"right\"\nkwVariants    = keyword_ \"variants\"\n\nkwModulo :: HighlightDocument d\n         => String  -- ^ What\n         -> String  -- ^ modulo theory\n         -> d\nkwModulo what thy = keyword_ what <-> parens (keyword_ \"modulo\" <-> text thy)\n\nkwRuleModulo, kwInstanceModulo, kwTypesModulo, kwVariantsModulo\n  :: HighlightDocument d => String -> d\nkwRuleModulo     = kwModulo \"rule\"\nkwInstanceModulo = kwModulo \"instance\"\nkwTypesModulo    = kwModulo \"type assertions\"\nkwVariantsModulo = kwModulo \"variants\"\n\n------------------------------------------------------------------------------\n-- Operators\n------------------------------------------------------------------------------\n\nopProvides, opRequires, opAction, opPath, opSubterm, opLess, opEqual, opDedBefore, opEdge,\n  opExists, opForall, opLAnd, opLOr, opImp, opIff, opDot\n    :: HighlightDocument d => d\nopProvides  = operator_ \":>\"\nopRequires  = operator_ \"<:\"\nopAction    = operator_ \"@\"\nopPath      = operator_ \">+>\"\nopLess      = operator_ \"<\"\nopSubterm   = operator_ \"⊏\"\nopEqual     = operator_ \"=\"\nopDedBefore = operator_ \"--|\"\nopEdge      = operator_ \">->\"\nopExists    = operator_ \"∃ \" -- \"Ex \"\nopForall    = operator_ \"∀ \" -- \"All \"\nopLAnd      = operator_ \"∧\" -- \"&\"\nopLOr       = operator_ \"∨\" -- \"|\"\nopImp       = operator_ \"⇒\" -- \"==>\"\nopIff       = operator_ \"⇔\" -- \"<=>\"\nopDot       = operator_ \".\"\n","numLines":184,"startLine":1,"totalLines":184}},"sourceToolAssistantUUID":"f97ced3a-ffbd-4727-a545-5c14603fd343","userType":"external","entrypoint":"cli","cwd":"/home/kamilner/tamarin-rs","sessionId":"57f8e1bc-d495-4b36-93c0-033347d5034a","version":"2.1.212","gitBranch":"main"}
