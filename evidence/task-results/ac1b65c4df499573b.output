{"parentUuid":"2eec5e1b-4d2f-4c1a-930b-147254186d83","isSidechain":true,"agentId":"ac1b65c4df499573b","message":{"model":"claude-opus-4-8","id":"msg_011Cd7dkGUGFuZegH2PkXcBH","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01GC7BKVWVm4J4rbWrmnhuGi","name":"Read","input":{"file_path":"/home/kamilner/tamarin-cleanroom/graphdot/workspace/graph-clean/src/abbrev.rs"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":18127,"cache_read_input_tokens":20468,"cache_creation":{"ephemeral_5m_input_tokens":18127,"ephemeral_1h_input_tokens":0},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Cd7dkEtm3Y9gWdn5UocE4","attributionAgent":"general-purpose","type":"assistant","uuid":"4546b557-3950-4923-b21f-3430ca534d94","timestamp":"2026-07-17T12:32:02.097Z","effort":"xhigh","userType":"external","entrypoint":"cli","cwd":"/home/kamilner/tamarin-rs","sessionId":"57f8e1bc-d495-4b36-93c0-033347d5034a","version":"2.1.212","gitBranch":"main"}
{"parentUuid":"4546b557-3950-4923-b21f-3430ca534d94","isSidechain":true,"promptId":"2961bd88-c930-4506-bcca-f9d40cc278bf","agentId":"ac1b65c4df499573b","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GC7BKVWVm4J4rbWrmnhuGi","type":"tool_result","content":"1\t//! Node abbreviation (BEHAVIOR.md §5): assigning short NAMES to complex terms\n2\t//! and rendering the legend table.\n3\t//!\n4\t//! Four things here are determined by observation and tested:\n5\t//!   * [`prefix_for_symbol`] — the `PREFIX` derivation,\n6\t//!   * [`Abbreviator`] — per-prefix sequential numbering + nesting substitution,\n7\t//!   * [`legend_html`] — the exact `<TABLE …>` bytes incl. the 65-space hang indent,\n8\t//!   * [`select`] — the SELECTION rule: abbreviate a sub-term iff its rendered\n9\t//!     length ≥ 10 and it occurs ≥ 2 times and it is not a tuple (§5c). Both\n10\t//!     necessary gates are corpus-exact (0 counterexamples / 97 538 abbreviations)\n11\t//!     and each was confirmed by a controlled black-box probe.\n12\t//!\n13\t//! The remaining gaps are the canonical numbering tie-break (§5b; the caller\n14\t//! controls insertion order) and, for DH/AC sub-terms, whose occurrences tamarin\n15\t//! counts over a normalised form (§5c residual).\n16\t\n17\tuse std::collections::HashMap;\n18\t\n19\tuse crate::term::Term;\n20\t\n21\t/// The opening tag of every legend table. Its byte length is the hang-indent\n22\t/// applied to continuation `<TR>` rows.\n23\tpub const TABLE_OPEN: &str =\n24\t    \"<TABLE BORDER=\\\"1\\\" CELLBORDER=\\\"0\\\" CELLSPACING=\\\"3\\\" CELLPADDING=\\\"1\\\">\";\n25\t\n26\t/// `PREFIX` for an abbreviation name: the first two *alphabetic* characters of\n27\t/// `name`, uppercased (one char if only one letter exists). Non-letters (digits,\n28\t/// `_`, `.`) are skipped. This is applied to the root symbol's *name* — for a\n29\t/// function `f(..)` that is `f`; for a constant `'c'` it is `c`; for a variable\n30\t/// `~v`/`$v`/`v` it is `v`; for an infix operator it is the operator's function\n31\t/// name (see [`Term::root_symbol_name`], which maps `^`→`exp`, `*`→`mult`,\n32\t/// `++`→`union`, `⊕`→`xor`).\n33\t///\n34\t/// Examples (all observed): `sign`→`SI`, `senc`→`SE`, `hash`→`HA`, `h2`→`H`,\n35\t/// `KDF`→`KD`, `pk`→`PK`, `aenc`→`AE`, `exp`→`EX`, `mult`→`MU`, `union`→`UN`,\n36\t/// `xor`→`XO`, `uninitialized`→`UN`, `F_status`→`FS`, `AMF_UE_NGAP_ID`→`AM`.\n37\tpub fn prefix_for_symbol(name: &str) -> String {\n38\t    name.chars()\n39\t        .filter(|c| c.is_ascii_alphabetic())\n40\t        .take(2)\n41\t        .flat_map(|c| c.to_uppercase())\n42\t        .collect()\n43\t}\n44\t\n45\t/// Assigns and remembers abbreviation names, de-duplicating identical terms and\n46\t/// numbering `1,2,3,…` per prefix in the order terms are [`Abbreviator::add`]ed.\n47\t///\n48\t/// Numbering order matches tamarin only where the canonical order is\n49\t/// unambiguous (see BEHAVIOR.md §5b); the caller decides insertion order.\n50\t#[derive(Default)]\n51\tpub struct Abbreviator {\n52\t    /// name -> the term it stands for, in insertion order.\n53\t    entries: Vec<(String, Term)>,\n54\t    /// canonical fully-expanded key -> assigned name (dedup).\n55\t    by_key: HashMap<String, String>,\n56\t    /// prefix -> next counter value.\n57\t    counters: HashMap<String, u32>,\n58\t}\n59\t\n60\timpl Abbreviator {\n61\t    pub fn new() -> Self {\n62\t        Self::default()\n63\t    }\n64\t\n65\t    /// Register `term` for abbreviation, returning its name. Terms that render\n66\t    /// identically (fully expanded) share one name.\n67\t    pub fn add(&mut self, term: Term) -> String {\n68\t        let key = term.render_full();\n69\t        if let Some(existing) = self.by_key.get(&key) {\n70\t            return existing.clone();\n71\t        }\n72\t        let prefix = prefix_for_symbol(&term.root_symbol_name());\n73\t        let n = self.counters.entry(prefix.clone()).or_insert(0);\n74\t        *n += 1;\n75\t        let name = format!(\"{}{}\", prefix, n);\n76\t        self.by_key.insert(key, name.clone());\n77\t        self.entries.push((name.clone(), term));\n78\t        name\n79\t    }\n80\t\n81\t    /// The name for an already-registered term, if any (by full rendering).\n82\t    pub fn name_of(&self, term: &Term) -> Option<&str> {\n83\t        self.by_key.get(&term.render_full()).map(String::as_str)\n84\t    }\n85\t\n86\t    /// Legend rows `(name, expansion)` in insertion order. Each expansion renders\n87\t    /// the term one level with any registered *sub*-term replaced by its name\n88\t    /// (nesting, §5b: `EX1 = 'g'^MU1`). The expansion string is NOT yet\n89\t    /// HTML-escaped; [`legend_html`] escapes it.\n90\t    pub fn rows(&self) -> Vec<(String, String)> {\n91\t        self.entries\n92\t            .iter()\n93\t            .map(|(name, term)| (name.clone(), term.render_abbrev(&self.by_key)))\n94\t            .collect()\n95\t    }\n96\t\n97\t    /// Render the legend as the exact inner HTML of the `plain` node's label\n98\t    /// (the bytes between `label=<` and `>`). Empty if no entries.\n99\t    pub fn legend_html(&self) -> String {\n100\t        legend_html(&self.rows())\n101\t    }\n102\t\n103\t    pub fn is_empty(&self) -> bool {\n104\t        self.entries.is_empty()\n105\t    }\n106\t    pub fn len(&self) -> usize {\n107\t        self.entries.len()\n108\t    }\n109\t}\n110\t\n111\t/// HTML-escape a legend expansion: `&`→`&amp;`, `<`→`&lt;`, `>`→`&gt;`. Single\n112\t/// quotes and `* ^ ~ $ ⊕ ++` are left literal (as observed).\n113\tpub fn escape_expansion(s: &str) -> String {\n114\t    let mut out = String::with_capacity(s.len());\n115\t    for c in s.chars() {\n116\t        match c {\n117\t            '&' => out.push_str(\"&amp;\"),\n118\t            '<' => out.push_str(\"&lt;\"),\n119\t            '>' => out.push_str(\"&gt;\"),\n120\t            _ => out.push(c),\n121\t        }\n122\t    }\n123\t    out\n124\t}\n125\t\n126\t/// Render one legend row's `<TR>…</TR>` (expansion is escaped here).\n127\tfn legend_row(name: &str, expansion: &str) -> String {\n128\t    format!(\n129\t        \"<TR><TD ALIGN=\\\"LEFT\\\" VALIGN=\\\"TOP\\\"><FONT COLOR=\\\"#000000\\\">{}</FONT></TD> <TD ALIGN=\\\"LEFT\\\" VALIGN=\\\"TOP\\\">=</TD> <TD ALIGN=\\\"LEFT\\\" VALIGN=\\\"TOP\\\">{}</TD></TR>\",\n130\t        name,\n131\t        escape_expansion(expansion),\n132\t    )\n133\t}\n134\t\n135\t/// The exact inner HTML for the legend `plain` node (between `label=<` and `>`):\n136\t/// `<TABLE …><TR>row0</TR>\\n<65sp><TR>row1</TR>\\n…<65sp><TR>rowN</TR></TABLE>`.\n137\t/// The first row is inline after the table tag; every continuation row is on its\n138\t/// own line indented by `TABLE_OPEN.len()` (= 65) spaces.\n139\tpub fn legend_html(rows: &[(String, String)]) -> String {\n140\t    if rows.is_empty() {\n141\t        return String::new();\n142\t    }\n143\t    let indent = \" \".repeat(TABLE_OPEN.len());\n144\t    let mut s = String::new();\n145\t    s.push_str(TABLE_OPEN);\n146\t    for (i, (name, exp)) in rows.iter().enumerate() {\n147\t        if i > 0 {\n148\t            s.push('\\n');\n149\t            s.push_str(&indent);\n150\t        }\n151\t        s.push_str(&legend_row(name, exp));\n152\t    }\n153\t    s.push_str(\"</TABLE>\");\n154\t    s\n155\t}\n156\t\n157\t/// Minimum fully-expanded rendered length for a sub-term to be abbreviated.\n158\t/// Corpus-exact: the shortest of 97 538 legend expansions is 10 chars, none is 9;\n159\t/// live probe: `'12345678'` (10) is abbreviated, `'1234567'` (9) is not.\n160\tpub const MIN_ABBREV_LEN: usize = 10;\n161\t/// Minimum occurrence count for a sub-term to be abbreviated. Live probe: a\n162\t/// 12-char term is abbreviated at 2 occurrences, a 42-char term is NOT at 1.\n163\tpub const MIN_ABBREV_OCC: usize = 2;\n164\t\n165\t/// Select which sub-terms of `roots` to abbreviate (BEHAVIOR.md §5c).\n166\t///\n167\t/// **The rule** (each gate confirmed independently by controlled black-box\n168\t/// probes; both necessary gates are corpus-exact with 0 counterexamples over\n169\t/// 97 538 abbreviations): a sub-term `t` is abbreviated **iff**\n170\t///  1. `t.render_len() >= MIN_ABBREV_LEN` (10),\n171\t///  2. `t` occurs `>= MIN_ABBREV_OCC` (2) times across `roots`, and\n172\t///  3. `t` is not a tuple/pair.\n173\t///\n174\t/// Atoms are eligible (a long constant/variable is abbreviated). Selection is\n175\t/// bottom-up (shortest first) so nested eligible sub-terms are named before the\n176\t/// terms that contain them (`LO1='longarg123'` before `H1='h(LO1)'`).\n177\t///\n178\t/// `roots` must be the full multiset of constraint-system terms (graph node-fact\n179\t/// arguments **and** the sequent's terms) — occurrence is a whole-system count,\n180\t/// not a per-drawn-node count. See BEHAVIOR.md §5c for the one documented\n181\t/// residual: for DH-exponentiation / AC-operator (`^ * ⊕ ++`) sub-terms tamarin\n182\t/// counts occurrences over the *normalised* term, which this structural count\n183\t/// does not model, so those may be over- or under-selected.\n184\tpub fn select(roots: &[Term]) -> Vec<Term> {\n185\t    select_with(roots, MIN_ABBREV_LEN, MIN_ABBREV_OCC)\n186\t}\n187\t\n188\t/// [`select`] with explicit thresholds (for probing / tests).\n189\tpub fn select_with(roots: &[Term], min_len: usize, min_occ: usize) -> Vec<Term> {\n190\t    let mut counts: HashMap<String, (usize, Term)> = HashMap::new();\n191\t    for r in roots {\n192\t        r.for_each_subterm(&mut |t| {\n193\t            if t.is_tuple() || t.render_len() < min_len {\n194\t                return;\n195\t            }\n196\t            let e = counts.entry(t.render_full()).or_insert((0, t.clone()));\n197\t            e.0 += 1;\n198\t        });\n199\t    }\n200\t    let mut picked: Vec<Term> = counts\n201\t        .into_values()\n202\t        .filter(|(c, _)| *c >= min_occ)\n203\t        .map(|(_, t)| t)\n204\t        .collect();\n205\t    // bottom-up: shortest rendering first so inner names are assigned before outer.\n206\t    picked.sort_by(|a, b| {\n207\t        a.render_len().cmp(&b.render_len()).then_with(|| a.render_full().cmp(&b.render_full()))\n208\t    });\n209\t    picked\n210\t}\n211\t"}]},"uuid":"dfcedb4d-833b-4216-a71a-70e5447d6403","timestamp":"2026-07-17T12:32:02.119Z","toolUseResult":{"type":"text","file":{"filePath":"/home/kamilner/tamarin-cleanroom/graphdot/workspace/graph-clean/src/abbrev.rs","content":"//! Node abbreviation (BEHAVIOR.md §5): assigning short NAMES to complex terms\n//! and rendering the legend table.\n//!\n//! Four things here are determined by observation and tested:\n//!   * [`prefix_for_symbol`] — the `PREFIX` derivation,\n//!   * [`Abbreviator`] — per-prefix sequential numbering + nesting substitution,\n//!   * [`legend_html`] — the exact `<TABLE …>` bytes incl. the 65-space hang indent,\n//!   * [`select`] — the SELECTION rule: abbreviate a sub-term iff its rendered\n//!     length ≥ 10 and it occurs ≥ 2 times and it is not a tuple (§5c). Both\n//!     necessary gates are corpus-exact (0 counterexamples / 97 538 abbreviations)\n//!     and each was confirmed by a controlled black-box probe.\n//!\n//! The remaining gaps are the canonical numbering tie-break (§5b; the caller\n//! controls insertion order) and, for DH/AC sub-terms, whose occurrences tamarin\n//! counts over a normalised form (§5c residual).\n\nuse std::collections::HashMap;\n\nuse crate::term::Term;\n\n/// The opening tag of every legend table. Its byte length is the hang-indent\n/// applied to continuation `<TR>` rows.\npub const TABLE_OPEN: &str =\n    \"<TABLE BORDER=\\\"1\\\" CELLBORDER=\\\"0\\\" CELLSPACING=\\\"3\\\" CELLPADDING=\\\"1\\\">\";\n\n/// `PREFIX` for an abbreviation name: the first two *alphabetic* characters of\n/// `name`, uppercased (one char if only one letter exists). Non-letters (digits,\n/// `_`, `.`) are skipped. This is applied to the root symbol's *name* — for a\n/// function `f(..)` that is `f`; for a constant `'c'` it is `c`; for a variable\n/// `~v`/`$v`/`v` it is `v`; for an infix operator it is the operator's function\n/// name (see [`Term::root_symbol_name`], which maps `^`→`exp`, `*`→`mult`,\n/// `++`→`union`, `⊕`→`xor`).\n///\n/// Examples (all observed): `sign`→`SI`, `senc`→`SE`, `hash`→`HA`, `h2`→`H`,\n/// `KDF`→`KD`, `pk`→`PK`, `aenc`→`AE`, `exp`→`EX`, `mult`→`MU`, `union`→`UN`,\n/// `xor`→`XO`, `uninitialized`→`UN`, `F_status`→`FS`, `AMF_UE_NGAP_ID`→`AM`.\npub fn prefix_for_symbol(name: &str) -> String {\n    name.chars()\n        .filter(|c| c.is_ascii_alphabetic())\n        .take(2)\n        .flat_map(|c| c.to_uppercase())\n        .collect()\n}\n\n/// Assigns and remembers abbreviation names, de-duplicating identical terms and\n/// numbering `1,2,3,…` per prefix in the order terms are [`Abbreviator::add`]ed.\n///\n/// Numbering order matches tamarin only where the canonical order is\n/// unambiguous (see BEHAVIOR.md §5b); the caller decides insertion order.\n#[derive(Default)]\npub struct Abbreviator {\n    /// name -> the term it stands for, in insertion order.\n    entries: Vec<(String, Term)>,\n    /// canonical fully-expanded key -> assigned name (dedup).\n    by_key: HashMap<String, String>,\n    /// prefix -> next counter value.\n    counters: HashMap<String, u32>,\n}\n\nimpl Abbreviator {\n    pub fn new() -> Self {\n        Self::default()\n    }\n\n    /// Register `term` for abbreviation, returning its name. Terms that render\n    /// identically (fully expanded) share one name.\n    pub fn add(&mut self, term: Term) -> String {\n        let key = term.render_full();\n        if let Some(existing) = self.by_key.get(&key) {\n            return existing.clone();\n        }\n        let prefix = prefix_for_symbol(&term.root_symbol_name());\n        let n = self.counters.entry(prefix.clone()).or_insert(0);\n        *n += 1;\n        let name = format!(\"{}{}\", prefix, n);\n        self.by_key.insert(key, name.clone());\n        self.entries.push((name.clone(), term));\n        name\n    }\n\n    /// The name for an already-registered term, if any (by full rendering).\n    pub fn name_of(&self, term: &Term) -> Option<&str> {\n        self.by_key.get(&term.render_full()).map(String::as_str)\n    }\n\n    /// Legend rows `(name, expansion)` in insertion order. Each expansion renders\n    /// the term one level with any registered *sub*-term replaced by its name\n    /// (nesting, §5b: `EX1 = 'g'^MU1`). The expansion string is NOT yet\n    /// HTML-escaped; [`legend_html`] escapes it.\n    pub fn rows(&self) -> Vec<(String, String)> {\n        self.entries\n            .iter()\n            .map(|(name, term)| (name.clone(), term.render_abbrev(&self.by_key)))\n            .collect()\n    }\n\n    /// Render the legend as the exact inner HTML of the `plain` node's label\n    /// (the bytes between `label=<` and `>`). Empty if no entries.\n    pub fn legend_html(&self) -> String {\n        legend_html(&self.rows())\n    }\n\n    pub fn is_empty(&self) -> bool {\n        self.entries.is_empty()\n    }\n    pub fn len(&self) -> usize {\n        self.entries.len()\n    }\n}\n\n/// HTML-escape a legend expansion: `&`→`&amp;`, `<`→`&lt;`, `>`→`&gt;`. Single\n/// quotes and `* ^ ~ $ ⊕ ++` are left literal (as observed).\npub fn escape_expansion(s: &str) -> String {\n    let mut out = String::with_capacity(s.len());\n    for c in s.chars() {\n        match c {\n            '&' => out.push_str(\"&amp;\"),\n            '<' => out.push_str(\"&lt;\"),\n            '>' => out.push_str(\"&gt;\"),\n            _ => out.push(c),\n        }\n    }\n    out\n}\n\n/// Render one legend row's `<TR>…</TR>` (expansion is escaped here).\nfn legend_row(name: &str, expansion: &str) -> String {\n    format!(\n        \"<TR><TD ALIGN=\\\"LEFT\\\" VALIGN=\\\"TOP\\\"><FONT COLOR=\\\"#000000\\\">{}</FONT></TD> <TD ALIGN=\\\"LEFT\\\" VALIGN=\\\"TOP\\\">=</TD> <TD ALIGN=\\\"LEFT\\\" VALIGN=\\\"TOP\\\">{}</TD></TR>\",\n        name,\n        escape_expansion(expansion),\n    )\n}\n\n/// The exact inner HTML for the legend `plain` node (between `label=<` and `>`):\n/// `<TABLE …><TR>row0</TR>\\n<65sp><TR>row1</TR>\\n…<65sp><TR>rowN</TR></TABLE>`.\n/// The first row is inline after the table tag; every continuation row is on its\n/// own line indented by `TABLE_OPEN.len()` (= 65) spaces.\npub fn legend_html(rows: &[(String, String)]) -> String {\n    if rows.is_empty() {\n        return String::new();\n    }\n    let indent = \" \".repeat(TABLE_OPEN.len());\n    let mut s = String::new();\n    s.push_str(TABLE_OPEN);\n    for (i, (name, exp)) in rows.iter().enumerate() {\n        if i > 0 {\n            s.push('\\n');\n            s.push_str(&indent);\n        }\n        s.push_str(&legend_row(name, exp));\n    }\n    s.push_str(\"</TABLE>\");\n    s\n}\n\n/// Minimum fully-expanded rendered length for a sub-term to be abbreviated.\n/// Corpus-exact: the shortest of 97 538 legend expansions is 10 chars, none is 9;\n/// live probe: `'12345678'` (10) is abbreviated, `'1234567'` (9) is not.\npub const MIN_ABBREV_LEN: usize = 10;\n/// Minimum occurrence count for a sub-term to be abbreviated. Live probe: a\n/// 12-char term is abbreviated at 2 occurrences, a 42-char term is NOT at 1.\npub const MIN_ABBREV_OCC: usize = 2;\n\n/// Select which sub-terms of `roots` to abbreviate (BEHAVIOR.md §5c).\n///\n/// **The rule** (each gate confirmed independently by controlled black-box\n/// probes; both necessary gates are corpus-exact with 0 counterexamples over\n/// 97 538 abbreviations): a sub-term `t` is abbreviated **iff**\n///  1. `t.render_len() >= MIN_ABBREV_LEN` (10),\n///  2. `t` occurs `>= MIN_ABBREV_OCC` (2) times across `roots`, and\n///  3. `t` is not a tuple/pair.\n///\n/// Atoms are eligible (a long constant/variable is abbreviated). Selection is\n/// bottom-up (shortest first) so nested eligible sub-terms are named before the\n/// terms that contain them (`LO1='longarg123'` before `H1='h(LO1)'`).\n///\n/// `roots` must be the full multiset of constraint-system terms (graph node-fact\n/// arguments **and** the sequent's terms) — occurrence is a whole-system count,\n/// not a per-drawn-node count. See BEHAVIOR.md §5c for the one documented\n/// residual: for DH-exponentiation / AC-operator (`^ * ⊕ ++`) sub-terms tamarin\n/// counts occurrences over the *normalised* term, which this structural count\n/// does not model, so those may be over- or under-selected.\npub fn select(roots: &[Term]) -> Vec<Term> {\n    select_with(roots, MIN_ABBREV_LEN, MIN_ABBREV_OCC)\n}\n\n/// [`select`] with explicit thresholds (for probing / tests).\npub fn select_with(roots: &[Term], min_len: usize, min_occ: usize) -> Vec<Term> {\n    let mut counts: HashMap<String, (usize, Term)> = HashMap::new();\n    for r in roots {\n        r.for_each_subterm(&mut |t| {\n            if t.is_tuple() || t.render_len() < min_len {\n                return;\n            }\n            let e = counts.entry(t.render_full()).or_insert((0, t.clone()));\n            e.0 += 1;\n        });\n    }\n    let mut picked: Vec<Term> = counts\n        .into_values()\n        .filter(|(c, _)| *c >= min_occ)\n        .map(|(_, t)| t)\n        .collect();\n    // bottom-up: shortest rendering first so inner names are assigned before outer.\n    picked.sort_by(|a, b| {\n        a.render_len().cmp(&b.render_len()).then_with(|| a.render_full().cmp(&b.render_full()))\n    });\n    picked\n}\n","numLines":211,"startLine":1,"totalLines":211}},"sourceToolAssistantUUID":"4546b557-3950-4923-b21f-3430ca534d94","userType":"external","entrypoint":"cli","cwd":"/home/kamilner/tamarin-rs","sessionId":"57f8e1bc-d495-4b36-93c0-033347d5034a","version":"2.1.212","gitBranch":"main"}
{"parentUuid":"dfcedb4d-833b-4216-a71a-70e5447d6403","isSidechain":true,"agentId":"ac1b65c4df499573b","message":{"model":"claude-opus-4-8","id":"msg_011Cd7dkGUGFuZegH2PkXcBH","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01AJcsMAdmfcWMJgWSc926gA","name":"Read","input":{"file_path":"/home/kamilner/tamarin-cleanroom/graphdot/workspace/graph-clean/src/term.rs"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":18127,"cache_read_input_tokens":20468,"cache_creation":{"ephemeral_5m_input_tokens":18127,"ephemeral_1h_input_tokens":0},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Cd7dkEtm3Y9gWdn5UocE4","attributionAgent":"general-purpose","type":"assistant","uuid":"b6975e7a-f586-4b38-aa11-0e6a8f1515a5","timestamp":"2026-07-17T12:32:02.533Z","effort":"xhigh","userType":"external","entrypoint":"cli","cwd":"/home/kamilner/tamarin-rs","sessionId":"57f8e1bc-d495-4b36-93c0-033347d5034a","version":"2.1.212","gitBranch":"main"}
{"parentUuid":"b6975e7a-f586-4b38-aa11-0e6a8f1515a5","isSidechain":true,"promptId":"2961bd88-c930-4506-bcca-f9d40cc278bf","agentId":"ac1b65c4df499573b","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AJcsMAdmfcWMJgWSc926gA","type":"tool_result","content":"1\t//! A minimal term model, sufficient to drive abbreviation (naming + expansion\n2\t//! rendering). It is an independent design; it renders tamarin-like surface\n3\t//! syntax for the common term shapes observed in legend expansions\n4\t//! (variables, constants, pairs, `exp`/`mult`/`union`/`xor`, function apps).\n5\t//!\n6\t//! Faithful reproduction of the solver's full term pretty-printer (all operators,\n7\t//! precedence, line wrapping) is out of scope — see BEHAVIOR.md §3a/§5. The\n8\t//! covered shapes are byte-tested against captured legend rows.\n9\t\n10\tuse std::collections::HashMap;\n11\t\n12\t/// A term. Variable kinds mirror tamarin's surface decorations.\n13\t#[derive(Clone, Debug, PartialEq, Eq)]\n14\tpub enum Term {\n15\t    /// Fresh variable, rendered `~name`.\n16\t    Fresh(String),\n17\t    /// Public variable, rendered `$name`.\n18\t    Pub(String),\n19\t    /// Bare message/temporal variable, rendered `name`.\n20\t    Msg(String),\n21\t    /// Public constant, rendered `'name'`.\n22\t    Const(String),\n23\t    /// Right-nested pair; rendered flattened as `<a, b, c>`.\n24\t    Pair(Box<Term>, Box<Term>),\n25\t    /// `exp(base, e)`, rendered `base^e` (the exponent carries its own parens\n26\t    /// when it is a product/sum).\n27\t    Exp(Box<Term>, Box<Term>),\n28\t    /// An associative-commutative operator rendered infix inside parentheses:\n29\t    /// `mult`→`*`, `union`→`++`, `xor`→`⊕`. `func` is the logical name used for\n30\t    /// the abbreviation prefix.\n31\t    Ac { func: String, op: String, args: Vec<Term> },\n32\t    /// Ordinary prefix application `func(a, b, …)`.\n33\t    App { func: String, args: Vec<Term> },\n34\t}\n35\t\n36\timpl Term {\n37\t    // ---- convenience constructors --------------------------------------\n38\t\n39\t    pub fn fresh(n: &str) -> Term {\n40\t        Term::Fresh(n.to_string())\n41\t    }\n42\t    pub fn pubv(n: &str) -> Term {\n43\t        Term::Pub(n.to_string())\n44\t    }\n45\t    pub fn msg(n: &str) -> Term {\n46\t        Term::Msg(n.to_string())\n47\t    }\n48\t    pub fn cst(n: &str) -> Term {\n49\t        Term::Const(n.to_string())\n50\t    }\n51\t    pub fn app(func: &str, args: Vec<Term>) -> Term {\n52\t        Term::App { func: func.to_string(), args }\n53\t    }\n54\t    pub fn exp(base: Term, e: Term) -> Term {\n55\t        Term::Exp(Box::new(base), Box::new(e))\n56\t    }\n57\t    pub fn mult(args: Vec<Term>) -> Term {\n58\t        Term::Ac { func: \"mult\".into(), op: \"*\".into(), args }\n59\t    }\n60\t    pub fn union(args: Vec<Term>) -> Term {\n61\t        Term::Ac { func: \"union\".into(), op: \"++\".into(), args }\n62\t    }\n63\t    pub fn xor(args: Vec<Term>) -> Term {\n64\t        Term::Ac { func: \"xor\".into(), op: \"\\u{2295}\".into(), args }\n65\t    }\n66\t    /// Build a flattened tuple `<a, b, c>` from ≥1 elements (right-nested pairs).\n67\t    pub fn tuple(mut elems: Vec<Term>) -> Term {\n68\t        let last = elems.pop().expect(\"tuple needs ≥1 element\");\n69\t        elems.into_iter().rev().fold(last, |acc, e| Term::Pair(Box::new(e), Box::new(acc)))\n70\t    }\n71\t\n72\t    // ---- naming --------------------------------------------------------\n73\t\n74\t    /// The root symbol's *name*, whose first two letters give the abbreviation\n75\t    /// prefix (see [`crate::abbrev::prefix_for_symbol`]).\n76\t    pub fn root_symbol_name(&self) -> String {\n77\t        match self {\n78\t            Term::Fresh(n) | Term::Pub(n) | Term::Msg(n) | Term::Const(n) => n.clone(),\n79\t            Term::Pair(..) => \"pair\".to_string(),\n80\t            Term::Exp(..) => \"exp\".to_string(),\n81\t            Term::Ac { func, .. } => func.clone(),\n82\t            Term::App { func, .. } => func.clone(),\n83\t        }\n84\t    }\n85\t\n86\t    /// Leaf terms (variables/constants) are atomic; everything else is not.\n87\t    pub fn is_atomic(&self) -> bool {\n88\t        matches!(self, Term::Fresh(_) | Term::Pub(_) | Term::Msg(_) | Term::Const(_))\n89\t    }\n90\t\n91\t    /// A tuple / pair `<a, b, …>`. Tuples are never abbreviated (BEHAVIOR.md §5c,\n92\t    /// observed: 0 of 97 538 legend entries is a top-level tuple, and a live probe\n93\t    /// left a length-18 tuple occurring twice un-abbreviated).\n94\t    pub fn is_tuple(&self) -> bool {\n95\t        matches!(self, Term::Pair(..))\n96\t    }\n97\t\n98\t    /// Number of Unicode scalar values in the fully-expanded surface rendering —\n99\t    /// the measure that gates abbreviation (BEHAVIOR.md §5c). This counts the\n100\t    /// surface decorations too (`'…'` quotes, `~`/`$` sigils), matching the\n101\t    /// observed boundary (`'12345678'` = 10 chars is abbreviated, `'1234567'` = 9\n102\t    /// is not).\n103\t    pub fn render_len(&self) -> usize {\n104\t        self.render_full().chars().count()\n105\t    }\n106\t\n107\t    /// Number of term nodes (atoms + operators) — a simple complexity measure.\n108\t    pub fn size(&self) -> usize {\n109\t        match self {\n110\t            Term::Fresh(_) | Term::Pub(_) | Term::Msg(_) | Term::Const(_) => 1,\n111\t            Term::Pair(a, b) => 1 + a.size() + b.size(),\n112\t            Term::Exp(a, b) => 1 + a.size() + b.size(),\n113\t            Term::Ac { args, .. } | Term::App { args, .. } => {\n114\t                1 + args.iter().map(Term::size).sum::<usize>()\n115\t            }\n116\t        }\n117\t    }\n118\t\n119\t    /// Visit this term and every sub-term (pre-order).\n120\t    pub fn for_each_subterm(&self, f: &mut dyn FnMut(&Term)) {\n121\t        f(self);\n122\t        match self {\n123\t            Term::Pair(a, b) | Term::Exp(a, b) => {\n124\t                a.for_each_subterm(f);\n125\t                b.for_each_subterm(f);\n126\t            }\n127\t            Term::Ac { args, .. } | Term::App { args, .. } => {\n128\t                for a in args {\n129\t                    a.for_each_subterm(f);\n130\t                }\n131\t            }\n132\t            _ => {}\n133\t        }\n134\t    }\n135\t\n136\t    // ---- rendering -----------------------------------------------------\n137\t\n138\t    /// Fully-expanded surface rendering (no abbreviations). Used as the dedup key.\n139\t    pub fn render_full(&self) -> String {\n140\t        self.render_with(&|t| t.render_full())\n141\t    }\n142\t\n143\t    /// Render this term's expansion, replacing any *registered* sub-term (present\n144\t    /// in `table`, keyed by its full rendering) with its abbreviation name. The\n145\t    /// top-level term itself is always rendered structurally.\n146\t    pub fn render_abbrev(&self, table: &HashMap<String, String>) -> String {\n147\t        self.render_with(&|t| t.substitute(table))\n148\t    }\n149\t\n150\t    /// Rendering used for children during abbreviation: a registered term yields\n151\t    /// its name, otherwise it renders structurally (recursing on its children).\n152\t    fn substitute(&self, table: &HashMap<String, String>) -> String {\n153\t        if let Some(name) = table.get(&self.render_full()) {\n154\t            return name.clone();\n155\t        }\n156\t        self.render_with(&|t| t.substitute(table))\n157\t    }\n158\t\n159\t    /// Structural rendering; `child` renders each immediate sub-term.\n160\t    fn render_with(&self, child: &dyn Fn(&Term) -> String) -> String {\n161\t        match self {\n162\t            Term::Fresh(n) => format!(\"~{}\", n),\n163\t            Term::Pub(n) => format!(\"${}\", n),\n164\t            Term::Msg(n) => n.clone(),\n165\t            Term::Const(n) => format!(\"'{}'\", n),\n166\t            Term::Pair(..) => {\n167\t                let elems = self.pair_spine();\n168\t                let parts: Vec<String> = elems.iter().map(|t| child(t)).collect();\n169\t                format!(\"<{}>\", parts.join(\", \"))\n170\t            }\n171\t            Term::Exp(base, e) => format!(\"{}^{}\", child(base), child(e)),\n172\t            Term::Ac { op, args, .. } => {\n173\t                let parts: Vec<String> = args.iter().map(|t| child(t)).collect();\n174\t                format!(\"({})\", parts.join(op))\n175\t            }\n176\t            Term::App { func, args } => {\n177\t                let parts: Vec<String> = args.iter().map(|t| child(t)).collect();\n178\t                format!(\"{}({})\", func, parts.join(\", \"))\n179\t            }\n180\t        }\n181\t    }\n182\t\n183\t    /// Flatten a right-nested pair into its element spine.\n184\t    fn pair_spine(&self) -> Vec<&Term> {\n185\t        let mut out = Vec::new();\n186\t        let mut cur = self;\n187\t        while let Term::Pair(a, b) = cur {\n188\t            out.push(a.as_ref());\n189\t            cur = b.as_ref();\n190\t        }\n191\t        out.push(cur);\n192\t        out\n193\t    }\n194\t}\n195\t"}]},"uuid":"f578a633-ced9-4605-a0dd-ccf6937579c7","timestamp":"2026-07-17T12:32:02.543Z","toolUseResult":{"type":"text","file":{"filePath":"/home/kamilner/tamarin-cleanroom/graphdot/workspace/graph-clean/src/term.rs","content":"//! A minimal term model, sufficient to drive abbreviation (naming + expansion\n//! rendering). It is an independent design; it renders tamarin-like surface\n//! syntax for the common term shapes observed in legend expansions\n//! (variables, constants, pairs, `exp`/`mult`/`union`/`xor`, function apps).\n//!\n//! Faithful reproduction of the solver's full term pretty-printer (all operators,\n//! precedence, line wrapping) is out of scope — see BEHAVIOR.md §3a/§5. The\n//! covered shapes are byte-tested against captured legend rows.\n\nuse std::collections::HashMap;\n\n/// A term. Variable kinds mirror tamarin's surface decorations.\n#[derive(Clone, Debug, PartialEq, Eq)]\npub enum Term {\n    /// Fresh variable, rendered `~name`.\n    Fresh(String),\n    /// Public variable, rendered `$name`.\n    Pub(String),\n    /// Bare message/temporal variable, rendered `name`.\n    Msg(String),\n    /// Public constant, rendered `'name'`.\n    Const(String),\n    /// Right-nested pair; rendered flattened as `<a, b, c>`.\n    Pair(Box<Term>, Box<Term>),\n    /// `exp(base, e)`, rendered `base^e` (the exponent carries its own parens\n    /// when it is a product/sum).\n    Exp(Box<Term>, Box<Term>),\n    /// An associative-commutative operator rendered infix inside parentheses:\n    /// `mult`→`*`, `union`→`++`, `xor`→`⊕`. `func` is the logical name used for\n    /// the abbreviation prefix.\n    Ac { func: String, op: String, args: Vec<Term> },\n    /// Ordinary prefix application `func(a, b, …)`.\n    App { func: String, args: Vec<Term> },\n}\n\nimpl Term {\n    // ---- convenience constructors --------------------------------------\n\n    pub fn fresh(n: &str) -> Term {\n        Term::Fresh(n.to_string())\n    }\n    pub fn pubv(n: &str) -> Term {\n        Term::Pub(n.to_string())\n    }\n    pub fn msg(n: &str) -> Term {\n        Term::Msg(n.to_string())\n    }\n    pub fn cst(n: &str) -> Term {\n        Term::Const(n.to_string())\n    }\n    pub fn app(func: &str, args: Vec<Term>) -> Term {\n        Term::App { func: func.to_string(), args }\n    }\n    pub fn exp(base: Term, e: Term) -> Term {\n        Term::Exp(Box::new(base), Box::new(e))\n    }\n    pub fn mult(args: Vec<Term>) -> Term {\n        Term::Ac { func: \"mult\".into(), op: \"*\".into(), args }\n    }\n    pub fn union(args: Vec<Term>) -> Term {\n        Term::Ac { func: \"union\".into(), op: \"++\".into(), args }\n    }\n    pub fn xor(args: Vec<Term>) -> Term {\n        Term::Ac { func: \"xor\".into(), op: \"\\u{2295}\".into(), args }\n    }\n    /// Build a flattened tuple `<a, b, c>` from ≥1 elements (right-nested pairs).\n    pub fn tuple(mut elems: Vec<Term>) -> Term {\n        let last = elems.pop().expect(\"tuple needs ≥1 element\");\n        elems.into_iter().rev().fold(last, |acc, e| Term::Pair(Box::new(e), Box::new(acc)))\n    }\n\n    // ---- naming --------------------------------------------------------\n\n    /// The root symbol's *name*, whose first two letters give the abbreviation\n    /// prefix (see [`crate::abbrev::prefix_for_symbol`]).\n    pub fn root_symbol_name(&self) -> String {\n        match self {\n            Term::Fresh(n) | Term::Pub(n) | Term::Msg(n) | Term::Const(n) => n.clone(),\n            Term::Pair(..) => \"pair\".to_string(),\n            Term::Exp(..) => \"exp\".to_string(),\n            Term::Ac { func, .. } => func.clone(),\n            Term::App { func, .. } => func.clone(),\n        }\n    }\n\n    /// Leaf terms (variables/constants) are atomic; everything else is not.\n    pub fn is_atomic(&self) -> bool {\n        matches!(self, Term::Fresh(_) | Term::Pub(_) | Term::Msg(_) | Term::Const(_))\n    }\n\n    /// A tuple / pair `<a, b, …>`. Tuples are never abbreviated (BEHAVIOR.md §5c,\n    /// observed: 0 of 97 538 legend entries is a top-level tuple, and a live probe\n    /// left a length-18 tuple occurring twice un-abbreviated).\n    pub fn is_tuple(&self) -> bool {\n        matches!(self, Term::Pair(..))\n    }\n\n    /// Number of Unicode scalar values in the fully-expanded surface rendering —\n    /// the measure that gates abbreviation (BEHAVIOR.md §5c). This counts the\n    /// surface decorations too (`'…'` quotes, `~`/`$` sigils), matching the\n    /// observed boundary (`'12345678'` = 10 chars is abbreviated, `'1234567'` = 9\n    /// is not).\n    pub fn render_len(&self) -> usize {\n        self.render_full().chars().count()\n    }\n\n    /// Number of term nodes (atoms + operators) — a simple complexity measure.\n    pub fn size(&self) -> usize {\n        match self {\n            Term::Fresh(_) | Term::Pub(_) | Term::Msg(_) | Term::Const(_) => 1,\n            Term::Pair(a, b) => 1 + a.size() + b.size(),\n            Term::Exp(a, b) => 1 + a.size() + b.size(),\n            Term::Ac { args, .. } | Term::App { args, .. } => {\n                1 + args.iter().map(Term::size).sum::<usize>()\n            }\n        }\n    }\n\n    /// Visit this term and every sub-term (pre-order).\n    pub fn for_each_subterm(&self, f: &mut dyn FnMut(&Term)) {\n        f(self);\n        match self {\n            Term::Pair(a, b) | Term::Exp(a, b) => {\n                a.for_each_subterm(f);\n                b.for_each_subterm(f);\n            }\n            Term::Ac { args, .. } | Term::App { args, .. } => {\n                for a in args {\n                    a.for_each_subterm(f);\n                }\n            }\n            _ => {}\n        }\n    }\n\n    // ---- rendering -----------------------------------------------------\n\n    /// Fully-expanded surface rendering (no abbreviations). Used as the dedup key.\n    pub fn render_full(&self) -> String {\n        self.render_with(&|t| t.render_full())\n    }\n\n    /// Render this term's expansion, replacing any *registered* sub-term (present\n    /// in `table`, keyed by its full rendering) with its abbreviation name. The\n    /// top-level term itself is always rendered structurally.\n    pub fn render_abbrev(&self, table: &HashMap<String, String>) -> String {\n        self.render_with(&|t| t.substitute(table))\n    }\n\n    /// Rendering used for children during abbreviation: a registered term yields\n    /// its name, otherwise it renders structurally (recursing on its children).\n    fn substitute(&self, table: &HashMap<String, String>) -> String {\n        if let Some(name) = table.get(&self.render_full()) {\n            return name.clone();\n        }\n        self.render_with(&|t| t.substitute(table))\n    }\n\n    /// Structural rendering; `child` renders each immediate sub-term.\n    fn render_with(&self, child: &dyn Fn(&Term) -> String) -> String {\n        match self {\n            Term::Fresh(n) => format!(\"~{}\", n),\n            Term::Pub(n) => format!(\"${}\", n),\n            Term::Msg(n) => n.clone(),\n            Term::Const(n) => format!(\"'{}'\", n),\n            Term::Pair(..) => {\n                let elems = self.pair_spine();\n                let parts: Vec<String> = elems.iter().map(|t| child(t)).collect();\n                format!(\"<{}>\", parts.join(\", \"))\n            }\n            Term::Exp(base, e) => format!(\"{}^{}\", child(base), child(e)),\n            Term::Ac { op, args, .. } => {\n                let parts: Vec<String> = args.iter().map(|t| child(t)).collect();\n                format!(\"({})\", parts.join(op))\n            }\n            Term::App { func, args } => {\n                let parts: Vec<String> = args.iter().map(|t| child(t)).collect();\n                format!(\"{}({})\", func, parts.join(\", \"))\n            }\n        }\n    }\n\n    /// Flatten a right-nested pair into its element spine.\n    fn pair_spine(&self) -> Vec<&Term> {\n        let mut out = Vec::new();\n        let mut cur = self;\n        while let Term::Pair(a, b) = cur {\n            out.push(a.as_ref());\n            cur = b.as_ref();\n        }\n        out.push(cur);\n        out\n    }\n}\n","numLines":195,"startLine":1,"totalLines":195}},"sourceToolAssistantUUID":"b6975e7a-f586-4b38-aa11-0e6a8f1515a5","userType":"external","entrypoint":"cli","cwd":"/home/kamilner/tamarin-rs","sessionId":"57f8e1bc-d495-4b36-93c0-033347d5034a","version":"2.1.212","gitBranch":"main"}
{"parentUuid":"f578a633-ced9-4605-a0dd-ccf6937579c7","isSidechain":true,"agentId":"ac1b65c4df499573b","message":{"model":"claude-opus-4-8","id":"msg_011Cd7dkGUGFuZegH2PkXcBH","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_0142LeZXz4qmZSkzVtahNfcU","name":"Read","input":{"file_path":"/home/kamilner/tamarin-cleanroom/graphdot/workspace/graph-clean/tests/abbrev_tests.rs"},"caller":{"type":"direct"}}],"stop_reason":"tool_use","stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":18127,"cache_read_input_tokens":20468,"output_tokens":410,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":18127},"inference_geo":"not_available","iterations":[{"input_tokens":2,"output_tokens":410,"cache_read_input_tokens":20468,"cache_creation_input_tokens":18127,"cache_creation":{"ephemeral_5m_input_tokens":18127,"ephemeral_1h_input_tokens":0},"type":"message"}],"speed":"standard"},"diagnostics":null},"requestId":"req_011Cd7dkEtm3Y9gWdn5UocE4","attributionAgent":"general-purpose","type":"assistant","uuid":"20948345-37df-44f2-88d5-0dd98b04a1a4","timestamp":"2026-07-17T12:32:03.082Z","effort":"xhigh","userType":"external","entrypoint":"cli","cwd":"/home/kamilner/tamarin-rs","sessionId":"57f8e1bc-d495-4b36-93c0-033347d5034a","version":"2.1.212","gitBranch":"main"}
{"parentUuid":"20948345-37df-44f2-88d5-0dd98b04a1a4","isSidechain":true,"promptId":"2961bd88-c930-4506-bcca-f9d40cc278bf","agentId":"ac1b65c4df499573b","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0142LeZXz4qmZSkzVtahNfcU","type":"tool_result","content":"1\t//! Abbreviation + clustering tests, grounded in observed payloads\n2\t//! (BEHAVIOR.md §4, §5).\n3\t\n4\tuse graph_clean::abbrev::{\n5\t    legend_html, prefix_for_symbol, select, select_with, Abbreviator, TABLE_OPEN,\n6\t};\n7\tuse graph_clean::model::*;\n8\tuse graph_clean::term::Term;\n9\t\n10\t/// Render the terms `select` picks, as `render_full` strings, for assertions.\n11\tfn picked(roots: &[Term]) -> Vec<String> {\n12\t    select(roots).iter().map(Term::render_full).collect()\n13\t}\n14\t\n15\t/// Extract the inner HTML of the first `plain` legend node (bytes between\n16\t/// `label=<` and `>];`).\n17\tfn legend_inner(dot: &str) -> String {\n18\t    let anchor = dot.find(\"shape=\\\"plain\\\",label=<\").unwrap();\n19\t    let start = anchor + dot[anchor..].find(\"label=<\").unwrap() + \"label=<\".len();\n20\t    let end = start + dot[start..].find(\">];\").unwrap();\n21\t    dot[start..end].to_string()\n22\t}\n23\t\n24\t#[test]\n25\tfn table_open_tag_is_65_bytes() {\n26\t    // The legend hang-indent equals this tag's byte length (BEHAVIOR.md §5a).\n27\t    assert_eq!(TABLE_OPEN.len(), 65);\n28\t}\n29\t\n30\t#[test]\n31\tfn prefix_rule_matches_observed_names() {\n32\t    // (root symbol name, observed prefix) pairs taken from the corpus legend.\n33\t    let cases = [\n34\t        (\"sign\", \"SI\"),\n35\t        (\"senc\", \"SE\"),\n36\t        (\"second\", \"SE\"),\n37\t        (\"hash\", \"HA\"),\n38\t        (\"h\", \"H\"),\n39\t        (\"h2\", \"H\"),\n40\t        (\"KDF\", \"KD\"),\n41\t        (\"kdf1\", \"KD\"),\n42\t        (\"pk\", \"PK\"),\n43\t        (\"aenc\", \"AE\"),\n44\t        (\"aead\", \"AE\"),\n45\t        (\"adec\", \"AD\"),\n46\t        (\"pmult\", \"PM\"),\n47\t        (\"plus\", \"PL\"),\n48\t        (\"pdec\", \"PD\"),\n49\t        (\"inv\", \"IN\"),\n50\t        (\"mac\", \"MA\"),\n51\t        (\"blind\", \"BL\"),\n52\t        (\"idsign\", \"ID\"),\n53\t        // operator function names\n54\t        (\"exp\", \"EX\"),\n55\t        (\"mult\", \"MU\"),\n56\t        (\"union\", \"UN\"),\n57\t        (\"xor\", \"XO\"),\n58\t        // constants (unquoted names), non-letters skipped\n59\t        (\"uninitialized\", \"UN\"),\n60\t        (\"F_status\", \"FS\"),\n61\t        (\"ho_req_ack\", \"HO\"),\n62\t        (\"no_message_state\", \"NO\"),\n63\t        (\"K_gNB_star\", \"KG\"),\n64\t        // variables (undecorated names)\n65\t        (\"AMF_UE_NGAP_ID\", \"AM\"),\n66\t        (\"cid_N26\", \"CI\"),\n67\t        (\"gNB_UE_ID\", \"GN\"),\n68\t        (\"commitmsg\", \"CO\"),\n69\t        (\"StateChannel\", \"ST\"),\n70\t    ];\n71\t    for (name, expect) in cases {\n72\t        assert_eq!(prefix_for_symbol(name), expect, \"prefix for {name:?}\");\n73\t    }\n74\t}\n75\t\n76\t#[test]\n77\tfn operator_terms_report_function_name_for_prefix() {\n78\t    assert_eq!(Term::mult(vec![Term::msg(\"a\")]).root_symbol_name(), \"mult\");\n79\t    assert_eq!(Term::union(vec![Term::msg(\"a\")]).root_symbol_name(), \"union\");\n80\t    assert_eq!(Term::xor(vec![Term::msg(\"a\")]).root_symbol_name(), \"xor\");\n81\t    assert_eq!(Term::exp(Term::cst(\"g\"), Term::msg(\"a\")).root_symbol_name(), \"exp\");\n82\t    assert_eq!(prefix_for_symbol(&Term::mult(vec![]).root_symbol_name()), \"MU\");\n83\t}\n84\t\n85\t#[test]\n86\tfn term_renders_observed_surface_syntax() {\n87\t    // H2 = h(<$I.1, $R.1, X, 'g'^~ekR, z, 'g'^(~lkR.1*~x.2)>)   (from multi_abbrev)\n88\t    let h2 = Term::app(\n89\t        \"h\",\n90\t        vec![Term::tuple(vec![\n91\t            Term::pubv(\"I.1\"),\n92\t            Term::pubv(\"R.1\"),\n93\t            Term::msg(\"X\"),\n94\t            Term::exp(Term::cst(\"g\"), Term::fresh(\"ekR\")),\n95\t            Term::msg(\"z\"),\n96\t            Term::exp(Term::cst(\"g\"), Term::mult(vec![Term::fresh(\"lkR.1\"), Term::fresh(\"x.2\")])),\n97\t        ])],\n98\t    );\n99\t    assert_eq!(\n100\t        h2.render_full(),\n101\t        \"h(<$I.1, $R.1, X, 'g'^~ekR, z, 'g'^(~lkR.1*~x.2)>)\"\n102\t    );\n103\t    // (~ekR*x*~ekR.1)\n104\t    assert_eq!(\n105\t        Term::mult(vec![Term::fresh(\"ekR\"), Term::msg(\"x\"), Term::fresh(\"ekR.1\")]).render_full(),\n106\t        \"(~ekR*x*~ekR.1)\"\n107\t    );\n108\t    // ('1'++'1'++z)\n109\t    assert_eq!(\n110\t        Term::union(vec![Term::cst(\"1\"), Term::cst(\"1\"), Term::msg(\"z\")]).render_full(),\n111\t        \"('1'++'1'++z)\"\n112\t    );\n113\t}\n114\t\n115\t#[test]\n116\tfn abbreviator_numbers_and_nests() {\n117\t    // Register MU1 first, then EX1 = 'g'^MU1 must reference it (nesting, §5b).\n118\t    let mut ab = Abbreviator::new();\n119\t    let mu = Term::mult(vec![Term::fresh(\"ekR\"), Term::msg(\"x\"), Term::fresh(\"ekR.1\")]);\n120\t    let ex = Term::exp(Term::cst(\"g\"), mu.clone());\n121\t    assert_eq!(ab.add(mu), \"MU1\");\n122\t    assert_eq!(ab.add(ex), \"EX1\");\n123\t    // second, structurally-identical mult dedups to MU1 (no MU2).\n124\t    let mu2 = Term::mult(vec![Term::fresh(\"ekR\"), Term::msg(\"x\"), Term::fresh(\"ekR.1\")]);\n125\t    assert_eq!(ab.add(mu2), \"MU1\");\n126\t    let rows = ab.rows();\n127\t    assert_eq!(rows, vec![\n128\t        (\"MU1\".to_string(), \"(~ekR*x*~ekR.1)\".to_string()),\n129\t        (\"EX1\".to_string(), \"'g'^MU1\".to_string()),\n130\t    ]);\n131\t}\n132\t\n133\t#[test]\n134\tfn per_prefix_counter_increments() {\n135\t    let mut ab = Abbreviator::new();\n136\t    assert_eq!(ab.add(Term::app(\"sign\", vec![Term::fresh(\"a\")])), \"SI1\");\n137\t    assert_eq!(ab.add(Term::app(\"sign\", vec![Term::fresh(\"b\")])), \"SI2\");\n138\t    assert_eq!(ab.add(Term::app(\"senc\", vec![Term::fresh(\"c\")])), \"SE1\");\n139\t    assert_eq!(ab.add(Term::app(\"sign\", vec![Term::fresh(\"d\")])), \"SI3\");\n140\t}\n141\t\n142\t#[test]\n143\tfn legend_html_single_row_matches_fixture() {\n144\t    let dot = include_str!(\"fixtures/simple_abbrev.dot\");\n145\t    let expected = legend_inner(dot);\n146\t    // SI1 = sign(<'2', $I, $R, hki, 'g'^~ekR>, ~ltkI)   (raw; legend escapes < >)\n147\t    let rows = vec![(\n148\t        \"SI1\".to_string(),\n149\t        \"sign(<'2', $I, $R, hki, 'g'^~ekR>, ~ltkI)\".to_string(),\n150\t    )];\n151\t    assert_eq!(legend_html(&rows), expected);\n152\t}\n153\t\n154\t#[test]\n155\tfn legend_html_multi_row_matches_fixture() {\n156\t    let dot = include_str!(\"fixtures/multi_abbrev.dot\");\n157\t    let expected = legend_inner(dot);\n158\t    // Rows in the fixture's order (order itself is a documented gap, §5b);\n159\t    // this asserts the RENDERING is byte-exact: escaping + 65-space hang indent.\n160\t    let rows: Vec<(String, String)> = [\n161\t        (\"EX2\", \"'g'^(~ekR*x)\"),\n162\t        (\"EX3\", \"'g'^~ekR.1\"),\n163\t        (\"EX4\", \"'g'^~lkR.1\"),\n164\t        (\"H2\", \"h(<$I.1, $R.1, X, 'g'^~ekR, z, 'g'^(~lkR.1*~x.2)>)\"),\n165\t        (\"MU1\", \"(~ekR*x*~ekR.1)\"),\n166\t        (\"EX1\", \"'g'^MU1\"),\n167\t        (\"H1\", \"h(<$I, $R, EX2, EX3, EX1, 'g'^(~lkR*~x.1)>)\"),\n168\t        (\"MU2\", \"(x*~ekR.1)\"),\n169\t    ]\n170\t    .iter()\n171\t    .map(|(a, b)| (a.to_string(), b.to_string()))\n172\t    .collect();\n173\t    assert_eq!(legend_html(&rows), expected);\n174\t}\n175\t\n176\t#[test]\n177\tfn legend_via_terms_and_abbreviator_matches_fixture() {\n178\t    // Reproduce the simple_abbrev legend end-to-end from a Term model + the\n179\t    // Abbreviator (naming + rendering), not from a hand-written row list.\n180\t    let dot = include_str!(\"fixtures/simple_abbrev.dot\");\n181\t    let expected = legend_inner(dot);\n182\t    let si = Term::app(\n183\t        \"sign\",\n184\t        vec![\n185\t            Term::tuple(vec![\n186\t                Term::cst(\"2\"),\n187\t                Term::pubv(\"I\"),\n188\t                Term::pubv(\"R\"),\n189\t                Term::msg(\"hki\"),\n190\t                Term::exp(Term::cst(\"g\"), Term::fresh(\"ekR\")),\n191\t            ]),\n192\t            Term::fresh(\"ltkI\"),\n193\t        ],\n194\t    );\n195\t    let mut ab = Abbreviator::new();\n196\t    assert_eq!(ab.add(si), \"SI1\");\n197\t    assert_eq!(ab.legend_html(), expected);\n198\t}\n199\t\n200\t#[test]\n201\tfn cluster_trigger_follows_role() {\n202\t    // role=\"Undefined\" everywhere -> Simple.\n203\t    let mut g = Graph::new(Header::Compact);\n204\t    g.push(Stmt::Node(Node::record(\n205\t        \"n5\",\n206\t        Record {\n207\t            columns: vec![vec![Cell::new(\"n0\", \"Fr( ~x )\")]],\n208\t            fillcolor: \"#d5d897\".into(),\n209\t            fontcolor: \"black\".into(),\n210\t            role: Role::undefined(),\n211\t        },\n212\t    )));\n213\t    assert_eq!(g.infer_header(), Header::Simple);\n214\t\n215\t    // a defined role anywhere -> Compact.\n216\t    g.push(Stmt::Cluster(Cluster {\n217\t        label: \"Initiator_Session_1\".into(),\n218\t        color: \"#4936D84C\".into(),\n219\t        body: vec![Stmt::Node(Node::record(\n220\t            \"n7\",\n221\t            Record {\n222\t                columns: vec![vec![Cell::new(\"n4\", \"State( ~k )\")]],\n223\t                fillcolor: \"#80404f\".into(),\n224\t                fontcolor: \"white\".into(),\n225\t                role: Role(\"Initiator\".into()),\n226\t            },\n227\t        ))],\n228\t    }));\n229\t    assert_eq!(g.infer_header(), Header::Compact);\n230\t}\n231\t\n232\t// ---------------------------------------------------------------------------\n233\t// Selection rule (BEHAVIOR.md §5c). Each test mirrors a controlled black-box\n234\t// probe of the server (see QUERIES.log): a crafted rule whose one graph node\n235\t// carries specific terms, so which term is abbreviated is directly observed.\n236\t// ---------------------------------------------------------------------------\n237\t\n238\t#[test]\n239\tfn select_length_boundary_is_ten() {\n240\t    // Probe: Keep(~x, '12345678', '12345678', '1234567', '1234567')\n241\t    //   => '12345678' (len 10, x2) abbreviated; '1234567' (len 9, x2) not.\n242\t    let c10 = Term::cst(\"12345678\"); // renders '12345678' == 10 chars\n243\t    let c9 = Term::cst(\"1234567\"); //  renders '1234567'  ==  9 chars\n244\t    assert_eq!(c10.render_len(), 10);\n245\t    assert_eq!(c9.render_len(), 9);\n246\t    let roots = vec![c10.clone(), c10.clone(), c9.clone(), c9.clone()];\n247\t    let got = picked(&roots);\n248\t    assert_eq!(got, vec![\"'12345678'\".to_string()]); // only the 10-char one\n249\t}\n250\t\n251\t#[test]\n252\tfn select_requires_two_occurrences_even_for_long_terms() {\n253\t    // Probe: 'aaaa…aaaa' (42 chars, x1) NOT abbreviated; 'shared1234' (12, x2) is.\n254\t    let long_once = Term::cst(&\"a\".repeat(40)); // renders with quotes == 42 chars\n255\t    let shared = Term::cst(\"shared1234\");\n256\t    assert!(long_once.render_len() > 10);\n257\t    let roots = vec![long_once, shared.clone(), shared.clone()];\n258\t    assert_eq!(picked(&roots), vec![\"'shared1234'\".to_string()]);\n259\t}\n260\t\n261\t#[test]\n262\tfn select_never_abbreviates_a_tuple() {\n263\t    // Probe: Keep(~x, <'aa','bb','cc'>, <'aa','bb','cc'>, h('longarg123'), h('longarg123'))\n264\t    //   => the length-18 tuple (x2) is NOT abbreviated; h('longarg123') and its\n265\t    //   inner 'longarg123' ARE (bottom-up nesting).\n266\t    let tup = Term::tuple(vec![Term::cst(\"aa\"), Term::cst(\"bb\"), Term::cst(\"cc\")]);\n267\t    assert!(tup.render_len() >= 10 && tup.is_tuple());\n268\t    let h = Term::app(\"h\", vec![Term::cst(\"longarg123\")]);\n269\t    let roots = vec![tup.clone(), tup.clone(), h.clone(), h.clone()];\n270\t    let got = picked(&roots);\n271\t    // tuple excluded; both h(...) and the nested 'longarg123' selected (bottom-up\n272\t    // => shorter 'longarg123' before h('longarg123')).\n273\t    assert_eq!(\n274\t        got,\n275\t        vec![\"'longarg123'\".to_string(), \"h('longarg123')\".to_string()]\n276\t    );\n277\t    assert!(!got.iter().any(|s| s.starts_with('<')), \"no tuple abbreviated\");\n278\t}\n279\t\n280\t#[test]\n281\tfn select_then_name_reproduces_probe_legend() {\n282\t    // End-to-end: feed the tuple probe's terms through select + Abbreviator and\n283\t    // reproduce the observed legend rows  LO1='longarg123' ; H1='h(LO1)'.\n284\t    let tup = Term::tuple(vec![Term::cst(\"aa\"), Term::cst(\"bb\"), Term::cst(\"cc\")]);\n285\t    let h = Term::app(\"h\", vec![Term::cst(\"longarg123\")]);\n286\t    let roots = vec![tup.clone(), tup, h.clone(), h];\n287\t    let mut ab = Abbreviator::new();\n288\t    for t in select(&roots) {\n289\t        ab.add(t);\n290\t    }\n291\t    assert_eq!(\n292\t        ab.rows(),\n293\t        vec![\n294\t            (\"LO1\".to_string(), \"'longarg123'\".to_string()),\n295\t            (\"H1\".to_string(), \"h(LO1)\".to_string()),\n296\t        ]\n297\t    );\n298\t}\n299\t\n300\t#[test]\n301\tfn select_counts_nested_occurrences() {\n302\t    // A long atom that appears only *inside* two copies of an outer term still\n303\t    // reaches occurrence 2 and is abbreviated (nested counting).\n304\t    let inner = Term::cst(\"longarg123\"); // len 12\n305\t    let outer = Term::app(\"h\", vec![inner.clone()]);\n306\t    let roots = vec![outer.clone(), outer]; // inner occurs twice, only nested\n307\t    let got = picked(&roots);\n308\t    assert!(got.contains(&\"'longarg123'\".to_string()));\n309\t    assert!(got.contains(&\"h('longarg123')\".to_string()));\n310\t}\n311\t\n312\t#[test]\n313\tfn select_with_custom_thresholds() {\n314\t    // The thresholds are parameterisable for probing.\n315\t    let t = Term::cst(\"abcdef\"); // len 8\n316\t    let roots = vec![t.clone(), t.clone()];\n317\t    assert!(select(&roots).is_empty()); // 8 < 10 default\n318\t    assert_eq!(select_with(&roots, 8, 2).len(), 1); // lowered length gate\n319\t    assert!(select_with(&roots, 8, 3).is_empty()); // raised occ gate\n320\t}\n321\t"}]},"uuid":"e68c20ab-c1b1-4ed2-ae20-ff9cb94e69f0","timestamp":"2026-07-17T12:32:03.102Z","toolUseResult":{"type":"text","file":{"filePath":"/home/kamilner/tamarin-cleanroom/graphdot/workspace/graph-clean/tests/abbrev_tests.rs","content":"//! Abbreviation + clustering tests, grounded in observed payloads\n//! (BEHAVIOR.md §4, §5).\n\nuse graph_clean::abbrev::{\n    legend_html, prefix_for_symbol, select, select_with, Abbreviator, TABLE_OPEN,\n};\nuse graph_clean::model::*;\nuse graph_clean::term::Term;\n\n/// Render the terms `select` picks, as `render_full` strings, for assertions.\nfn picked(roots: &[Term]) -> Vec<String> {\n    select(roots).iter().map(Term::render_full).collect()\n}\n\n/// Extract the inner HTML of the first `plain` legend node (bytes between\n/// `label=<` and `>];`).\nfn legend_inner(dot: &str) -> String {\n    let anchor = dot.find(\"shape=\\\"plain\\\",label=<\").unwrap();\n    let start = anchor + dot[anchor..].find(\"label=<\").unwrap() + \"label=<\".len();\n    let end = start + dot[start..].find(\">];\").unwrap();\n    dot[start..end].to_string()\n}\n\n#[test]\nfn table_open_tag_is_65_bytes() {\n    // The legend hang-indent equals this tag's byte length (BEHAVIOR.md §5a).\n    assert_eq!(TABLE_OPEN.len(), 65);\n}\n\n#[test]\nfn prefix_rule_matches_observed_names() {\n    // (root symbol name, observed prefix) pairs taken from the corpus legend.\n    let cases = [\n        (\"sign\", \"SI\"),\n        (\"senc\", \"SE\"),\n        (\"second\", \"SE\"),\n        (\"hash\", \"HA\"),\n        (\"h\", \"H\"),\n        (\"h2\", \"H\"),\n        (\"KDF\", \"KD\"),\n        (\"kdf1\", \"KD\"),\n        (\"pk\", \"PK\"),\n        (\"aenc\", \"AE\"),\n        (\"aead\", \"AE\"),\n        (\"adec\", \"AD\"),\n        (\"pmult\", \"PM\"),\n        (\"plus\", \"PL\"),\n        (\"pdec\", \"PD\"),\n        (\"inv\", \"IN\"),\n        (\"mac\", \"MA\"),\n        (\"blind\", \"BL\"),\n        (\"idsign\", \"ID\"),\n        // operator function names\n        (\"exp\", \"EX\"),\n        (\"mult\", \"MU\"),\n        (\"union\", \"UN\"),\n        (\"xor\", \"XO\"),\n        // constants (unquoted names), non-letters skipped\n        (\"uninitialized\", \"UN\"),\n        (\"F_status\", \"FS\"),\n        (\"ho_req_ack\", \"HO\"),\n        (\"no_message_state\", \"NO\"),\n        (\"K_gNB_star\", \"KG\"),\n        // variables (undecorated names)\n        (\"AMF_UE_NGAP_ID\", \"AM\"),\n        (\"cid_N26\", \"CI\"),\n        (\"gNB_UE_ID\", \"GN\"),\n        (\"commitmsg\", \"CO\"),\n        (\"StateChannel\", \"ST\"),\n    ];\n    for (name, expect) in cases {\n        assert_eq!(prefix_for_symbol(name), expect, \"prefix for {name:?}\");\n    }\n}\n\n#[test]\nfn operator_terms_report_function_name_for_prefix() {\n    assert_eq!(Term::mult(vec![Term::msg(\"a\")]).root_symbol_name(), \"mult\");\n    assert_eq!(Term::union(vec![Term::msg(\"a\")]).root_symbol_name(), \"union\");\n    assert_eq!(Term::xor(vec![Term::msg(\"a\")]).root_symbol_name(), \"xor\");\n    assert_eq!(Term::exp(Term::cst(\"g\"), Term::msg(\"a\")).root_symbol_name(), \"exp\");\n    assert_eq!(prefix_for_symbol(&Term::mult(vec![]).root_symbol_name()), \"MU\");\n}\n\n#[test]\nfn term_renders_observed_surface_syntax() {\n    // H2 = h(<$I.1, $R.1, X, 'g'^~ekR, z, 'g'^(~lkR.1*~x.2)>)   (from multi_abbrev)\n    let h2 = Term::app(\n        \"h\",\n        vec![Term::tuple(vec![\n            Term::pubv(\"I.1\"),\n            Term::pubv(\"R.1\"),\n            Term::msg(\"X\"),\n            Term::exp(Term::cst(\"g\"), Term::fresh(\"ekR\")),\n            Term::msg(\"z\"),\n            Term::exp(Term::cst(\"g\"), Term::mult(vec![Term::fresh(\"lkR.1\"), Term::fresh(\"x.2\")])),\n        ])],\n    );\n    assert_eq!(\n        h2.render_full(),\n        \"h(<$I.1, $R.1, X, 'g'^~ekR, z, 'g'^(~lkR.1*~x.2)>)\"\n    );\n    // (~ekR*x*~ekR.1)\n    assert_eq!(\n        Term::mult(vec![Term::fresh(\"ekR\"), Term::msg(\"x\"), Term::fresh(\"ekR.1\")]).render_full(),\n        \"(~ekR*x*~ekR.1)\"\n    );\n    // ('1'++'1'++z)\n    assert_eq!(\n        Term::union(vec![Term::cst(\"1\"), Term::cst(\"1\"), Term::msg(\"z\")]).render_full(),\n        \"('1'++'1'++z)\"\n    );\n}\n\n#[test]\nfn abbreviator_numbers_and_nests() {\n    // Register MU1 first, then EX1 = 'g'^MU1 must reference it (nesting, §5b).\n    let mut ab = Abbreviator::new();\n    let mu = Term::mult(vec![Term::fresh(\"ekR\"), Term::msg(\"x\"), Term::fresh(\"ekR.1\")]);\n    let ex = Term::exp(Term::cst(\"g\"), mu.clone());\n    assert_eq!(ab.add(mu), \"MU1\");\n    assert_eq!(ab.add(ex), \"EX1\");\n    // second, structurally-identical mult dedups to MU1 (no MU2).\n    let mu2 = Term::mult(vec![Term::fresh(\"ekR\"), Term::msg(\"x\"), Term::fresh(\"ekR.1\")]);\n    assert_eq!(ab.add(mu2), \"MU1\");\n    let rows = ab.rows();\n    assert_eq!(rows, vec![\n        (\"MU1\".to_string(), \"(~ekR*x*~ekR.1)\".to_string()),\n        (\"EX1\".to_string(), \"'g'^MU1\".to_string()),\n    ]);\n}\n\n#[test]\nfn per_prefix_counter_increments() {\n    let mut ab = Abbreviator::new();\n    assert_eq!(ab.add(Term::app(\"sign\", vec![Term::fresh(\"a\")])), \"SI1\");\n    assert_eq!(ab.add(Term::app(\"sign\", vec![Term::fresh(\"b\")])), \"SI2\");\n    assert_eq!(ab.add(Term::app(\"senc\", vec![Term::fresh(\"c\")])), \"SE1\");\n    assert_eq!(ab.add(Term::app(\"sign\", vec![Term::fresh(\"d\")])), \"SI3\");\n}\n\n#[test]\nfn legend_html_single_row_matches_fixture() {\n    let dot = include_str!(\"fixtures/simple_abbrev.dot\");\n    let expected = legend_inner(dot);\n    // SI1 = sign(<'2', $I, $R, hki, 'g'^~ekR>, ~ltkI)   (raw; legend escapes < >)\n    let rows = vec![(\n        \"SI1\".to_string(),\n        \"sign(<'2', $I, $R, hki, 'g'^~ekR>, ~ltkI)\".to_string(),\n    )];\n    assert_eq!(legend_html(&rows), expected);\n}\n\n#[test]\nfn legend_html_multi_row_matches_fixture() {\n    let dot = include_str!(\"fixtures/multi_abbrev.dot\");\n    let expected = legend_inner(dot);\n    // Rows in the fixture's order (order itself is a documented gap, §5b);\n    // this asserts the RENDERING is byte-exact: escaping + 65-space hang indent.\n    let rows: Vec<(String, String)> = [\n        (\"EX2\", \"'g'^(~ekR*x)\"),\n        (\"EX3\", \"'g'^~ekR.1\"),\n        (\"EX4\", \"'g'^~lkR.1\"),\n        (\"H2\", \"h(<$I.1, $R.1, X, 'g'^~ekR, z, 'g'^(~lkR.1*~x.2)>)\"),\n        (\"MU1\", \"(~ekR*x*~ekR.1)\"),\n        (\"EX1\", \"'g'^MU1\"),\n        (\"H1\", \"h(<$I, $R, EX2, EX3, EX1, 'g'^(~lkR*~x.1)>)\"),\n        (\"MU2\", \"(x*~ekR.1)\"),\n    ]\n    .iter()\n    .map(|(a, b)| (a.to_string(), b.to_string()))\n    .collect();\n    assert_eq!(legend_html(&rows), expected);\n}\n\n#[test]\nfn legend_via_terms_and_abbreviator_matches_fixture() {\n    // Reproduce the simple_abbrev legend end-to-end from a Term model + the\n    // Abbreviator (naming + rendering), not from a hand-written row list.\n    let dot = include_str!(\"fixtures/simple_abbrev.dot\");\n    let expected = legend_inner(dot);\n    let si = Term::app(\n        \"sign\",\n        vec![\n            Term::tuple(vec![\n                Term::cst(\"2\"),\n                Term::pubv(\"I\"),\n                Term::pubv(\"R\"),\n                Term::msg(\"hki\"),\n                Term::exp(Term::cst(\"g\"), Term::fresh(\"ekR\")),\n            ]),\n            Term::fresh(\"ltkI\"),\n        ],\n    );\n    let mut ab = Abbreviator::new();\n    assert_eq!(ab.add(si), \"SI1\");\n    assert_eq!(ab.legend_html(), expected);\n}\n\n#[test]\nfn cluster_trigger_follows_role() {\n    // role=\"Undefined\" everywhere -> Simple.\n    let mut g = Graph::new(Header::Compact);\n    g.push(Stmt::Node(Node::record(\n        \"n5\",\n        Record {\n            columns: vec![vec![Cell::new(\"n0\", \"Fr( ~x )\")]],\n            fillcolor: \"#d5d897\".into(),\n            fontcolor: \"black\".into(),\n            role: Role::undefined(),\n        },\n    )));\n    assert_eq!(g.infer_header(), Header::Simple);\n\n    // a defined role anywhere -> Compact.\n    g.push(Stmt::Cluster(Cluster {\n        label: \"Initiator_Session_1\".into(),\n        color: \"#4936D84C\".into(),\n        body: vec![Stmt::Node(Node::record(\n            \"n7\",\n            Record {\n                columns: vec![vec![Cell::new(\"n4\", \"State( ~k )\")]],\n                fillcolor: \"#80404f\".into(),\n                fontcolor: \"white\".into(),\n                role: Role(\"Initiator\".into()),\n            },\n        ))],\n    }));\n    assert_eq!(g.infer_header(), Header::Compact);\n}\n\n// ---------------------------------------------------------------------------\n// Selection rule (BEHAVIOR.md §5c). Each test mirrors a controlled black-box\n// probe of the server (see QUERIES.log): a crafted rule whose one graph node\n// carries specific terms, so which term is abbreviated is directly observed.\n// ---------------------------------------------------------------------------\n\n#[test]\nfn select_length_boundary_is_ten() {\n    // Probe: Keep(~x, '12345678', '12345678', '1234567', '1234567')\n    //   => '12345678' (len 10, x2) abbreviated; '1234567' (len 9, x2) not.\n    let c10 = Term::cst(\"12345678\"); // renders '12345678' == 10 chars\n    let c9 = Term::cst(\"1234567\"); //  renders '1234567'  ==  9 chars\n    assert_eq!(c10.render_len(), 10);\n    assert_eq!(c9.render_len(), 9);\n    let roots = vec![c10.clone(), c10.clone(), c9.clone(), c9.clone()];\n    let got = picked(&roots);\n    assert_eq!(got, vec![\"'12345678'\".to_string()]); // only the 10-char one\n}\n\n#[test]\nfn select_requires_two_occurrences_even_for_long_terms() {\n    // Probe: 'aaaa…aaaa' (42 chars, x1) NOT abbreviated; 'shared1234' (12, x2) is.\n    let long_once = Term::cst(&\"a\".repeat(40)); // renders with quotes == 42 chars\n    let shared = Term::cst(\"shared1234\");\n    assert!(long_once.render_len() > 10);\n    let roots = vec![long_once, shared.clone(), shared.clone()];\n    assert_eq!(picked(&roots), vec![\"'shared1234'\".to_string()]);\n}\n\n#[test]\nfn select_never_abbreviates_a_tuple() {\n    // Probe: Keep(~x, <'aa','bb','cc'>, <'aa','bb','cc'>, h('longarg123'), h('longarg123'))\n    //   => the length-18 tuple (x2) is NOT abbreviated; h('longarg123') and its\n    //   inner 'longarg123' ARE (bottom-up nesting).\n    let tup = Term::tuple(vec![Term::cst(\"aa\"), Term::cst(\"bb\"), Term::cst(\"cc\")]);\n    assert!(tup.render_len() >= 10 && tup.is_tuple());\n    let h = Term::app(\"h\", vec![Term::cst(\"longarg123\")]);\n    let roots = vec![tup.clone(), tup.clone(), h.clone(), h.clone()];\n    let got = picked(&roots);\n    // tuple excluded; both h(...) and the nested 'longarg123' selected (bottom-up\n    // => shorter 'longarg123' before h('longarg123')).\n    assert_eq!(\n        got,\n        vec![\"'longarg123'\".to_string(), \"h('longarg123')\".to_string()]\n    );\n    assert!(!got.iter().any(|s| s.starts_with('<')), \"no tuple abbreviated\");\n}\n\n#[test]\nfn select_then_name_reproduces_probe_legend() {\n    // End-to-end: feed the tuple probe's terms through select + Abbreviator and\n    // reproduce the observed legend rows  LO1='longarg123' ; H1='h(LO1)'.\n    let tup = Term::tuple(vec![Term::cst(\"aa\"), Term::cst(\"bb\"), Term::cst(\"cc\")]);\n    let h = Term::app(\"h\", vec![Term::cst(\"longarg123\")]);\n    let roots = vec![tup.clone(), tup, h.clone(), h];\n    let mut ab = Abbreviator::new();\n    for t in select(&roots) {\n        ab.add(t);\n    }\n    assert_eq!(\n        ab.rows(),\n        vec![\n            (\"LO1\".to_string(), \"'longarg123'\".to_string()),\n            (\"H1\".to_string(), \"h(LO1)\".to_string()),\n        ]\n    );\n}\n\n#[test]\nfn select_counts_nested_occurrences() {\n    // A long atom that appears only *inside* two copies of an outer term still\n    // reaches occurrence 2 and is abbreviated (nested counting).\n    let inner = Term::cst(\"longarg123\"); // len 12\n    let outer = Term::app(\"h\", vec![inner.clone()]);\n    let roots = vec![outer.clone(), outer]; // inner occurs twice, only nested\n    let got = picked(&roots);\n    assert!(got.contains(&\"'longarg123'\".to_string()));\n    assert!(got.contains(&\"h('longarg123')\".to_string()));\n}\n\n#[test]\nfn select_with_custom_thresholds() {\n    // The thresholds are parameterisable for probing.\n    let t = Term::cst(\"abcdef\"); // len 8\n    let roots = vec![t.clone(), t.clone()];\n    assert!(select(&roots).is_empty()); // 8 < 10 default\n    assert_eq!(select_with(&roots, 8, 2).len(), 1); // lowered length gate\n    assert!(select_with(&roots, 8, 3).is_empty()); // raised occ gate\n}\n","numLines":321,"startLine":1,"totalLines":321}},"sourceToolAssistantUUID":"20948345-37df-44f2-88d5-0dd98b04a1a4","userType":"external","entrypoint":"cli","cwd":"/home/kamilner/tamarin-rs","sessionId":"57f8e1bc-d495-4b36-93c0-033347d5034a","version":"2.1.212","gitBranch":"main"}
