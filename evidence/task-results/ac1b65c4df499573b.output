{"parentUuid":"7c7aa5f6-6a73-4c85-a3f4-ee1a29244a93","isSidechain":true,"promptId":"2961bd88-c930-4506-bcca-f9d40cc278bf","agentId":"ac1b65c4df499573b","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TmMbHZizrLZtwLkthwfnrV","type":"tool_result","content":"/home/kamilner/tamarin-rs/tamarin-prover/lib/theory/src/Theory/Constraint/System/JSON.hs\n/home/kamilner/tamarin-rs/tamarin-prover/lib/theory/src/Theory/Constraint/System/Guarded.hs\n/home/kamilner/tamarin-rs/tamarin-prover/lib/theory/src/Theory/Constraint/System/Constraints.hs\n/home/kamilner/tamarin-rs/tamarin-prover/lib/theory/src/Theory/Constraint/System/Dot.hs\n/home/kamilner/tamarin-rs/tamarin-prover/lib/theory/src/Theory/Constraint/System/Graph/GraphRepr.hs\n/home/kamilner/tamarin-rs/tamarin-prover/lib/theory/src/Theory/Constraint/System/Graph/Graph.hs\n/home/kamilner/tamarin-rs/tamarin-prover/lib/theory/src/Theory/Constraint/System/Graph/Simplification.hs\n/home/kamilner/tamarin-rs/tamarin-prover/lib/theory/src/Theory/Constraint/System/Graph/Abbreviation.hs","is_error":false}]},"uuid":"650272d5-6051-4578-8262-25b81a73943d","timestamp":"2026-07-17T12:32:08.488Z","toolUseResult":{"stdout":"/home/kamilner/tamarin-rs/tamarin-prover/lib/theory/src/Theory/Constraint/System/JSON.hs\n/home/kamilner/tamarin-rs/tamarin-prover/lib/theory/src/Theory/Constraint/System/Guarded.hs\n/home/kamilner/tamarin-rs/tamarin-prover/lib/theory/src/Theory/Constraint/System/Constraints.hs\n/home/kamilner/tamarin-rs/tamarin-prover/lib/theory/src/Theory/Constraint/System/Dot.hs\n/home/kamilner/tamarin-rs/tamarin-prover/lib/theory/src/Theory/Constraint/System/Graph/GraphRepr.hs\n/home/kamilner/tamarin-rs/tamarin-prover/lib/theory/src/Theory/Constraint/System/Graph/Graph.hs\n/home/kamilner/tamarin-rs/tamarin-prover/lib/theory/src/Theory/Constraint/System/Graph/Simplification.hs\n/home/kamilner/tamarin-rs/tamarin-prover/lib/theory/src/Theory/Constraint/System/Graph/Abbreviation.hs","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false},"sourceToolAssistantUUID":"7c7aa5f6-6a73-4c85-a3f4-ee1a29244a93","userType":"external","entrypoint":"cli","cwd":"/home/kamilner/tamarin-rs","sessionId":"57f8e1bc-d495-4b36-93c0-033347d5034a","version":"2.1.212","gitBranch":"main"}
{"parentUuid":"650272d5-6051-4578-8262-25b81a73943d","isSidechain":true,"agentId":"ac1b65c4df499573b","message":{"model":"claude-opus-4-8","id":"msg_011Cd7dmCtjfBzSFbdBiF2QE","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_019mnhXxK4XRpWnDeMWVrzWX","name":"Read","input":{"file_path":"/home/kamilner/tamarin-rs/tamarin-prover/lib/theory/src/Theory/Constraint/System/Graph/Abbreviation.hs"},"caller":{"type":"direct"}}],"stop_reason":"tool_use","stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":662,"cache_read_input_tokens":53291,"output_tokens":103,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":662},"inference_geo":"not_available","iterations":[{"input_tokens":2,"output_tokens":103,"cache_read_input_tokens":53291,"cache_creation_input_tokens":662,"cache_creation":{"ephemeral_5m_input_tokens":662,"ephemeral_1h_input_tokens":0},"type":"message"}],"speed":"standard"},"diagnostics":null},"requestId":"req_011Cd7dmBh4LrwP4FmVSQPDN","attributionAgent":"general-purpose","type":"assistant","uuid":"38776c4b-4985-4648-a53b-e303db5de424","timestamp":"2026-07-17T12:32:11.019Z","effort":"xhigh","userType":"external","entrypoint":"cli","cwd":"/home/kamilner/tamarin-rs","sessionId":"57f8e1bc-d495-4b36-93c0-033347d5034a","version":"2.1.212","gitBranch":"main"}
{"parentUuid":"38776c4b-4985-4648-a53b-e303db5de424","isSidechain":true,"promptId":"2961bd88-c930-4506-bcca-f9d40cc278bf","agentId":"ac1b65c4df499573b","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019mnhXxK4XRpWnDeMWVrzWX","type":"tool_result","content":"1\t{-# LANGUAGE TypeOperators   #-}\n2\t{-# LANGUAGE ViewPatterns #-}\n3\t-- |\n4\t-- Copyright   : (c) 2010, 2011 Simon Meier\n5\t-- License     : GPL v3 (see LICENSE)\n6\t--\n7\t-- Portability : GHC only\n8\t--\n9\t-- This implements generating abbreviations for a given graph representation.\n10\t-- The abbreviations are computed from all LNTerm's in the graph and the method is based on cleandot.py \n11\t-- All terms in the graph are weighted based on their multiplicity and length, highest weighted terms are abbreviated first.\n12\t-- The abbreviation itself is based on the string representation of a term. \n13\t-- E.g. Function(a,b,c) => FU1\n14\tmodule Theory.Constraint.System.Graph.Abbreviation (\n15\t    Abbreviations\n16\t  , lookupAbbreviation\n17\t  , computeAbbreviations\n18\t  , AbbreviationOptions(..)\n19\t  , AbbreviationTerm\n20\t  , AbbreviationExpansion\n21\t  , defaultAbbreviationOptions\n22\t  , applyAbbreviationsFact\n23\t  , applyAbbreviationsTerm\n24\t  ) where\n25\t\n26\timport           Data.Char                (isAlphaNum, toUpper, isAlpha)\n27\timport qualified Data.Text                as T\n28\timport qualified Data.Map                 as M\n29\timport           Data.Maybe\n30\timport qualified Data.Ord                 \n31\timport qualified Data.ByteString.Char8 as BC\n32\timport           Data.List                (sort, nub, mapAccumL)\n33\timport           Extension.Data.Label\n34\timport           Extension.Prelude\n35\timport           Text.PrettyPrint.Class\n36\timport           Theory.Constraint.System.Graph.GraphRepr\n37\timport           Term.LTerm\n38\timport           Theory                   (LNFact, rPrems, rConcs, rActs, factTerms)\n39\timport Debug.Trace.EnvTracer (etraceSectionLn, etraceLn)\n40\t\n41\t-- | Type for the abbreviation itself, which is always a literal containing the string representation.\n42\ttype AbbreviationTerm = LNTerm\n43\t-- | Type for the expanded abbreviation, which is the original term where subterms are replaced by other abbreviations where possible.\n44\ttype AbbreviationExpansion = LNTerm\n45\t-- | Abbreviations are represented as a map from the original LNTerm \n46\t-- to the abbreviated LNTerm and the original LNTerm where all existing\n47\t-- abbreviations have already been applied.\n48\t-- ==== __Example__:\n49\t--   [ Function1(a,b)              => Fun1, Function1(a,b)\n50\t--   , Function2(Function1(a,b),c) => Fun2, Function2(Fun1,c)\n51\t--   ]\n52\ttype Abbreviations = M.Map LNTerm (AbbreviationTerm, AbbreviationExpansion)\n53\t\n54\ttype Weight = Int\n55\t-- | Options to control the abbreviation generation.\n56\tdata AbbreviationOptions = AbbreviationOptions \n57\t  { aoAbbrevsSoftLimit   :: Int    -- ^ The soft limit of how many abbreviations to generate if the term weight is not greater or equal than 'aoAlwaysAbbrevWeight'.\n58\t  , aoAlwaysAbbrevWeight :: Weight -- ^ Terms that have weight greater or equal to this always generate an abbreviation even if the number of abbreviations is greater than 'aoAbbrevsSoftLimit'.\n59\t  , aoFirstIndex         :: Int    -- ^ The first index to use when generating abbreviations.\n60\t  , aoPrefixLength       :: Int    -- ^ The length of an abbreviation prefixes.\n61\t  }\n62\t  deriving( Eq, Ord )\n63\t\n64\t\n65\t-- | The default abbreviation options.\n66\tdefaultAbbreviationOptions :: AbbreviationOptions\n67\tdefaultAbbreviationOptions = AbbreviationOptions \n68\t  { aoAbbrevsSoftLimit = 10\n69\t  , aoAlwaysAbbrevWeight = 30 -- a.d. TODO what is a good default value for this?\n70\t  , aoFirstIndex = 1\n71\t  , aoPrefixLength = 2\n72\t  }\n73\t\n74\t-- | Lookup a single term in an abbreviations map and return the abbreviation name.\n75\tlookupAbbreviation :: Abbreviations -> LNTerm -> Maybe AbbreviationTerm\n76\tlookupAbbreviation abbrevs t = fst <$> M.lookup t abbrevs\n77\t\n78\t-- | Weigh each term based on its size and how often it appears in the graph.\n79\tjudgeTerm :: M.Map LNTerm LNTerm -- ^ The existing set of abbreviations used to compute the screen size of the current term under consideration.\n80\t          -> LNTerm              -- ^ The current term to consider for abbreviating.\n81\t          -> (Int, [Int])        -- ^ The total number of occurrences and a list where each element is the number of occurrences in the existing set of abbreviations.\n82\t          -> Weight              -- ^ The resulting weight we give to that abbreviation.\n83\tjudgeTerm abbrevs t (occs, legendOccs) \n84\t  | termWeight < 10 = -1\n85\t  | relativeOccs <= 1 = -1\n86\t  | otherwise = relativeOccs * termWeight\n87\t  where\n88\t    -- | The termsize is the length of the term rendered as a string.\n89\t    termWeight :: Weight\n90\t    termWeight = \n91\t      let replacedTerm = applyAbbreviationsTerm (\\k -> M.lookup k abbrevs) t in\n92\t      length $ render $ prettyLNTerm replacedTerm\n93\t    \n94\t    -- | A \"relative\" occurrence is computed by comparing the total number of occurrences\n95\t    -- with the number of occurrences only in the legend.\n96\t    -- If we find the only occurrence of a term only in the legend then we will never abbreviate it.\n97\t    relativeOccs :: Int\n98\t    relativeOccs = \n99\t      if occs == 1 && legendOccs == [1]\n100\t      then 0\n101\t      else occs\n102\t\n103\t-- | Find a suitable abbreviation prefix for the given term in upper-case.\n104\t-- For a literal we take the first 2 characters and for function symbols we either special-case the name or also take the first 2 characters.\n105\t-- If more fine-grained control is needed we can use viewTerm2 instead of viewTerm.\n106\tgetTermPrefix :: AbbreviationOptions -> LNTerm -> String\n107\tgetTermPrefix options t = map toUpper $ take (aoPrefixLength options) $ filter isAlpha go\n108\t  where\n109\t    go = case viewTerm t of\n110\t         Lit l                  -> show l\n111\t         FApp   (NoEq (s,_)) _  -> BC.unpack s\n112\t         -- a.d. TODO what is a good abbreviation for the \"emap\"?\n113\t         FApp   (C _) _         -> \"EMP\"\n114\t         FApp   List _          -> \"LST\"\n115\t         FApp   (AC o) _        -> show o\n116\t\n117\t\n118\ttype PrefixMap = M.Map String Int\n119\t\n120\t-- | For a given term `t`, find a suitable abbreviation and update the prefix index map.\n121\t-- The prefixMap maps a prefix to the next possible index candidate.\n122\tabbreviateTerm :: AbbreviationOptions -> [String] -> PrefixMap -> LNTerm -> (PrefixMap, LNTerm)\n123\tabbreviateTerm options allNames prefixMap t = \n124\t  let pref = getTermPrefix options t\n125\t      idxCandidate = getIndexCandidate pref in\n126\t    go pref idxCandidate\n127\t  where\n128\t    -- | Try out successive index candidates to create an abbreviation. \n129\t    -- For each candidate we create the abbreviation and check if it is contained in the global map.\n130\t    -- If it already exists we try the next index candidate.\n131\t    go :: String -> Int -> (PrefixMap, LNTerm)\n132\t    go pref idxCandidate = \n133\t      let nameCandidate = pref ++ show idxCandidate \n134\t          idxCandidateNext = idxCandidate + 1 in\n135\t      if nameCandidate `elem` allNames \n136\t      then go pref idxCandidateNext\n137\t      else (M.insert pref idxCandidateNext prefixMap, var nameCandidate)\n138\t\n139\t    -- | Check the prefix index map for a suitable index for the given prefix.\n140\t    getIndexCandidate :: String -> Int\n141\t    getIndexCandidate pref = fromMaybe (aoFirstIndex options) $ M.lookup pref prefixMap \n142\t        \n143\t    -- | Create a variable from some prefix and index. \n144\t    -- We append the index to the string directly instead of using the variable index since \n145\t    -- the variable renderer inserts a point between name and index.\n146\t    var :: String -> LNTerm\n147\t    var name = \n148\t      let  in\n149\t      lit $ Var $ LVar name LSortMsg 0\n150\t    \n151\t\n152\t-- | For a given graph representation, compute possible abbreviations that can be applied.\n153\t-- Abbreviations are always LNTerm variables with a differentiating number suffix.\n154\t--\n155\t-- actually what would lead to the best abbreviations is:\n156\t--   calculate terms + occurrences\n157\t--   calculate weights\n158\t--   take term X with maximum weight and make abbreviation\n159\t--   now for each subterm of X, decrement its occurrence (this can be reasonable fast if we keep the allTermOccs and just delete X, then go through all its subterms and decrement them)\n160\t--     this is good in a situation where \n161\t--   for each other term that has X as a subterm, reduce replace X by its abbreviation when calculating the term size (this can be made fast by keeping around the list of abbreviations and applying it to each expression when calculating the term size)\n162\t--     this is good in a situation where you have a term X = F(Y) where Y has bigger weight than X and is abbreviated first. When Y is replaced by an abbreviation the weight of X drops a lot and probably does not need to be abbreviated.\n163\t--   repeat finding the next term with maximum weight\n164\t--   This algorithm is probably cubic in the number of terms, as finding all subterms is already quadratic and now we do this for each term.\n165\t    \n166\tcomputeAbbreviations :: GraphRepr -> AbbreviationOptions -> Abbreviations \n167\tcomputeAbbreviations repr options = makeRecursive $ M.toList $ go allTermOccs M.empty M.empty\n168\t  where\n169\t    go :: M.Map LNTerm (Int, [Int]) -> PrefixMap -> M.Map LNTerm LNTerm -> M.Map LNTerm LNTerm\n170\t    go termOccs prefixMap abbrevs = \n171\t      let weightedTerms = M.mapWithKey (judgeTerm abbrevs) termOccs\n172\t          candidateM = filterCandidateTerm $ M.toList weightedTerms\n173\t      in\n174\t        case candidateM of\n175\t          Nothing -> abbrevs\n176\t          Just (candidate, weight) -> \n177\t            -- If the candidate weight is too low and we already have enough abbreviations, return the current abbreviations.\n178\t            if weight < aoAlwaysAbbrevWeight options && length abbrevs >= aoAbbrevsSoftLimit options\n179\t            then abbrevs\n180\t            else \n181\t              -- make an abbreviation for this term\n182\t              let (newPrefixMap, abbrevName) = abbreviateTerm options allNames prefixMap candidate\n183\t                  -- Delete the candidate from the list of terms and decrement the occurrences of other terms.\n184\t                  newTermOccs = M.mapWithKey (\\term (occs, legendOccs) -> (occs, countProperSubterms term candidate : legendOccs))\n185\t                                $ M.delete candidate termOccs\n186\t                  newAbbrevs = M.insert candidate abbrevName abbrevs\n187\t              in\n188\t                go newTermOccs newPrefixMap newAbbrevs\n189\t              \n190\t            \n191\t    -- | Collect all terms in our graph along with their number of occurrences\n192\t    allTermOccs :: M.Map LNTerm (Int, [Int])\n193\t    allTermOccs = \n194\t      let terms = concatMap getNodeTerms (get grNodes repr) ++ concatMap (\\c -> concatMap getNodeTerms $ get cNodes c) (get grClusters repr) in\n195\t      M.map (\\occs -> (occs, [])) $ M.fromListWith (+) $ map (\\t -> (t,1)) terms\n196\t\n197\t    -- | Collect all terms in a single graph node. \n198\t    -- At the moment terms only appear in SystemNodes and UnsolvedActionNodes.\n199\t    getNodeTerms :: Node -> [LNTerm]\n200\t    getNodeTerms (Node _ (SystemNode ru)) =\n201\t      concatMap getFactTerms (get rPrems ru)\n202\t      ++ concatMap getFactTerms (get rActs ru)\n203\t      ++ concatMap getFactTerms (get rConcs ru) \n204\t    getNodeTerms (Node _ (UnsolvedActionNode facts)) = concatMap getFactTerms facts\n205\t    getNodeTerms _ = []\n206\t\n207\t    -- | Collect all terms of a LNFact.\n208\t    -- We filter out pairs so that we do not abbreviate pairs of terms but only the inner terms.\n209\t    getFactTerms :: LNFact -> [LNTerm]\n210\t    getFactTerms fact = filter (not . isPair) $ concatMap getSubTerms $ factTerms fact \n211\t\n212\t    -- | Subterms are the term itself along with ts of an FApp\n213\t    getSubTerms :: LNTerm -> [LNTerm]\n214\t    getSubTerms t@(viewTerm -> FApp _ ts) = t : ts\n215\t    getSubTerms t = [t]\n216\t\n217\t    -- | Collect all names that appear somewhere in the graph to avoid generating abbreviations with the same name as existing objects.\n218\t    --  quickest way to do this is to render the entire graph as a string and pull out all alphanumeric substrings.\n219\t    --  We convert all names to upper-case to compare in a case-insensitive way.\n220\t    allNames :: [String]\n221\t    allNames = \n222\t      let rendered = T.pack $ show repr\n223\t          names = filter (not . null) $ map (T.unpack . T.toUpper) $ T.split (not . isAlphaNum) rendered\n224\t      in\n225\t        sort $ nub names\n226\t\n227\t    -- | For a number of weighted terms, take the first aoMaxAbbrevs terms sorted by decreasing weight.\n228\t    filterCandidateTerm :: [(LNTerm, Weight)] -> Maybe (LNTerm, Weight)\n229\t    filterCandidateTerm weightedTerms = \n230\t      let relevantWeights = sortOn (Data.Ord.Down . snd) $ filter (\\(_, weight) -> weight > 0) weightedTerms in\n231\t      listToMaybe relevantWeights\n232\t\n233\t    -- | For a given list of terms, find suitable abbreviations and return a mapping from the original to the abbreviated terms. \n234\t    -- The prefix index map is initially empty and accumulates the next possible index candidate for each prefix while we create abbreviations.\n235\t    abbreviateTerms :: [LNTerm] -> [(LNTerm, LNTerm)]\n236\t    abbreviateTerms ts =\n237\t      let (_, abbrevNames) = mapAccumL (abbreviateTerm options allNames) M.empty ts in\n238\t      zip ts abbrevNames\n239\t\n240\t    -- | For a given list of (expansion, abbrevName) pairs, compute a recursiveExpansion that is the original expansion term where any subterm which is also an expansion is replaced by the respective abbrevName. \n241\t    -- Going through all expansions once is enough because abbrevNames do not contain any subterms themselves, so we do not introduce any new possibilities for recursive occurrences. \n242\t    --\n243\t    -- ==== __Example__:\n244\t    -- [(A(B, C), H1), (B, H2)] => [(A(H2, C), H1), (B, H2)]\n245\t    makeRecursive :: [(LNTerm, LNTerm)] -> Abbreviations\n246\t    makeRecursive abbrevs = \n247\t      let replacementMap = M.fromList abbrevs \n248\t          replacement t = fromMaybe t (M.lookup t replacementMap)\n249\t          recursiveExpansions = map (replaceProperSubterm replacement . fst) abbrevs\n250\t          recursiveAbbrevs = zipWith (\\(expansion, abbrevName) recursiveExpansion -> \n251\t                                        (expansion, (abbrevName, recursiveExpansion))) \n252\t                                      abbrevs recursiveExpansions\n253\t      in\n254\t        M.fromList recursiveAbbrevs\n255\t\n256\t-- | Go through an LNTerm and replace all possible subterms with their abbreviation top-down.\n257\tapplyAbbreviationsTerm :: (LNTerm -> Maybe AbbreviationTerm) -> LNTerm -> LNTerm\n258\tapplyAbbreviationsTerm lookupTerm term = \n259\t  let replaceWithAbbrev t = fromMaybe t $ lookupTerm t\n260\t      replacedTerm = replaceSubterm replaceWithAbbrev term\n261\t  in\n262\t    replacedTerm\n263\t\n264\t-- | Go through an LNFact and apply the abbreviations to all contained LNTerm's.\n265\tapplyAbbreviationsFact :: (LNTerm -> Maybe AbbreviationTerm) -> LNFact -> LNFact\n266\tapplyAbbreviationsFact lookupTerm fact = \n267\t  let terms = factTerms fact\n268\t      replacedTerms = map (applyAbbreviationsTerm lookupTerm) terms\n269\t  in \n270\t    fact { factTerms = replacedTerms }\n271\t"}]},"uuid":"37c31fe6-d3ce-4d4a-a462-73f4540e6b45","timestamp":"2026-07-17T12:32:11.030Z","toolUseResult":{"type":"text","file":{"filePath":"/home/kamilner/tamarin-rs/tamarin-prover/lib/theory/src/Theory/Constraint/System/Graph/Abbreviation.hs","content":"{-# LANGUAGE TypeOperators   #-}\n{-# LANGUAGE ViewPatterns #-}\n-- |\n-- Copyright   : (c) 2010, 2011 Simon Meier\n-- License     : GPL v3 (see LICENSE)\n--\n-- Portability : GHC only\n--\n-- This implements generating abbreviations for a given graph representation.\n-- The abbreviations are computed from all LNTerm's in the graph and the method is based on cleandot.py \n-- All terms in the graph are weighted based on their multiplicity and length, highest weighted terms are abbreviated first.\n-- The abbreviation itself is based on the string representation of a term. \n-- E.g. Function(a,b,c) => FU1\nmodule Theory.Constraint.System.Graph.Abbreviation (\n    Abbreviations\n  , lookupAbbreviation\n  , computeAbbreviations\n  , AbbreviationOptions(..)\n  , AbbreviationTerm\n  , AbbreviationExpansion\n  , defaultAbbreviationOptions\n  , applyAbbreviationsFact\n  , applyAbbreviationsTerm\n  ) where\n\nimport           Data.Char                (isAlphaNum, toUpper, isAlpha)\nimport qualified Data.Text                as T\nimport qualified Data.Map                 as M\nimport           Data.Maybe\nimport qualified Data.Ord                 \nimport qualified Data.ByteString.Char8 as BC\nimport           Data.List                (sort, nub, mapAccumL)\nimport           Extension.Data.Label\nimport           Extension.Prelude\nimport           Text.PrettyPrint.Class\nimport           Theory.Constraint.System.Graph.GraphRepr\nimport           Term.LTerm\nimport           Theory                   (LNFact, rPrems, rConcs, rActs, factTerms)\nimport Debug.Trace.EnvTracer (etraceSectionLn, etraceLn)\n\n-- | Type for the abbreviation itself, which is always a literal containing the string representation.\ntype AbbreviationTerm = LNTerm\n-- | Type for the expanded abbreviation, which is the original term where subterms are replaced by other abbreviations where possible.\ntype AbbreviationExpansion = LNTerm\n-- | Abbreviations are represented as a map from the original LNTerm \n-- to the abbreviated LNTerm and the original LNTerm where all existing\n-- abbreviations have already been applied.\n-- ==== __Example__:\n--   [ Function1(a,b)              => Fun1, Function1(a,b)\n--   , Function2(Function1(a,b),c) => Fun2, Function2(Fun1,c)\n--   ]\ntype Abbreviations = M.Map LNTerm (AbbreviationTerm, AbbreviationExpansion)\n\ntype Weight = Int\n-- | Options to control the abbreviation generation.\ndata AbbreviationOptions = AbbreviationOptions \n  { aoAbbrevsSoftLimit   :: Int    -- ^ The soft limit of how many abbreviations to generate if the term weight is not greater or equal than 'aoAlwaysAbbrevWeight'.\n  , aoAlwaysAbbrevWeight :: Weight -- ^ Terms that have weight greater or equal to this always generate an abbreviation even if the number of abbreviations is greater than 'aoAbbrevsSoftLimit'.\n  , aoFirstIndex         :: Int    -- ^ The first index to use when generating abbreviations.\n  , aoPrefixLength       :: Int    -- ^ The length of an abbreviation prefixes.\n  }\n  deriving( Eq, Ord )\n\n\n-- | The default abbreviation options.\ndefaultAbbreviationOptions :: AbbreviationOptions\ndefaultAbbreviationOptions = AbbreviationOptions \n  { aoAbbrevsSoftLimit = 10\n  , aoAlwaysAbbrevWeight = 30 -- a.d. TODO what is a good default value for this?\n  , aoFirstIndex = 1\n  , aoPrefixLength = 2\n  }\n\n-- | Lookup a single term in an abbreviations map and return the abbreviation name.\nlookupAbbreviation :: Abbreviations -> LNTerm -> Maybe AbbreviationTerm\nlookupAbbreviation abbrevs t = fst <$> M.lookup t abbrevs\n\n-- | Weigh each term based on its size and how often it appears in the graph.\njudgeTerm :: M.Map LNTerm LNTerm -- ^ The existing set of abbreviations used to compute the screen size of the current term under consideration.\n          -> LNTerm              -- ^ The current term to consider for abbreviating.\n          -> (Int, [Int])        -- ^ The total number of occurrences and a list where each element is the number of occurrences in the existing set of abbreviations.\n          -> Weight              -- ^ The resulting weight we give to that abbreviation.\njudgeTerm abbrevs t (occs, legendOccs) \n  | termWeight < 10 = -1\n  | relativeOccs <= 1 = -1\n  | otherwise = relativeOccs * termWeight\n  where\n    -- | The termsize is the length of the term rendered as a string.\n    termWeight :: Weight\n    termWeight = \n      let replacedTerm = applyAbbreviationsTerm (\\k -> M.lookup k abbrevs) t in\n      length $ render $ prettyLNTerm replacedTerm\n    \n    -- | A \"relative\" occurrence is computed by comparing the total number of occurrences\n    -- with the number of occurrences only in the legend.\n    -- If we find the only occurrence of a term only in the legend then we will never abbreviate it.\n    relativeOccs :: Int\n    relativeOccs = \n      if occs == 1 && legendOccs == [1]\n      then 0\n      else occs\n\n-- | Find a suitable abbreviation prefix for the given term in upper-case.\n-- For a literal we take the first 2 characters and for function symbols we either special-case the name or also take the first 2 characters.\n-- If more fine-grained control is needed we can use viewTerm2 instead of viewTerm.\ngetTermPrefix :: AbbreviationOptions -> LNTerm -> String\ngetTermPrefix options t = map toUpper $ take (aoPrefixLength options) $ filter isAlpha go\n  where\n    go = case viewTerm t of\n         Lit l                  -> show l\n         FApp   (NoEq (s,_)) _  -> BC.unpack s\n         -- a.d. TODO what is a good abbreviation for the \"emap\"?\n         FApp   (C _) _         -> \"EMP\"\n         FApp   List _          -> \"LST\"\n         FApp   (AC o) _        -> show o\n\n\ntype PrefixMap = M.Map String Int\n\n-- | For a given term `t`, find a suitable abbreviation and update the prefix index map.\n-- The prefixMap maps a prefix to the next possible index candidate.\nabbreviateTerm :: AbbreviationOptions -> [String] -> PrefixMap -> LNTerm -> (PrefixMap, LNTerm)\nabbreviateTerm options allNames prefixMap t = \n  let pref = getTermPrefix options t\n      idxCandidate = getIndexCandidate pref in\n    go pref idxCandidate\n  where\n    -- | Try out successive index candidates to create an abbreviation. \n    -- For each candidate we create the abbreviation and check if it is contained in the global map.\n    -- If it already exists we try the next index candidate.\n    go :: String -> Int -> (PrefixMap, LNTerm)\n    go pref idxCandidate = \n      let nameCandidate = pref ++ show idxCandidate \n          idxCandidateNext = idxCandidate + 1 in\n      if nameCandidate `elem` allNames \n      then go pref idxCandidateNext\n      else (M.insert pref idxCandidateNext prefixMap, var nameCandidate)\n\n    -- | Check the prefix index map for a suitable index for the given prefix.\n    getIndexCandidate :: String -> Int\n    getIndexCandidate pref = fromMaybe (aoFirstIndex options) $ M.lookup pref prefixMap \n        \n    -- | Create a variable from some prefix and index. \n    -- We append the index to the string directly instead of using the variable index since \n    -- the variable renderer inserts a point between name and index.\n    var :: String -> LNTerm\n    var name = \n      let  in\n      lit $ Var $ LVar name LSortMsg 0\n    \n\n-- | For a given graph representation, compute possible abbreviations that can be applied.\n-- Abbreviations are always LNTerm variables with a differentiating number suffix.\n--\n-- actually what would lead to the best abbreviations is:\n--   calculate terms + occurrences\n--   calculate weights\n--   take term X with maximum weight and make abbreviation\n--   now for each subterm of X, decrement its occurrence (this can be reasonable fast if we keep the allTermOccs and just delete X, then go through all its subterms and decrement them)\n--     this is good in a situation where \n--   for each other term that has X as a subterm, reduce replace X by its abbreviation when calculating the term size (this can be made fast by keeping around the list of abbreviations and applying it to each expression when calculating the term size)\n--     this is good in a situation where you have a term X = F(Y) where Y has bigger weight than X and is abbreviated first. When Y is replaced by an abbreviation the weight of X drops a lot and probably does not need to be abbreviated.\n--   repeat finding the next term with maximum weight\n--   This algorithm is probably cubic in the number of terms, as finding all subterms is already quadratic and now we do this for each term.\n    \ncomputeAbbreviations :: GraphRepr -> AbbreviationOptions -> Abbreviations \ncomputeAbbreviations repr options = makeRecursive $ M.toList $ go allTermOccs M.empty M.empty\n  where\n    go :: M.Map LNTerm (Int, [Int]) -> PrefixMap -> M.Map LNTerm LNTerm -> M.Map LNTerm LNTerm\n    go termOccs prefixMap abbrevs = \n      let weightedTerms = M.mapWithKey (judgeTerm abbrevs) termOccs\n          candidateM = filterCandidateTerm $ M.toList weightedTerms\n      in\n        case candidateM of\n          Nothing -> abbrevs\n          Just (candidate, weight) -> \n            -- If the candidate weight is too low and we already have enough abbreviations, return the current abbreviations.\n            if weight < aoAlwaysAbbrevWeight options && length abbrevs >= aoAbbrevsSoftLimit options\n            then abbrevs\n            else \n              -- make an abbreviation for this term\n              let (newPrefixMap, abbrevName) = abbreviateTerm options allNames prefixMap candidate\n                  -- Delete the candidate from the list of terms and decrement the occurrences of other terms.\n                  newTermOccs = M.mapWithKey (\\term (occs, legendOccs) -> (occs, countProperSubterms term candidate : legendOccs))\n                                $ M.delete candidate termOccs\n                  newAbbrevs = M.insert candidate abbrevName abbrevs\n              in\n                go newTermOccs newPrefixMap newAbbrevs\n              \n            \n    -- | Collect all terms in our graph along with their number of occurrences\n    allTermOccs :: M.Map LNTerm (Int, [Int])\n    allTermOccs = \n      let terms = concatMap getNodeTerms (get grNodes repr) ++ concatMap (\\c -> concatMap getNodeTerms $ get cNodes c) (get grClusters repr) in\n      M.map (\\occs -> (occs, [])) $ M.fromListWith (+) $ map (\\t -> (t,1)) terms\n\n    -- | Collect all terms in a single graph node. \n    -- At the moment terms only appear in SystemNodes and UnsolvedActionNodes.\n    getNodeTerms :: Node -> [LNTerm]\n    getNodeTerms (Node _ (SystemNode ru)) =\n      concatMap getFactTerms (get rPrems ru)\n      ++ concatMap getFactTerms (get rActs ru)\n      ++ concatMap getFactTerms (get rConcs ru) \n    getNodeTerms (Node _ (UnsolvedActionNode facts)) = concatMap getFactTerms facts\n    getNodeTerms _ = []\n\n    -- | Collect all terms of a LNFact.\n    -- We filter out pairs so that we do not abbreviate pairs of terms but only the inner terms.\n    getFactTerms :: LNFact -> [LNTerm]\n    getFactTerms fact = filter (not . isPair) $ concatMap getSubTerms $ factTerms fact \n\n    -- | Subterms are the term itself along with ts of an FApp\n    getSubTerms :: LNTerm -> [LNTerm]\n    getSubTerms t@(viewTerm -> FApp _ ts) = t : ts\n    getSubTerms t = [t]\n\n    -- | Collect all names that appear somewhere in the graph to avoid generating abbreviations with the same name as existing objects.\n    --  quickest way to do this is to render the entire graph as a string and pull out all alphanumeric substrings.\n    --  We convert all names to upper-case to compare in a case-insensitive way.\n    allNames :: [String]\n    allNames = \n      let rendered = T.pack $ show repr\n          names = filter (not . null) $ map (T.unpack . T.toUpper) $ T.split (not . isAlphaNum) rendered\n      in\n        sort $ nub names\n\n    -- | For a number of weighted terms, take the first aoMaxAbbrevs terms sorted by decreasing weight.\n    filterCandidateTerm :: [(LNTerm, Weight)] -> Maybe (LNTerm, Weight)\n    filterCandidateTerm weightedTerms = \n      let relevantWeights = sortOn (Data.Ord.Down . snd) $ filter (\\(_, weight) -> weight > 0) weightedTerms in\n      listToMaybe relevantWeights\n\n    -- | For a given list of terms, find suitable abbreviations and return a mapping from the original to the abbreviated terms. \n    -- The prefix index map is initially empty and accumulates the next possible index candidate for each prefix while we create abbreviations.\n    abbreviateTerms :: [LNTerm] -> [(LNTerm, LNTerm)]\n    abbreviateTerms ts =\n      let (_, abbrevNames) = mapAccumL (abbreviateTerm options allNames) M.empty ts in\n      zip ts abbrevNames\n\n    -- | For a given list of (expansion, abbrevName) pairs, compute a recursiveExpansion that is the original expansion term where any subterm which is also an expansion is replaced by the respective abbrevName. \n    -- Going through all expansions once is enough because abbrevNames do not contain any subterms themselves, so we do not introduce any new possibilities for recursive occurrences. \n    --\n    -- ==== __Example__:\n    -- [(A(B, C), H1), (B, H2)] => [(A(H2, C), H1), (B, H2)]\n    makeRecursive :: [(LNTerm, LNTerm)] -> Abbreviations\n    makeRecursive abbrevs = \n      let replacementMap = M.fromList abbrevs \n          replacement t = fromMaybe t (M.lookup t replacementMap)\n          recursiveExpansions = map (replaceProperSubterm replacement . fst) abbrevs\n          recursiveAbbrevs = zipWith (\\(expansion, abbrevName) recursiveExpansion -> \n                                        (expansion, (abbrevName, recursiveExpansion))) \n                                      abbrevs recursiveExpansions\n      in\n        M.fromList recursiveAbbrevs\n\n-- | Go through an LNTerm and replace all possible subterms with their abbreviation top-down.\napplyAbbreviationsTerm :: (LNTerm -> Maybe AbbreviationTerm) -> LNTerm -> LNTerm\napplyAbbreviationsTerm lookupTerm term = \n  let replaceWithAbbrev t = fromMaybe t $ lookupTerm t\n      replacedTerm = replaceSubterm replaceWithAbbrev term\n  in\n    replacedTerm\n\n-- | Go through an LNFact and apply the abbreviations to all contained LNTerm's.\napplyAbbreviationsFact :: (LNTerm -> Maybe AbbreviationTerm) -> LNFact -> LNFact\napplyAbbreviationsFact lookupTerm fact = \n  let terms = factTerms fact\n      replacedTerms = map (applyAbbreviationsTerm lookupTerm) terms\n  in \n    fact { factTerms = replacedTerms }\n","numLines":271,"startLine":1,"totalLines":271}},"sourceToolAssistantUUID":"38776c4b-4985-4648-a53b-e303db5de424","userType":"external","entrypoint":"cli","cwd":"/home/kamilner/tamarin-rs","sessionId":"57f8e1bc-d495-4b36-93c0-033347d5034a","version":"2.1.212","gitBranch":"main"}
